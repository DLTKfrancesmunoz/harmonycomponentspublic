  "contentOrder": [
    ".shell-page-header__left"
  ],
  "layoutRules": {
    ".shell-page-header__actions": {
      "buttonOrder": [
        "outline",
        "primary"
      ],
      "description": "Outline/secondary buttons first (left), primary button last (right)."
    }
  },
  "guidance": {
    "patterns": {
      "actions-order": "In the actions slot, DOM order equals visual order; ShellPageHeader does not reorder. Place outline/secondary buttons first (left), primary button last (right) to match Harmony design. When using props only, the component renders outline buttons then primary by default."
    },
    "guidelines": {}
  },
  "specKeyOrder": [
    "theme",
    "mode"
  ],
