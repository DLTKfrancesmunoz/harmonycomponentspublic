{
  "name": "Tooltip",
  "type": "component",
  "filePath": "src/components/ui/Tooltip.astro",
  "description": "Tooltip Component",
  "props": {
    "text": {
      "type": "string",
      "optional": false,
      "default": null
    },
    "position": {
      "type": "'top' | 'bottom' | 'left' | 'right'",
      "optional": true,
      "default": "'top'"
    },
    "cornerVariant": {
      "type": "'top' | 'bottom' | 'left' | 'right'",
      "optional": true,
      "default": null
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light"
  },
  "specs": {
    "cp-light": {
      "_meta": {
        "theme": "cp",
        "mode": "light",
        "locked": true
      },
      "_buildContract": {
        "criticalSelectors": {
          ".tooltip": {
            "position": "relative",
            "display": "inline-block"
          },
          ".tooltip__content": {
            "position": "absolute",
            "bottom": "100%",
            "left": "50%",
            "transform": "translateX(-50%)",
            "margin-bottom": "8px",
            "padding": "8px 12px",
            "font-size": "0.75rem",
            "color": "white",
            "background-color": "#373F4E",
            "border-radius": "0.375rem",
            "white-space": "nowrap",
            "opacity": "0",
            "visibility": "hidden",
            "transition": "opacity 0.2s ease, visibility 0.2s ease",
            "z-index": "500",
            "display": "block",
            "font-family": "'Figtree', sans-serif"
          }
        },
        "forbiddenModifications": [
          "Do not use Tailwind arbitrary values",
          "Do not change hex colors to named colors",
          "Do not simplify box-shadow values",
          "Do not add CSS properties that are not in criticalSelectors or in elements[].styles (or element states)",
          "Do not reorder children: follow contentOrder and elements[].children order exactly",
          "Build exactly what is in the spec: structure, styles, and defaultContent from the JSON only; no inference, no additions, no \"fixes\""
        ]
      },
      "elements": [
        {
          "selector": ".tooltip",
          "tag": "div",
          "styles": {
            "position": "relative",
            "display": "inline-block"
          },
          "children": [
            ".tooltip__content"
          ]
        },
        {
          "selector": ".tooltip__content",
          "tag": "span",
          "styles": {
            "position": "absolute",
            "bottom": "100%",
            "left": "50%",
            "transform": "translateX(-50%)",
            "margin-bottom": "8px",
            "padding": "8px 12px",
            "font-size": "0.75rem",
            "color": "white",
            "background-color": "#373F4E",
            "border-radius": "0.375rem",
            "white-space": "nowrap",
            "opacity": "0",
            "visibility": "hidden",
            "transition": "opacity 0.2s ease, visibility 0.2s ease",
            "z-index": "500",
            "display": "block",
            "font-family": "'Figtree', sans-serif"
          },
          "parent": ".tooltip",
          "states": {
            "rootHover": {
              "opacity": "1",
              "visibility": "visible"
            }
          }
        }
      ]
    },
