{
  "name": "DateInput",
  "type": "component",
  "filePath": "src/components/ui/DateInput.astro",
  "description": "DateInput Component",
  "props": {
    "type": {
      "type": "'date' | 'time' | 'datetime-local' | 'month' | 'week'",
      "optional": true,
      "default": "'date'"
    },
    "value": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "name": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "id": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "disabled": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "min": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "max": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "required": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "label": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "labelVariant": {
      "type": "'inline' | 'stacked'",
      "optional": true,
      "default": null
    },
    "labelFor": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "timeFormat": {
      "type": "'12' | '24'",
      "optional": true,
      "default": "'24'"
    },
    "locale": {
      "type": "string",
      "optional": true,
      "default": "'en-US'"
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
