{
  "name": "Avatar",
  "type": "component",
  "filePath": "src/components/ui/Avatar.astro",
  "description": "Avatar Component",
  "props": {
    "size": {
      "type": "'sm' | 'md' | 'lg'",
      "optional": true,
      "default": "'md'"
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light",
    "size": "'md'"
  },
  "specs": {
    "cp-light-sm": {
      "_meta": {
        "theme": "cp",
        "mode": "light",
        "locked": true
      },
      "_buildContract": {
        "criticalSelectors": {
          ".avatar": {
            "display": "inline-flex",
            "align-items": "center",
            "justify-content": "center",
            "border-radius": "8px",
            "background-color": "#4C92D9",
            "flex-shrink": "0",
            "width": "32px",
            "height": "32px"
          },
          ".avatar__icon": {
            "color": "white"
          }
        },
        "forbiddenModifications": [
          "Do not use Tailwind arbitrary values",
          "Do not change hex colors to named colors",
          "Do not simplify box-shadow values",
          "Do not add CSS properties that are not in criticalSelectors or in elements[].styles (or element states)",
          "Do not reorder children: follow contentOrder and elements[].children order exactly",
          "Build exactly what is in the spec: structure, styles, and defaultContent from the JSON only; no inference, no additions, no \"fixes\""
        ]
      },
      "elements": [
        {
          "selector": ".avatar",
          "tag": "div",
          "styles": {
            "display": "inline-flex",
            "align-items": "center",
            "justify-content": "center",
            "border-radius": "8px",
            "background-color": "#4C92D9",
            "flex-shrink": "0",
            "width": "32px",
            "height": "32px"
          },
          "children": [
            ".avatar__icon"
          ]
        },
        {
          "selector": ".avatar__icon",
          "tag": "span",
          "styles": {
            "color": "white"
          },
          "parent": ".avatar"
        }
      ]
    },
