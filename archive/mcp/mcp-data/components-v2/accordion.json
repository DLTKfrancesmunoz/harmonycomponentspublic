    "cp-light": {
      "_meta": {
        "theme": "cp",
        "mode": "light",
        "locked": true
      },
      "_buildContract": {
        "criticalSelectors": {
          ".accordion": {
            "border": "1px solid #BFC6D4",
            "border-radius": "0.5rem",
            "overflow": "hidden"
          },
          ".accordion__content": {
            "display": "block",
            "padding": "0 16px 16px",
            "font-size": "0.875rem",
            "color": "#525969",
            "font-family": "'Figtree', sans-serif"
          },
          ".accordion__icon": {
            "color": "#6B7280",
            "transition": "transform 150ms ease",
            "transform": "rotate(180deg)"
          },
          ".accordion__item": {
            "border-bottom": "1px solid #BFC6D4"
          },
          ".accordion__trigger": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "space-between",
            "width": "100%",
            "padding": "16px",
            "font-size": "1rem",
            "font-weight": "500",
            "color": "#373F4E",
            "text-align": "left",
            "background-color": "rgba(0,0,0,0)",
            "cursor": "pointer",
            "transition": "background-color 150ms ease",
            "font-family": "'Figtree', sans-serif"
          }
        },
        "forbiddenModifications": [
          "Do not use Tailwind arbitrary values",
          "Do not change hex colors to named colors",
          "Do not simplify box-shadow values",
          "Do not add CSS properties that are not in criticalSelectors or in elements[].styles (or element states)",
          "Do not reorder children: follow contentOrder and elements[].children order exactly",
          "Build exactly what is in the spec: structure, styles, and defaultContent from the JSON only; no inference, no additions, no \"fixes\""
        ]
      },
      "elements": [
        {
          "selector": ".accordion",
          "tag": "div",
          "styles": {
            "border": "1px solid #BFC6D4",
            "border-radius": "0.5rem",
            "overflow": "hidden"
          },
          "children": [
            ".accordion__content",
