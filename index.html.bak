                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Outline Buttons</h3>
                                <div class="flex flex-wrap gap-4">
                                    <button class="px-6 py-2.5 border-2 border-slate-900 dark:border-white text-slate-900 dark:text-white rounded-md hover:bg-slate-900 dark:hover:bg-white hover:text-white dark:hover:text-slate-900 transition-colors font-medium">
                                        Outline
                                    </button>
                                    <button class="px-6 py-2.5 border-2 border-theme-primary text-theme-primary rounded-md hover:bg-theme-primary hover:text-slate-900 transition-colors font-medium">
