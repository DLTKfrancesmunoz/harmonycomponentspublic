<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Design System Documentation</title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts: TASA Orbiter Display and Figtree -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet">
    
    <!-- Tabler Icons -->
    <script src="https://unpkg.com/@tabler/icons-web-font@latest/dist/tabler-icons.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />
    
    <!-- Heroicons (for component examples) -->
    <script src="https://cdn.jsdelivr.net/npm/heroicons@2.0.18/24/outline/index.js"></script>
    
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Figtree', 'sans-serif'],
                        display: ['Lexend', 'sans-serif'],
                    },
                    colors: {
                        obsidian: '#09090b',
                        charcoal: '#18181b',
                        concrete: '#f4f4f5',
                        acid: '#ccff00',
                        danger: '#D14343',
                        void: '#000000',
                        surface: '#0a0a0a',
                        panel: '#111111',
                        border: '#222222',
                        accent: '#043852',
                        success: '#52BD94',
                        error: '#D14343',
                        lime: '#ccff00',
                        dim: '#444444',
                        muted: '#525252',
                        text: '#e5e5e5',
                        warning: '#FFB020',
                        info: '#3366FF',
                        'theme-primary': 'var(--theme-primary)',
                        'theme-primary-hover': 'var(--theme-primary-hover)',
                        'theme-primary-light': 'var(--theme-primary-light)',
                    },
                }
            }
        }
    </script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;800;900&display=swap');
        
        .font-display {
            font-family: 'Lexend', 'Figtree', sans-serif;
        }
        
        body {
            background-color: #000;
            color: #e5e5e5;
        }
        
        .light body {
            background-color: #ffffff;
            color: #09090b;
        }
        
        /* Theme Color Variables */
        :root {
            --theme-primary: #4C92D9;
            --theme-primary-hover: #3d7ab8;
            --theme-primary-light: rgba(76, 146, 217, 0.1);
        }
        
        /* CP Theme */
        html.theme-cp {
            --theme-primary: #4C92D9;
            --theme-primary-hover: #3d7ab8;
            --theme-primary-light: rgba(76, 146, 217, 0.1);
        }
        html.dark.theme-cp {
            --theme-primary: #59ACFF;
            --theme-primary-hover: #78baff;
            --theme-primary-light: rgba(89, 172, 255, 0.1);
        }
        
        /* VP Theme */
        html.theme-vp {
            --theme-primary: #4C92D9;
            --theme-primary-hover: #3d7ab8;
            --theme-primary-light: rgba(76, 146, 217, 0.1);
        }
        html.dark.theme-vp {
            --theme-primary: #59ACFF;
            --theme-primary-hover: #78baff;
            --theme-primary-light: rgba(89, 172, 255, 0.1);
        }
        
        /* PPM Theme */
        html.theme-ppm {
            --theme-primary: #30659F;
            --theme-primary-hover: #265180;
            --theme-primary-light: rgba(48, 101, 159, 0.1);
        }
        html.dark.theme-ppm {
            --theme-primary: #1A88FF;
            --theme-primary-hover: #4da3ff;
            --theme-primary-light: rgba(26, 136, 255, 0.1);
        }
        
        /* Maconomy Theme */
        html.theme-maconomy {
            --theme-primary: #804A98;
            --theme-primary-hover: #663b79;
            --theme-primary-light: rgba(128, 74, 152, 0.1);
        }
        html.dark.theme-maconomy {
            --theme-primary: #A659EE;
            --theme-primary-hover: #b877f1;
            --theme-primary-light: rgba(166, 89, 238, 0.1);
        }
        
        /* CP Theme - Compact Inputs */
        html.theme-cp input:not([type="checkbox"]):not([type="radio"]),
        html.theme-cp select,
        html.theme-cp .dropdown-trigger {
            height: 20px;
            min-height: 20px;
            padding-top: 0;
            padding-bottom: 0;
            font-size: 12px;
            line-height: 20px;
        }
        
        /* Custom Scrollbar */
        .custom-scroll::-webkit-scrollbar {
            width: 5px;
        }
        
        .custom-scroll::-webkit-scrollbar-track {
            background: #09090b;
        }
        
        .light .custom-scroll::-webkit-scrollbar-track {
            background: #f4f4f5;
        }
        
        .custom-scroll::-webkit-scrollbar-thumb {
            background: #333;
            border-radius: 2px;
        }
        
        .light .custom-scroll::-webkit-scrollbar-thumb {
            background: #d4d4d8;
        }
        
        .custom-scroll::-webkit-scrollbar-thumb:hover {
            background: #444;
        }
        
        .light .custom-scroll::-webkit-scrollbar-thumb:hover {
            background: #a1a1aa;
        }
        
        /* Smooth scroll */
        html {
            scroll-behavior: smooth;
        }
        
        /* Component card hover effects */
        .component-example {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        /* Active nav item */
        .nav-item.active {
            background-color: var(--theme-primary-light);
            border-left: 2px solid var(--theme-primary);
        }
    </style>
</head>
<body class="bg-void dark:bg-obsidian text-slate-900 dark:text-slate-100 min-h-screen overflow-hidden">
    <div class="flex flex-col h-screen w-full">
        <!-- TOP HEADER -->
        <header class="w-full h-14 bg-white dark:bg-surface border-b border-slate-200 dark:border-border flex items-center justify-between px-4 sm:px-6 relative z-50 shrink-0">
            <!-- Brand / Left -->
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2 group cursor-pointer">
                    <div class="w-5 h-5 bg-theme-primary rounded-sm group-hover:bg-slate-900 dark:group-hover:bg-white transition-colors"></div>
                    <h1 class="font-display font-bold tracking-tight text-slate-900 dark:text-white text-sm">
                        DESIGN <span class="text-slate-400 dark:text-slate-500 font-normal">SYSTEM</span>
                    </h1>
                </div>
            </div>
            
            <!-- Center Info -->
            <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
                <span class="text-xs text-slate-500 dark:text-slate-400 font-mono">Component Library v1.0</span>
            </div>
            
            <!-- Right Actions -->
            <div class="flex items-center gap-3">
                <!-- Theme Switcher -->
                <div class="relative">
                    <button id="theme-picker-btn" class="flex items-center gap-2 px-3 py-1.5 rounded hover:bg-slate-100 dark:hover:bg-white/5 transition-colors">
                        <i class="ti ti-palette text-base text-slate-600 dark:text-slate-400"></i>
                        <span id="current-theme-name" class="text-xs font-medium text-slate-900 dark:text-white">CP</span>
                        <i class="ti ti-chevron-down text-xs text-slate-500 dark:text-slate-400"></i>
                    </button>
                    
                    <div id="theme-picker-menu" class="hidden absolute top-full right-0 mt-2 w-44 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg shadow-xl py-2 z-50">
                        <button data-theme="cp" class="theme-option w-full px-4 py-2.5 text-left text-sm hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center justify-between transition-colors">
                            <span class="font-medium text-slate-900 dark:text-white">CP</span>
                            <span class="w-3 h-3 rounded-full" style="background: #4C92D9"></span>
                        </button>
                        <button data-theme="vp" class="theme-option w-full px-4 py-2.5 text-left text-sm hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center justify-between transition-colors">
                            <span class="font-medium text-slate-900 dark:text-white">VP</span>
                            <span class="w-3 h-3 rounded-full" style="background: #4C92D9"></span>
                        </button>
                        <button data-theme="ppm" class="theme-option w-full px-4 py-2.5 text-left text-sm hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center justify-between transition-colors">
                            <span class="font-medium text-slate-900 dark:text-white">PPM</span>
                            <span class="w-3 h-3 rounded-full" style="background: #30659F"></span>
                        </button>
                        <button data-theme="maconomy" class="theme-option w-full px-4 py-2.5 text-left text-sm hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center justify-between transition-colors">
                            <span class="font-medium text-slate-900 dark:text-white">Maconomy</span>
                            <span class="w-3 h-3 rounded-full" style="background: #804A98"></span>
                        </button>
                    </div>
                </div>
                <!-- Theme Toggle -->
                <button id="theme-toggle" class="w-8 h-8 flex items-center justify-center rounded hover:bg-slate-100 dark:hover:bg-white/5 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
                    <i class="ti ti-sun text-lg dark:hidden"></i>
                    <i class="ti ti-moon text-lg hidden dark:inline-block"></i>
                </button>
                
                <div class="h-5 w-px bg-slate-200 dark:bg-border mx-1"></div>
                
                <div class="flex items-center gap-2 pl-1 cursor-pointer hover:opacity-80 transition-opacity">
                    <div class="w-6 h-6 rounded-full bg-gradient-to-tr from-slate-300 to-slate-200 dark:from-slate-700 dark:to-slate-600 border border-slate-400 dark:border-slate-500"></div>
                </div>
            </div>
        </header>
        
        <!-- CONTENT WRAPPER -->
        <div class="flex flex-1 overflow-hidden relative">
            <!-- LEFT SIDEBAR -->
            <aside class="w-64 border-r border-slate-200 dark:border-border bg-white dark:bg-surface hidden lg:flex flex-col justify-between h-full">
                <div class="p-4 border-b border-slate-200 dark:border-border">
                    <div class="text-[10px] font-mono text-slate-500 dark:text-dim uppercase tracking-wider mb-2">Navigation</div>
                    <div class="flex items-center gap-2 text-sm text-slate-900 dark:text-white font-medium">
                        <i class="ti ti-components text-theme-primary"></i>
                        35 Sections
                    </div>
                </div>
                
                <nav class="flex-1 overflow-y-auto custom-scroll p-4 space-y-1">
                    <div class="px-3 py-2 text-[10px] font-mono text-slate-500 dark:text-dim uppercase tracking-wider">Foundation</div>
                    <a href="#color" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-palette text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Color
                    </a>
                    <a href="#typography" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-typography text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Typography
                    </a>
                    <a href="#spacing" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-dimensions text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Spacing
                    </a>
                    <a href="#elevations" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-stack text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Elevations
                    </a>
                    
                    <div class="px-3 py-2 text-[10px] font-mono text-slate-500 dark:text-dim uppercase tracking-wider mt-6">Shell Layout</div>
                    <a href="#shell-layout" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-layout-2 text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Shell Layout
                    </a>
                    <a href="#shell-header" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-layout-navbar text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Shell Header
                    </a>
                    <a href="#shell-footer" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-layout-bottombar text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Shell Footer
                    </a>
                    <a href="#shell-page-content" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-file-text text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Page Content
                    </a>
                    <a href="#shell-left-sidebar" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-layout-sidebar-left text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Left Sidebar
                    </a>
                    <a href="#shell-right-sidebar" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-layout-sidebar-right text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Right Sidebar
                    </a>
                    
                    <div class="px-3 py-2 text-[10px] font-mono text-slate-500 dark:text-dim uppercase tracking-wider mt-6">Components</div>
                    <a href="#accordion" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-chevron-down text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Accordion
                    </a>
                    <a href="#alerts" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-alert-circle text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Alerts
                    </a>
                    <a href="#badges" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-badge text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Badges
                    </a>
                    <a href="#buttons" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-hand-click text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Buttons
                    </a>
                    <a href="#button-groups" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-layout-distribute-horizontal text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Button Groups
                    </a>
                    <a href="#cards" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-layout-cards text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Cards
                    </a>
                    <a href="#checkboxes" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-checkbox text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Checkboxes
                    </a>
                    <a href="#checkbox-groups" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-list-check text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Checkbox Groups
                    </a>
                    <a href="#chips" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-tag text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Chips
                    </a>
                    <a href="#dialogs" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-layout text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Dialogs
                    </a>
                    <a href="#dropdowns" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-select text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Dropdowns
                    </a>
                    <a href="#date-picker" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-calendar text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Date Picker
                    </a>
                    <a href="#inputs" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-forms text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Inputs
                    </a>
                    <a href="#labels" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-text text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Labels
                    </a>
                    <a href="#links" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-link text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Links
                    </a>
                    <a href="#list-menu" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-list text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        List Menu
                    </a>
                    <a href="#progress-bar" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-progress text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Progress Bar
                    </a>
                    <a href="#radio-buttons" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-circle-dot text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Radio Buttons
                    </a>
                    <a href="#radio-groups" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-layout-list text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Radio Groups
                    </a>
                    <a href="#scrollbar" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-arrows-vertical text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Scrollbar
                    </a>
                    <a href="#specialty-inputs" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-hash text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
                        Specialty Inputs
                    </a>
                    <a href="#spinner" class="nav-item flex items-center gap-3 px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded transition-colors group">
                        <i class="ti ti-loader text-slate-400 dark:text-dim group-hover:text-theme-primary text-base"></i>
