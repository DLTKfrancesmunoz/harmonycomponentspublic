                                    </button>
                                    <button class="px-6 py-2.5 border-2 border-slate-300 dark:border-slate-700 text-slate-400 dark:text-slate-600 rounded-md opacity-50 cursor-not-allowed font-medium">
                                        Disabled
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Ghost Buttons -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Ghost Buttons</h3>
                                <div class="flex flex-wrap gap-4">
