                                    <button class="px-4 py-2 text-sm font-medium text-slate-900 dark:text-white bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-r-md hover:bg-slate-50 dark:hover:bg-slate-700">
                                        Right
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Segmented Control -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Segmented Control</h3>
                                <div class="inline-flex p-1 bg-slate-200 dark:bg-slate-800 rounded-lg" role="group">
                                    <button class="px-4 py-2 text-sm font-medium text-slate-900 dark:text-white bg-white dark:bg-slate-900 rounded-md shadow-sm">
                                        List
                                    </button>
                                    <button class="px-4 py-2 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white">
                                        Grid
                                    </button>
                                    <button class="px-4 py-2 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white">
                                        Gallery
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Icon Group -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Icon Group</h3>
                                <div class="inline-flex rounded-md shadow-sm" role="group">
                                    <button class="px-3 py-2 text-sm font-medium text-slate-900 dark:text-white bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-l-md hover:bg-slate-50 dark:hover:bg-slate-700">
                                        <i class="ti ti-bold"></i>
                                    </button>
                                    <button class="px-3 py-2 text-sm font-medium text-slate-900 dark:text-white bg-white dark:bg-slate-800 border-t border-b border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700">
                                        <i class="ti ti-italic"></i>
                                    </button>
                                    <button class="px-3 py-2 text-sm font-medium text-slate-900 dark:text-white bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-r-md hover:bg-slate-50 dark:hover:bg-slate-700">
                                        <i class="ti ti-underline"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 3. BADGES -->
                    <section id="badges" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Badges</h2>
                            <p class="text-slate-600 dark:text-slate-400">Status indicators and labels with color variants.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Default Badges -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Default</h3>
                                <div class="flex flex-wrap gap-3">
                                    <span class="px-3 py-1 bg-slate-200 dark:bg-slate-800 text-slate-900 dark:text-white text-xs font-medium rounded-full">
                                        Default
                                    </span>
                                    <span class="px-3 py-1 bg-slate-900 dark:bg-white text-white dark:text-slate-900 text-xs font-medium rounded-full">
                                        Primary
                                    </span>
                                    <span class="px-3 py-1 bg-theme-primary text-slate-900 text-xs font-medium rounded-full">
                                        Accent
                                    </span>
                                </div>
                            </div>
                            
                            <!-- Status Badges -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Status</h3>
                                <div class="flex flex-wrap gap-3">
                                    <span class="px-3 py-1 bg-[#52BD94]/10 dark:bg-[#52BD94]/20 text-[#52BD94] dark:text-[#52BD94] text-xs font-medium rounded-full">
                                        Success
                                    </span>
                                    <span class="px-3 py-1 bg-[#FFB020]/10 dark:bg-[#FFB020]/20 text-[#FFB020] dark:text-[#FFB020] text-xs font-medium rounded-full">
                                        Warning
                                    </span>
                                    <span class="px-3 py-1 bg-[#D14343]/10 dark:bg-[#D14343]/20 text-[#D14343] dark:text-[#D14343] text-xs font-medium rounded-full">
                                        Error
                                    </span>
                                    <span class="px-3 py-1 bg-[#3366FF]/10 dark:bg-[#3366FF]/20 text-[#3366FF] dark:text-[#3366FF] text-xs font-medium rounded-full">
                                        Info
                                    </span>
                                </div>
                            </div>
                            
                            <!-- With Icons -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">With Icons</h3>
                                <div class="flex flex-wrap gap-3">
                                    <span class="px-3 py-1 bg-[#52BD94]/10 dark:bg-[#52BD94]/20 text-[#52BD94] dark:text-[#52BD94] text-xs font-medium rounded-full flex items-center gap-1.5">
                                        <i class="ti ti-check text-sm"></i>
                                        Completed
                                    </span>
                                    <span class="px-3 py-1 bg-[#3366FF]/10 dark:bg-[#3366FF]/20 text-[#3366FF] dark:text-[#3366FF] text-xs font-medium rounded-full flex items-center gap-1.5">
                                        <i class="ti ti-clock text-sm"></i>
                                        Pending
                                    </span>
                                    <span class="px-3 py-1 bg-purple-100 dark:bg-purple-900/30 text-purple-800 dark:text-purple-400 text-xs font-medium rounded-full flex items-center gap-1.5">
                                        <i class="ti ti-star text-sm"></i>
                                        Featured
                                    </span>
                                </div>
                            </div>
                            
                            <!-- Outline Badges -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Outline</h3>
                                <div class="flex flex-wrap gap-3">
                                    <span class="px-3 py-1 border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-white text-xs font-medium rounded-full">
                                        Default
                                    </span>
                                    <span class="px-3 py-1 border border-[#52BD94] text-[#52BD94] text-xs font-medium rounded-full">
                                        Success
                                    </span>
                                    <span class="px-3 py-1 border border-theme-primary text-theme-primary text-xs font-medium rounded-full">
                                        Accent
                                    </span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 4. LINKS -->
                    <section id="links" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Links</h2>
                            <p class="text-slate-600 dark:text-slate-400">Text links with multiple styles and states.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Default Links -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Default</h3>
                                <div class="flex flex-wrap gap-6">
                                    <a href="#" class="text-slate-900 dark:text-white underline hover:text-theme-primary transition-colors">
                                        Standard Link
                                    </a>
                                    <a href="#" class="text-theme-primary hover:text-theme-primary-hover transition-colors">
                                        Accent Link
                                    </a>
                                    <a href="#" class="text-slate-400 dark:text-slate-600 cursor-not-allowed">
                                        Disabled Link
                                    </a>
                                </div>
                            </div>
                            
                            <!-- With Icons -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">With Icons</h3>
                                <div class="flex flex-wrap gap-6">
                                    <a href="#" class="text-slate-900 dark:text-white hover:text-theme-primary transition-colors flex items-center gap-2">
                                        <i class="ti ti-external-link"></i>
                                        External Link
                                    </a>
                                    <a href="#" class="text-slate-900 dark:text-white hover:text-theme-primary transition-colors flex items-center gap-2">
                                        Download File
                                        <i class="ti ti-download"></i>
                                    </a>
                                    <a href="#" class="text-slate-900 dark:text-white hover:text-theme-primary transition-colors flex items-center gap-2">
                                        <i class="ti ti-arrow-right"></i>
                                        Continue
                                    </a>
                                </div>
                            </div>
                            
                            <!-- Underline Variants -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Underline Variants</h3>
                                <div class="flex flex-wrap gap-6">
                                    <a href="#" class="text-slate-900 dark:text-white no-underline hover:underline transition-all">
                                        Hover Underline
                                    </a>
                                    <a href="#" class="text-slate-900 dark:text-white underline decoration-2 underline-offset-4 hover:text-theme-primary transition-colors">
                                        Thick Underline
                                    </a>
                                    <a href="#" class="text-slate-900 dark:text-white underline decoration-dotted underline-offset-4 hover:text-theme-primary transition-colors">
                                        Dotted Underline
                                    </a>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 5. CARDS -->
                    <section id="cards" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Cards</h2>
                            <p class="text-slate-600 dark:text-slate-400">Content containers with multiple variants.</p>
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            <!-- Basic Card -->
                            <div class="p-6 border border-slate-200 dark:border-slate-800 bg-white dark:bg-surface rounded-lg hover:border-slate-300 dark:hover:border-slate-700 transition-colors">
                                <h3 class="text-lg font-semibold mb-2 text-slate-900 dark:text-white">Basic Card</h3>
                                <p class="text-sm text-slate-600 dark:text-slate-400">
                                    A simple card component with title and description text content.
                                </p>
                            </div>
                            
                            <!-- Card with Icon -->
                            <div class="p-6 border border-slate-200 dark:border-slate-800 bg-white dark:bg-surface rounded-lg hover:border-slate-300 dark:hover:border-slate-700 transition-colors">
                                <div class="w-10 h-10 bg-theme-primary rounded-lg flex items-center justify-center mb-4">
                                    <i class="ti ti-rocket text-slate-900 text-xl"></i>
                                </div>
                                <h3 class="text-lg font-semibold mb-2 text-slate-900 dark:text-white">With Icon</h3>
                                <p class="text-sm text-slate-600 dark:text-slate-400">
                                    Card featuring an icon at the top for visual emphasis.
                                </p>
                            </div>
                            
                            <!-- Interactive Card -->
                            <div class="p-6 border border-slate-200 dark:border-slate-800 bg-white dark:bg-surface rounded-lg hover:border-theme-primary hover:shadow-lg hover:shadow-theme-primary-light transition-all cursor-pointer">
                                <h3 class="text-lg font-semibold mb-2 text-slate-900 dark:text-white">Interactive</h3>
                                <p class="text-sm text-slate-600 dark:text-slate-400">
                                    Clickable card with hover effects and enhanced interactivity.
                                </p>
                            </div>
                            
                            <!-- Card with Footer -->
                            <div class="border border-slate-200 dark:border-slate-800 bg-white dark:bg-surface rounded-lg overflow-hidden hover:border-slate-300 dark:hover:border-slate-700 transition-colors">
                                <div class="p-6">
                                    <h3 class="text-lg font-semibold mb-2 text-slate-900 dark:text-white">With Footer</h3>
                                    <p class="text-sm text-slate-600 dark:text-slate-400">
                                        Card component that includes a dedicated footer section.
                                    </p>
                                </div>
                                <div class="px-6 py-3 bg-slate-50 dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between">
                                    <span class="text-xs text-slate-500 dark:text-slate-400">Last updated</span>
                                    <span class="text-xs text-slate-900 dark:text-white">2 days ago</span>
                                </div>
                            </div>
                            
                            <!-- Featured Card -->
                            <div class="p-6 border-2 border-theme-primary bg-theme-primary/5 rounded-lg">
                                <div class="flex items-start justify-between mb-3">
                                    <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Featured</h3>
                                    <span class="px-2 py-0.5 bg-theme-primary text-slate-900 text-xs font-medium rounded">NEW</span>
                                </div>
                                <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">
                                    Highlighted card with accent border and badge.
                                </p>
                                <button class="text-sm font-medium text-theme-primary hover:text-theme-primary-hover transition-colors flex items-center gap-1">
                                    Learn more
                                    <i class="ti ti-arrow-right text-xs"></i>
                                </button>
                            </div>
                            
                            <!-- Card with Stats -->
                            <div class="p-6 border border-slate-200 dark:border-slate-800 bg-white dark:bg-surface rounded-lg">
                                <h3 class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Total Users</h3>
                                <div class="flex items-end gap-2 mb-2">
                                    <span class="text-3xl font-bold text-slate-900 dark:text-white">12,458</span>
                                    <span class="text-sm text-[#52BD94] flex items-center gap-1 mb-1">
                                        <i class="ti ti-arrow-up text-xs"></i>
                                        12%
                                    </span>
                                </div>
                                <p class="text-xs text-slate-500 dark:text-slate-400">vs. last month</p>
                            </div>
                        </div>
                    </section>

                    <!-- 6. CHIPS -->
                    <section id="chips" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Chips</h2>
                            <p class="text-slate-600 dark:text-slate-400">Dismissible tags and compact labels.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Default Chips -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
