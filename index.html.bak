                            <!-- Color Variants -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Color Variants</h3>
                                <div class="flex flex-wrap gap-2">
                                    <span class="px-3 py-1.5 bg-[#52BD94]/10 dark:bg-[#52BD94]/20 text-[#52BD94] dark:text-[#52BD94] text-sm rounded-full flex items-center gap-2">
                                        Success
                                        <button class="hover:bg-green-200 dark:hover:bg-green-900/50 rounded-full p-0.5 transition-colors">
                                            <i class="ti ti-x text-xs"></i>
                                        </button>
                                    </span>
                                    <span class="px-3 py-1.5 bg-[#3366FF]/10 dark:bg-[#3366FF]/20 text-[#3366FF] dark:text-[#3366FF] text-sm rounded-full flex items-center gap-2">
                                        Info
                                        <button class="hover:bg-blue-200 dark:hover:bg-blue-900/50 rounded-full p-0.5 transition-colors">
                                            <i class="ti ti-x text-xs"></i>
                                        </button>
                                    </span>
                                    <span class="px-3 py-1.5 bg-theme-primary/20 text-slate-900 dark:text-theme-primary text-sm rounded-full flex items-center gap-2">
                                        Accent
                                        <button class="hover:bg-theme-primary/30 rounded-full p-0.5 transition-colors">
                                            <i class="ti ti-x text-xs"></i>
                                        </button>
                                    </span>
                                </div>
                            </div>
                            
                            <!-- With Icons -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">With Icons</h3>
                                <div class="flex flex-wrap gap-2">
                                    <span class="px-3 py-1.5 bg-slate-200 dark:bg-slate-800 text-slate-900 dark:text-white text-sm rounded-full flex items-center gap-2">
                                        <i class="ti ti-user text-sm"></i>
                                        User
                                        <button class="hover:bg-slate-300 dark:hover:bg-slate-700 rounded-full p-0.5 transition-colors">
                                            <i class="ti ti-x text-xs"></i>
                                        </button>
                                    </span>
                                    <span class="px-3 py-1.5 bg-slate-200 dark:bg-slate-800 text-slate-900 dark:text-white text-sm rounded-full flex items-center gap-2">
                                        <i class="ti ti-folder text-sm"></i>
                                        Project
                                        <button class="hover:bg-slate-300 dark:hover:bg-slate-700 rounded-full p-0.5 transition-colors">
                                            <i class="ti ti-x text-xs"></i>
                                        </button>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 7. LABELS -->
                    <section id="labels" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Labels</h2>
                            <p class="text-slate-600 dark:text-slate-400">Form labels with various styles and states.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Default Labels -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Default</h3>
                                <div class="space-y-4">
                                    <div>
                                        <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                                            Email Address
                                        </label>
                                        <input type="email" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="you@example.com">
                                    </div>
                                    
                                    <div>
                                        <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                                            Password
                                            <span class="text-slate-500 dark:text-slate-400 font-normal">(optional)</span>
                                        </label>
                                        <input type="password" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="••••••••">
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Required Labels -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Required</h3>
                                <div>
                                    <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                                        Full Name
                                        <span class="text-[#D14343]">*</span>
                                    </label>
                                    <input type="text" required class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="John Doe">
                                </div>
                            </div>
                            
                            <!-- With Helper Text -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">With Helper Text</h3>
                                <div>
                                    <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                                        Username
                                    </label>
                                    <input type="text" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="johndoe">
                                    <p class="mt-1.5 text-xs text-slate-500 dark:text-slate-400">
                                        Your username must be unique and contain only letters, numbers, and underscores.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 8. SPINNER -->
                    <section id="spinner" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Spinner</h2>
                            <p class="text-slate-600 dark:text-slate-400">Loading indicators with various sizes and styles.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Default Spinners -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Sizes</h3>
                                <div class="flex flex-wrap items-center gap-8">
                                    <!-- Small -->
                                    <div class="flex flex-col items-center gap-2">
                                        <div class="animate-spin rounded-full h-4 w-4 border-2 border-slate-300 dark:border-slate-700 border-t-slate-900 dark:border-t-white"></div>
                                        <span class="text-xs text-slate-500 dark:text-slate-400">Small</span>
                                    </div>
                                    <!-- Medium -->
                                    <div class="flex flex-col items-center gap-2">
                                        <div class="animate-spin rounded-full h-8 w-8 border-2 border-slate-300 dark:border-slate-700 border-t-slate-900 dark:border-t-white"></div>
                                        <span class="text-xs text-slate-500 dark:text-slate-400">Medium</span>
                                    </div>
                                    <!-- Large -->
                                    <div class="flex flex-col items-center gap-2">
                                        <div class="animate-spin rounded-full h-12 w-12 border-2 border-slate-300 dark:border-slate-700 border-t-slate-900 dark:border-t-white"></div>
                                        <span class="text-xs text-slate-500 dark:text-slate-400">Large</span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Color Variants -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Colors</h3>
                                <div class="flex flex-wrap items-center gap-8">
                                    <div class="flex flex-col items-center gap-2">
                                        <div class="animate-spin rounded-full h-8 w-8 border-2 border-slate-300 dark:border-slate-700 border-t-slate-900 dark:border-t-white"></div>
                                        <span class="text-xs text-slate-500 dark:text-slate-400">Default</span>
                                    </div>
                                    <div class="flex flex-col items-center gap-2">
                                        <div class="animate-spin rounded-full h-8 w-8 border-2 border-theme-primary/30 border-t-theme-primary"></div>
                                        <span class="text-xs text-slate-500 dark:text-slate-400">Accent</span>
                                    </div>
                                    <div class="flex flex-col items-center gap-2">
                                        <div class="animate-spin rounded-full h-8 w-8 border-2 border-green-200 dark:border-green-900 border-t-green-600 dark:border-t-green-400"></div>
                                        <span class="text-xs text-slate-500 dark:text-slate-400">Success</span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- With Text -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">With Text</h3>
                                <div class="flex items-center gap-3">
                                    <div class="animate-spin rounded-full h-5 w-5 border-2 border-slate-300 dark:border-slate-700 border-t-slate-900 dark:border-t-white"></div>
                                    <span class="text-sm text-slate-600 dark:text-slate-400">Loading...</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 9. INPUTS -->
                    <section id="inputs" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Inputs</h2>
                            <p class="text-slate-600 dark:text-slate-400">Text, textarea, and password input fields.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Text Input -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Text Input</h3>
                                <div class="space-y-4 max-w-md">
                                    <input type="text" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="Enter text...">
                                    <input type="text" class="w-full px-4 py-2 border border-red-300 dark:border-red-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-red-500" placeholder="Error state">
                                    <input type="text" disabled class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-500 rounded-md cursor-not-allowed" placeholder="Disabled">
                                </div>
                            </div>
                            
                            <!-- Textarea -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Textarea</h3>
                                <div class="max-w-md">
                                    <textarea rows="4" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary resize-none" placeholder="Enter your message..."></textarea>
                                </div>
                            </div>
                            
                            <!-- Password Input -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Password Input</h3>
                                <div class="max-w-md">
                                    <div class="relative">
                                        <input type="password" id="password-input" class="w-full px-4 py-2 pr-10 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="Enter password">
                                        <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-900 dark:hover:text-white">
                                            <i class="ti ti-eye"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- With Icons -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">With Icons</h3>
                                <div class="space-y-4 max-w-md">
                                    <div class="relative">
                                        <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
                                        <input type="text" class="w-full pl-10 pr-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="Search...">
                                    </div>
                                    <div class="relative">
                                        <i class="ti ti-mail absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
                                        <input type="email" class="w-full pl-10 pr-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="Email address">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 10. SPECIALTY INPUTS -->
                    <section id="specialty-inputs" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Specialty Inputs</h2>
                            <p class="text-slate-600 dark:text-slate-400">Specialized input fields for numbers and URLs.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Number Input -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Number Input</h3>
                                <div class="space-y-4 max-w-md">
                                    <input type="number" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="0" min="0" max="100">
                                    <div class="flex gap-2">
                                        <input type="number" class="flex-1 px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="Min" value="0">
                                        <span class="flex items-center text-slate-500 dark:text-slate-400">to</span>
                                        <input type="number" class="flex-1 px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="Max" value="100">
                                    </div>
                                </div>
                            </div>
                            
                            <!-- URL Input -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">URL Input</h3>
                                <div class="max-w-md">
                                    <div class="relative">
                                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">https://</span>
                                        <input type="url" class="w-full pl-20 pr-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="example.com">
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Currency Input -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Currency Input</h3>
                                <div class="max-w-md">
                                    <div class="relative">
                                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">$</span>
                                        <input type="number" class="w-full pl-8 pr-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="0.00" step="0.01">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 11. CHECKBOXES -->
                    <section id="checkboxes" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Checkboxes</h2>
                            <p class="text-slate-600 dark:text-slate-400">Single checkbox inputs with different states.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Default Checkboxes -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">States</h3>
                                <div class="space-y-4">
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="checkbox" class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-2">
                                        <span class="text-sm text-slate-900 dark:text-white">Unchecked</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="checkbox" checked class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-2">
                                        <span class="text-sm text-slate-900 dark:text-white">Checked</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-not-allowed opacity-50">
                                        <input type="checkbox" disabled class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary">
                                        <span class="text-sm text-slate-900 dark:text-white">Disabled</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-not-allowed opacity-50">
                                        <input type="checkbox" checked disabled class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary">
                                        <span class="text-sm text-slate-900 dark:text-white">Checked & Disabled</span>
                                    </label>
                                </div>
                            </div>
                            
                            <!-- With Descriptions -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">With Descriptions</h3>
                                <div class="space-y-4">
                                    <label class="flex items-start gap-3 cursor-pointer">
                                        <input type="checkbox" class="w-5 h-5 mt-0.5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-2">
                                        <div>
                                            <div class="text-sm font-medium text-slate-900 dark:text-white">Marketing emails</div>
                                            <div class="text-xs text-slate-500 dark:text-slate-400">Receive promotional emails and updates</div>
                                        </div>
                                    </label>
                                    <label class="flex items-start gap-3 cursor-pointer">
                                        <input type="checkbox" checked class="w-5 h-5 mt-0.5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-2">
                                        <div>
                                            <div class="text-sm font-medium text-slate-900 dark:text-white">Security notifications</div>
                                            <div class="text-xs text-slate-500 dark:text-slate-400">Get notified about account security</div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 12. CHECKBOX GROUPS -->
                    <section id="checkbox-groups" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Checkbox Groups</h2>
                            <p class="text-slate-600 dark:text-slate-400">Multiple checkbox selections.</p>
                        </div>
                        
                        <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                            <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Select Multiple</h3>
                            <div class="space-y-3">
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" checked class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-2">
                                    <span class="text-sm text-slate-900 dark:text-white">React</span>
                                </label>
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" checked class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-2">
                                    <span class="text-sm text-slate-900 dark:text-white">Vue</span>
                                </label>
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-2">
                                    <span class="text-sm text-slate-900 dark:text-white">Angular</span>
                                </label>
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" checked class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-2">
                                    <span class="text-sm text-slate-900 dark:text-white">Svelte</span>
                                </label>
                            </div>
                        </div>
                    </section>

                    <!-- 13. RADIO BUTTONS -->
                    <section id="radio-buttons" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Radio Buttons</h2>
                            <p class="text-slate-600 dark:text-slate-400">Single selection radio inputs.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Default Radio -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">States</h3>
                                <div class="space-y-4">
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="radio" name="radio-demo" class="w-5 h-5 border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-2">
                                        <span class="text-sm text-slate-900 dark:text-white">Unselected</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="radio" name="radio-demo" checked class="w-5 h-5 border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-2">
                                        <span class="text-sm text-slate-900 dark:text-white">Selected</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-not-allowed opacity-50">
                                        <input type="radio" name="radio-demo" disabled class="w-5 h-5 border-slate-300 dark:border-slate-700 text-theme-primary">
                                        <span class="text-sm text-slate-900 dark:text-white">Disabled</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 14. RADIO GROUPS -->
                    <section id="radio-groups" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Radio Groups</h2>
                            <p class="text-slate-600 dark:text-slate-400">Grouped radio button selections.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Vertical Group -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Vertical Layout</h3>
                                <div class="space-y-3">
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="radio" name="plan" value="free" checked class="w-5 h-5 border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-2">
                                        <span class="text-sm text-slate-900 dark:text-white">Free Plan</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="radio" name="plan" value="pro" class="w-5 h-5 border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-2">
                                        <span class="text-sm text-slate-900 dark:text-white">Pro Plan</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="radio" name="plan" value="enterprise" class="w-5 h-5 border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-2">
                                        <span class="text-sm text-slate-900 dark:text-white">Enterprise Plan</span>
                                    </label>
                                </div>
                            </div>
                            
                            <!-- Card Style -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Card Style</h3>
                                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                    <label class="relative cursor-pointer">
                                        <input type="radio" name="plan-card" value="starter" checked class="peer sr-only">
                                        <div class="p-4 border-2 border-slate-200 dark:border-slate-800 rounded-lg peer-checked:border-theme-primary peer-checked:bg-theme-primary/5 transition-colors">
                                            <div class="text-sm font-semibold text-slate-900 dark:text-white mb-1">Starter</div>
                                            <div class="text-xs text-slate-500 dark:text-slate-400">$0/month</div>
                                        </div>
                                    </label>
                                    <label class="relative cursor-pointer">
                                        <input type="radio" name="plan-card" value="pro" class="peer sr-only">
                                        <div class="p-4 border-2 border-slate-200 dark:border-slate-800 rounded-lg peer-checked:border-theme-primary peer-checked:bg-theme-primary/5 transition-colors">
                                            <div class="text-sm font-semibold text-slate-900 dark:text-white mb-1">Pro</div>
                                            <div class="text-xs text-slate-500 dark:text-slate-400">$29/month</div>
                                        </div>
                                    </label>
                                    <label class="relative cursor-pointer">
                                        <input type="radio" name="plan-card" value="team" class="peer sr-only">
                                        <div class="p-4 border-2 border-slate-200 dark:border-slate-800 rounded-lg peer-checked:border-theme-primary peer-checked:bg-theme-primary/5 transition-colors">
                                            <div class="text-sm font-semibold text-slate-900 dark:text-white mb-1">Team</div>
                                            <div class="text-xs text-slate-500 dark:text-slate-400">$99/month</div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 15. TOGGLE SWITCHES -->
                    <section id="toggle-switches" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Toggle Switches</h2>
                            <p class="text-slate-600 dark:text-slate-400">On/off toggle controls.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Default Toggles -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">States</h3>
                                <div class="space-y-4">
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <div class="relative">
                                            <input type="checkbox" class="sr-only peer">
                                            <div class="w-11 h-6 bg-slate-300 dark:bg-slate-700 rounded-full peer peer-checked:bg-theme-primary peer-focus:ring-2 peer-focus:ring-theme-primary/50 transition-colors"></div>
                                            <div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full peer-checked:translate-x-5 transition-transform"></div>
                                        </div>
                                        <span class="text-sm text-slate-900 dark:text-white">Off</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <div class="relative">
                                            <input type="checkbox" checked class="sr-only peer">
                                            <div class="w-11 h-6 bg-slate-300 dark:bg-slate-700 rounded-full peer peer-checked:bg-theme-primary peer-focus:ring-2 peer-focus:ring-theme-primary/50 transition-colors"></div>
                                            <div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full peer-checked:translate-x-5 transition-transform"></div>
                                        </div>
                                        <span class="text-sm text-slate-900 dark:text-white">On</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-not-allowed opacity-50">
                                        <div class="relative">
                                            <input type="checkbox" disabled class="sr-only peer">
                                            <div class="w-11 h-6 bg-slate-300 dark:bg-slate-700 rounded-full transition-colors"></div>
                                            <div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full transition-transform"></div>
                                        </div>
                                        <span class="text-sm text-slate-900 dark:text-white">Disabled</span>
                                    </label>
                                </div>
                            </div>
                            
                            <!-- With Labels -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">With Descriptions</h3>
                                <div class="space-y-6">
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <div class="text-sm font-medium text-slate-900 dark:text-white">Email notifications</div>
                                            <div class="text-xs text-slate-500 dark:text-slate-400">Receive emails about your account activity</div>
                                        </div>
                                        <label class="relative cursor-pointer">
                                            <input type="checkbox" checked class="sr-only peer">
                                            <div class="w-11 h-6 bg-slate-300 dark:bg-slate-700 rounded-full peer peer-checked:bg-theme-primary transition-colors"></div>
                                            <div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full peer-checked:translate-x-5 transition-transform"></div>
                                        </label>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <div class="text-sm font-medium text-slate-900 dark:text-white">Push notifications</div>
                                            <div class="text-xs text-slate-500 dark:text-slate-400">Get push notifications on your device</div>
                                        </div>
                                        <label class="relative cursor-pointer">
                                            <input type="checkbox" class="sr-only peer">
                                            <div class="w-11 h-6 bg-slate-300 dark:bg-slate-700 rounded-full peer peer-checked:bg-theme-primary transition-colors"></div>
                                            <div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full peer-checked:translate-x-5 transition-transform"></div>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 16. DROPDOWNS -->
                    <section id="dropdowns" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Dropdowns</h2>
                            <p class="text-slate-600 dark:text-slate-400">Select menus and dropdown controls.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Basic Select -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Basic Select</h3>
                                <div class="max-w-md">
                                    <select class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary">
                                        <option>Select an option...</option>
                                        <option>Option 1</option>
                                        <option>Option 2</option>
                                        <option>Option 3</option>
                                    </select>
                                </div>
                            </div>
                            
                            <!-- Custom Dropdown -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Custom Dropdown</h3>
                                <div class="relative max-w-md">
                                    <button type="button" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary flex items-center justify-between">
                                        <span>Select option</span>
                                        <i class="ti ti-chevron-down"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 17. DATE PICKER -->
                    <section id="date-picker" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Date Picker</h2>
                            <p class="text-slate-600 dark:text-slate-400">Calendar date selection input.</p>
                        </div>
                        
                        <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                            <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Date Input</h3>
                            <div class="max-w-md space-y-4">
                                <div class="relative">
                                    <input type="date" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary">
                                </div>
                                <div class="flex gap-2">
                                    <input type="date" class="flex-1 px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="Start date">
                                    <input type="date" class="flex-1 px-4 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-theme-primary" placeholder="End date">
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 18. ACCORDION -->
                    <section id="accordion" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Accordion</h2>
                            <p class="text-slate-600 dark:text-slate-400">Expandable and collapsible content panels.</p>
                        </div>
                        
                        <div class="max-w-2xl space-y-2">
                            <div class="border border-slate-200 dark:border-slate-800 rounded-lg overflow-hidden bg-white dark:bg-surface">
                                <button class="accordion-trigger w-full px-6 py-4 text-left flex items-center justify-between hover:bg-slate-50 dark:hover:bg-slate-900 transition-colors">
                                    <span class="font-medium text-slate-900 dark:text-white">What is a design system?</span>
                                    <i class="ti ti-chevron-down text-slate-500 dark:text-slate-400 transition-transform"></i>
                                </button>
                                <div class="accordion-content hidden px-6 pb-4 text-sm text-slate-600 dark:text-slate-400">
                                    A design system is a collection of reusable components, guided by clear standards, that can be assembled together to build any number of applications.
                                </div>
                            </div>
                            
                            <div class="border border-slate-200 dark:border-slate-800 rounded-lg overflow-hidden bg-white dark:bg-surface">
                                <button class="accordion-trigger w-full px-6 py-4 text-left flex items-center justify-between hover:bg-slate-50 dark:hover:bg-slate-900 transition-colors">
                                    <span class="font-medium text-slate-900 dark:text-white">How do I use these components?</span>
                                    <i class="ti ti-chevron-down text-slate-500 dark:text-slate-400 transition-transform"></i>
                                </button>
                                <div class="accordion-content hidden px-6 pb-4 text-sm text-slate-600 dark:text-slate-400">
                                    Simply copy the HTML markup for any component and customize it to fit your needs. All components are built with Tailwind CSS utility classes.
                                </div>
                            </div>
                            
                            <div class="border border-slate-200 dark:border-slate-800 rounded-lg overflow-hidden bg-white dark:bg-surface">
                                <button class="accordion-trigger w-full px-6 py-4 text-left flex items-center justify-between hover:bg-slate-50 dark:hover:bg-slate-900 transition-colors">
                                    <span class="font-medium text-slate-900 dark:text-white">Are these components accessible?</span>
                                    <i class="ti ti-chevron-down text-slate-500 dark:text-slate-400 transition-transform"></i>
                                </button>
                                <div class="accordion-content hidden px-6 pb-4 text-sm text-slate-600 dark:text-slate-400">
                                    Yes, all components are built with accessibility in mind, using semantic HTML and ARIA attributes where necessary.
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 19. TAB STRIP -->
                    <section id="tab-strip" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Tab Strip</h2>
                            <p class="text-slate-600 dark:text-slate-400">Horizontal tab navigation.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Underline Tabs -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Underline Style</h3>
                                <div class="border-b border-slate-200 dark:border-slate-800">
                                    <nav class="flex gap-6">
                                        <button class="pb-3 border-b-2 border-theme-primary text-sm font-medium text-slate-900 dark:text-white">Overview</button>
                                        <button class="pb-3 border-b-2 border-transparent text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-slate-700 transition-colors">Analytics</button>
                                        <button class="pb-3 border-b-2 border-transparent text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-slate-700 transition-colors">Reports</button>
                                        <button class="pb-3 border-b-2 border-transparent text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-slate-700 transition-colors">Settings</button>
                                    </nav>
                                </div>
                            </div>
                            
                            <!-- Pill Tabs -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Pill Style</h3>
                                <div class="inline-flex p-1 bg-slate-200 dark:bg-slate-800 rounded-lg gap-1">
                                    <button class="px-4 py-2 bg-white dark:bg-slate-900 text-slate-900 dark:text-white text-sm font-medium rounded-md shadow-sm">All</button>
                                    <button class="px-4 py-2 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white text-sm font-medium rounded-md">Active</button>
                                    <button class="px-4 py-2 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white text-sm font-medium rounded-md">Completed</button>
                                    <button class="px-4 py-2 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white text-sm font-medium rounded-md">Archived</button>
                                </div>
                            </div>
                            
                            <!-- With Icons -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">With Icons</h3>
                                <div class="border-b border-slate-200 dark:border-slate-800">
                                    <nav class="flex gap-6">
                                        <button class="pb-3 border-b-2 border-theme-primary text-sm font-medium text-slate-900 dark:text-white flex items-center gap-2">
                                            <i class="ti ti-home"></i>
                                            Home
                                        </button>
                                        <button class="pb-3 border-b-2 border-transparent text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-slate-700 transition-colors flex items-center gap-2">
                                            <i class="ti ti-chart-bar"></i>
                                            Stats
                                        </button>
                                        <button class="pb-3 border-b-2 border-transparent text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-slate-700 transition-colors flex items-center gap-2">
                                            <i class="ti ti-settings"></i>
                                            Settings
                                        </button>
                                    </nav>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- 20. LIST MENU -->
                    <section id="list-menu" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">List Menu</h2>
