                    <!-- 2. BUTTON GROUPS -->
                    <section id="button-groups" class="mb-24 scroll-mt-20">
                        <div class="mb-8">
                            <h2 class="font-display text-3xl font-bold mb-2 text-slate-900 dark:text-white">Button Groups</h2>
                            <p class="text-slate-600 dark:text-slate-400">Segmented controls and grouped button layouts.</p>
                        </div>
                        
                        <div class="space-y-8">
                            <!-- Horizontal Group -->
                            <div class="p-8 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50 rounded-lg">
                                <h3 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Horizontal Group</h3>
                                <div class="inline-flex rounded-md shadow-sm" role="group">
                                    <button class="px-4 py-2 text-sm font-medium text-slate-900 dark:text-white bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-l-md hover:bg-slate-50 dark:hover:bg-slate-700">
