---
import '../../styles/global.css';
import RadioButton from '../../components/ui/RadioButton.astro';
import Label from '../../components/ui/Label.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme') || 'dark';
        const savedColorTheme = localStorage.getItem('colorTheme') || 'cp';
        if (savedTheme === 'dark') document.documentElement.classList.add('dark');
        document.documentElement.classList.add('theme-' + savedColorTheme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Radio Buttons Preview</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; width: 100%; }
      body { padding: 48px; display: flex; flex-direction: column; gap: 16px; }
    </style>
  </head>
  <body>
    <div style="display: flex; align-items: center; gap: 8px;">
      <RadioButton id="rb1" name="radio-group" checked />
      <Label for="rb1">Option 1</Label>
    </div>
    <div style="display: flex; align-items: center; gap: 8px;">
      <RadioButton id="rb2" name="radio-group" />
      <Label for="rb2">Option 2</Label>
    </div>
    <div style="display: flex; align-items: center; gap: 8px;">
      <RadioButton id="rb3" name="radio-group" />
      <Label for="rb3">Option 3</Label>
    </div>
    <div style="display: flex; align-items: center; gap: 8px;">
      <RadioButton id="rb4" name="radio-group2" disabled />
      <Label for="rb4">Disabled option</Label>
    </div>
  </body>
</html>

