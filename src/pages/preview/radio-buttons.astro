---
import '../../styles/global.css';
import RadioButton from '../../components/ui/RadioButton.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme') || 'dark';
        const savedColorTheme = localStorage.getItem('colorTheme') || 'cp';
        if (savedTheme === 'dark') document.documentElement.classList.add('dark');
        document.documentElement.classList.add('theme-' + savedColorTheme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Radio Buttons Preview</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; width: 100%; }
      body { padding: 48px; display: flex; flex-direction: column; gap: 24px; }
      .preview-section { display: flex; flex-direction: column; gap: 12px; }
      .preview-section h3 { font-size: 0.875rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 4px; }
    </style>
  </head>
  <body>
    <div class="preview-section">
      <h3>Basic (medium default)</h3>
      <RadioButton name="basic" value="1" label="Option 1" />
      <RadioButton name="basic" value="2" label="Option 2" checked />
      <RadioButton name="basic" value="3" label="Option 3" />
    </div>
    <div class="preview-section">
      <h3>Size variants</h3>
      <RadioButton name="sizes" value="sm" label="Small" size="small" />
      <RadioButton name="sizes" value="md" label="Medium" size="medium" checked />
      <RadioButton name="sizes" value="lg" label="Large" size="large" />
    </div>
    <div class="preview-section">
      <h3>States</h3>
      <RadioButton name="states" value="1" label="Unchecked" />
      <RadioButton name="states" value="2" label="Checked" checked />
      <RadioButton name="states-disabled" value="3" label="Disabled" disabled />
      <RadioButton name="states-disabled" value="4" label="Checked & Disabled" checked disabled />
    </div>
    <div class="preview-section">
      <h3>Warning & error</h3>
      <RadioButton name="warn" value="1" label="Warning" warning warningMessage="Review carefully" />
      <RadioButton name="err" value="1" label="Error" error errorMessage="This field is required" />
    </div>
  </body>
</html>

