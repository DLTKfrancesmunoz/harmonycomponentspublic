                <span style="display: inline-flex; flex-wrap: wrap; align-items: center; gap: 4px" aria-hidden="true">
                  <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: #F58220; flex-shrink: 0"></span>
                  <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: #D32F2F; flex-shrink: 0"></span>
                </span>
              </td>
              <td style="color: var(--color-error-text, var(--color-error))">1/2</td>
            </tr>
            <tr data-row-id="PR-2047">
