---
import '../../styles/global.css';
import Table from '../../components/ui/Table.astro';
import Badge from '../../components/ui/Badge.astro';
import Checkbox from '../../components/ui/Checkbox.astro';
import Icon from '../../components/ui/Icon.astro';
import Dropdown from '../../components/ui/Dropdown.astro';
import Button from '../../components/ui/Button.astro';
import Chip from '../../components/ui/Chip.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme') || 'dark';
        const savedColorTheme = localStorage.getItem('colorTheme') || 'cp';
        if (savedTheme === 'dark') document.documentElement.classList.add('dark');
        document.documentElement.classList.add('theme-' + savedColorTheme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tables Preview</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; width: 100%; }
      body { padding: 48px; display: flex; flex-direction: column; gap: 32px; }
    </style>
  </head>
  <body>
    <!-- Basic Table with Gray Header -->
    <div>
      <h2 style="margin-bottom: 16px; font-size: 18px; font-weight: 600;">Basic Table - Gray Header</h2>
      <div class="overflow-x-auto">
        <Table headerVariant="gray">
          <Fragment slot="header">
            <tr>
              <th class="text-left">Project ID</th>
              <th class="text-left">Name</th>
              <th class="text-left">Status</th>
              <th class="text-right">Budget</th>
            </tr>
          </Fragment>
          <Fragment slot="body">
            <tr>
              <td>PRJ-001</td>
              <td>Website Redesign</td>
              <td>
                <Badge variant="success">Active</Badge>
              </td>
              <td class="text-right">$25,000</td>
            </tr>
            <tr>
              <td>PRJ-002</td>
              <td>Mobile App Development</td>
              <td>
                <Badge variant="warning">In Progress</Badge>
              </td>
              <td class="text-right">$150,000</td>
            </tr>
            <tr>
              <td>PRJ-003</td>
              <td>Database Migration</td>
              <td>
                <Badge variant="default">Pending</Badge>
              </td>
              <td class="text-right">$45,000</td>
            </tr>
          </Fragment>
        </Table>
      </div>
    </div>

    <!-- Table with White Header -->
    <div>
      <h2 style="margin-bottom: 16px; font-size: 18px; font-weight: 600;">Table - White Header</h2>
      <div class="overflow-x-auto">
        <Table headerVariant="white">
          <Fragment slot="header">
            <tr>
              <th class="text-left">Project ID</th>
              <th class="text-left">Name</th>
              <th class="text-left">Status</th>
              <th class="text-right">Budget</th>
            </tr>
          </Fragment>
          <Fragment slot="body">
            <tr>
              <td>PRJ-001</td>
              <td>Website Redesign</td>
              <td>
                <Badge variant="success">Active</Badge>
              </td>
              <td class="text-right">$25,000</td>
            </tr>
            <tr>
              <td>PRJ-002</td>
              <td>Mobile App Development</td>
              <td>
                <Badge variant="warning">In Progress</Badge>
              </td>
              <td class="text-right">$150,000</td>
            </tr>
          </Fragment>
        </Table>
      </div>
    </div>

    <!-- Interactive Table with Selection -->
    <div>
      <h2 style="margin-bottom: 16px; font-size: 18px; font-weight: 600;">Interactive Table - Row Selection (Blue Highlight)</h2>
      <div class="overflow-x-auto">
        <Table headerVariant="gray">
          <Fragment slot="header">
            <tr>
              <th class="w-10">
                <Checkbox name="select-all" aria-label="Select all rows" />
              </th>
              <th class="text-left">Employee</th>
              <th class="text-left">Department</th>
              <th class="text-left">Role</th>
              <th class="text-right">Actions</th>
            </tr>
          </Fragment>
          <Fragment slot="body">
            <tr>
              <td>
                <Checkbox name="select-employee-1" aria-label="Select row for John Doe" />
              </td>
              <td>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: var(--theme-primary);">
                    <span class="text-xs font-medium" style="color: var(--text-inverse);">JD</span>
                  </div>
                  <div>
                    <div class="font-medium text-primary">John Doe</div>
                    <div class="text-xs text-muted">john.doe@company.com</div>
                  </div>
                </div>
              </td>
              <td>Engineering</td>
              <td>Senior Developer</td>
              <td class="table-cell--actions">
                <button type="button" class="icon-btn">
                  <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                </button>
              </td>
            </tr>
            <tr>
              <td>
                <Checkbox name="select-employee-2" aria-label="Select row for Jane Smith" />
              </td>
              <td>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: var(--theme-primary);">
                    <span class="text-xs font-medium" style="color: var(--text-inverse);">JS</span>
                  </div>
                  <div>
                    <div class="font-medium text-primary">Jane Smith</div>
                    <div class="text-xs text-muted">jane.smith@company.com</div>
                  </div>
                </div>
              </td>
              <td>Design</td>
              <td>UX Lead</td>
              <td class="table-cell--actions">
                <button type="button" class="icon-btn">
                  <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                </button>
              </td>
            </tr>
            <tr>
              <td>
                <Checkbox name="select-employee-3" aria-label="Select row for Mike Johnson" />
              </td>
              <td>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: var(--theme-primary);">
                    <span class="text-xs font-medium" style="color: var(--text-inverse);">MJ</span>
                  </div>
                  <div>
                    <div class="font-medium text-primary">Mike Johnson</div>
                    <div class="text-xs text-muted">mike.j@company.com</div>
                  </div>
                </div>
              </td>
              <td>Marketing</td>
              <td>Manager</td>
              <td class="table-cell--actions">
                <button type="button" class="icon-btn">
                  <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                </button>
              </td>
            </tr>
          </Fragment>
        </Table>
      </div>
    </div>

    <!-- Table with Filter Bar -->
    <div>
      <h2 style="margin-bottom: 16px; font-size: 18px; font-weight: 600;">Table with Filter Bar</h2>
      <div class="overflow-x-auto">
        <Table headerVariant="gray">
          <div slot="filter-bar" style="display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap;">
            <Dropdown
              options={[
                { value: 'all', label: 'All periods' },
                { value: 'q1-2025', label: 'Q1 2025' },
                { value: 'q2-2025', label: 'Q2 2025' },
                { value: 'q3-2025', label: 'Q3 2025' },
              ]}
              value="q1-2025"
              placeholder="Period"
            />
            <Dropdown
              options={[
                { value: 'all', label: 'All Statuses' },
                { value: 'active', label: 'Active' },
                { value: 'in-progress', label: 'In Progress' },
                { value: 'pending', label: 'Pending' },
              ]}
              value="active"
              placeholder="Status"
            />
            <Button variant="ghost" size="sm">
              Clear
            </Button>
            <div style="display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap;">
              <Chip label="Q1 2025" removable />
              <Chip label="Active" removable />
            </div>
          </div>
          <Fragment slot="header">
            <tr>
              <th class="text-left">Project ID</th>
              <th class="text-left">Name</th>
              <th class="text-left">Status</th>
              <th class="text-right">Budget</th>
            </tr>
          </Fragment>
          <Fragment slot="body">
            <tr>
              <td>PRJ-001</td>
              <td>Website Redesign</td>
              <td>
                <Badge variant="success">Active</Badge>
              </td>
              <td class="text-right">$25,000</td>
            </tr>
            <tr>
              <td>PRJ-002</td>
              <td>Mobile App Development</td>
              <td>
                <Badge variant="warning">In Progress</Badge>
              </td>
              <td class="text-right">$150,000</td>
            </tr>
            <tr>
              <td>PRJ-003</td>
              <td>Database Migration</td>
              <td>
                <Badge variant="default">Pending</Badge>
              </td>
              <td class="text-right">$45,000</td>
            </tr>
          </Fragment>
        </Table>
      </div>
    </div>

    <!-- Striped Table with Total Row -->
    <div>
      <h2 style="margin-bottom: 16px; font-size: 18px; font-weight: 600;">Striped Table - Blue Total Row</h2>
      <div class="overflow-x-auto">
        <Table headerVariant="gray" striped>
          <Fragment slot="header">
            <tr>
              <th class="text-left">Code</th>
              <th class="text-left">Description</th>
              <th class="text-right">Amount</th>
            </tr>
          </Fragment>
          <Fragment slot="body">
            <tr>
              <td class="font-mono">ACC-1001</td>
              <td>Operating Expenses</td>
              <td class="text-right">$12,450.00</td>
            </tr>
            <tr>
              <td class="font-mono">ACC-1002</td>
              <td>Equipment Purchase</td>
              <td class="text-right">$8,750.00</td>
            </tr>
            <tr>
              <td class="font-mono">ACC-1003</td>
              <td>Travel & Entertainment</td>
              <td class="text-right">$3,200.00</td>
            </tr>
            <tr>
              <td class="font-mono">ACC-1004</td>
              <td>Software Licenses</td>
              <td class="text-right">$15,600.00</td>
            </tr>
            <tr class="table-row--total font-semibold">
              <td colspan="2">Total</td>
              <td class="text-right">$40,000.00</td>
            </tr>
          </Fragment>
        </Table>
      </div>
    </div>

    <!-- Table with Reorderable Rows -->
    <div>
      <h2 style="margin-bottom: 16px; font-size: 18px; font-weight: 600;">Table with Reorderable Rows</h2>
      <div class="overflow-x-auto">
        <Table headerVariant="gray" reorderable>
          <Fragment slot="header">
            <tr>
              <th class="table__grip-column" scope="col" aria-label="Reorder"></th>
              <th class="text-left">Project ID</th>
              <th class="text-left">Name</th>
              <th class="text-left">Status</th>
              <th class="text-right">Budget</th>
            </tr>
          </Fragment>
          <Fragment slot="body">
            <tr>
              <td>PRJ-001</td>
              <td>Website Redesign</td>
              <td>
                <Badge variant="success">Active</Badge>
              </td>
              <td class="text-right">$25,000</td>
            </tr>
            <tr>
              <td>PRJ-002</td>
              <td>Mobile App Development</td>
              <td>
                <Badge variant="warning">In Progress</Badge>
              </td>
              <td class="text-right">$150,000</td>
            </tr>
            <tr>
              <td>PRJ-003</td>
              <td>Database Migration</td>
              <td>
                <Badge variant="default">Pending</Badge>
              </td>
              <td class="text-right">$45,000</td>
            </tr>
            <tr>
              <td>PRJ-004</td>
              <td>Security Audit</td>
              <td>
                <Badge variant="info">Review</Badge>
              </td>
              <td class="text-right">$12,500</td>
            </tr>
          </Fragment>
        </Table>
      </div>
    </div>

    <!-- Table with Grouped Rows -->
    <div>
      <h2 style="margin-bottom: 16px; font-size: 18px; font-weight: 600;">Table with Grouped Rows</h2>
      <div class="overflow-x-auto">
        <Table headerVariant="gray" grouped>
          <h1 slot="title-bar-content" style="font-family: var(--font-display); font-size: var(--text-13); font-weight: var(--font-semibold); line-height: var(--leading-snug); color: var(--text-primary); margin: 0;">Title Bar</h1>
          <div slot="title-bar-icons" style="display: flex; align-items: center; gap: var(--space-2);">
            <button type="button" class="table__title-bar-icon" aria-label="Help">
              <Icon name="question-mark-circle" size="sm" />
            </button>
            <button type="button" class="table__title-bar-icon" aria-label="Minimize">
              <Icon name="minimize" size="sm" />
            </button>
            <button type="button" class="table__title-bar-icon" aria-label="Window">
              <Icon name="window" size="sm" />
            </button>
            <button type="button" class="table__title-bar-icon" aria-label="Close">
              <Icon name="x-mark" size="sm" />
            </button>
          </div>
          <div slot="action-bar" style="display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap;">
            <Button variant="ghost" size="sm" icon="document-duplicate" iconPosition="right">Copy</Button>
            <Button variant="ghost" size="sm" icon="plus" iconPosition="right">Add</Button>
            <Button variant="ghost" size="sm" icon="trash">Delete</Button>
            <span style="color: var(--text-secondary); font-size: var(--text-sm); padding: 0 var(--space-1);">|</span>
            <Button variant="ghost" size="sm" icon="queue-list">Group</Button>
            <Button variant="ghost" size="sm" icon="cog-6-tooth">Customize Columns</Button>
            <span style="font-family: var(--font-sans); font-size: var(--text-sm); font-weight: var(--font-normal); color: var(--text-primary); padding: var(--space-1) var(--space-2);">All Filters</span>
          </div>
          <Fragment slot="header">
            <tr>
              <th class="table__expand-column" scope="col" aria-label="Expand"></th>
              <th class="text-left">Project ID</th>
              <th class="text-left">Name</th>
              <th class="text-left">Status</th>
              <th class="text-right">Budget</th>
              <th class="text-right">Actions</th>
            </tr>
          </Fragment>
          <Fragment slot="body">
            <tr data-row-id="r1" data-has-children>
              <td>PRJ-001</td>
              <td>Website Redesign</td>
              <td>
                <Badge variant="success">Active</Badge>
              </td>
              <td class="text-right">$25,000</td>
              <td class="table-cell--actions">
                <button type="button" class="icon-btn">
                  <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                </button>
              </td>
            </tr>
            <tr data-parent-id="r1" data-depth="1">
              <td>PRJ-001-A</td>
              <td>Frontend Development</td>
              <td>
                <Badge variant="warning">In Progress</Badge>
              </td>
              <td class="text-right">$12,000</td>
              <td class="table-cell--actions">
                <button type="button" class="icon-btn">
                  <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                </button>
              </td>
            </tr>
            <tr data-row-id="r2" data-has-children>
              <td>PRJ-002</td>
              <td>Mobile App Development</td>
              <td>
                <Badge variant="warning">In Progress</Badge>
              </td>
              <td class="text-right">$150,000</td>
              <td class="table-cell--actions">
                <button type="button" class="icon-btn">
                  <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                </button>
              </td>
            </tr>
            <tr data-parent-id="r2" data-depth="1">
              <td>PRJ-002-A</td>
              <td>iOS Module</td>
              <td>
                <Badge variant="info">Review</Badge>
              </td>
              <td class="text-right">$75,000</td>
              <td class="table-cell--actions">
                <button type="button" class="icon-btn">
                  <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                </button>
              </td>
            </tr>
          </Fragment>
        </Table>
      </div>
    </div>

  </body>
</html>
