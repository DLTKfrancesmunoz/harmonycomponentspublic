---
import '../../styles/global.css';
import FloatingNav from '../../components/ui/FloatingNav.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme') || 'dark';
        const savedColorTheme = localStorage.getItem('colorTheme') || 'cp';
        if (savedTheme === 'dark') document.documentElement.classList.add('dark');
        document.documentElement.classList.add('theme-' + savedColorTheme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Floating Nav Preview</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; width: 100%; }
      body { padding: 48px; display: flex; flex-direction: column; gap: 24px; }
    </style>
  </head>
  <body>
    <div style="display: flex; justify-content: center;">
      <FloatingNav variant="full" showExecute={true} saveDisabled={false} />
    </div>
    <div style="display: flex; justify-content: center;">
      <FloatingNav variant="compact" showExecute={false} saveDisabled={true} />
    </div>
  </body>
</html>

