---
import '../../styles/global.css';
import Checkbox from '../../components/ui/Checkbox.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme') || 'dark';
        const savedColorTheme = localStorage.getItem('colorTheme') || 'cp';
        if (savedTheme === 'dark') document.documentElement.classList.add('dark');
        document.documentElement.classList.add('theme-' + savedColorTheme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Checkbox Groups Preview</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; width: 100%; }
      body { padding: 48px; display: flex; flex-direction: column; gap: 24px; }
    </style>
  </head>
  <body>
    <fieldset class="space-y-4">
      <legend class="text-sm font-semibold text-primary mb-2">Notification Preferences</legend>
      <div class="flex flex-col gap-3 pl-2">
        <Checkbox label="Email notifications" name="notif-email" checked />
        <Checkbox label="SMS notifications" name="notif-sms" />
        <Checkbox label="Push notifications" name="notif-push" checked />
        <Checkbox label="Marketing emails" name="notif-marketing" />
      </div>
    </fieldset>
    <fieldset>
      <legend class="text-sm font-semibold text-primary mb-3">Select Categories</legend>
      <div class="flex flex-wrap gap-4">
        <Checkbox label="News" name="cat-news" checked />
        <Checkbox label="Sports" name="cat-sports" />
        <Checkbox label="Technology" name="cat-tech" checked />
        <Checkbox label="Entertainment" name="cat-ent" />
      </div>
    </fieldset>
  </body>
</html>

