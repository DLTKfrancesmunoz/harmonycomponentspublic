---
import '../../styles/global.css';
import Checkbox from '../../components/ui/Checkbox.astro';
import Label from '../../components/ui/Label.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme') || 'dark';
        const savedColorTheme = localStorage.getItem('colorTheme') || 'cp';
        if (savedTheme === 'dark') document.documentElement.classList.add('dark');
        document.documentElement.classList.add('theme-' + savedColorTheme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Checkboxes Preview</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; width: 100%; }
      body { padding: 48px; display: flex; flex-direction: column; gap: 16px; }
    </style>
  </head>
  <body>
    <div style="display: flex; align-items: center; gap: 8px;">
      <Checkbox id="cb1" checked />
      <Label for="cb1">Checked checkbox</Label>
    </div>
    <div style="display: flex; align-items: center; gap: 8px;">
      <Checkbox id="cb2" />
      <Label for="cb2">Unchecked checkbox</Label>
    </div>
    <div style="display: flex; align-items: center; gap: 8px;">
      <Checkbox id="cb3" disabled />
      <Label for="cb3">Disabled checkbox</Label>
    </div>
    <div style="display: flex; align-items: center; gap: 8px;">
      <Checkbox id="cb4" checked disabled />
      <Label for="cb4">Checked disabled</Label>
    </div>
  </body>
</html>

