---
import '../../styles/global.css';
import Tooltip from '../../components/ui/Tooltip.astro';
import Button from '../../components/ui/Button.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme') || 'dark';
        const savedColorTheme = localStorage.getItem('colorTheme') || 'cp';
        if (savedTheme === 'dark') document.documentElement.classList.add('dark');
        document.documentElement.classList.add('theme-' + savedColorTheme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tooltips Preview</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; width: 100%; }
      body { padding: 48px; display: flex; flex-wrap: wrap; gap: 24px; align-items: center; }
    </style>
  </head>
  <body>
    <Tooltip text="This is a tooltip">
      <Button>Hover me</Button>
    </Tooltip>
    <Tooltip text="Top tooltip" position="top">
      <Button>Top</Button>
    </Tooltip>
    <Tooltip text="Right tooltip" position="right">
      <Button>Right</Button>
    </Tooltip>
    <Tooltip text="Bottom tooltip" position="bottom">
      <Button>Bottom</Button>
    </Tooltip>
    <Tooltip text="Left tooltip" position="left">
      <Button>Left</Button>
    </Tooltip>
  </body>
</html>

