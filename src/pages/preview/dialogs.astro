---
import '../../styles/global.css';
import Dialog from '../../components/ui/Dialog.astro';
import Button from '../../components/ui/Button.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme') || 'dark';
        const savedColorTheme = localStorage.getItem('colorTheme') || 'cp';
        if (savedTheme === 'dark') document.documentElement.classList.add('dark');
        document.documentElement.classList.add('theme-' + savedColorTheme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dialogs Preview</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; width: 100%; }
      body { padding: 48px; }
    </style>
  </head>
  <body>
    <Button onclick="openDialog('preview-dialog')">Open Dialog</Button>
    <Button onclick="openDialog('preview-dialog-long')" style="margin-left: 12px;">Open Long Content</Button>

    <Dialog id="preview-dialog" title="Dialog Title">
      <p class="text-secondary">
        This is a basic dialog with sticky header and footer. Min width 600px, default 700px; all styles use design tokens.
      </p>
      <div slot="footer">
        <Button variant="ghost" onclick="closeDialog('preview-dialog')">Cancel</Button>
        <Button onclick="closeDialog('preview-dialog')">Confirm</Button>
      </div>
    </Dialog>

    <Dialog id="preview-dialog-long" title="Sticky Header & Footer">
      <div class="space-y-4">
        <p class="text-secondary">Only the body scrolls; header and footer stay visible.</p>
        <p class="text-secondary">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.</p>
        <p class="text-secondary">Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident.</p>
      </div>
      <div slot="footer">
        <Button onclick="closeDialog('preview-dialog-long')">Confirm</Button>
        <Button variant="ghost" onclick="closeDialog('preview-dialog-long')">Cancel</Button>
      </div>
    </Dialog>

    <script>
      function openDialog(id: string) {
        document.getElementById(id + '-overlay')?.classList.add('is-open');
      }
      function closeDialog(id: string) {
        document.getElementById(id + '-overlay')?.classList.remove('is-open');
      }
    </script>
  </body>
</html>

