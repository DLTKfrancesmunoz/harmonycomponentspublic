---
import '../../styles/global.css';
import Dialog from '../../components/ui/Dialog.astro';
import Button from '../../components/ui/Button.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme') || 'dark';
        const savedColorTheme = localStorage.getItem('colorTheme') || 'cp';
        if (savedTheme === 'dark') document.documentElement.classList.add('dark');
        document.documentElement.classList.add('theme-' + savedColorTheme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dialogs Preview</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; width: 100%; }
      body { padding: 48px; }
    </style>
  </head>
  <body>
    <Button onclick="openDialog('preview-dialog')">Open Dialog</Button>
    
    <Dialog id="preview-dialog" title="Dialog Title">
      <p class="text-secondary">
        This is a basic dialog with some content. You can add any content here including forms, images, or other components.
      </p>
      <div slot="footer">
        <Button variant="ghost" onclick="closeDialog('preview-dialog')">Cancel</Button>
        <Button onclick="closeDialog('preview-dialog')">Confirm</Button>
      </div>
    </Dialog>

    <script>
      function openDialog(id) {
        document.getElementById(id)?.setAttribute('open', '');
      }
      function closeDialog(id) {
        document.getElementById(id)?.removeAttribute('open');
      }
    </script>
  </body>
</html>

