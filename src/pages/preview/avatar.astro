---
import '../../styles/global.css';
import Avatar from '../../components/ui/Avatar.astro';

const demoPhoto =
  'https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&w=128&h=128&fit=crop&q=80';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme') || 'dark';
        const savedColorTheme = localStorage.getItem('colorTheme') || 'cp';
        if (savedTheme === 'dark') document.documentElement.classList.add('dark');
        document.documentElement.classList.add('theme-' + savedColorTheme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Avatar Preview</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; width: 100%; }
      body { padding: 48px; display: flex; flex-wrap: wrap; gap: 24px; align-items: center; }
    </style>
  </head>
  <body>
    <Avatar size="sm" />
    <Avatar size="md" />
    <Avatar size="lg" />
    <Avatar size="md" variant="initials" initials="Jane Doe" />
    <Avatar size="sm" variant="initials" initials="AB" />
    <Avatar size="sm" variant="image" src={demoPhoto} alt="Sample portrait" />
    <Avatar size="md" variant="image" src={demoPhoto} alt="Sample portrait" />
    <Avatar size="lg" variant="image" src={demoPhoto} alt="Sample portrait" />
    <Avatar size="sm" interactive />
    <Avatar size="md" interactive class="avatar--demo-hover" />
    <Avatar size="md" interactive class="avatar--demo-focus" />
    <Avatar size="md" interactive disabled />
  </body>
</html>
