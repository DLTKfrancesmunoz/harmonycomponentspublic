---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import Icon from '../../components/ui/Icon.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import RadioButton from '../../components/ui/RadioButton.astro';
import RadioGroup from '../../components/ui/RadioGroup.astro';

const props = [
  { name: 'name', type: 'string', default: '—', description: 'Radio group name (required) - all radio buttons in the group must share this name' },
  { name: 'legend', type: 'string', default: '—', description: 'Legend text displayed above the radio group' },
  { name: 'error', type: 'boolean', default: 'false', description: 'Shows error state on the group and all child radio buttons' },
  { name: 'warning', type: 'boolean', default: 'false', description: 'Shows warning state on the group and all child radio buttons' },
  { name: 'errorMessage', type: 'string', default: '—', description: 'Error message displayed below the group' },
  { name: 'warningMessage', type: 'string', default: '—', description: 'Warning message displayed below the group' },
  { name: 'orientation', type: "'vertical' | 'horizontal'", default: "'vertical'", description: 'Layout orientation of radio buttons' },
  { name: 'class', type: 'string', default: '—', description: 'Additional CSS classes' },
];
---

<DocsLayout title="Radio Groups" description="Groups of radio buttons for single selection.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Radio Groups</h1>
        <span class="badge badge--success">stable</span>
      </div>
      <p class="page-header__description">
        Radio groups allow users to select a single option from a set of mutually exclusive choices.
      </p>
    </header>

    <nav class="article-nav">
      <a href="#examples" class="article-nav__link"><Icon name="eye" size="sm" /> Examples</a>
      <a href="#props" class="article-nav__link"><Icon name="queue-list" size="sm" /> Props</a>
      <a href="#accessibility" class="article-nav__link"><Icon name="check-badge" size="sm" /> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="section__title">Examples</h2>

      <ExampleSection title="Basic Group" description="Standard radio group.">
        <fieldset class="space-y-4">
          <legend class="text-sm font-semibold text-primary mb-2">Shipping Method</legend>
          <div class="flex flex-col gap-3 pl-2">
            <RadioButton name="shipping" value="standard" label="Standard (5-7 days)" checked />
            <RadioButton name="shipping" value="express" label="Express (2-3 days)" />
            <RadioButton name="shipping" value="overnight" label="Overnight (Next day)" />
          </div>
        </fieldset>
      </ExampleSection>

      <ExampleSection title="Inline Group" description="Radio buttons arranged horizontally.">
        <fieldset>
          <legend class="text-sm font-semibold text-primary mb-3">Select Plan</legend>
          <div class="flex flex-wrap gap-6">
            <RadioButton name="plan" value="free" label="Free" />
            <RadioButton name="plan" value="pro" label="Pro" checked />
            <RadioButton name="plan" value="enterprise" label="Enterprise" />
          </div>
        </fieldset>
      </ExampleSection>

      <ExampleSection title="Using RadioGroup Component" description="RadioGroup component provides a cleaner API with built-in error/warning state support.">
        <RadioGroup name="shipping-group" legend="Shipping Method">
          <RadioButton name="shipping-group" value="standard" label="Standard (5-7 days)" checked />
          <RadioButton name="shipping-group" value="express" label="Express (2-3 days)" />
          <RadioButton name="shipping-group" value="overnight" label="Overnight (Next day)" />
        </RadioGroup>
      </ExampleSection>

      <ExampleSection title="Horizontal Layout" description="RadioGroup with horizontal orientation.">
        <RadioGroup name="plan-group" legend="Select Plan" orientation="horizontal">
          <RadioButton name="plan-group" value="free" label="Free" />
          <RadioButton name="plan-group" value="pro" label="Pro" checked />
          <RadioButton name="plan-group" value="enterprise" label="Enterprise" />
        </RadioGroup>
      </ExampleSection>

      <ExampleSection title="Error State" description="RadioGroup with error state - applies error styling to all child radio buttons and displays error message.">
        <div class="flex flex-col gap-6">
          <RadioGroup 
            name="shipping-error" 
            legend="Shipping Method *" 
            error 
            errorMessage="Please select a shipping method"
          >
            <RadioButton name="shipping-error" value="standard" label="Standard (5-7 days)" />
            <RadioButton name="shipping-error" value="express" label="Express (2-3 days)" />
            <RadioButton name="shipping-error" value="overnight" label="Overnight (Next day)" />
          </RadioGroup>
        </div>
      </ExampleSection>

      <ExampleSection title="Warning State" description="RadioGroup with warning state - applies warning styling to all child radio buttons and displays warning message.">
        <RadioGroup 
          name="shipping-warning" 
          legend="Shipping Method" 
          warning 
          warningMessage="Express shipping may have additional fees"
        >
          <RadioButton name="shipping-warning" value="standard" label="Standard (5-7 days)" checked />
          <RadioButton name="shipping-warning" value="express" label="Express (2-3 days)" />
          <RadioButton name="shipping-warning" value="overnight" label="Overnight (Next day)" />
        </RadioGroup>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="section__title">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="accessibility" class="space-y-4">
      <h2 class="section__title">Accessibility</h2>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="tag" size="sm" />
          Fieldset and Legend
        </h3>
        <p class="a11y-card__text">
          The RadioGroup component uses <code>&lt;fieldset&gt;</code> and <code>&lt;legend&gt;</code> elements to group related radio buttons. This provides semantic structure and helps screen readers understand the relationship between options.
        </p>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="keyboard" size="sm" />
          Keyboard Navigation
        </h3>
        <p class="a11y-card__text">
          Radio buttons in a group are keyboard accessible. Use <kbd>Tab</kbd> to navigate to the group, then <kbd>Arrow Up/Down</kbd> or <kbd>Arrow Left/Right</kbd> to move between options. <kbd>Space</kbd> selects the focused option.
        </p>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="tag" size="sm" />
          Group Association
        </h3>
        <p class="a11y-card__text">
          All radio buttons in a group must share the same <code>name</code> attribute. The RadioGroup component ensures this by requiring a <code>name</code> prop that is applied to all child radio buttons.
        </p>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="check-badge" size="sm" />
          Error and Warning States
        </h3>
        <p class="a11y-card__text">
          When <code>error</code> or <code>warning</code> props are set, the group and all child radio buttons display the appropriate state. Error/warning messages are associated via <code>aria-describedby</code> and announced to screen readers.
        </p>
      </div>
    </section>
  </article>
</DocsLayout>
