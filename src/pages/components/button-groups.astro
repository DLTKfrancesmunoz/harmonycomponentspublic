---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import ButtonGroup from '../../components/ui/ButtonGroup.astro';
import Button from '../../components/ui/Button.astro';

const props = [
  { name: 'orientation', type: "'horizontal' | 'vertical'", default: "'horizontal'", description: 'Orientation of the button group' },
  { name: 'attached', type: 'boolean', default: 'false', description: 'Attach buttons (remove gaps, round only outer edges)' },
];
---

<DocsLayout title="Button Groups" description="Horizontal button groups and segmented controls.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Button Groups</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Group related buttons together or create segmented controls for switching between views.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Basic Button Group" description="Buttons attached together with shared borders.">
        <ButtonGroup attached>
          <Button variant="outline">Left</Button>
          <Button variant="outline">Center</Button>
          <Button variant="outline">Right</Button>
        </ButtonGroup>
      </ExampleSection>

      <ExampleSection title="Primary Variants" description="Button groups with different variants.">
        <div class="flex flex-col gap-4">
          <ButtonGroup attached>
            <Button variant="primary">Save</Button>
            <Button variant="primary" icon="ti-chevron-down" />
          </ButtonGroup>
          <ButtonGroup attached>
            <Button variant="outline">Edit</Button>
            <Button variant="outline">Duplicate</Button>
            <Button variant="outline">Delete</Button>
          </ButtonGroup>
        </div>
      </ExampleSection>

      <ExampleSection title="Segmented Control" description="Toggle between mutually exclusive options.">
        <div class="inline-flex rounded-lg bg-slate-100 dark:bg-slate-800 p-1">
          <button class="px-4 py-1.5 text-sm font-medium rounded-md bg-white dark:bg-slate-700 text-slate-900 dark:text-white shadow-sm">Day</button>
          <button class="px-4 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white">Week</button>
          <button class="px-4 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white">Month</button>
          <button class="px-4 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white">Year</button>
        </div>
      </ExampleSection>

      <ExampleSection title="Icon Button Group" description="Grouped icon buttons for compact toolbars.">
        <ButtonGroup attached>
          <Button variant="outline" icon="ti-bold" size="sm" />
          <Button variant="outline" icon="ti-italic" size="sm" />
          <Button variant="outline" icon="ti-underline" size="sm" />
          <Button variant="outline" icon="ti-strikethrough" size="sm" />
        </ButtonGroup>
      </ExampleSection>

      <ExampleSection title="Text Alignment Toolbar" description="Common use case for alignment controls.">
        <div class="inline-flex rounded-lg border border-slate-200 dark:border-slate-700 overflow-hidden">
          <button class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 border-r border-slate-200 dark:border-slate-700">
            <i class="ti ti-align-left text-slate-600 dark:text-slate-400"></i>
          </button>
          <button class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 border-r border-slate-200 dark:border-slate-700 bg-theme-primary/10">
            <i class="ti ti-align-center text-theme-primary"></i>
          </button>
          <button class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 border-r border-slate-200 dark:border-slate-700">
            <i class="ti ti-align-right text-slate-600 dark:text-slate-400"></i>
          </button>
          <button class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800">
            <i class="ti ti-align-justified text-slate-600 dark:text-slate-400"></i>
          </button>
        </div>
      </ExampleSection>

      <ExampleSection title="Split Button" description="Button with dropdown trigger.">
        <div class="flex">
          <Button variant="primary" class="rounded-r-none">Save Changes</Button>
          <Button variant="primary" icon="ti-chevron-down" class="rounded-l-none border-l border-white/20" />
        </div>
      </ExampleSection>

      <ExampleSection title="View Switcher" description="Toggle between different view modes.">
        <div class="inline-flex rounded-lg border border-slate-200 dark:border-slate-700 overflow-hidden">
          <button class="px-3 py-2 text-sm font-medium bg-theme-primary text-white">
            <i class="ti ti-layout-grid mr-1.5"></i>
            Grid
          </button>
          <button class="px-3 py-2 text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 border-l border-slate-200 dark:border-slate-700">
            <i class="ti ti-list mr-1.5"></i>
            List
          </button>
          <button class="px-3 py-2 text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 border-l border-slate-200 dark:border-slate-700">
            <i class="ti ti-table mr-1.5"></i>
            Table
          </button>
        </div>
      </ExampleSection>

      <ExampleSection title="Pagination Controls" description="Button group for page navigation.">
        <ButtonGroup attached>
          <Button variant="outline" icon="ti-chevron-left" size="sm" />
          <Button variant="outline" size="sm">1</Button>
          <Button variant="primary" size="sm">2</Button>
          <Button variant="outline" size="sm">3</Button>
          <Button variant="outline" size="sm">...</Button>
          <Button variant="outline" size="sm">10</Button>
          <Button variant="outline" icon="ti-chevron-right" size="sm" />
        </ButtonGroup>
      </ExampleSection>

      <ExampleSection title="Spaced Button Group" description="Button group with gaps between buttons.">
        <ButtonGroup gap="md">
          <Button variant="primary">Submit</Button>
          <Button variant="outline">Save Draft</Button>
          <Button variant="ghost">Cancel</Button>
        </ButtonGroup>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Group related actions together</li>
            <li>• Use for toolbars and control strips</li>
            <li>• Maintain consistent button sizes</li>
            <li>• Order by importance or sequence</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Mix unrelated actions</li>
            <li>• Use too many buttons in a group</li>
            <li>• Mix different button sizes</li>
            <li>• Use for primary navigation</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-accessible text-theme-primary"></i>
            Group Role
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            The ButtonGroup component uses <code>role="group"</code> to indicate that the buttons are related.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-keyboard text-theme-primary"></i>
            Keyboard Navigation
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Use <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Tab</kbd> to navigate between buttons in the group.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>
