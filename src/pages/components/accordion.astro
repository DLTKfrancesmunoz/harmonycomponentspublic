---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Accordion from '../../components/ui/Accordion.astro';
import Icon from '../../components/ui/Icon.astro';

const props = [
  { name: 'items', type: 'AccordionItem[]', default: '[]', description: 'Per section: title, content; optional defaultOpen and disabled' },
  { name: 'allowMultiple', type: 'boolean', default: 'false', description: 'Allow multiple items to be open' },
  { name: 'label', type: 'string', default: '—', description: 'Optional label above the control; sets role="group" and aria-labelledby' },
  { name: 'class', type: 'string', default: '—', description: 'Additional CSS classes on the root wrapper (.accordion-field)' },
];

const basicItems = [
  { title: 'What is this design system?', content: 'This is a comprehensive design system built with accessibility, performance, and flexibility in mind. It includes foundation elements, shell layout components, and 25 production-ready UI components.' },
  { title: 'How do I get started?', content: 'Start by exploring the Foundation section to understand our design tokens. Then check out the Shell Layout for page structure, and finally browse the Components for ready-to-use UI elements.' },
  { title: 'Is it accessible?', content: 'Yes! All components are built with accessibility as a priority. They include proper ARIA attributes, keyboard navigation, and follow WCAG guidelines.' },
];

const faqItems = [
  { title: 'Can I customize the colors?', content: 'Absolutely! The design system uses CSS custom properties (variables) for all colors. You can override them in your project to match your brand.', defaultOpen: true },
  { title: 'What browsers are supported?', content: 'We support all modern browsers including Chrome, Firefox, Safari, and Edge. IE11 is not supported.' },
  { title: 'Can I use this commercially?', content: 'Yes, this design system is available for commercial use. Please check the license for specific terms.' },
];

const labeledItems = [
  { title: 'Notifications', content: 'Choose how you receive updates and alerts.' },
  { title: 'Privacy', content: 'Control what data is stored and shared.' },
];

const disabledMixItems = [
  { title: 'Editable section', content: 'This section can be expanded or collapsed.' },
  { title: 'Locked section', content: 'This content is not available yet.', disabled: true },
  { title: 'Another editable section', content: 'Disabled sections are skipped in the tab order and cannot be opened.' },
];
---

<DocsLayout title="Accordion" description="Accordion components for collapsible content sections.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Accordion</h1>
        <span class="badge badge--success">stable</span>
      </div>
      <p class="page-header__description">
        Accordions organize content into collapsible sections, helping users navigate large amounts of information.
      </p>
    </header>

    <nav class="article-nav">
      <a href="#examples" class="article-nav__link"><Icon name="eye" size="sm" /> Examples</a>
      <a href="#example-with-label" class="article-nav__link"><Icon name="tag" size="sm" /> With label</a>
      <a href="#props" class="article-nav__link"><Icon name="queue-list" size="sm" /> Props</a>
      <a href="#accessibility" class="article-nav__link"><Icon name="check-badge" size="sm" /> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="section__title">Examples</h2>

      <ExampleSection title="Basic Accordion" description="Standard accordion with single item open.">
        <div class="max-w-2xl">
          <Accordion items={basicItems} />
        </div>
      </ExampleSection>

      <div id="example-with-label">
        <ExampleSection title="With Label" description="Pass the label prop to show a heading above the accordion. The control uses role=&quot;group&quot; and aria-labelledby for accessibility.">
          <div class="max-w-2xl">
            <Accordion label="Account preferences" items={labeledItems} />
          </div>
        </ExampleSection>
      </div>

      <ExampleSection title="With Default Open" description="Accordion with an item open by default.">
        <div class="max-w-2xl">
          <Accordion items={faqItems} />
        </div>
      </ExampleSection>

      <ExampleSection title="Allow Multiple" description="Multiple items can be open simultaneously.">
        <div class="max-w-2xl">
          <Accordion items={basicItems} allowMultiple />
        </div>
      </ExampleSection>

      <ExampleSection title="Disabled Sections" description="Set disabled on an item to prevent expanding that section and to apply disabled header styling.">
        <div class="max-w-2xl">
          <Accordion items={disabledMixItems} allowMultiple />
        </div>
      </ExampleSection>

      <ExampleSection title="Focus" description="Focused section headers use the same grey background as the hover state (pointer or keyboard). An open section does not keep that styling unless its header still has focus—for example, after focusing another header in multi-expand mode.">
        <div class="max-w-2xl">
          <p class="text-sm text-secondary mb-3">Tab through the headers below or click to move focus and see the focus state.</p>
          <Accordion items={basicItems} allowMultiple />
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="section__title">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="accessibility" class="space-y-4">
      <h2 class="section__title">Accessibility</h2>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="keyboard" size="sm" />
          Keyboard Navigation
        </h3>
        <p class="a11y-card__text">
          Accordion headers are fully keyboard accessible. Use <kbd>Tab</kbd> to navigate to accordion items, and <kbd>Enter</kbd> or <kbd>Space</kbd> to toggle expansion.
        </p>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="tag" size="sm" />
          ARIA Attributes
        </h3>
        <p class="a11y-card__text">
          The Accordion component uses proper ARIA attributes:
        </p>
        <ul class="a11y-card__text" style="list-style: disc; padding-left: 1.5rem; margin-top: 0.5rem;">
          <li>Native <code>&lt;button&gt;</code> elements for section headers (keyboard and screen reader support)</li>
          <li><code>aria-expanded</code> indicates open/closed state</li>
          <li><code>aria-controls</code> associates headers with content panels</li>
          <li>When <code>label</code> is set: <code>role="group"</code> and <code>aria-labelledby</code> reference the visible label</li>
          <li>Disabled sections use the <code>disabled</code> attribute on the header button (removed from tab order)</li>
        </ul>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="eye" size="sm" />
          Screen Reader Support
        </h3>
        <p class="a11y-card__text">
          Screen readers announce the accordion header text, expansion state, and content when expanded. The relationship between headers and their content is clearly communicated.
        </p>
      </div>
    </section>
  </article>
</DocsLayout>
