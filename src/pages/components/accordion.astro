---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';

const props = [
  { name: 'type', type: "'single' | 'multiple'", default: "'single'", description: 'Allow single or multiple items open' },
  { name: 'defaultOpen', type: 'string | string[]', default: '—', description: 'Initially open item(s)' },
  { name: 'collapsible', type: 'boolean', default: 'true', description: 'Allow all items to be closed' },
];
---

<DocsLayout title="Accordion" description="Expandable/collapsible content panels.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Accordion</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Accordions display content in collapsible sections, allowing users to expand one or more panels to view content.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Basic Accordion" description="Simple accordion with expandable items.">
        <div class="max-w-lg divide-y divide-slate-200 dark:divide-slate-800 border border-slate-200 dark:border-slate-800 rounded-lg">
          <div>
            <button class="accordion-trigger w-full flex items-center justify-between p-4 text-left font-medium text-slate-900 dark:text-white hover:bg-slate-50 dark:hover:bg-surface/50 transition-colors">
              <span>What is a design system?</span>
              <i class="ti ti-chevron-down text-slate-400 transition-transform"></i>
            </button>
            <div class="px-4 pb-4 text-sm text-slate-600 dark:text-slate-400">
              A design system is a collection of reusable components, guided by clear standards, that can be assembled to build any number of applications.
            </div>
          </div>
          <div>
            <button class="accordion-trigger w-full flex items-center justify-between p-4 text-left font-medium text-slate-900 dark:text-white hover:bg-slate-50 dark:hover:bg-surface/50 transition-colors">
              <span>Why use a design system?</span>
              <i class="ti ti-chevron-down text-slate-400 transition-transform"></i>
            </button>
            <div class="hidden px-4 pb-4 text-sm text-slate-600 dark:text-slate-400">
              Design systems help teams create consistent user experiences, speed up development, and improve collaboration between designers and developers.
            </div>
          </div>
          <div>
            <button class="accordion-trigger w-full flex items-center justify-between p-4 text-left font-medium text-slate-900 dark:text-white hover:bg-slate-50 dark:hover:bg-surface/50 transition-colors">
              <span>How do I get started?</span>
              <i class="ti ti-chevron-down text-slate-400 transition-transform"></i>
            </button>
            <div class="hidden px-4 pb-4 text-sm text-slate-600 dark:text-slate-400">
              Start by exploring our foundation elements, then move on to components. Each component page includes examples and code snippets you can copy.
            </div>
          </div>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="accordion.html"
        code={`<div class="divide-y divide-slate-200 dark:divide-slate-800 border border-slate-200 dark:border-slate-800 rounded-lg">
  <div>
    <button class="accordion-trigger w-full flex items-center justify-between p-4 text-left font-medium text-slate-900 dark:text-white hover:bg-slate-50 dark:hover:bg-surface/50 transition-colors">
      <span>Accordion Title</span>
      <i class="ti ti-chevron-down text-slate-400 transition-transform"></i>
    </button>
    <div class="px-4 pb-4 text-sm text-slate-600 dark:text-slate-400">
      Accordion content goes here.
    </div>
  </div>
  <!-- More items... -->
</div>

<script>
  document.querySelectorAll('.accordion-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const content = trigger.nextElementSibling;
      const icon = trigger.querySelector('i');
      content.classList.toggle('hidden');
      icon.style.transform = content.classList.contains('hidden') ? '' : 'rotate(180deg)';
    });
  });
</script>`}
      />

      <ExampleSection title="With Icons" description="Accordion items with leading icons.">
        <div class="max-w-lg divide-y divide-slate-200 dark:divide-slate-800 border border-slate-200 dark:border-slate-800 rounded-lg">
          <div>
            <button class="accordion-trigger w-full flex items-center gap-3 p-4 text-left hover:bg-slate-50 dark:hover:bg-surface/50 transition-colors">
              <i class="ti ti-settings text-theme-primary"></i>
              <span class="flex-1 font-medium text-slate-900 dark:text-white">Settings</span>
              <i class="ti ti-chevron-down text-slate-400 transition-transform"></i>
            </button>
            <div class="px-4 pb-4 pl-11 text-sm text-slate-600 dark:text-slate-400">
              Configure your account settings and preferences.
            </div>
          </div>
          <div>
            <button class="accordion-trigger w-full flex items-center gap-3 p-4 text-left hover:bg-slate-50 dark:hover:bg-surface/50 transition-colors">
              <i class="ti ti-shield text-theme-primary"></i>
              <span class="flex-1 font-medium text-slate-900 dark:text-white">Security</span>
              <i class="ti ti-chevron-down text-slate-400 transition-transform"></i>
            </button>
            <div class="hidden px-4 pb-4 pl-11 text-sm text-slate-600 dark:text-slate-400">
              Manage your security settings and two-factor authentication.
            </div>
          </div>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for FAQ sections</li>
            <li>• Group related content</li>
            <li>• Keep headers concise</li>
            <li>• Consider default open state</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Hide critical information</li>
            <li>• Use for navigation</li>
            <li>• Nest accordions deeply</li>
            <li>• Have too many items</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-keyboard text-theme-primary"></i>
            Keyboard Navigation
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Use <code>aria-expanded</code> on triggers and <code>aria-controls</code> to link to panel IDs. Support arrow key navigation between items.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>

<script>
  document.querySelectorAll('.accordion-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const content = trigger.nextElementSibling as HTMLElement;
      const icon = trigger.querySelector('i:last-child') as HTMLElement;
      if (content && icon) {
        content.classList.toggle('hidden');
        icon.style.transform = content.classList.contains('hidden') ? '' : 'rotate(180deg)';
      }
    });
  });
</script>

