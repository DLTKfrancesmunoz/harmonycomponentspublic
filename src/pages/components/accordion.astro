---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Accordion from '../../components/ui/Accordion.astro';

const props = [
  { name: 'title', type: 'string', description: 'Accordion header/title text', required: true },
  { name: 'open', type: 'boolean', default: 'false', description: 'Initially open state' },
  { name: 'id', type: 'string', default: '—', description: 'Accordion id for accessibility' },
];
---

<DocsLayout title="Accordion" description="Expandable/collapsible content panels.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Accordion</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Accordions display content in collapsible sections, allowing users to expand one or more panels to view content.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Basic Accordion" description="Simple accordion with expandable items. Click to toggle.">
        <div class="max-w-lg space-y-2">
          <Accordion title="What is a design system?" open>
            A design system is a collection of reusable components, guided by clear standards, that can be assembled to build any number of applications.
          </Accordion>
          <Accordion title="Why use a design system?">
            Design systems help teams create consistent user experiences, speed up development, and improve collaboration between designers and developers.
          </Accordion>
          <Accordion title="How do I get started?">
            Start by exploring our foundation elements, then move on to components. Each component page includes examples and code snippets you can copy.
          </Accordion>
        </div>
      </ExampleSection>

      <ExampleSection title="FAQ Section" description="Common use case for frequently asked questions.">
        <div class="max-w-lg space-y-2">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Frequently Asked Questions</h3>
          <Accordion title="How do I reset my password?">
            Click on "Forgot Password" on the login page and enter your email address. You'll receive a link to reset your password within a few minutes.
          </Accordion>
          <Accordion title="Can I change my subscription plan?">
            Yes, you can upgrade or downgrade your subscription at any time from your account settings. Changes take effect at the start of your next billing cycle.
          </Accordion>
          <Accordion title="Do you offer refunds?">
            We offer a 30-day money-back guarantee for all plans. If you're not satisfied, contact our support team for a full refund.
          </Accordion>
          <Accordion title="How do I contact support?">
            You can reach our support team via email at support@example.com or through the in-app chat feature available in your dashboard.
          </Accordion>
        </div>
      </ExampleSection>

      <ExampleSection title="Default Open" description="Accordion with content visible by default.">
        <div class="max-w-lg space-y-2">
          <Accordion title="Important Information" open>
            This content is visible by default because the <code>open</code> prop is set to true. Users can still collapse it by clicking the header.
          </Accordion>
          <Accordion title="Additional Details">
            This panel is collapsed by default. Click to expand and see the content.
          </Accordion>
        </div>
      </ExampleSection>

      <ExampleSection title="Rich Content" description="Accordions can contain any type of content.">
        <div class="max-w-lg space-y-2">
          <Accordion title="Product Features" open>
            <ul class="space-y-2 text-sm">
              <li class="flex items-center gap-2">
                <i class="ti ti-check text-success"></i>
                Unlimited projects
              </li>
              <li class="flex items-center gap-2">
                <i class="ti ti-check text-success"></i>
                Advanced analytics
              </li>
              <li class="flex items-center gap-2">
                <i class="ti ti-check text-success"></i>
                Priority support
              </li>
              <li class="flex items-center gap-2">
                <i class="ti ti-check text-success"></i>
                Custom integrations
              </li>
            </ul>
          </Accordion>
          <Accordion title="Pricing Details">
            <div class="grid grid-cols-2 gap-4 text-sm">
              <div class="p-3 rounded-lg bg-slate-100 dark:bg-slate-800">
                <p class="font-medium text-slate-900 dark:text-white">Starter</p>
                <p class="text-lg font-bold text-theme-primary">$9/mo</p>
              </div>
              <div class="p-3 rounded-lg bg-theme-primary/10 border border-theme-primary/30">
                <p class="font-medium text-slate-900 dark:text-white">Pro</p>
                <p class="text-lg font-bold text-theme-primary">$29/mo</p>
              </div>
            </div>
          </Accordion>
        </div>
      </ExampleSection>

      <ExampleSection title="Settings Panel" description="Accordion for organizing settings categories.">
        <div class="max-w-lg space-y-2">
          <Accordion title="General Settings" open>
            <div class="space-y-3 text-sm">
              <div class="flex items-center justify-between">
                <span class="text-slate-600 dark:text-slate-400">Language</span>
                <span class="text-slate-900 dark:text-white">English (US)</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-slate-600 dark:text-slate-400">Timezone</span>
                <span class="text-slate-900 dark:text-white">UTC-5 (Eastern)</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-slate-600 dark:text-slate-400">Date Format</span>
                <span class="text-slate-900 dark:text-white">MM/DD/YYYY</span>
              </div>
            </div>
          </Accordion>
          <Accordion title="Privacy Settings">
            <div class="space-y-3 text-sm">
              <div class="flex items-center justify-between">
                <span class="text-slate-600 dark:text-slate-400">Profile Visibility</span>
                <span class="text-slate-900 dark:text-white">Public</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-slate-600 dark:text-slate-400">Activity Status</span>
                <span class="text-slate-900 dark:text-white">Visible</span>
              </div>
            </div>
          </Accordion>
          <Accordion title="Notification Settings">
            <div class="space-y-3 text-sm">
              <div class="flex items-center justify-between">
                <span class="text-slate-600 dark:text-slate-400">Email Notifications</span>
                <span class="text-success">Enabled</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-slate-600 dark:text-slate-400">Push Notifications</span>
                <span class="text-success">Enabled</span>
              </div>
            </div>
          </Accordion>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for FAQ sections</li>
            <li>• Group related content logically</li>
            <li>• Keep headers concise and descriptive</li>
            <li>• Consider which items should be open by default</li>
            <li>• Use for progressive disclosure of information</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Hide critical information in collapsed panels</li>
            <li>• Use for primary navigation</li>
            <li>• Nest accordions too deeply</li>
            <li>• Have too many items (consider pagination)</li>
            <li>• Use when content should always be visible</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-accessible text-theme-primary"></i>
            ARIA Attributes
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            The Accordion component includes <code>aria-expanded</code> on triggers and <code>aria-controls</code> to link triggers to their content panels.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-keyboard text-theme-primary"></i>
            Keyboard Navigation
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Accordion triggers are focusable buttons. Press <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Enter</kbd> or <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Space</kbd> to toggle.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>
