---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Toggle from '../../components/ui/Toggle.astro';

const props = [
  { name: 'label', type: 'string', default: '—', description: 'Toggle label text' },
  { name: 'checked', type: 'boolean', default: 'false', description: 'Toggle state' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the toggle' },
  { name: 'size', type: "'sm' | 'md'", default: "'md'", description: 'Toggle size' },
  { name: 'name', type: 'string', default: '—', description: 'Toggle name attribute' },
  { name: 'id', type: 'string', default: '—', description: 'Toggle id attribute' },
];
---

<DocsLayout title="Toggle Switches" description="On/off toggle controls for binary choices.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Toggle Switches</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Toggle switches represent binary options that can be turned on or off, typically used for settings and preferences.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Basic Toggle" description="Simple on/off toggles with and without labels.">
        <div class="space-y-4">
          <div class="flex items-center gap-6">
            <Toggle />
            <Toggle checked />
          </div>
          <div class="flex flex-col gap-3">
            <Toggle label="Off state" />
            <Toggle label="On state" checked />
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Sizes" description="Two size options for different contexts.">
        <div class="flex items-center gap-8">
          <div class="text-center">
            <Toggle size="sm" checked />
            <span class="text-xs text-slate-500 mt-2 block">Small</span>
          </div>
          <div class="text-center">
            <Toggle size="md" checked />
            <span class="text-xs text-slate-500 mt-2 block">Medium</span>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="States" description="Different toggle states.">
        <div class="space-y-3">
          <Toggle label="Default (off)" />
          <Toggle label="Checked (on)" checked />
          <Toggle label="Disabled (off)" disabled />
          <Toggle label="Disabled (on)" checked disabled />
        </div>
      </ExampleSection>

      <ExampleSection title="Settings Panel" description="Common use case for application settings.">
        <div class="max-w-sm p-6 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-charcoal">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-4">Notification Settings</h3>
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <div>
                <span class="text-sm font-medium text-slate-900 dark:text-white block">Email Notifications</span>
                <span class="text-xs text-slate-500">Receive updates via email</span>
              </div>
              <Toggle checked name="email-notif" />
            </div>
            <div class="flex items-center justify-between">
              <div>
                <span class="text-sm font-medium text-slate-900 dark:text-white block">Push Notifications</span>
                <span class="text-xs text-slate-500">Get alerts on your device</span>
              </div>
              <Toggle checked name="push-notif" />
            </div>
            <div class="flex items-center justify-between">
              <div>
                <span class="text-sm font-medium text-slate-900 dark:text-white block">SMS Alerts</span>
                <span class="text-xs text-slate-500">Critical alerts via text</span>
              </div>
              <Toggle name="sms-notif" />
            </div>
            <div class="flex items-center justify-between">
              <div>
                <span class="text-sm font-medium text-slate-900 dark:text-white block">Marketing Emails</span>
                <span class="text-xs text-slate-500">Product news and offers</span>
              </div>
              <Toggle name="marketing-notif" />
            </div>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Appearance Settings" description="Theme and display preferences.">
        <div class="max-w-sm p-6 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-charcoal">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-4">Appearance</h3>
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <i class="ti ti-moon text-slate-400"></i>
                <span class="text-sm text-slate-900 dark:text-white">Dark Mode</span>
              </div>
              <Toggle checked name="dark-mode" />
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <i class="ti ti-contrast text-slate-400"></i>
                <span class="text-sm text-slate-900 dark:text-white">High Contrast</span>
              </div>
              <Toggle name="high-contrast" />
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <i class="ti ti-typography text-slate-400"></i>
                <span class="text-sm text-slate-900 dark:text-white">Large Text</span>
              </div>
              <Toggle name="large-text" />
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <i class="ti ti-eye-off text-slate-400"></i>
                <span class="text-sm text-slate-900 dark:text-white">Reduce Motion</span>
              </div>
              <Toggle name="reduce-motion" />
            </div>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Feature Flags" description="Enable/disable features in development.">
        <div class="max-w-md p-6 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-charcoal">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-4">Feature Flags</h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between p-3 rounded-lg bg-success/5 border border-success/20">
              <div>
                <span class="text-sm font-medium text-slate-900 dark:text-white">New Dashboard</span>
                <span class="text-xs text-success block">Production</span>
              </div>
              <Toggle checked name="new-dashboard" />
            </div>
            <div class="flex items-center justify-between p-3 rounded-lg bg-warning/5 border border-warning/20">
              <div>
                <span class="text-sm font-medium text-slate-900 dark:text-white">AI Assistant</span>
                <span class="text-xs text-warning block">Beta</span>
              </div>
              <Toggle checked name="ai-assistant" />
            </div>
            <div class="flex items-center justify-between p-3 rounded-lg bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700">
              <div>
                <span class="text-sm font-medium text-slate-900 dark:text-white">Advanced Analytics</span>
                <span class="text-xs text-slate-500 block">Alpha</span>
              </div>
              <Toggle name="advanced-analytics" />
            </div>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Inline Toggle" description="Toggle integrated in a single line.">
        <div class="flex items-center gap-3 p-3 rounded-lg bg-slate-100 dark:bg-slate-800 max-w-fit">
          <span class="text-sm text-slate-600 dark:text-slate-400">Auto-save:</span>
          <Toggle size="sm" checked />
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for instant on/off settings</li>
            <li>• Provide clear, positive labels</li>
            <li>• Use consistent positioning (usually right side)</li>
            <li>• Make the current state visually obvious</li>
            <li>• Group related toggles together</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for form submissions (use checkbox)</li>
            <li>• Use negative labels ("Disable X")</li>
            <li>• Require additional confirmation steps</li>
            <li>• Use when checkbox is more appropriate</li>
            <li>• Use for non-binary choices</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-accessible text-theme-primary"></i>
            Switch Role
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            The Toggle component uses <code>role="switch"</code> and <code>aria-checked</code> for proper screen reader announcements.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-keyboard text-theme-primary"></i>
            Keyboard Support
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Toggles can be activated with <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Space</kbd> and navigated with <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Tab</kbd>.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-eye text-theme-primary"></i>
            Visual State
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            The toggle clearly indicates its on/off state through color and thumb position, ensuring visibility for all users.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>
