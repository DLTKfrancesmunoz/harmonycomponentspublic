---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';

const props = [
  { name: 'checked', type: 'boolean', default: 'false', description: 'Toggle state' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the toggle' },
  { name: 'size', type: "'sm' | 'md' | 'lg'", default: "'md'", description: 'Toggle size' },
  { name: 'label', type: 'string', default: '—', description: 'Label text' },
];
---

<DocsLayout title="Toggle Switches" description="On/off toggle controls for binary choices.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Toggle Switches</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Toggle switches represent binary options that can be turned on or off, typically used for settings and preferences.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Basic Toggle" description="Simple on/off toggle.">
        <div class="flex items-center gap-4">
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" class="sr-only peer">
            <div class="w-11 h-6 bg-slate-200 dark:bg-slate-700 peer-focus:ring-2 peer-focus:ring-theme-primary/50 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-theme-primary"></div>
          </label>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" checked class="sr-only peer">
            <div class="w-11 h-6 bg-slate-200 dark:bg-slate-700 peer-focus:ring-2 peer-focus:ring-theme-primary/50 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-theme-primary"></div>
          </label>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="toggle.html"
        code={`<label class="relative inline-flex items-center cursor-pointer">
  <input type="checkbox" class="sr-only peer">
  <div class="w-11 h-6 bg-slate-200 dark:bg-slate-700 peer-focus:ring-2 peer-focus:ring-theme-primary/50 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-theme-primary"></div>
</label>`}
      />

      <ExampleSection title="With Labels" description="Toggle with descriptive labels.">
        <div class="space-y-4 max-w-sm">
          <div class="flex items-center justify-between">
            <div>
              <span class="text-sm font-medium text-slate-900 dark:text-white block">Dark Mode</span>
              <span class="text-xs text-slate-500">Enable dark theme</span>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" checked class="sr-only peer">
              <div class="w-11 h-6 bg-slate-200 dark:bg-slate-700 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-theme-primary"></div>
            </label>
          </div>
          <div class="flex items-center justify-between">
            <div>
              <span class="text-sm font-medium text-slate-900 dark:text-white block">Notifications</span>
              <span class="text-xs text-slate-500">Receive push notifications</span>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" class="sr-only peer">
              <div class="w-11 h-6 bg-slate-200 dark:bg-slate-700 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-theme-primary"></div>
            </label>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Sizes" description="Different toggle sizes.">
        <div class="flex items-center gap-6">
          <!-- Small -->
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" checked class="sr-only peer">
            <div class="w-8 h-4 bg-slate-200 dark:bg-slate-700 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-theme-primary"></div>
            <span class="ml-2 text-xs text-slate-500">Small</span>
          </label>
          <!-- Medium -->
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" checked class="sr-only peer">
            <div class="w-11 h-6 bg-slate-200 dark:bg-slate-700 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-theme-primary"></div>
            <span class="ml-2 text-xs text-slate-500">Medium</span>
          </label>
          <!-- Large -->
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" checked class="sr-only peer">
            <div class="w-14 h-7 bg-slate-200 dark:bg-slate-700 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[3px] after:left-[3px] after:bg-white after:rounded-full after:h-5.5 after:w-6 after:transition-all peer-checked:bg-theme-primary"></div>
            <span class="ml-2 text-xs text-slate-500">Large</span>
          </label>
        </div>
      </ExampleSection>

      <ExampleSection title="Disabled State" description="Toggle in disabled state.">
        <div class="flex items-center gap-4">
          <label class="relative inline-flex items-center cursor-not-allowed opacity-50">
            <input type="checkbox" disabled class="sr-only peer">
            <div class="w-11 h-6 bg-slate-200 dark:bg-slate-700 rounded-full peer after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5"></div>
            <span class="ml-2 text-sm text-slate-500">Disabled Off</span>
          </label>
          <label class="relative inline-flex items-center cursor-not-allowed opacity-50">
            <input type="checkbox" checked disabled class="sr-only peer">
            <div class="w-11 h-6 bg-theme-primary rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5"></div>
            <span class="ml-2 text-sm text-slate-500">Disabled On</span>
          </label>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for instant on/off settings</li>
            <li>• Provide clear labels</li>
            <li>• Use consistent positioning</li>
            <li>• Make the current state obvious</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for form submissions</li>
            <li>• Use negative labels (avoid "Disable...")</li>
            <li>• Require additional confirmation</li>
            <li>• Use when checkbox is more appropriate</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
        <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
          <i class="ti ti-accessible text-theme-primary"></i>
          Switch Role
        </h3>
        <p class="text-sm text-slate-600 dark:text-slate-400">
          Use <code>role="switch"</code> and <code>aria-checked</code> for proper screen reader announcements. Ensure the label clearly indicates what the switch controls.
        </p>
      </div>
    </section>
  </article>
</DocsLayout>

