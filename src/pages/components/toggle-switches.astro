---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Toggle from '../../components/ui/Toggle.astro';
import Icon from '../../components/ui/Icon.astro';

const props = [
  { name: 'name', type: 'string', default: '—', description: 'Form input name attribute' },
  { name: 'id', type: 'string', default: '—', description: 'Element ID (auto-generated if not provided)' },
  { name: 'checked', type: 'boolean', default: 'false', description: 'Toggle state (segmented: false = left option, true = right option)' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the toggle' },
  { name: 'label', type: 'string', default: '—', description: 'Label text beside the track (default variant only; ignored when variant is segmented)' },
  { name: 'variant', type: "'default' | 'segmented'", default: "'default'", description: 'Segmented shows two in-track labels with a sliding thumb instead of the circular thumb' },
  { name: 'optionLabelLeft', type: 'string', default: "'Item 1'", description: 'Left option label (segmented variant only)' },
  { name: 'optionLabelRight', type: 'string', default: "'Item 2'", description: 'Right option label (segmented variant only)' },
  { name: 'size', type: "'sm' | 'md'", default: "'md'", description: 'Toggle size' },
];
---

<DocsLayout title="Toggle Switches" description="Toggle switch components for on/off states.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Toggle Switches</h1>
        <span class="badge badge--success">stable</span>
      </div>
      <p class="page-header__description">
        Toggle switches are used for binary on/off settings where the effect is immediate, or for choosing between two labeled options with the segmented variant.
      </p>
    </header>

    <nav class="article-nav">
      <a href="#examples" class="article-nav__link"><Icon name="eye" size="sm" /> Examples</a>
      <a href="#props" class="article-nav__link"><Icon name="queue-list" size="sm" /> Props</a>
      <a href="#accessibility" class="article-nav__link"><Icon name="check-badge" size="sm" /> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="section__title">Examples</h2>

      <ExampleSection title="Basic Toggle" description="Standard toggle switch.">
        <div class="flex flex-col gap-4">
          <Toggle label="Enable notifications" />
          <Toggle label="Dark mode" checked />
        </div>
      </ExampleSection>

      <ExampleSection title="States" description="Different toggle states.">
        <div class="flex flex-col gap-4">
          <Toggle label="Unchecked" />
          <Toggle label="Checked" checked />
          <Toggle label="Disabled" disabled />
          <Toggle label="Checked & Disabled" checked disabled />
        </div>
      </ExampleSection>

      <ExampleSection title="Sizes" description="Different toggle sizes.">
        <div class="flex items-center gap-6">
          <Toggle size="sm" label="Small" />
          <Toggle size="md" label="Medium" />
        </div>
      </ExampleSection>

      <ExampleSection title="Without Label" description="Toggle without visible label.">
        <div class="flex items-center gap-4">
          <Toggle />
          <Toggle checked />
          <Toggle disabled />
        </div>
      </ExampleSection>

      <ExampleSection
        title="Segmented toggle"
        description="Two labeled options inside the control. Unchecked selects the left option; checked selects the right option. The label prop is not used for this variant."
      >
        <div class="flex flex-col gap-4">
          <div class="flex flex-wrap items-center gap-6">
            <Toggle variant="segmented" />
            <Toggle variant="segmented" checked />
          </div>
          <Toggle variant="segmented" disabled />
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="section__title">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="accessibility" class="space-y-4">
      <h2 class="section__title">Accessibility</h2>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="tag" size="sm" />
          Labels
        </h3>
        <p class="a11y-card__text">
          For the default variant, visible label text sits inside the wrapping <code>label</code> element so it is associated with the control. The segmented variant has no external label; both options are visible in the track, and a default <code>aria-label</code> lists both option names unless you pass your own.
        </p>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="keyboard" size="sm" />
          Keyboard Navigation
        </h3>
        <p class="a11y-card__text">
          Toggle switches are keyboard accessible. Use <kbd>Tab</kbd> to navigate to toggles and <kbd>Space</kbd> to toggle the state.
        </p>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="tag" size="sm" />
          ARIA Attributes
        </h3>
        <p class="a11y-card__text">
          Toggles use <code>role="switch"</code> and <code>aria-checked</code> to reflect the current state. For the segmented variant, <code>aria-checked</code> is <code>false</code> when the left option is selected and <code>true</code> when the right option is selected.
        </p>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="eye" size="sm" />
          Screen Reader Support
        </h3>
        <p class="a11y-card__text">
          Screen readers announce the toggle label and current state (on/off). State changes are announced when toggles are activated.
        </p>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="no-symbol" size="sm" />
          Disabled State
        </h3>
        <p class="a11y-card__text">
          Disabled toggles are marked with the <code>disabled</code> attribute and are not focusable. Screen readers announce them as disabled.
        </p>
      </div>
    </section>
  </article>
</DocsLayout>
