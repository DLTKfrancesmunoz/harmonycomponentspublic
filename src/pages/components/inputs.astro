---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';

const props = [
  { name: 'type', type: "'text' | 'email' | 'password' | 'number' | 'url'", default: "'text'", description: 'Input type' },
  { name: 'placeholder', type: 'string', default: '—', description: 'Placeholder text' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the input' },
  { name: 'error', type: 'boolean', default: 'false', description: 'Shows error state' },
  { name: 'icon', type: 'string', default: '—', description: 'Leading icon class' },
];
---

<DocsLayout title="Inputs" description="Form input components for collecting user data.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Inputs</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Text inputs allow users to enter and edit text. They're used in forms, search fields, and anywhere text input is needed.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Basic Input" description="Standard text input with label.">
        <div class="max-w-sm space-y-2">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Email</label>
          <input type="email" placeholder="you@example.com" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-theme-primary focus:border-transparent transition-shadow">
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="input-basic.html"
        code={`<div class="space-y-2">
  <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Email</label>
  <input 
    type="email" 
    placeholder="you@example.com" 
    class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-theme-primary focus:border-transparent transition-shadow"
  >
</div>`}
      />

      <ExampleSection title="With Icon" description="Input with leading icon for context.">
        <div class="max-w-sm space-y-2">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Search</label>
          <div class="relative">
            <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
            <input type="text" placeholder="Search..." class="w-full pl-10 pr-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-theme-primary focus:border-transparent transition-shadow">
          </div>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="input-icon.html"
        code={`<div class="relative">
  <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
  <input 
    type="text" 
    placeholder="Search..." 
    class="w-full pl-10 pr-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-theme-primary focus:border-transparent"
  >
</div>`}
      />

      <ExampleSection title="States" description="Different input states.">
        <div class="max-w-sm space-y-4">
          <div class="space-y-2">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Disabled</label>
            <input type="text" disabled value="Disabled input" class="w-full px-4 py-2 border border-slate-200 dark:border-slate-800 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-500 cursor-not-allowed">
          </div>
          <div class="space-y-2">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Error</label>
            <input type="text" value="Invalid value" class="w-full px-4 py-2 border-2 border-error rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-error/50">
            <p class="text-sm text-error">Please enter a valid value</p>
          </div>
          <div class="space-y-2">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Success</label>
            <input type="text" value="Valid input" class="w-full px-4 py-2 border-2 border-success rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-success/50">
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Textarea" description="Multi-line text input.">
        <div class="max-w-sm space-y-2">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Description</label>
          <textarea rows="4" placeholder="Enter your message..." class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-theme-primary focus:border-transparent resize-none"></textarea>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="textarea.html"
        code={`<textarea 
  rows="4" 
  placeholder="Enter your message..." 
  class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-theme-primary focus:border-transparent resize-none"
></textarea>`}
      />
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Always use labels with inputs</li>
            <li>• Provide helpful placeholder text</li>
            <li>• Show validation feedback inline</li>
            <li>• Use appropriate input types</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use placeholder as label</li>
            <li>• Hide error messages</li>
            <li>• Disable without explanation</li>
            <li>• Use generic error messages</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-tag text-theme-primary"></i>
            Labels
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Always associate labels with inputs using <code>for</code> attribute or wrapping the input in a <code>&lt;label&gt;</code> element.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-alert-circle text-theme-primary"></i>
            Error Announcements
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Use <code>aria-describedby</code> to associate error messages with inputs for screen reader users.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>

