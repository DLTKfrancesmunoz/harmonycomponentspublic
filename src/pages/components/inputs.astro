---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Input from '../../components/ui/Input.astro';
import Textarea from '../../components/ui/Textarea.astro';
import Label from '../../components/ui/Label.astro';

const props = [
  { name: 'type', type: "'text' | 'email' | 'password' | 'number' | 'url' | 'search' | 'tel'", default: "'text'", description: 'Input type' },
  { name: 'placeholder', type: 'string', default: '—', description: 'Placeholder text' },
  { name: 'value', type: 'string', default: '—', description: 'Input value' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the input' },
  { name: 'error', type: 'boolean', default: 'false', description: 'Shows error state' },
  { name: 'errorMessage', type: 'string', default: '—', description: 'Error message to display' },
  { name: 'icon', type: 'string', default: '—', description: 'Leading icon class (e.g., ti-search)' },
  { name: 'required', type: 'boolean', default: 'false', description: 'Makes the input required' },
];

const textareaProps = [
  { name: 'placeholder', type: 'string', default: '—', description: 'Placeholder text' },
  { name: 'value', type: 'string', default: '—', description: 'Textarea value' },
  { name: 'rows', type: 'number', default: '4', description: 'Number of visible rows' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the textarea' },
  { name: 'error', type: 'boolean', default: 'false', description: 'Shows error state' },
  { name: 'errorMessage', type: 'string', default: '—', description: 'Error message to display' },
  { name: 'resizable', type: 'boolean', default: 'false', description: 'Allow resizing' },
];
---

<DocsLayout title="Inputs" description="Form input components for collecting user data.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Inputs</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Text inputs allow users to enter and edit text. They're used in forms, search fields, and anywhere text input is needed.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Basic Input" description="Standard text input with label.">
        <div class="max-w-sm space-y-2">
          <Label for="email-basic">Email</Label>
          <Input type="email" id="email-basic" placeholder="you@example.com" />
        </div>
      </ExampleSection>

      <ExampleSection title="Input Types" description="Different input types for various data.">
        <div class="max-w-sm space-y-4">
          <div class="space-y-2">
            <Label for="text-input">Text</Label>
            <Input type="text" id="text-input" placeholder="Enter text..." />
          </div>
          <div class="space-y-2">
            <Label for="email-input">Email</Label>
            <Input type="email" id="email-input" placeholder="you@example.com" />
          </div>
          <div class="space-y-2">
            <Label for="password-input">Password</Label>
            <Input type="password" id="password-input" placeholder="Enter password" />
          </div>
          <div class="space-y-2">
            <Label for="number-input">Number</Label>
            <Input type="number" id="number-input" placeholder="0" />
          </div>
          <div class="space-y-2">
            <Label for="tel-input">Phone</Label>
            <Input type="tel" id="tel-input" placeholder="(555) 555-5555" />
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="With Icon" description="Input with leading icon for context.">
        <div class="max-w-sm space-y-4">
          <div class="space-y-2">
            <Label for="search-input">Search</Label>
            <Input icon="ti-search" id="search-input" placeholder="Search..." />
          </div>
          <div class="space-y-2">
            <Label for="email-icon">Email</Label>
            <Input icon="ti-mail" type="email" id="email-icon" placeholder="you@example.com" />
          </div>
          <div class="space-y-2">
            <Label for="user-icon">Username</Label>
            <Input icon="ti-user" id="user-icon" placeholder="johndoe" />
          </div>
          <div class="space-y-2">
            <Label for="lock-icon">Password</Label>
            <Input icon="ti-lock" type="password" id="lock-icon" placeholder="••••••••" />
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="States" description="Different input states for feedback.">
        <div class="max-w-sm space-y-4">
          <div class="space-y-2">
            <Label for="default-state">Default</Label>
            <Input id="default-state" placeholder="Default state" />
          </div>
          <div class="space-y-2">
            <Label for="disabled-state">Disabled</Label>
            <Input id="disabled-state" disabled value="Disabled input" />
          </div>
          <div class="space-y-2">
            <Label for="error-state">Error</Label>
            <Input id="error-state" error errorMessage="Please enter a valid value" value="Invalid value" />
          </div>
          <div class="space-y-2">
            <Label for="required-state" required>Required Field</Label>
            <Input id="required-state" required placeholder="This field is required" />
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Textarea" description="Multi-line text input.">
        <div class="max-w-sm space-y-4">
          <div class="space-y-2">
            <Label for="textarea-basic">Description</Label>
            <Textarea id="textarea-basic" placeholder="Enter your message..." />
          </div>
          <div class="space-y-2">
            <Label for="textarea-resizable">Resizable Textarea</Label>
            <Textarea id="textarea-resizable" placeholder="This textarea can be resized..." resizable />
          </div>
          <div class="space-y-2">
            <Label for="textarea-rows">Custom Rows (6)</Label>
            <Textarea id="textarea-rows" rows={6} placeholder="Larger textarea..." />
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Textarea States" description="Textarea with different states.">
        <div class="max-w-sm space-y-4">
          <div class="space-y-2">
            <Label for="textarea-disabled">Disabled</Label>
            <Textarea id="textarea-disabled" disabled value="This textarea is disabled" />
          </div>
          <div class="space-y-2">
            <Label for="textarea-error">Error</Label>
            <Textarea id="textarea-error" error errorMessage="Description is required" />
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Form Example" description="Complete form with inputs and labels.">
        <div class="max-w-md p-6 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-charcoal">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-4">Contact Form</h3>
          <form class="space-y-4">
            <div class="grid sm:grid-cols-2 gap-4">
              <div class="space-y-2">
                <Label for="first-name" required>First Name</Label>
                <Input id="first-name" placeholder="John" required />
              </div>
              <div class="space-y-2">
                <Label for="last-name" required>Last Name</Label>
                <Input id="last-name" placeholder="Doe" required />
              </div>
            </div>
            <div class="space-y-2">
              <Label for="contact-email" required>Email</Label>
              <Input icon="ti-mail" type="email" id="contact-email" placeholder="john@example.com" required />
            </div>
            <div class="space-y-2">
              <Label for="phone">Phone (optional)</Label>
              <Input icon="ti-phone" type="tel" id="phone" placeholder="(555) 555-5555" />
            </div>
            <div class="space-y-2">
              <Label for="message" required>Message</Label>
              <Textarea id="message" rows={4} placeholder="How can we help you?" required />
            </div>
            <button type="submit" class="w-full px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
              Send Message
            </button>
          </form>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Input Props</h2>
      <PropsTable props={props} />
      
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4 mt-8">Textarea Props</h2>
      <PropsTable props={textareaProps} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Always use labels with inputs</li>
            <li>• Provide helpful placeholder text</li>
            <li>• Show validation feedback inline</li>
            <li>• Use appropriate input types</li>
            <li>• Mark required fields clearly</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use placeholder as label</li>
            <li>• Hide error messages</li>
            <li>• Disable without explanation</li>
            <li>• Use generic error messages</li>
            <li>• Forget to handle validation</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-tag text-theme-primary"></i>
            Labels
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Always associate labels with inputs using the <code>for</code> attribute. The Label component handles this automatically.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-alert-circle text-theme-primary"></i>
            Error Announcements
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Error messages are automatically associated with inputs via <code>aria-describedby</code>. Use the <code>errorMessage</code> prop for clear feedback.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-asterisk text-theme-primary"></i>
            Required Fields
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Use the <code>required</code> prop on both Label and Input to clearly indicate required fields with visual and semantic indicators.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>
