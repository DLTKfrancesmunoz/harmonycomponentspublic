---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Radio Buttons" description="Single selection radio inputs.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Radio Buttons</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Radio buttons allow users to select a single option from a mutually exclusive set.
      </p>
    </header>

    <ExampleSection title="Basic Radio" description="Standard radio button with label.">
      <div class="space-y-3">
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="radio" name="option" checked class="w-5 h-5 border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary dark:bg-slate-900">
          <span class="text-sm text-slate-700 dark:text-slate-300">Option 1</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="radio" name="option" class="w-5 h-5 border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary dark:bg-slate-900">
          <span class="text-sm text-slate-700 dark:text-slate-300">Option 2</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="radio" name="option" class="w-5 h-5 border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary dark:bg-slate-900">
          <span class="text-sm text-slate-700 dark:text-slate-300">Option 3</span>
        </label>
      </div>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="radio.html"
      code={`<label class="flex items-center gap-3 cursor-pointer">
  <input type="radio" name="option" class="w-5 h-5 border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary dark:bg-slate-900">
  <span class="text-sm text-slate-700 dark:text-slate-300">Option label</span>
</label>`}
    />
  </article>
</DocsLayout>

