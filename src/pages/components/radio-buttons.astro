---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Icon from '../../components/ui/Icon.astro';
import PropsTable from '../../components/PropsTable.astro';
import Icon from '../../components/ui/Icon.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Icon from '../../components/ui/Icon.astro';
import RadioButton from '../../components/ui/RadioButton.astro';
import Icon from '../../components/ui/Icon.astro';

const props = [
  { name: 'name', type: 'string', default: '—', description: 'Radio group name (required)' },
  { name: 'value', type: 'string', default: '—', description: 'Radio value (required)' },
  { name: 'label', type: 'string', default: '—', description: 'Label text' },
  { name: 'checked', type: 'boolean', default: 'false', description: 'Checked state' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the radio' },
];
---

<DocsLayout title="Radio Buttons" description="Radio button components for single selection.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Radio Buttons</h1>
        <span class="badge badge--success">stable</span>
      </div>
      <p class="page-header__description">
        Radio buttons allow users to select a single option from a list of mutually exclusive choices.
      </p>
    </header>

    <nav class="article-nav">
      <a href="#examples" class="article-nav__link"><Icon name="eye" size="sm" /> Examples</a>
      <a href="#props" class="article-nav__link"><Icon name="queue-list" size="sm" /> Props</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="section__title">Examples</h2>

      <ExampleSection title="Basic Radio Group" description="Standard radio button group.">
        <div class="flex flex-col gap-3">
          <RadioButton name="size" value="small" label="Small" />
          <RadioButton name="size" value="medium" label="Medium" checked />
          <RadioButton name="size" value="large" label="Large" />
        </div>
      </ExampleSection>

      <ExampleSection title="States" description="Different radio button states.">
        <div class="flex flex-col gap-3">
          <RadioButton name="states" value="1" label="Unchecked" />
          <RadioButton name="states" value="2" label="Checked" checked />
          <RadioButton name="states2" value="3" label="Disabled" disabled />
          <RadioButton name="states2" value="4" label="Checked & Disabled" checked disabled />
        </div>
      </ExampleSection>

      <ExampleSection title="Inline Layout" description="Radio buttons arranged horizontally.">
        <div class="flex flex-wrap items-center gap-6">
          <RadioButton name="color" value="red" label="Red" />
          <RadioButton name="color" value="green" label="Green" checked />
          <RadioButton name="color" value="blue" label="Blue" />
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="section__title">Props</h2>
      <PropsTable props={props} />
    </section>
  </article>
</DocsLayout>
