---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import RadioButton from '../../components/ui/RadioButton.astro';

const props = [
  { name: 'name', type: 'string', description: 'Radio group name (required for grouping)', required: true },
  { name: 'value', type: 'string', description: 'Radio button value', required: true },
  { name: 'label', type: 'string', default: '—', description: 'Radio button label text' },
  { name: 'checked', type: 'boolean', default: 'false', description: 'Checked state' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the radio button' },
  { name: 'id', type: 'string', default: '—', description: 'Radio button id attribute' },
];
---

<DocsLayout title="Radio Buttons" description="Single selection radio inputs.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Radio Buttons</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Radio buttons allow users to select a single option from a mutually exclusive set.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Basic Radio Group" description="Standard radio buttons with one selected.">
        <div class="flex flex-col gap-3">
          <RadioButton name="basic" value="option1" label="Option 1" checked />
          <RadioButton name="basic" value="option2" label="Option 2" />
          <RadioButton name="basic" value="option3" label="Option 3" />
        </div>
      </ExampleSection>

      <ExampleSection title="States" description="Different radio button states.">
        <div class="flex flex-col gap-3">
          <RadioButton name="states" value="unchecked" label="Unchecked" />
          <RadioButton name="states" value="checked" label="Checked" checked />
          <RadioButton name="states-disabled" value="disabled" label="Disabled" disabled />
          <RadioButton name="states-disabled-checked" value="disabled-checked" label="Disabled & Checked" disabled checked />
        </div>
      </ExampleSection>

      <ExampleSection title="Plan Selection" description="Radio buttons for selecting a plan.">
        <fieldset class="max-w-sm">
          <legend class="text-sm font-semibold text-slate-900 dark:text-white mb-3">Select a plan</legend>
          <div class="flex flex-col gap-3">
            <RadioButton name="plan" value="free" label="Free - $0/month" />
            <RadioButton name="plan" value="starter" label="Starter - $9/month" checked />
            <RadioButton name="plan" value="pro" label="Pro - $29/month" />
            <RadioButton name="plan" value="enterprise" label="Enterprise - Custom pricing" />
          </div>
        </fieldset>
      </ExampleSection>

      <ExampleSection title="Shipping Options" description="Common use case for delivery selection.">
        <fieldset class="max-w-md">
          <legend class="text-sm font-semibold text-slate-900 dark:text-white mb-3">Shipping Method</legend>
          <div class="flex flex-col gap-3">
            <RadioButton name="shipping" value="standard" label="Standard Shipping (5-7 business days) - Free" checked />
            <RadioButton name="shipping" value="express" label="Express Shipping (2-3 business days) - $9.99" />
            <RadioButton name="shipping" value="overnight" label="Overnight Shipping (Next business day) - $24.99" />
          </div>
        </fieldset>
      </ExampleSection>

      <ExampleSection title="Inline Layout" description="Radio buttons arranged horizontally.">
        <fieldset>
          <legend class="text-sm font-semibold text-slate-900 dark:text-white mb-3">Size</legend>
          <div class="flex flex-wrap items-center gap-6">
            <RadioButton name="size" value="xs" label="XS" />
            <RadioButton name="size" value="s" label="S" />
            <RadioButton name="size" value="m" label="M" checked />
            <RadioButton name="size" value="l" label="L" />
            <RadioButton name="size" value="xl" label="XL" />
          </div>
        </fieldset>
      </ExampleSection>

      <ExampleSection title="Card Style" description="Radio buttons styled as selectable cards.">
        <div class="grid sm:grid-cols-3 gap-4 max-w-2xl">
          <label class="relative cursor-pointer">
            <input type="radio" name="card-style" value="basic" class="peer sr-only" />
            <div class="p-4 rounded-lg border-2 border-slate-200 dark:border-slate-800 peer-checked:border-theme-primary peer-checked:bg-theme-primary/5 transition-colors">
              <div class="flex items-center justify-between mb-2">
                <span class="font-medium text-slate-900 dark:text-white">Basic</span>
                <div class="w-4 h-4 rounded-full border-2 border-slate-300 dark:border-slate-600 peer-checked:border-theme-primary peer-checked:bg-theme-primary"></div>
              </div>
              <span class="text-sm text-slate-500">$10/month</span>
            </div>
          </label>
          <label class="relative cursor-pointer">
            <input type="radio" name="card-style" value="pro" checked class="peer sr-only" />
            <div class="p-4 rounded-lg border-2 border-theme-primary bg-theme-primary/5 transition-colors">
              <div class="flex items-center justify-between mb-2">
                <span class="font-medium text-slate-900 dark:text-white">Pro</span>
                <div class="w-4 h-4 rounded-full bg-theme-primary border-2 border-theme-primary flex items-center justify-center">
                  <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
                </div>
              </div>
              <span class="text-sm text-slate-500">$25/month</span>
            </div>
          </label>
          <label class="relative cursor-pointer">
            <input type="radio" name="card-style" value="enterprise" class="peer sr-only" />
            <div class="p-4 rounded-lg border-2 border-slate-200 dark:border-slate-800 peer-checked:border-theme-primary peer-checked:bg-theme-primary/5 transition-colors">
              <div class="flex items-center justify-between mb-2">
                <span class="font-medium text-slate-900 dark:text-white">Enterprise</span>
                <div class="w-4 h-4 rounded-full border-2 border-slate-300 dark:border-slate-600"></div>
              </div>
              <span class="text-sm text-slate-500">Custom</span>
            </div>
          </label>
        </div>
      </ExampleSection>

      <ExampleSection title="With Descriptions" description="Radio buttons with additional context.">
        <fieldset class="max-w-md">
          <legend class="text-sm font-semibold text-slate-900 dark:text-white mb-3">Notification Frequency</legend>
          <div class="flex flex-col gap-4">
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="radio" name="freq" value="realtime" checked class="mt-0.5 w-4 h-4 border-slate-300 dark:border-slate-600 text-theme-primary focus:ring-theme-primary" />
              <div>
                <span class="text-sm font-medium text-slate-900 dark:text-white block">Real-time</span>
                <span class="text-sm text-slate-500">Get notified immediately when something happens</span>
              </div>
            </label>
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="radio" name="freq" value="daily" class="mt-0.5 w-4 h-4 border-slate-300 dark:border-slate-600 text-theme-primary focus:ring-theme-primary" />
              <div>
                <span class="text-sm font-medium text-slate-900 dark:text-white block">Daily digest</span>
                <span class="text-sm text-slate-500">Receive a summary of all activity once per day</span>
              </div>
            </label>
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="radio" name="freq" value="weekly" class="mt-0.5 w-4 h-4 border-slate-300 dark:border-slate-600 text-theme-primary focus:ring-theme-primary" />
              <div>
                <span class="text-sm font-medium text-slate-900 dark:text-white block">Weekly summary</span>
                <span class="text-sm text-slate-500">Get a weekly roundup of important updates</span>
              </div>
            </label>
          </div>
        </fieldset>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for mutually exclusive choices</li>
            <li>• Always have one option selected by default</li>
            <li>• Group related options with fieldset/legend</li>
            <li>• Use clear, concise labels</li>
            <li>• Order options logically</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for multiple selections (use checkboxes)</li>
            <li>• Use for more than 7-8 options</li>
            <li>• Use without labels</li>
            <li>• Allow no selection without explicit "None"</li>
            <li>• Use for binary on/off (use toggle switch)</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-users text-theme-primary"></i>
            Group Labels
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Use <code>&lt;fieldset&gt;</code> and <code>&lt;legend&gt;</code> to provide context for radio groups to screen readers.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-keyboard text-theme-primary"></i>
            Keyboard Navigation
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Use <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Tab</kbd> to navigate to the group, then arrow keys to move between options. <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Space</kbd> selects the focused option.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>
