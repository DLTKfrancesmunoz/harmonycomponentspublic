---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';

const props = [
  { name: 'checked', type: 'boolean', default: 'false', description: 'Checkbox state' },
  { name: 'indeterminate', type: 'boolean', default: 'false', description: 'Partially checked state' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the checkbox' },
  { name: 'label', type: 'string', default: '—', description: 'Label text' },
  { name: 'description', type: 'string', default: '—', description: 'Helper text below label' },
];
---

<DocsLayout title="Checkboxes" description="Checkbox components for multiple selection inputs.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Checkboxes</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Checkboxes allow users to select one or more items from a set, or toggle a single option on/off.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Basic Checkbox" description="Standard checkbox with label.">
        <div class="space-y-3">
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-offset-0 dark:bg-slate-900">
            <span class="text-sm text-slate-700 dark:text-slate-300">Option 1</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" checked class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-offset-0 dark:bg-slate-900">
            <span class="text-sm text-slate-700 dark:text-slate-300">Option 2 (checked)</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-offset-0 dark:bg-slate-900">
            <span class="text-sm text-slate-700 dark:text-slate-300">Option 3</span>
          </label>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="checkbox.html"
        code={`<label class="flex items-center gap-3 cursor-pointer">
  <input 
    type="checkbox" 
    class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-offset-0 dark:bg-slate-900"
  >
  <span class="text-sm text-slate-700 dark:text-slate-300">Option label</span>
</label>`}
      />

      <ExampleSection title="With Description" description="Checkbox with helper text.">
        <div class="space-y-4">
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" checked class="w-5 h-5 mt-0.5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-offset-0 dark:bg-slate-900">
            <div>
              <span class="text-sm font-medium text-slate-900 dark:text-white block">Email notifications</span>
              <span class="text-sm text-slate-500 dark:text-slate-400">Receive email updates about your account activity.</span>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" class="w-5 h-5 mt-0.5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-offset-0 dark:bg-slate-900">
            <div>
              <span class="text-sm font-medium text-slate-900 dark:text-white block">Marketing emails</span>
              <span class="text-sm text-slate-500 dark:text-slate-400">Receive tips, product updates, and special offers.</span>
            </div>
          </label>
        </div>
      </ExampleSection>

      <ExampleSection title="States" description="Different checkbox states.">
        <div class="space-y-3">
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-offset-0 dark:bg-slate-900">
            <span class="text-sm text-slate-700 dark:text-slate-300">Unchecked</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" checked class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary focus:ring-offset-0 dark:bg-slate-900">
            <span class="text-sm text-slate-700 dark:text-slate-300">Checked</span>
          </label>
          <label class="flex items-center gap-3 cursor-not-allowed opacity-50">
            <input type="checkbox" disabled class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary cursor-not-allowed dark:bg-slate-900">
            <span class="text-sm text-slate-700 dark:text-slate-300">Disabled</span>
          </label>
          <label class="flex items-center gap-3 cursor-not-allowed opacity-50">
            <input type="checkbox" checked disabled class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary cursor-not-allowed dark:bg-slate-900">
            <span class="text-sm text-slate-700 dark:text-slate-300">Checked & Disabled</span>
          </label>
        </div>
      </ExampleSection>

      <ExampleSection title="Custom Styled" description="Checkbox with custom styling.">
        <div class="space-y-3">
          <label class="flex items-center gap-3 cursor-pointer group">
            <div class="relative">
              <input type="checkbox" class="peer sr-only">
              <div class="w-5 h-5 rounded border-2 border-slate-300 dark:border-slate-700 peer-checked:border-theme-primary peer-checked:bg-theme-primary transition-colors flex items-center justify-center">
                <i class="ti ti-check text-white text-sm opacity-0 peer-checked:opacity-100"></i>
              </div>
            </div>
            <span class="text-sm text-slate-700 dark:text-slate-300 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">Custom checkbox</span>
          </label>
        </div>
      </ExampleSection>

      <ExampleSection title="Card Style" description="Checkbox as selectable card.">
        <div class="grid sm:grid-cols-2 gap-4 max-w-md">
          <label class="relative cursor-pointer">
            <input type="checkbox" class="peer sr-only">
            <div class="p-4 rounded-lg border-2 border-slate-200 dark:border-slate-800 peer-checked:border-theme-primary peer-checked:bg-theme-primary/5 transition-colors">
              <div class="flex items-center justify-between mb-2">
                <span class="font-medium text-slate-900 dark:text-white">Basic</span>
                <div class="w-5 h-5 rounded-full border-2 border-slate-300 dark:border-slate-700 peer-checked:border-theme-primary peer-checked:bg-theme-primary flex items-center justify-center">
                  <i class="ti ti-check text-white text-xs hidden peer-checked:block"></i>
                </div>
              </div>
              <span class="text-sm text-slate-500">$10/month</span>
            </div>
          </label>
          <label class="relative cursor-pointer">
            <input type="checkbox" checked class="peer sr-only">
            <div class="p-4 rounded-lg border-2 border-slate-200 dark:border-slate-800 peer-checked:border-theme-primary peer-checked:bg-theme-primary/5 transition-colors">
              <div class="flex items-center justify-between mb-2">
                <span class="font-medium text-slate-900 dark:text-white">Pro</span>
                <div class="w-5 h-5 rounded-full border-2 border-theme-primary bg-theme-primary flex items-center justify-center">
                  <i class="ti ti-check text-white text-xs"></i>
                </div>
              </div>
              <span class="text-sm text-slate-500">$25/month</span>
            </div>
          </label>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for multiple selections</li>
            <li>• Provide clear, concise labels</li>
            <li>• Group related options together</li>
            <li>• Use for binary on/off choices</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for mutually exclusive options</li>
            <li>• Have checkboxes without labels</li>
            <li>• Use negative phrasing</li>
            <li>• Pre-check options unexpectedly</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-tag text-theme-primary"></i>
            Labels
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Always associate checkboxes with labels using <code>&lt;label&gt;</code> elements or <code>aria-labelledby</code>.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-keyboard text-theme-primary"></i>
            Keyboard
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Checkboxes should be togglable with <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Space</kbd> key and navigable with <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Tab</kbd>.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>

