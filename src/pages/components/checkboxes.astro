---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Checkbox from '../../components/ui/Checkbox.astro';

const props = [
  { name: 'label', type: 'string', default: '—', description: 'Checkbox label text' },
  { name: 'checked', type: 'boolean', default: 'false', description: 'Checked state' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the checkbox' },
  { name: 'error', type: 'boolean', default: 'false', description: 'Shows error state' },
  { name: 'name', type: 'string', default: '—', description: 'Checkbox name attribute' },
  { name: 'id', type: 'string', default: '—', description: 'Checkbox id attribute' },
  { name: 'value', type: 'string', default: '—', description: 'Checkbox value' },
];
---

<DocsLayout title="Checkboxes" description="Checkbox components for multiple selection inputs.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Checkboxes</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Checkboxes allow users to select one or more items from a set, or toggle a single option on/off.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Basic Checkbox" description="Standard checkbox with label.">
        <div class="flex flex-col gap-3">
          <Checkbox label="Option 1" name="basic-1" />
          <Checkbox label="Option 2 (checked)" name="basic-2" checked />
          <Checkbox label="Option 3" name="basic-3" />
        </div>
      </ExampleSection>

      <ExampleSection title="States" description="Different checkbox states.">
        <div class="flex flex-col gap-3">
          <Checkbox label="Unchecked" name="state-unchecked" />
          <Checkbox label="Checked" name="state-checked" checked />
          <Checkbox label="Disabled" name="state-disabled" disabled />
          <Checkbox label="Checked & Disabled" name="state-checked-disabled" checked disabled />
          <Checkbox label="Error state" name="state-error" error />
        </div>
      </ExampleSection>

      <ExampleSection title="Without Labels" description="Checkboxes can be used without labels for compact layouts.">
        <div class="flex items-center gap-4">
          <Checkbox name="no-label-1" />
          <Checkbox name="no-label-2" checked />
          <Checkbox name="no-label-3" disabled />
        </div>
      </ExampleSection>

      <ExampleSection title="In a Form Group" description="Multiple checkboxes with a group label.">
        <fieldset class="flex flex-col gap-4">
          <legend class="text-sm font-semibold text-slate-900 dark:text-white mb-2">Notification Preferences</legend>
          <div class="flex flex-col gap-3 pl-1">
            <Checkbox label="Email notifications" name="notif-email" checked />
            <Checkbox label="SMS notifications" name="notif-sms" />
            <Checkbox label="Push notifications" name="notif-push" checked />
            <Checkbox label="Marketing emails" name="notif-marketing" />
          </div>
        </fieldset>
      </ExampleSection>

      <ExampleSection title="With Description Cards" description="Checkboxes styled as selectable cards.">
        <div class="space-y-3 max-w-md">
          <label class="flex items-start gap-3 p-4 rounded-lg border border-slate-200 dark:border-slate-800 hover:border-theme-primary dark:hover:border-theme-primary cursor-pointer transition-colors">
            <input type="checkbox" checked class="mt-0.5 w-4 h-4 rounded border-slate-300 dark:border-slate-600 text-theme-primary focus:ring-theme-primary focus:ring-offset-0" />
            <div>
              <span class="text-sm font-medium text-slate-900 dark:text-white block">Email notifications</span>
              <span class="text-sm text-slate-500 dark:text-slate-400">Receive email updates about your account activity.</span>
            </div>
          </label>
          <label class="flex items-start gap-3 p-4 rounded-lg border border-slate-200 dark:border-slate-800 hover:border-theme-primary dark:hover:border-theme-primary cursor-pointer transition-colors">
            <input type="checkbox" class="mt-0.5 w-4 h-4 rounded border-slate-300 dark:border-slate-600 text-theme-primary focus:ring-theme-primary focus:ring-offset-0" />
            <div>
              <span class="text-sm font-medium text-slate-900 dark:text-white block">Marketing emails</span>
              <span class="text-sm text-slate-500 dark:text-slate-400">Receive tips, product updates, and special offers.</span>
            </div>
          </label>
          <label class="flex items-start gap-3 p-4 rounded-lg border border-slate-200 dark:border-slate-800 hover:border-theme-primary dark:hover:border-theme-primary cursor-pointer transition-colors">
            <input type="checkbox" class="mt-0.5 w-4 h-4 rounded border-slate-300 dark:border-slate-600 text-theme-primary focus:ring-theme-primary focus:ring-offset-0" />
            <div>
              <span class="text-sm font-medium text-slate-900 dark:text-white block">Security alerts</span>
              <span class="text-sm text-slate-500 dark:text-slate-400">Get notified about security issues and suspicious activity.</span>
            </div>
          </label>
        </div>
      </ExampleSection>

      <ExampleSection title="Select All Pattern" description="Parent checkbox controlling children.">
        <div class="flex flex-col gap-3 max-w-sm">
          <div class="pb-2 border-b border-slate-200 dark:border-slate-800">
            <Checkbox label="Select all" name="select-all" />
          </div>
          <div class="pl-6 flex flex-col gap-2">
            <Checkbox label="First item" name="item-1" checked />
            <Checkbox label="Second item" name="item-2" checked />
            <Checkbox label="Third item" name="item-3" />
            <Checkbox label="Fourth item" name="item-4" />
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Inline Layout" description="Checkboxes arranged horizontally.">
        <div class="flex flex-wrap items-center gap-6">
          <Checkbox label="Option A" name="inline-a" />
          <Checkbox label="Option B" name="inline-b" checked />
          <Checkbox label="Option C" name="inline-c" />
          <Checkbox label="Option D" name="inline-d" />
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for multiple selections</li>
            <li>• Provide clear, concise labels</li>
            <li>• Group related options together</li>
            <li>• Use for binary on/off choices</li>
            <li>• Use descriptive labels that make sense independently</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for mutually exclusive options (use radio buttons)</li>
            <li>• Have checkboxes without labels</li>
            <li>• Use negative phrasing ("Don't send emails")</li>
            <li>• Pre-check options unexpectedly</li>
            <li>• Use for more than 7-10 options (use a different pattern)</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-tag text-theme-primary"></i>
            Labels
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            The Checkbox component automatically wraps the input in a <code>&lt;label&gt;</code> element, ensuring proper association.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-keyboard text-theme-primary"></i>
            Keyboard
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Checkboxes are togglable with <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Space</kbd> key and navigable with <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Tab</kbd>.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-users text-theme-primary"></i>
            Group Labels
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            When grouping checkboxes, use <code>&lt;fieldset&gt;</code> and <code>&lt;legend&gt;</code> to provide context for screen readers.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>
