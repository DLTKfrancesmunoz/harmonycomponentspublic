---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Dropdown from '../../components/ui/Dropdown.astro';
import Label from '../../components/ui/Label.astro';
import Icon from '../../components/ui/Icon.astro';

const props = [
  { name: 'options', type: 'Option[]', default: '[]', description: 'Array of options with value and label' },
  { name: 'value', type: 'string', default: '—', description: 'Selected value' },
  { name: 'placeholder', type: 'string', default: "'Select an option'", description: 'Placeholder text' },
  { name: 'name', type: 'string', default: '—', description: 'Form input name attribute' },
  { name: 'id', type: 'string', default: '—', description: 'Element ID (auto-generated if not provided)' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the dropdown' },
  { name: 'label', type: 'string', default: '—', description: 'Label text for the dropdown' },
  { name: 'labelVariant', type: "'inline' | 'stacked'", default: "'stacked' (inline for CP theme)", description: 'Label alignment variant - inline (left) or stacked (top)' },
  { name: 'labelFor', type: 'string', default: '—', description: 'ID of the dropdown element the label is associated with' },
];

const countries = [
  { value: 'us', label: 'United States' },
  { value: 'ca', label: 'Canada' },
  { value: 'uk', label: 'United Kingdom' },
  { value: 'de', label: 'Germany' },
  { value: 'fr', label: 'France' },
];

const priorities = [
  { value: 'low', label: 'Low' },
  { value: 'medium', label: 'Medium' },
  { value: 'high', label: 'High' },
  { value: 'urgent', label: 'Urgent' },
];
---

<DocsLayout title="Dropdowns" description="Dropdown select components for choosing from options.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Dropdowns</h1>
        <span class="badge badge--success">stable</span>
      </div>
      <p class="page-header__description">
        Dropdowns allow users to select an option from a list. They're useful when space is limited or options exceed 5 items.
      </p>
    </header>

    <nav class="article-nav">
      <a href="#examples" class="article-nav__link"><Icon name="eye" size="sm" /> Examples</a>
      <a href="#props" class="article-nav__link"><Icon name="queue-list" size="sm" /> Props</a>
      <a href="#accessibility" class="article-nav__link"><Icon name="check-badge" size="sm" /> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="section__title">Examples</h2>

      <ExampleSection title="Basic Dropdown" description="Standard dropdown with options.">
        <div class="max-w-sm space-y-2">
          <Label>Country</Label>
          <Dropdown options={countries} placeholder="Select a country" />
        </div>
      </ExampleSection>

      <ExampleSection title="With Label (Stacked)" description="Dropdown with label on top (default for non-CP themes).">
        <div class="max-w-sm">
          <Dropdown 
            options={countries} 
            placeholder="Select a country" 
            label="Country"
            labelVariant="stacked"
          />
        </div>
      </ExampleSection>

      <ExampleSection title="With Label (Inline)" description="Dropdown with label to the left (default for CP theme).">
        <div class="max-w-sm">
          <Dropdown 
            options={countries} 
            placeholder="Select a country" 
            label="Country"
            labelVariant="inline"
          />
        </div>
      </ExampleSection>

      <ExampleSection title="With Pre-selected Value" description="Dropdown with a default selection.">
        <div class="max-w-sm space-y-2">
          <Label>Priority</Label>
          <Dropdown options={priorities} value="medium" />
        </div>
      </ExampleSection>

      <ExampleSection title="Disabled" description="Disabled dropdown state.">
        <div class="max-w-sm space-y-2">
          <Label>Country (Disabled)</Label>
          <Dropdown options={countries} value="us" disabled />
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="section__title">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="accessibility" class="space-y-4">
      <h2 class="section__title">Accessibility</h2>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="tag" size="sm" />
          Labels
        </h3>
        <p class="a11y-card__text">
          Always associate labels with dropdowns using the <code>label</code> prop or a separate <code>Label</code> component with the <code>for</code> attribute. This ensures screen readers can identify the dropdown's purpose.
        </p>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="keyboard" size="sm" />
          Keyboard Navigation
        </h3>
        <p class="a11y-card__text">
          Dropdowns support full keyboard navigation:
        </p>
        <ul class="a11y-card__text" style="list-style: disc; padding-left: 1.5rem; margin-top: 0.5rem;">
          <li><kbd>Tab</kbd> - Navigate to/from dropdown</li>
          <li><kbd>Enter</kbd> or <kbd>Space</kbd> - Open dropdown menu</li>
          <li><kbd>Arrow Up/Down</kbd> - Navigate options</li>
          <li><kbd>Enter</kbd> - Select option</li>
          <li><kbd>Escape</kbd> - Close dropdown</li>
        </ul>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="tag" size="sm" />
          ARIA Attributes
        </h3>
        <p class="a11y-card__text">
          The Dropdown component includes proper ARIA attributes:
        </p>
        <ul class="a11y-card__text" style="list-style: disc; padding-left: 1.5rem; margin-top: 0.5rem;">
          <li><code>role="combobox"</code> on the dropdown trigger</li>
          <li><code>aria-expanded</code> indicates open/closed state</li>
          <li><code>aria-haspopup="listbox"</code> indicates a popup menu</li>
          <li><code>aria-controls</code> associates trigger with menu</li>
          <li><code>aria-label</code> or <code>aria-labelledby</code> for accessible name</li>
        </ul>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="no-symbol" size="sm" />
          Disabled State
        </h3>
        <p class="a11y-card__text">
          Disabled dropdowns are marked with the <code>disabled</code> attribute and are not focusable. Screen readers announce them as disabled.
        </p>
      </div>
    </section>
  </article>
</DocsLayout>
