---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';

const props = [
  { name: 'options', type: 'Option[]', description: 'Array of options', required: true },
  { name: 'value', type: 'string', default: '—', description: 'Selected value' },
  { name: 'placeholder', type: 'string', default: "'Select...'", description: 'Placeholder text' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the dropdown' },
  { name: 'searchable', type: 'boolean', default: 'false', description: 'Enable search filtering' },
];
---

<DocsLayout title="Dropdowns" description="Select menus and dropdown components.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Dropdowns</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Dropdowns allow users to select a single option from a list. They're ideal when space is limited or when there are many options.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Native Select" description="Standard HTML select element with custom styling.">
        <div class="max-w-xs space-y-2">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Country</label>
          <select class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-theme-primary appearance-none bg-no-repeat bg-right pr-10" style="background-image: url('data:image/svg+xml;charset=UTF-8,%3csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 24 24%27 fill=%27none%27 stroke=%27%236b7280%27 stroke-width=%272%27%3e%3cpath d=%27M6 9l6 6 6-6%27/%3e%3c/svg%3e'); background-size: 1.5rem;">
            <option value="">Select a country</option>
            <option value="us">United States</option>
            <option value="uk">United Kingdom</option>
            <option value="ca">Canada</option>
            <option value="au">Australia</option>
          </select>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="select.html"
        code={`<select class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-theme-primary">
  <option value="">Select an option</option>
  <option value="1">Option 1</option>
  <option value="2">Option 2</option>
  <option value="3">Option 3</option>
</select>`}
      />

      <ExampleSection title="Custom Dropdown" description="Styled dropdown with custom options. Click to toggle.">
        <div class="max-w-xs">
          <div class="dropdown-container relative">
            <button class="dropdown-trigger w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-theme-primary flex items-center justify-between">
              <span class="text-slate-500">Select a status</span>
              <i class="ti ti-chevron-down text-slate-400"></i>
            </button>
            <div class="dropdown-menu hidden absolute top-full left-0 right-0 mt-1 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg shadow-lg py-1 z-10">
              <button class="w-full px-4 py-2 text-left text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-success"></span>
                Active
              </button>
              <button class="w-full px-4 py-2 text-left text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-warning"></span>
                Pending
              </button>
              <button class="w-full px-4 py-2 text-left text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-error"></span>
                Inactive
              </button>
            </div>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="With Icons" description="Dropdown options with icons. Click to toggle.">
        <div class="max-w-xs">
          <div class="dropdown-container relative">
            <button class="dropdown-trigger w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white flex items-center justify-between">
              <span class="flex items-center gap-2">
                <i class="ti ti-folder text-theme-primary"></i>
                Projects
              </span>
              <i class="ti ti-chevron-down text-slate-400"></i>
            </button>
            <div class="dropdown-menu hidden absolute top-full left-0 right-0 mt-1 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg shadow-lg py-1 z-10">
              <button class="w-full px-4 py-2 text-left text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center gap-2">
                <i class="ti ti-folder text-slate-400"></i>
                Projects
              </button>
              <button class="w-full px-4 py-2 text-left text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center gap-2">
                <i class="ti ti-users text-slate-400"></i>
                Team
              </button>
              <button class="w-full px-4 py-2 text-left text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center gap-2">
                <i class="ti ti-settings text-slate-400"></i>
                Settings
              </button>
            </div>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="States" description="Different dropdown states.">
        <div class="flex flex-wrap gap-4">
          <select disabled class="px-4 py-2 border border-slate-200 dark:border-slate-800 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-500 cursor-not-allowed">
            <option>Disabled</option>
          </select>
          <select class="px-4 py-2 border-2 border-error rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white">
            <option>Error State</option>
          </select>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for single selection from 5+ options</li>
            <li>• Provide clear placeholder text</li>
            <li>• Order options logically</li>
            <li>• Consider searchable for long lists</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for 2-3 options (use radio)</li>
            <li>• Hide critical options</li>
            <li>• Make options too long</li>
            <li>• Use for navigation</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-keyboard text-theme-primary"></i>
            Keyboard Navigation
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Support arrow keys for navigation, Enter/Space to select, Escape to close, and type-ahead search for quick option finding.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-accessible text-theme-primary"></i>
            ARIA Attributes
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Use <code>role="listbox"</code> for custom dropdowns with <code>aria-activedescendant</code> to indicate the focused option.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>

<script>
  // Dropdown toggle functionality
  document.querySelectorAll('.dropdown-trigger').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const menu = btn.nextElementSibling;
      const isOpen = !menu.classList.contains('hidden');
      
      // Close all other dropdowns first
      document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.add('hidden'));
      
      // Toggle current dropdown
      if (!isOpen) {
        menu.classList.remove('hidden');
      }
    });
  });

  // Close dropdowns when clicking outside
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.dropdown-container')) {
      document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.add('hidden'));
    }
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.add('hidden'));
    }
  });
</script>

