---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Icon from '../../components/ui/Icon.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Icon from '../../components/ui/Icon.astro';
import Checkbox from '../../components/ui/Checkbox.astro';
import Icon from '../../components/ui/Icon.astro';
---

<DocsLayout title="Checkbox Groups" description="Groups of related checkbox inputs.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Checkbox Groups</h1>
        <span class="badge badge--success">stable</span>
      </div>
      <p class="page-header__description">
        Checkbox groups allow users to select multiple options from a related set.
      </p>
    </header>

    <nav class="article-nav">
      <a href="#examples" class="article-nav__link"><Icon name="eye" size="sm" /> Examples</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="section__title">Examples</h2>

      <ExampleSection title="Basic Group" description="Simple checkbox group with fieldset.">
        <fieldset class="space-y-4">
          <legend class="text-sm font-semibold text-primary mb-2">Notification Preferences</legend>
          <div class="flex flex-col gap-3 pl-2">
            <Checkbox label="Email notifications" name="notif-email" checked />
            <Checkbox label="SMS notifications" name="notif-sms" />
            <Checkbox label="Push notifications" name="notif-push" checked />
            <Checkbox label="Marketing emails" name="notif-marketing" />
          </div>
        </fieldset>
      </ExampleSection>

      <ExampleSection title="Inline Group" description="Checkboxes arranged horizontally.">
        <fieldset>
          <legend class="text-sm font-semibold text-primary mb-3">Select Categories</legend>
          <div class="flex flex-wrap gap-4">
            <Checkbox label="News" name="cat-news" checked />
            <Checkbox label="Sports" name="cat-sports" />
            <Checkbox label="Technology" name="cat-tech" checked />
            <Checkbox label="Entertainment" name="cat-ent" />
          </div>
        </fieldset>
      </ExampleSection>
    </section>
  </article>
</DocsLayout>
