---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Icons" description="Icon system and usage guidelines for the design system.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Icons</h1>
      </div>
      <p class="page-header__description">
        The Harmony Design System uses Tabler Icons as its primary icon set. Icons are used throughout the interface to provide visual cues and enhance usability.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="section__title">Icon Set</h2>
      <p class="text-secondary mb-6">
        We use <a href="https://tabler-icons.io/" target="_blank" class="link">Tabler Icons</a> - a set of over 4,500 free MIT-licensed high-quality SVG icons.
      </p>
      
      <ExampleSection title="Common Icons" description="Frequently used icons in the design system.">
        <div class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 gap-4">
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-home text-2xl text-secondary"></i>
            <span class="text-xs text-muted">home</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-search text-2xl text-secondary"></i>
            <span class="text-xs text-muted">search</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-settings text-2xl text-secondary"></i>
            <span class="text-xs text-muted">settings</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-user text-2xl text-secondary"></i>
            <span class="text-xs text-muted">user</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-bell text-2xl text-secondary"></i>
            <span class="text-xs text-muted">bell</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-mail text-2xl text-secondary"></i>
            <span class="text-xs text-muted">mail</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-calendar text-2xl text-secondary"></i>
            <span class="text-xs text-muted">calendar</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-file text-2xl text-secondary"></i>
            <span class="text-xs text-muted">file</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-folder text-2xl text-secondary"></i>
            <span class="text-xs text-muted">folder</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-trash text-2xl text-secondary"></i>
            <span class="text-xs text-muted">trash</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-edit text-2xl text-secondary"></i>
            <span class="text-xs text-muted">edit</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-plus text-2xl text-secondary"></i>
            <span class="text-xs text-muted">plus</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-minus text-2xl text-secondary"></i>
            <span class="text-xs text-muted">minus</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-x text-2xl text-secondary"></i>
            <span class="text-xs text-muted">x</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-check text-2xl text-secondary"></i>
            <span class="text-xs text-muted">check</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-refresh text-2xl text-secondary"></i>
            <span class="text-xs text-muted">refresh</span>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Navigation Icons" description="Icons used for navigation and wayfinding.">
        <div class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 gap-4">
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-chevron-up text-2xl text-secondary"></i>
            <span class="text-xs text-muted">chevron-up</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-chevron-down text-2xl text-secondary"></i>
            <span class="text-xs text-muted">chevron-down</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-chevron-left text-2xl text-secondary"></i>
            <span class="text-xs text-muted">chevron-left</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-chevron-right text-2xl text-secondary"></i>
            <span class="text-xs text-muted">chevron-right</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-arrow-up text-2xl text-secondary"></i>
            <span class="text-xs text-muted">arrow-up</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-arrow-down text-2xl text-secondary"></i>
            <span class="text-xs text-muted">arrow-down</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-arrow-left text-2xl text-secondary"></i>
            <span class="text-xs text-muted">arrow-left</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-hover-bg transition-colors">
            <i class="ti ti-arrow-right text-2xl text-secondary"></i>
            <span class="text-xs text-muted">arrow-right</span>
          </div>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Icon Sizes</h2>
      
      <ExampleSection title="Size Variations" description="Icons can be displayed at different sizes.">
        <div class="flex items-end gap-8 p-6 bg-card rounded-lg border">
          <div class="flex flex-col items-center gap-2">
            <i class="ti ti-home text-xs text-secondary"></i>
            <span class="text-xs text-muted">xs (12px)</span>
          </div>
          <div class="flex flex-col items-center gap-2">
            <i class="ti ti-home text-sm text-secondary"></i>
            <span class="text-xs text-muted">sm (14px)</span>
          </div>
          <div class="flex flex-col items-center gap-2">
            <i class="ti ti-home text-base text-secondary"></i>
            <span class="text-xs text-muted">base (16px)</span>
          </div>
          <div class="flex flex-col items-center gap-2">
            <i class="ti ti-home text-lg text-secondary"></i>
            <span class="text-xs text-muted">lg (18px)</span>
          </div>
          <div class="flex flex-col items-center gap-2">
            <i class="ti ti-home text-xl text-secondary"></i>
            <span class="text-xs text-muted">xl (20px)</span>
          </div>
          <div class="flex flex-col items-center gap-2">
            <i class="ti ti-home text-2xl text-secondary"></i>
            <span class="text-xs text-muted">2xl (24px)</span>
          </div>
          <div class="flex flex-col items-center gap-2">
            <i class="ti ti-home text-3xl text-secondary"></i>
            <span class="text-xs text-muted">3xl (30px)</span>
          </div>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Usage Guidelines</h2>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <i class="ti ti-info-circle a11y-card__title-icon"></i>
          Implementation
        </h3>
        <div class="a11y-card__text space-y-2">
          <p>Icons are implemented using the Tabler Icons web font. To use an icon:</p>
          <code class="block bg-card p-3 rounded-md text-sm">
            &lt;i class="ti ti-icon-name"&gt;&lt;/i&gt;
          </code>
          <p class="text-sm mt-2">
            Replace <code>icon-name</code> with the desired icon name from the Tabler Icons library.
          </p>
        </div>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <i class="ti ti-accessible a11y-card__title-icon"></i>
          Accessibility
        </h3>
        <p class="a11y-card__text">
          When using icons without accompanying text, always include an <code>aria-label</code> attribute to provide context for screen readers. Decorative icons should have <code>aria-hidden="true"</code>.
        </p>
      </div>
    </section>
  </article>
</DocsLayout>

