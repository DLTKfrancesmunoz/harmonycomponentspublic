    'arrow-right-start-on-rectangle', 'arrow-top-right-on-square', 'arrow-trending-down', 'arrow-trending-up',
    'arrow-up', 'arrow-up-circle', 'arrow-up-left', 'arrow-up-on-square', 'arrow-up-on-square-stack',
