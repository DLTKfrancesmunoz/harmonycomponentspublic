    'chevron-double-down', 'chevron-double-left', 'chevron-double-right', 'chevron-double-up',
    'chevron-down', 'chevron-left', 'chevron-right', 'chevron-up', 'chevron-up-down',
    'home', 'home-modern'
  ],
  'Actions': [
    'plus', 'plus-circle', 'minus', 'minus-circle', 'x-mark', 'x-circle',
    'check', 'check-circle', 'check-badge',
    'pencil', 'pencil-square', 'trash',
    'archive-box', 'archive-box-arrow-down', 'archive-box-x-mark',
    'clipboard', 'clipboard-document', 'clipboard-document-check', 'clipboard-document-list',
    'cloud-arrow-down', 'cloud-arrow-up',
    'link', 'paper-clip', 'scissors', 'share',
    'magnifying-glass', 'magnifying-glass-circle', 'magnifying-glass-minus', 'magnifying-glass-plus',
    'funnel', 'adjustments-horizontal', 'adjustments-vertical',
    'bars-arrow-down', 'bars-arrow-up', 'queue-list',
    'power', 'bolt', 'bolt-slash'
  ],
  'Interface & Layout': [
    'bars-2', 'bars-3', 'bars-3-bottom-left', 'bars-3-bottom-right', 'bars-3-center-left', 'bars-4',
    'squares-2x2', 'squares-plus', 'square-2-stack', 'square-3-stack-3d',
    'rectangle-group', 'rectangle-stack', 'view-columns', 'table-cells',
    'cog', 'cog-6-tooth', 'cog-8-tooth',
    'ellipsis-horizontal', 'ellipsis-horizontal-circle', 'ellipsis-vertical',
    'window', 'viewfinder-circle',
    'cursor-arrow-rays', 'cursor-arrow-ripple',
    'swatch', 'paint-brush', 'eye-dropper'
  ],
  'Communication': [
    'envelope', 'envelope-open', 'inbox', 'inbox-arrow-down', 'inbox-stack',
    'chat-bubble-bottom-center', 'chat-bubble-bottom-center-text', 'chat-bubble-left',
    'chat-bubble-left-ellipsis', 'chat-bubble-left-right', 'chat-bubble-oval-left', 'chat-bubble-oval-left-ellipsis',
    'phone', 'phone-arrow-down-left', 'phone-arrow-up-right', 'phone-x-mark',
    'bell', 'bell-alert', 'bell-slash', 'bell-snooze',
    'megaphone', 'paper-airplane', 'at-symbol', 'hashtag', 'rss',
    'language', 'globe-alt', 'globe-americas', 'globe-asia-australia', 'globe-europe-africa'
  ],
  'Media & Files': [
    'photo', 'camera', 'film', 'video-camera', 'video-camera-slash',
    'microphone', 'speaker-wave', 'speaker-x-mark', 'musical-note', 'radio',
    'play', 'play-circle', 'play-pause', 'pause', 'pause-circle', 'stop', 'stop-circle',
    'forward', 'backward',
    'document', 'document-arrow-down', 'document-arrow-up', 'document-chart-bar',
    'document-check', 'document-duplicate', 'document-magnifying-glass',
    'document-minus', 'document-plus', 'document-text',
    'folder', 'folder-arrow-down', 'folder-minus', 'folder-open', 'folder-plus',
    'gif', 'qr-code'
  ],
  'Users & People': [
    'user', 'user-circle', 'user-group', 'user-minus', 'user-plus', 'users',
    'identification', 'finger-print',
    'hand-raised', 'hand-thumb-down', 'hand-thumb-up',
    'face-frown', 'face-smile', 'heart'
  ],
  'Objects & Things': [
    'academic-cap', 'beaker', 'book-open', 'bookmark', 'bookmark-slash', 'bookmark-square',
    'briefcase', 'building-library', 'building-office', 'building-office-2', 'building-storefront',
