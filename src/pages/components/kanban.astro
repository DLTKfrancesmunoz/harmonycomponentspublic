  { name: 'badges', type: 'Array<{ label: string; variant?: BadgeVariant }>', default: '[]', description: 'Array of badge objects displayed at top-right' },
  { name: 'icons', type: 'Array<{ name: string; size?: "xs" | "sm" | "md" }>', default: '[]', description: 'Array of icon objects displayed at top-right before badges' },
  { name: 'progress', type: 'number', default: '—', description: 'Progress value (0-100) to display progress bar' },
  { name: 'date', type: 'string', default: '—', description: 'Date string to display at bottom (e.g., "00/00/0000")' },
  { name: 'time', type: 'string', default: '—', description: 'Time string to display at bottom (e.g., "Monday 9:45 PM")' },
  { name: 'class', type: 'string', default: '—', description: 'Additional CSS classes to apply to the card' },
