---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Card from '../../components/ui/Card.astro';

const props = [
  { name: 'variant', type: "'default' | 'elevated' | 'outlined' | 'interactive' | 'topBorder'", default: "'default'", description: 'Card style variant' },
  { name: 'padding', type: "'none' | 'sm' | 'md' | 'lg'", default: "'md'", description: 'Internal padding' },
  { name: 'href', type: 'string', default: '—', description: 'Makes card a link (interactive)' },
  { name: 'borderColor', type: 'string', default: 'theme-primary', description: 'Top border color for topBorder variant' },
];
---

<DocsLayout title="Cards" description="Card containers for grouping related content.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Cards</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Cards are containers that group related information and actions. They help organize content into digestible sections.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Basic Card" description="Simple card with title and content.">
        <div class="max-w-sm">
          <Card>
            <h3 class="font-semibold text-slate-900 dark:text-white mb-2">Card Title</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400">
              This is a basic card with some example content. Cards are great for grouping related information.
            </p>
          </Card>
        </div>
      </ExampleSection>

      <ExampleSection title="Card with Icon" description="Card with leading icon.">
        <div class="max-w-sm">
          <Card>
            <div class="w-10 h-10 rounded-lg bg-theme-primary/10 flex items-center justify-center mb-4">
              <i class="ti ti-chart-bar text-xl text-theme-primary"></i>
            </div>
            <h3 class="font-semibold text-slate-900 dark:text-white mb-2">Analytics</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400">
              View detailed analytics and insights about your project performance.
            </p>
          </Card>
        </div>
      </ExampleSection>

      <ExampleSection title="Interactive Card" description="Clickable card with hover effects.">
        <div class="grid sm:grid-cols-2 gap-4 max-w-2xl">
          <Card variant="interactive" href="#">
            <div class="w-10 h-10 rounded-lg bg-theme-primary/10 flex items-center justify-center mb-4 group-hover:bg-theme-primary/20 transition-colors">
              <i class="ti ti-folder text-xl text-theme-primary"></i>
            </div>
            <h3 class="font-semibold text-slate-900 dark:text-white mb-2 group-hover:text-theme-primary transition-colors">Projects</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400">
              Manage and organize your projects.
            </p>
          </Card>
          <Card variant="interactive" href="#">
            <div class="w-10 h-10 rounded-lg bg-theme-primary/10 flex items-center justify-center mb-4 group-hover:bg-theme-primary/20 transition-colors">
              <i class="ti ti-users text-xl text-theme-primary"></i>
            </div>
            <h3 class="font-semibold text-slate-900 dark:text-white mb-2 group-hover:text-theme-primary transition-colors">Team</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400">
              Collaborate with your team members.
            </p>
          </Card>
        </div>
      </ExampleSection>

      <ExampleSection title="Elevated Card" description="Card with shadow for emphasis.">
        <div class="max-w-sm">
          <Card variant="elevated">
            <h3 class="font-semibold text-slate-900 dark:text-white mb-2">Featured Card</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400">
              This elevated card uses shadow instead of border for a floating effect.
            </p>
          </Card>
        </div>
      </ExampleSection>

      <ExampleSection title="Top Border Card" description="Card with 6px theme-colored top border accent. Used for App Panels in CP.">
        <div class="max-w-md">
          <Card variant="topBorder" padding="none">
            <div class="p-4 border-b border-slate-200 dark:border-slate-700 flex items-center justify-between bg-slate-50 dark:bg-slate-800/50">
              <h3 class="font-semibold text-slate-900 dark:text-white text-sm">App Panel Title</h3>
              <div class="flex items-center gap-2">
                <button class="px-2 py-1 text-xs bg-theme-primary text-white rounded">New</button>
                <button class="px-2 py-1 text-xs bg-white dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded text-slate-600 dark:text-slate-300">Copy</button>
              </div>
            </div>
            <div class="p-4">
              <p class="text-sm text-slate-600 dark:text-slate-400">
                The 6px top border in the theme primary color provides visual hierarchy and branding for App Panel cards.
              </p>
            </div>
          </Card>
        </div>
      </ExampleSection>

      <ExampleSection title="Card with Actions" description="Card with header and action buttons.">
        <div class="max-w-sm">
          <Card padding="none">
            <div class="p-4 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between">
              <h3 class="font-semibold text-slate-900 dark:text-white">Card Header</h3>
              <button class="text-slate-400 hover:text-slate-600 dark:hover:text-white">
                <i class="ti ti-dots-vertical"></i>
              </button>
            </div>
            <div class="p-4">
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Card content goes here with useful information.
              </p>
            </div>
            <div class="p-4 border-t border-slate-200 dark:border-slate-800 flex gap-2">
              <button class="px-3 py-1.5 text-sm bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
                Save
              </button>
              <button class="px-3 py-1.5 text-sm hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg font-medium transition-colors">
                Cancel
              </button>
            </div>
          </Card>
        </div>
      </ExampleSection>

      <ExampleSection title="Padding Variations" description="Cards with different padding sizes.">
        <div class="grid sm:grid-cols-4 gap-4">
          <Card padding="none">
            <div class="p-2 text-center">
              <span class="text-xs text-slate-500">none</span>
            </div>
          </Card>
          <Card padding="sm">
            <div class="text-center">
              <span class="text-xs text-slate-500">sm (p-4)</span>
            </div>
          </Card>
          <Card padding="md">
            <div class="text-center">
              <span class="text-xs text-slate-500">md (p-6)</span>
            </div>
          </Card>
          <Card padding="lg">
            <div class="text-center">
              <span class="text-xs text-slate-500">lg (p-8)</span>
            </div>
          </Card>
        </div>
      </ExampleSection>

      <ExampleSection title="All Variants" description="Overview of all card style variants.">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <Card variant="default">
            <h4 class="font-semibold text-slate-900 dark:text-white mb-1">Default</h4>
            <p class="text-xs text-slate-500">Border with background</p>
          </Card>
          <Card variant="elevated">
            <h4 class="font-semibold text-slate-900 dark:text-white mb-1">Elevated</h4>
            <p class="text-xs text-slate-500">Shadow, no border</p>
          </Card>
          <Card variant="outlined">
            <h4 class="font-semibold text-slate-900 dark:text-white mb-1">Outlined</h4>
            <p class="text-xs text-slate-500">2px border, transparent bg</p>
          </Card>
          <Card variant="interactive" href="#">
            <h4 class="font-semibold text-slate-900 dark:text-white mb-1 group-hover:text-theme-primary transition-colors">Interactive</h4>
            <p class="text-xs text-slate-500">Hover effects, clickable</p>
          </Card>
          <Card variant="topBorder">
            <h4 class="font-semibold text-slate-900 dark:text-white mb-1">Top Border</h4>
            <p class="text-xs text-slate-500">6px theme accent top</p>
          </Card>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Group related content together</li>
            <li>• Use consistent padding and spacing</li>
            <li>• Provide clear visual hierarchy</li>
            <li>• Make interactive cards obviously clickable</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Overload cards with too much content</li>
            <li>• Nest cards within cards</li>
            <li>• Use inconsistent card styles</li>
            <li>• Mix interactive and static cards</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-link text-theme-primary"></i>
            Interactive Cards
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Use the <code>href</code> prop to make cards into proper links for keyboard navigation and screen reader support.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-hierarchy text-theme-primary"></i>
            Heading Hierarchy
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Maintain proper heading levels within cards. Card titles should follow the page's heading hierarchy.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>
