---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import PropsTable from '../../components/PropsTable.astro';
import Icon from '../../components/ui/Icon.astro';
import Checkbox from '../../components/ui/Checkbox.astro';
import Table from '../../components/ui/Table.astro';
import TableCostpointGrid from '../../components/ui/TableCostpointGrid.astro';
import CommandCenterPanel from '../../components/ui/CommandCenterPanel.astro';
import CommandCenterPanelSection from '../../components/ui/CommandCenterPanelSection.astro';
import Button from '../../components/ui/Button.astro';
import Dropdown from '../../components/ui/Dropdown.astro';
import Chip from '../../components/ui/Chip.astro';

const commandCenterSortColumns = [
  { key: 'prId', label: 'PR ID', align: 'left' as const },
  { key: 'vendor', label: 'Preferred Vendor Name', align: 'left' as const },
  { key: 'amount', label: 'Total Amount', align: 'right' as const },
  { key: 'status', label: 'Status', align: 'left' as const },
  { key: 'overdue', label: 'Overdue', align: 'left' as const },
];

/** Costpoint split-grid demo: nine body rows (vertical scroll after six). */
const cpDgDemoRows = Array.from({ length: 9 }, (_, i) => ({
  selected: i === 0,
  voucher: String(10042 + i),
  fiscalYear: '2020',
  period: String((i % 4) + 1),
  subperiod: String((i % 2) + 1),
  vendor: `V${100004 + i}`,
  vendorName: ['ACME Supplies', 'Contoso LLC', 'Fabrikam Parts', 'Northwind', 'Tailspin'][i % 5],
  termsOption: i % 2,
  appr: i % 2 === 0,
  inv: `INV-${9921 + i}`,
  invDate: `03/${String(15 + (i % 10)).padStart(2, '0')}/2020`,
  invAmt: `${((i + 1) * 1000).toLocaleString('en-US')}.00`,
  discountPercent: i === 1 ? '2.00' : '0.00',
  discountDate: i === 1 ? '03/25/2020' : `03/${String(10 + (i % 15)).padStart(2, '0')}/2020`,
  discountAmount: i === 1 ? '84.01' : '0.00',
  apAccount: '2000 — Accounts Payable',
  cashAccount: '1000 — Operating Cash',
  dueDate: `04/${String(10 + (i % 14)).padStart(2, '0')}/2020`,
  dueAmount: `${((i + 1) * 1000 - (i === 1 ? 84 : 0)).toLocaleString('en-US')}.00`,
  voucherType: i % 8 === 7 ? 'Credit' : 'Standard',
  voucherLineDist: i % 3 === 0 ? 'Prorate' : i % 3 === 1 ? 'None' : 'Prorate',
  salesTaxCharged: i % 2 === 0 ? 'On receipt' : 'Never',
  inputFileVoucherNo: i === 5 ? 'IF-001' : '',
  totalTaxAmt: i % 4 === 0 ? '12.50' : '0.00',
  remainingBalance: `${((i + 1) * 1000).toLocaleString('en-US')}.00`,
  taxId: i === 2 ? 'T-88' : '',
  taxingDate: i === 2 ? '03/20/2020' : `05/${String(1 + (i % 27)).padStart(2, '0')}/2020`,
  taxLocation: ['MA', 'WA', 'IL', 'TX', 'FL'][i % 5],
}));

const tableCostpointGridProps = [
  {
    name: 'maxHeight',
    type: 'string',
    default: '—',
    description: 'Caps the vertical scroller height (overrides the default of six visible body rows plus header).',
  },
  {
    name: 'scrollChrome',
    type: 'boolean',
    default: 'false',
    description: 'When true, shows horizontal scroll arrow buttons under the panes and vertical arrows on the right.',
  },
  {
    name: 'resizableSplit',
    type: 'boolean',
    default: 'true',
    description: 'When true, the split bar resizes the frozen vs scroll panes (pointer drag and keyboard).',
  },
  {
    name: 'class',
    type: 'string',
    default: '—',
    description: 'Additional classes on the root `.cp-datagrid` container.',
  },
  {
    name: 'instanceId',
    type: 'string',
    default: 'random id',
    description: 'Stable prefix for scroll region ids; set when multiple grids exist on one page.',
  },
];

const props = [
  { name: 'headerVariant', type: "'gray' | 'white' | 'none'", default: "'gray'", description: "Header background (ignored when variant is 'commandCenter', which uses the command-center header style via sortColumns).", },
  { name: 'variant', type: "'default' | 'commandCenter'", default: "'default'", description: "Command Center: full grid borders (#E0E4EB in light), sort and filter header controls (sortColumns), body typography and cell padding aligned with default tables; default zebra striping unless striped={false}." },
  { name: 'striped', type: 'boolean', default: 'false', description: "Zebra rows. For variant commandCenter, defaults to true; pass striped={false} to disable." },
  { name: 'reorderable', type: 'boolean', default: 'false', description: 'Enable row reordering via drag-and-drop. Displays a grip icon at the far left of each row.' },
  { name: 'grouped', type: 'boolean', default: 'false', description: 'Enable grouped rows with expand/collapse. Rows with data-has-children show an arrow; child rows use data-parent-id and data-depth (max 4 levels).' },
  { name: 'groupedDefaultExpanded', type: 'string', default: '—', description: "When grouped: comma- or space-separated data-row-id values for parents to render expanded on load (child rows must follow the parent in the body)." },
  { name: 'groupedExpandedRowIds / onGroupedExpandedRowIdsChange (React only)', type: 'string[] / fn', default: '—', description: "Optional controlled expansion: current expanded parent data-row-id values and callback. Use to wire Collapse/Expand all with variant commandCenter + grouped." },
  { name: 'class', type: 'string', default: '—', description: 'Additional CSS classes to apply to the table element' },
  { name: 'sortColumns / sortColumn / sortDirection', type: 'array / string / asc|desc', default: '—', description: 'When sortColumns is set, Table renders a sortable header row. For commandCenter, headers also show filter icon affordances; wire behavior in your app (see React Table onFilterClick).', },
  { name: 'filter-bar (slot)', type: 'slot', default: '—', description: 'Content for the filter bar above the table (dropdowns, chips, clear button)' },
  { name: 'command-center-toolbar (slot)', type: 'slot', default: '—', description: "Optional row above the table (e.g. 'As of' date or status) when using variant commandCenter" },
];
---

<DocsLayout title="Tables" description="Data table components and patterns for displaying structured information.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Tables</h1>
      </div>
      <p class="page-header__description">
        Tables are used to organize and display data efficiently. They allow users to scan, compare, and analyze information quickly.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="section__title">Basic Table</h2>
      
      <ExampleSection title="Default Table with Gray Header" description="A simple table with light gray header background.">
        <div class="overflow-x-auto">
          <Table headerVariant="gray">
            <Fragment slot="header">
              <tr>
                <th class="text-left">Project ID</th>
                <th class="text-left">Name</th>
                <th class="text-left">Status</th>
                <th class="text-right">Budget</th>
              </tr>
            </Fragment>
            <Fragment slot="body">
              <tr>
                <td>PRJ-001</td>
                <td>Website Redesign</td>
                <td>
                  <span class="badge badge--success">Active</span>
                </td>
                <td class="text-right">$25,000</td>
              </tr>
              <tr>
                <td>PRJ-002</td>
                <td>Mobile App Development</td>
                <td>
                  <span class="badge badge--warning">In Progress</span>
                </td>
                <td class="text-right">$150,000</td>
              </tr>
              <tr>
                <td>PRJ-003</td>
                <td>Database Migration</td>
                <td>
                  <span class="badge badge--default">Pending</span>
                </td>
                <td class="text-right">$45,000</td>
              </tr>
              <tr>
                <td>PRJ-004</td>
                <td>Security Audit</td>
                <td>
                  <span class="badge badge--info">Review</span>
                </td>
                <td class="text-right">$12,500</td>
              </tr>
            </Fragment>
          </Table>
        </div>
      </ExampleSection>

      <ExampleSection title="Table with White Header" description="Table with white header background.">
        <div class="overflow-x-auto">
          <Table headerVariant="white">
            <Fragment slot="header">
              <tr>
                <th class="text-left">Project ID</th>
                <th class="text-left">Name</th>
                <th class="text-left">Status</th>
                <th class="text-right">Budget</th>
              </tr>
            </Fragment>
            <Fragment slot="body">
              <tr>
                <td>PRJ-001</td>
                <td>Website Redesign</td>
                <td>
                  <span class="badge badge--success">Active</span>
                </td>
                <td class="text-right">$25,000</td>
              </tr>
              <tr>
                <td>PRJ-002</td>
                <td>Mobile App Development</td>
                <td>
                  <span class="badge badge--warning">In Progress</span>
                </td>
                <td class="text-right">$150,000</td>
              </tr>
            </Fragment>
          </Table>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Table with Actions</h2>
      
      <ExampleSection title="Interactive Table" description="The header checkbox selects or deselects all rows. Selected rows are highlighted in blue.">
        <div class="overflow-x-auto">
          <Table headerVariant="gray">
            <Fragment slot="header">
              <tr>
                <th class="w-10">
                  <Checkbox name="select-all" aria-label="Select all rows" />
                </th>
                <th class="text-left">Employee</th>
                <th class="text-left">Department</th>
                <th class="text-left">Role</th>
                <th class="text-right">Actions</th>
              </tr>
            </Fragment>
            <Fragment slot="body">
              <tr>
                <td>
                  <Checkbox name="select-employee-1" aria-label="Select row for John Doe" />
                </td>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: var(--theme-primary);">
                      <span class="text-xs font-medium" style="color: var(--text-inverse);">JD</span>
                    </div>
                    <div>
                      <div class="font-medium text-primary">John Doe</div>
                      <div class="text-xs text-muted">john.doe@company.com</div>
                    </div>
                  </div>
                </td>
                <td>Engineering</td>
                <td>Senior Developer</td>
                <td class="table-cell--actions">
                  <button type="button" class="icon-btn">
                    <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                  </button>
                </td>
              </tr>
              <tr>
                <td>
                  <Checkbox name="select-employee-2" aria-label="Select row for Jane Smith" />
                </td>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: var(--theme-primary);">
                      <span class="text-xs font-medium" style="color: var(--text-inverse);">JS</span>
                    </div>
                    <div>
                      <div class="font-medium text-primary">Jane Smith</div>
                      <div class="text-xs text-muted">jane.smith@company.com</div>
                    </div>
                  </div>
                </td>
                <td>Design</td>
                <td>UX Lead</td>
                <td class="table-cell--actions">
                  <button type="button" class="icon-btn">
                    <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                  </button>
                </td>
              </tr>
              <tr>
                <td>
                  <Checkbox name="select-employee-3" aria-label="Select row for Mike Johnson" />
                </td>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: var(--theme-primary);">
                      <span class="text-xs font-medium" style="color: var(--text-inverse);">MJ</span>
                    </div>
                    <div>
                      <div class="font-medium text-primary">Mike Johnson</div>
                      <div class="text-xs text-muted">mike.j@company.com</div>
                    </div>
                  </div>
                </td>
                <td>Marketing</td>
                <td>Manager</td>
                <td class="table-cell--actions">
                  <button type="button" class="icon-btn">
                    <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
