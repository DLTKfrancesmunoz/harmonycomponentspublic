        High-density Costpoint-only grid with frozen row-handle and voucher columns, split bar, horizontal scroll for detail
        columns, Lexend typography, diagonal hatch on read-only cells, native scrollbars when content overflows, and a solid
        header row. This block is visible when the docs theme is Costpoint (<code class="text-xs">html.theme-cp</code>). The
        React gallery and this Astro example both use the same scrollable column set from Subperiod through Tax Location, with
        the same layout mechanics.
      </p>
      <ExampleSection
        title="Split frozen / scroll table"
        description="Use TableCostpointGrid.astro with matching row counts in both panes. Nine sample rows exercise vertical scroll (six body rows visible by default). First row shows selected state and an active Invoice cell."
      >
        <TableCostpointGrid instanceId="tables-cp-dg">
          <Fragment slot="frozen-thead">
            <tr>
              <th class="cp-datagrid__cell--center cp-datagrid__cell--gutter" aria-label="Row" />
              <th>Voucher</th>
              <th>Fiscal year *</th>
              <th>Period *</th>
            </tr>
          </Fragment>
          <Fragment slot="frozen-tbody">
            {cpDgDemoRows.map((r) => (
              <tr aria-selected={r.selected ? 'true' : undefined}>
                <td class="cp-datagrid__cell--center cp-datagrid__cell--gutter" aria-label={`Select row ${r.voucher}`} />
                <td class="cp-datagrid__cell--right">
                  <input class="cp-datagrid__input cp-datagrid__input--edit" type="text" value={r.voucher} aria-label="Voucher" />
                </td>
                <td class="cp-datagrid__cell--left">
                  <input class="cp-datagrid__input cp-datagrid__input--edit" type="text" value={r.fiscalYear} aria-label="Fiscal year" />
                </td>
                <td class="cp-datagrid__cell--right">
                  <input class="cp-datagrid__input cp-datagrid__input--edit" type="text" value={r.period} aria-label="Period" />
                </td>
              </tr>
            ))}
          </Fragment>
          <Fragment slot="scroll-thead">
            <tr>
              <th class="cp-datagrid__cell--right">Subperiod *</th>
              <th class="cp-datagrid__cell--left">Original Voucher</th>
              <th class="cp-datagrid__cell--left">Vendor *</th>
              <th class="cp-datagrid__cell--left">Vendor Name</th>
              <th class="cp-datagrid__cell--left">Terms</th>
              <th class="cp-datagrid__cell--center">Approved</th>
              <th class="cp-datagrid__cell--left">Invoice</th>
              <th class="cp-datagrid__cell--left">Invoice Date</th>
              <th class="cp-datagrid__cell--left">Invoice Amount *</th>
              <th class="cp-datagrid__cell--right">Discount Percent</th>
              <th class="cp-datagrid__cell--left">Discount Date</th>
              <th class="cp-datagrid__cell--right">Discount Amount</th>
              <th class="cp-datagrid__cell--left">A/P Account Description</th>
              <th class="cp-datagrid__cell--left">Cash Account Description</th>
              <th class="cp-datagrid__cell--left">Due Date</th>
              <th class="cp-datagrid__cell--right">Due Amount</th>
              <th class="cp-datagrid__cell--left">Voucher Type</th>
              <th class="cp-datagrid__cell--left">Voucher Line Distribution Recalculation Method</th>
              <th class="cp-datagrid__cell--left">When Calculated Sales Tax is Charged</th>
              <th class="cp-datagrid__cell--left">Input File Voucher No</th>
              <th class="cp-datagrid__cell--right">Total Tax Amt</th>
              <th class="cp-datagrid__cell--right">Remaining Balance</th>
              <th class="cp-datagrid__cell--left">Tax ID</th>
              <th class="cp-datagrid__cell--left">Taxing Date</th>
              <th class="cp-datagrid__cell--left">Tax Location</th>
            </tr>
          </Fragment>
          <Fragment slot="scroll-tbody">
            {cpDgDemoRows.map((r) => (
              <tr aria-selected={r.selected ? 'true' : undefined}>
                <td class="cp-datagrid__cell--right">
                  <input class="cp-datagrid__input cp-datagrid__input--edit" type="text" value={r.subperiod} aria-label="Subperiod" />
                </td>
                <td class:list={['cp-datagrid__cell--left', 'cp-datagrid__cell--hatch']}>
                  <input class="cp-datagrid__input" type="text" value="" readonly aria-label="Original Voucher" />
                </td>
                <td class:list={['cp-datagrid__cell--left', 'cp-datagrid__cell--hatch']}>
                  <input class="cp-datagrid__input" type="text" value={r.vendor} readonly aria-label="Vendor" />
                </td>
                <td class:list={['cp-datagrid__cell--left', 'cp-datagrid__cell--hatch']}>
                  <input class="cp-datagrid__input" type="text" value={r.vendorName} readonly aria-label="Vendor Name" />
                </td>
                <td class="cp-datagrid__cell--left">
                  <select class="cp-datagrid__select" aria-label="Terms">
                    <option selected={r.termsOption === 0}>NET 30</option>
                    <option selected={r.termsOption === 1}>90 Days</option>
                  </select>
                </td>
                <td class="cp-datagrid__cell--center">
                  <div class="cp-datagrid__cell-inner">
                    <Checkbox checked={r.appr} aria-label="Approved" />
                  </div>
                </td>
                <td class="cp-datagrid__cell--left">
                  <input
                    class={r.selected
                      ? 'cp-datagrid__input cp-datagrid__input--edit cp-datagrid__input--active'
                      : 'cp-datagrid__input cp-datagrid__input--edit'}
                    type="text"
                    value={r.inv}
                    aria-label="Invoice"
                  />
                </td>
                <td class="cp-datagrid__cell--left">
                  <div class="cp-datagrid__date-wrap">
                    <input class="cp-datagrid__input cp-datagrid__input--edit" type="text" value={r.invDate} aria-label="Invoice Date" />
                    <button type="button" class="cp-datagrid__scroll-btn" style="width: 24px; height: 24px" aria-label="Open calendar">
                      <Icon name="calendar" size="sm" aria-hidden="true" />
                    </button>
                  </div>
                </td>
                <td class="cp-datagrid__cell--left">
