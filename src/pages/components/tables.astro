              </tr>
            </Fragment>
          </Table>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Striped Table</h2>
      
      <ExampleSection title="Alternating Rows" description="Table with alternating row background colors for easier scanning. Total row uses blue highlight.">
        <div class="overflow-x-auto">
          <Table headerVariant="gray" striped>
            <Fragment slot="header">
              <tr>
                <th class="text-left">Code</th>
                <th class="text-left">Description</th>
                <th class="text-right">Amount</th>
              </tr>
            </Fragment>
            <Fragment slot="body">
              <tr>
                <td class="font-mono">ACC-1001</td>
                <td>Operating Expenses</td>
                <td class="text-right">$12,450.00</td>
              </tr>
              <tr>
                <td class="font-mono">ACC-1002</td>
                <td>Equipment Purchase</td>
                <td class="text-right">$8,750.00</td>
              </tr>
              <tr>
                <td class="font-mono">ACC-1003</td>
                <td>Travel & Entertainment</td>
                <td class="text-right">$3,200.00</td>
              </tr>
              <tr>
                <td class="font-mono">ACC-1004</td>
                <td>Software Licenses</td>
                <td class="text-right">$15,600.00</td>
              </tr>
              <tr class="table-row--total font-semibold">
                <td colspan="2">Total</td>
                <td class="text-right">$40,000.00</td>
              </tr>
            </Fragment>
          </Table>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Table with Reorderable Rows</h2>
      
      <ExampleSection title="Table with Reorderable Rows" description="When reorderable is enabled, a grip icon (vertical dots) appears at the far left of each row. Users can drag the grip to reorder rows up or down. When using the header slot with reorderable, add an empty th with class table__grip-column and aria-label='Reorder' as the first column.">
        <div class="overflow-x-auto">
          <Table headerVariant="gray" reorderable>
            <Fragment slot="header">
              <tr>
                <th class="table__grip-column" scope="col" aria-label="Reorder"></th>
                <th class="text-left">Project ID</th>
                <th class="text-left">Name</th>
                <th class="text-left">Status</th>
                <th class="text-right">Budget</th>
              </tr>
            </Fragment>
            <Fragment slot="body">
              <tr>
                <td>PRJ-001</td>
                <td>Website Redesign</td>
                <td>
                  <span class="badge badge--success">Active</span>
                </td>
                <td class="text-right">$25,000</td>
              </tr>
              <tr>
                <td>PRJ-002</td>
                <td>Mobile App Development</td>
                <td>
                  <span class="badge badge--warning">In Progress</span>
                </td>
                <td class="text-right">$150,000</td>
              </tr>
              <tr>
                <td>PRJ-003</td>
                <td>Database Migration</td>
                <td>
                  <span class="badge badge--default">Pending</span>
                </td>
                <td class="text-right">$45,000</td>
              </tr>
              <tr>
                <td>PRJ-004</td>
                <td>Security Audit</td>
                <td>
                  <span class="badge badge--info">Review</span>
                </td>
                <td class="text-right">$12,500</td>
              </tr>
            </Fragment>
          </Table>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Table with Grouped Rows</h2>
      
      <ExampleSection title="Table with Grouped Rows" description="Expandable rows (those with child rows) display a small arrow icon on the far left. Click the arrow to expand or collapse child rows. Child rows are indented based on their depth.">
        <div class="overflow-x-auto">
          <Table headerVariant="gray" grouped>
            <Fragment slot="header">
              <tr>
                <th class="table__expand-column" scope="col" aria-label="Expand"></th>
                <th class="text-left">Project ID</th>
                <th class="text-left">Name</th>
                <th class="text-left">Status</th>
                <th class="text-right">Budget</th>
                <th class="text-right">Actions</th>
              </tr>
            </Fragment>
            <Fragment slot="body">
              <tr data-row-id="r1" data-has-children>
                <td>PRJ-001</td>
                <td>Website Redesign</td>
                <td>
                  <span class="badge badge--success">Active</span>
                </td>
                <td class="text-right">$25,000</td>
                <td class="table-cell--actions">
                  <button type="button" class="icon-btn">
                    <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                  </button>
                </td>
              </tr>
              <tr data-parent-id="r1" data-depth="1">
                <td>PRJ-001-A</td>
                <td>Frontend Development</td>
                <td>
                  <span class="badge badge--warning">In Progress</span>
                </td>
                <td class="text-right">$12,000</td>
                <td class="table-cell--actions">
                  <button type="button" class="icon-btn">
                    <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                  </button>
                </td>
              </tr>
              <tr data-parent-id="r1" data-depth="1">
                <td>PRJ-001-B</td>
                <td>Backend API</td>
                <td>
                  <span class="badge badge--default">Pending</span>
                </td>
                <td class="text-right">$13,000</td>
                <td class="table-cell--actions">
                  <button type="button" class="icon-btn">
                    <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                  </button>
                </td>
              </tr>
              <tr data-row-id="r2" data-has-children>
                <td>PRJ-002</td>
                <td>Mobile App Development</td>
                <td>
                  <span class="badge badge--warning">In Progress</span>
                </td>
                <td class="text-right">$150,000</td>
                <td class="table-cell--actions">
                  <button type="button" class="icon-btn">
                    <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                  </button>
                </td>
              </tr>
              <tr data-parent-id="r2" data-depth="1">
                <td>PRJ-002-A</td>
                <td>iOS Module</td>
                <td>
                  <span class="badge badge--info">Review</span>
                </td>
                <td class="text-right">$75,000</td>
                <td class="table-cell--actions">
                  <button type="button" class="icon-btn">
                    <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                  </button>
                </td>
              </tr>
              <tr data-row-id="r3">
                <td>PRJ-003</td>
                <td>Database Migration</td>
                <td>
                  <span class="badge badge--default">Pending</span>
                </td>
                <td class="text-right">$45,000</td>
                <td class="table-cell--actions">
                  <button type="button" class="icon-btn">
                    <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                  </button>
                </td>
              </tr>
            </Fragment>
          </Table>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Sortable column headers</h2>

      <ExampleSection title="Sortable column headers" description="Column headers can be sortable with icons indicating sort order: chevron up (ascending), chevron down (descending), and chevron-up-down (unsorted). Use aria-sort on the active column for accessibility.">
        <div class="overflow-x-auto">
          <Table headerVariant="gray">
            <Fragment slot="header">
              <tr>
                <th class="text-left" scope="col" aria-sort="ascending">
                  <button type="button" class="table__sort-header" aria-label="Sort by Project ID ascending">
                    Project ID
                    <Icon name="chevron-up" size="sm" />
                  </button>
                </th>
                <th class="text-left" scope="col" aria-sort="descending">
                  <button type="button" class="table__sort-header" aria-label="Sort by Name descending">
                    Name
                    <Icon name="chevron-down" size="sm" />
                  </button>
                </th>
                <th class="text-left" scope="col">
                  <button type="button" class="table__sort-header" aria-label="Sort by Status">
                    Status
                    <Icon name="chevron-up-down" size="sm" />
                  </button>
                </th>
                <th class="text-right" scope="col">
                  <button type="button" class="table__sort-header" aria-label="Sort by Budget">
                    Budget
                    <Icon name="chevron-up-down" size="sm" />
                  </button>
                </th>
              </tr>
            </Fragment>
            <Fragment slot="body">
              <tr>
                <td>PRJ-001</td>
                <td>Website Redesign</td>
                <td>
                  <span class="badge badge--success">Active</span>
                </td>
                <td class="text-right">$25,000</td>
              </tr>
              <tr>
                <td>PRJ-002</td>
                <td>Mobile App Development</td>
                <td>
                  <span class="badge badge--warning">In Progress</span>
                </td>
                <td class="text-right">$150,000</td>
              </tr>
              <tr>
                <td>PRJ-003</td>
                <td>Database Migration</td>
                <td>
                  <span class="badge badge--default">Pending</span>
                </td>
                <td class="text-right">$45,000</td>
              </tr>
              <tr>
                <td>PRJ-004</td>
                <td>Security Audit</td>
                <td>
                  <span class="badge badge--info">Review</span>
                </td>
                <td class="text-right">$12,500</td>
              </tr>
            </Fragment>
          </Table>
        </div>
      </ExampleSection>
