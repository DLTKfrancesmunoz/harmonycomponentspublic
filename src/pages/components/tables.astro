    <section class="space-y-6">
      <h2 class="section__title">Table with Title Bar and Action Bar</h2>
      
      <ExampleSection title="Table with Title Bar" description="Table with optional title bar containing title and window control icons. Table header background color remains unchanged.">
        <div class="overflow-x-auto">
          <Table headerVariant="gray">
            <h1 slot="title-bar-content" style="font-family: var(--font-display); font-size: var(--text-13); font-weight: var(--font-semibold); line-height: var(--leading-snug); color: var(--text-primary); margin: 0;">Table Title</h1>
            <div slot="title-bar-icons" style="display: flex; align-items: center; gap: var(--space-2);">
              <button type="button" class="table__title-bar-icon" aria-label="Help">
                <Icon name="question-mark-circle" size="sm" />
              </button>
              <button type="button" class="table__title-bar-icon" aria-label="Minimize">
                <Icon name="minimize" size="sm" />
              </button>
              <button type="button" class="table__title-bar-icon" aria-label="Window">
                <Icon name="window" size="sm" />
              </button>
              <button type="button" class="table__title-bar-icon" aria-label="Close">
                <Icon name="x-mark" size="sm" />
              </button>
            </div>
            <Fragment slot="header">
              <tr>
                <th class="text-left">Project ID</th>
                <th class="text-left">Name</th>
                <th class="text-left">Status</th>
                <th class="text-right">Budget</th>
              </tr>
            </Fragment>
            <Fragment slot="body">
              <tr>
                <td>PRJ-001</td>
                <td>Website Redesign</td>
                <td>
                  <span class="badge badge--success">Active</span>
                </td>
                <td class="text-right">$25,000</td>
              </tr>
              <tr>
                <td>PRJ-002</td>
                <td>Mobile App Development</td>
                <td>
                  <span class="badge badge--warning">In Progress</span>
                </td>
                <td class="text-right">$150,000</td>
              </tr>
            </Fragment>
          </Table>
        </div>
