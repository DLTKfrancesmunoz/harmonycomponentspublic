---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import PropsTable from '../../components/PropsTable.astro';
import Icon from '../../components/ui/Icon.astro';
import Checkbox from '../../components/ui/Checkbox.astro';
import Table from '../../components/ui/Table.astro';
import Button from '../../components/ui/Button.astro';

const props = [
  { name: 'headerVariant', type: "'gray' | 'white' | 'none'", default: "'gray'", description: 'Header background variant: gray (light gray background), white (white background), or none (transparent)' },
  { name: 'striped', type: 'boolean', default: 'false', description: 'Enable alternating row background colors (zebra striping) for easier scanning' },
  { name: 'class', type: 'string', default: '—', description: 'Additional CSS classes to apply to the table element' },
];
---

<DocsLayout title="Tables" description="Data table components and patterns for displaying structured information.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Tables</h1>
      </div>
      <p class="page-header__description">
        Tables are used to organize and display data efficiently. They allow users to scan, compare, and analyze information quickly.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="section__title">Basic Table</h2>
      
      <ExampleSection title="Default Table with Gray Header" description="A simple table with light gray header background.">
        <div class="overflow-x-auto">
          <Table headerVariant="gray">
            <thead slot="header">
              <tr>
                <th class="text-left">Project ID</th>
                <th class="text-left">Name</th>
                <th class="text-left">Status</th>
                <th class="text-right">Budget</th>
              </tr>
            </thead>
            <tbody slot="body">
              <tr>
                <td>PRJ-001</td>
                <td>Website Redesign</td>
                <td>
                  <span class="badge badge--success">Active</span>
                </td>
                <td class="text-right">$25,000</td>
              </tr>
              <tr>
                <td>PRJ-002</td>
                <td>Mobile App Development</td>
                <td>
                  <span class="badge badge--warning">In Progress</span>
                </td>
                <td class="text-right">$150,000</td>
              </tr>
              <tr>
                <td>PRJ-003</td>
                <td>Database Migration</td>
                <td>
                  <span class="badge badge--default">Pending</span>
                </td>
                <td class="text-right">$45,000</td>
              </tr>
              <tr>
                <td>PRJ-004</td>
                <td>Security Audit</td>
                <td>
                  <span class="badge badge--info">Review</span>
                </td>
                <td class="text-right">$12,500</td>
              </tr>
            </tbody>
          </Table>
        </div>
      </ExampleSection>

      <ExampleSection title="Table with White Header" description="Table with white header background.">
        <div class="overflow-x-auto">
          <Table headerVariant="white">
            <thead slot="header">
              <tr>
                <th class="text-left">Project ID</th>
                <th class="text-left">Name</th>
                <th class="text-left">Status</th>
                <th class="text-right">Budget</th>
              </tr>
            </thead>
            <tbody slot="body">
              <tr>
                <td>PRJ-001</td>
                <td>Website Redesign</td>
                <td>
                  <span class="badge badge--success">Active</span>
                </td>
                <td class="text-right">$25,000</td>
              </tr>
              <tr>
                <td>PRJ-002</td>
                <td>Mobile App Development</td>
                <td>
                  <span class="badge badge--warning">In Progress</span>
                </td>
                <td class="text-right">$150,000</td>
              </tr>
            </tbody>
          </Table>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Table with Actions</h2>
      
      <ExampleSection title="Interactive Table" description="Table with row actions and selection. Selected rows are highlighted in blue.">
        <div class="overflow-x-auto">
          <Table headerVariant="gray">
            <thead slot="header">
              <tr>
                <th class="w-10">
                  <Checkbox name="select-all" aria-label="Select all rows" />
                </th>
                <th class="text-left">Employee</th>
                <th class="text-left">Department</th>
                <th class="text-left">Role</th>
                <th class="text-right">Actions</th>
              </tr>
            </thead>
            <tbody slot="body">
              <tr>
                <td>
                  <Checkbox name="select-employee-1" aria-label="Select row for John Doe" />
                </td>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: var(--theme-primary);">
                      <span class="text-xs font-medium" style="color: var(--text-inverse);">JD</span>
                    </div>
                    <div>
                      <div class="font-medium text-primary">John Doe</div>
                      <div class="text-xs text-muted">john.doe@company.com</div>
                    </div>
                  </div>
                </td>
                <td>Engineering</td>
                <td>Senior Developer</td>
                <td class="table-cell--actions">
                  <button type="button" class="icon-btn">
                    <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                  </button>
                </td>
              </tr>
              <tr>
                <td>
                  <Checkbox name="select-employee-2" aria-label="Select row for Jane Smith" />
                </td>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: var(--theme-primary);">
                      <span class="text-xs font-medium" style="color: var(--text-inverse);">JS</span>
                    </div>
                    <div>
                      <div class="font-medium text-primary">Jane Smith</div>
                      <div class="text-xs text-muted">jane.smith@company.com</div>
                    </div>
                  </div>
                </td>
                <td>Design</td>
                <td>UX Lead</td>
                <td class="table-cell--actions">
                  <button type="button" class="icon-btn">
                    <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                  </button>
                </td>
              </tr>
              <tr>
                <td>
                  <Checkbox name="select-employee-3" aria-label="Select row for Mike Johnson" />
                </td>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: var(--theme-primary);">
                      <span class="text-xs font-medium" style="color: var(--text-inverse);">MJ</span>
                    </div>
                    <div>
                      <div class="font-medium text-primary">Mike Johnson</div>
                      <div class="text-xs text-muted">mike.j@company.com</div>
                    </div>
                  </div>
                </td>
                <td>Marketing</td>
                <td>Manager</td>
                <td class="table-cell--actions">
                  <button type="button" class="icon-btn">
                    <Icon name="ellipsis-vertical" size="md" class="icon-btn__icon" />
                  </button>
                </td>
              </tr>
            </tbody>
          </Table>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Striped Table</h2>
      
      <ExampleSection title="Alternating Rows" description="Table with alternating row background colors for easier scanning. Total row uses blue highlight.">
        <div class="overflow-x-auto">
          <Table headerVariant="gray" striped>
            <thead slot="header">
              <tr>
                <th class="text-left">Code</th>
                <th class="text-left">Description</th>
                <th class="text-right">Amount</th>
              </tr>
            </thead>
            <tbody slot="body">
              <tr>
                <td class="font-mono">ACC-1001</td>
                <td>Operating Expenses</td>
                <td class="text-right">$12,450.00</td>
              </tr>
              <tr>
                <td class="font-mono">ACC-1002</td>
                <td>Equipment Purchase</td>
                <td class="text-right">$8,750.00</td>
              </tr>
              <tr>
                <td class="font-mono">ACC-1003</td>
                <td>Travel & Entertainment</td>
                <td class="text-right">$3,200.00</td>
              </tr>
              <tr>
                <td class="font-mono">ACC-1004</td>
                <td>Software Licenses</td>
                <td class="text-right">$15,600.00</td>
              </tr>
              <tr class="table-row--total font-semibold">
                <td colspan="2">Total</td>
                <td class="text-right">$40,000.00</td>
              </tr>
            </tbody>
          </Table>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Table with Title Bar and Action Bar</h2>
      
      <ExampleSection title="Table with Title Bar" description="Table with optional title bar containing title and window control icons. Table header background color remains unchanged.">
        <div class="overflow-x-auto">
          <Table headerVariant="gray">
            <h1 slot="title-bar-content" style="font-family: var(--font-display); font-size: var(--text-13); font-weight: var(--font-semibold); line-height: var(--leading-snug); color: var(--text-primary); margin: 0;">Table Title</h1>
            <div slot="title-bar-icons" style="display: flex; align-items: center; gap: var(--space-2);">
              <button type="button" class="table__title-bar-icon" aria-label="Help">
                <Icon name="question-mark-circle" size="sm" />
              </button>
              <button type="button" class="table__title-bar-icon" aria-label="Minimize">
                <Icon name="minimize" size="sm" />
              </button>
              <button type="button" class="table__title-bar-icon" aria-label="Window">
                <Icon name="window" size="sm" />
              </button>
              <button type="button" class="table__title-bar-icon" aria-label="Close">
                <Icon name="x-mark" size="sm" />
              </button>
            </div>
            <thead slot="header">
              <tr>
                <th class="text-left">Project ID</th>
                <th class="text-left">Name</th>
                <th class="text-left">Status</th>
                <th class="text-right">Budget</th>
              </tr>
            </thead>
            <tbody slot="body">
              <tr>
                <td>PRJ-001</td>
                <td>Website Redesign</td>
                <td>
                  <span class="badge badge--success">Active</span>
                </td>
                <td class="text-right">$25,000</td>
              </tr>
              <tr>
                <td>PRJ-002</td>
                <td>Mobile App Development</td>
                <td>
                  <span class="badge badge--warning">In Progress</span>
                </td>
                <td class="text-right">$150,000</td>
              </tr>
            </tbody>
          </Table>
        </div>
      </ExampleSection>

      <ExampleSection title="Table with Action Bar" description="Table with optional action bar containing action buttons. Table header background color remains unchanged.">
        <div class="overflow-x-auto">
          <Table headerVariant="gray">
            <div slot="action-bar" style="display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap;">
              <Button variant="ghost" size="sm" icon="document-duplicate" iconPosition="right">
                Copy
              </Button>
              <Button variant="ghost" size="sm" icon="plus" iconPosition="right">
                Add
              </Button>
              <Button variant="ghost" size="sm" icon="trash">
                Delete
              </Button>
              <span style="color: var(--text-secondary); font-size: var(--text-sm); padding: 0 var(--space-1);">|</span>
              <Button variant="ghost" size="sm" icon="queue-list">
                Group
              </Button>
              <Button variant="ghost" size="sm" icon="cog-6-tooth">
                Customize Columns
              </Button>
              <span style="font-family: var(--font-sans); font-size: var(--text-sm); font-weight: var(--font-normal); color: var(--text-primary); padding: var(--space-1) var(--space-2);">All Filters</span>
            </div>
            <thead slot="header">
              <tr>
                <th class="text-left">Project ID</th>
                <th class="text-left">Name</th>
                <th class="text-left">Status</th>
                <th class="text-right">Budget</th>
              </tr>
            </thead>
            <tbody slot="body">
              <tr>
                <td>PRJ-001</td>
                <td>Website Redesign</td>
                <td>
                  <span class="badge badge--success">Active</span>
                </td>
                <td class="text-right">$25,000</td>
              </tr>
              <tr>
                <td>PRJ-002</td>
                <td>Mobile App Development</td>
                <td>
                  <span class="badge badge--warning">In Progress</span>
                </td>
                <td class="text-right">$150,000</td>
              </tr>
            </tbody>
          </Table>
        </div>
      </ExampleSection>

      <ExampleSection title="Table with Title Bar and Action Bar" description="Table with both title bar and action bar. Table header background color remains unchanged regardless of title bar or action bar presence.">
        <div class="overflow-x-auto">
          <Table headerVariant="gray">
            <h1 slot="title-bar-content" style="font-family: var(--font-display); font-size: var(--text-13); font-weight: var(--font-semibold); line-height: var(--leading-snug); color: var(--text-primary); margin: 0;">Table Title</h1>
            <div slot="title-bar-icons" style="display: flex; align-items: center; gap: var(--space-2);">
              <button type="button" class="table__title-bar-icon" aria-label="Help">
                <Icon name="question-mark-circle" size="sm" />
              </button>
              <button type="button" class="table__title-bar-icon" aria-label="Minimize">
                <Icon name="minimize" size="sm" />
              </button>
              <button type="button" class="table__title-bar-icon" aria-label="Window">
                <Icon name="window" size="sm" />
              </button>
              <button type="button" class="table__title-bar-icon" aria-label="Close">
                <Icon name="x-mark" size="sm" />
              </button>
            </div>
            <div slot="action-bar" style="display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap;">
              <Button variant="ghost" size="sm" icon="document-duplicate" iconPosition="right">
                Copy
              </Button>
              <Button variant="ghost" size="sm" icon="plus" iconPosition="right">
                Add
              </Button>
              <Button variant="ghost" size="sm" icon="trash">
                Delete
              </Button>
              <span style="color: var(--text-secondary); font-size: var(--text-sm); padding: 0 var(--space-1);">|</span>
              <Button variant="ghost" size="sm" icon="queue-list">
                Group
              </Button>
              <Button variant="ghost" size="sm" icon="cog-6-tooth">
                Customize Columns
              </Button>
              <span style="font-family: var(--font-sans); font-size: var(--text-sm); font-weight: var(--font-normal); color: var(--text-primary); padding: var(--space-1) var(--space-2);">All Filters</span>
            </div>
            <thead slot="header">
              <tr>
                <th class="text-left">Project ID</th>
                <th class="text-left">Name</th>
                <th class="text-left">Status</th>
                <th class="text-right">Budget</th>
              </tr>
            </thead>
            <tbody slot="body">
              <tr>
                <td>PRJ-001</td>
                <td>Website Redesign</td>
                <td>
                  <span class="badge badge--success">Active</span>
                </td>
                <td class="text-right">$25,000</td>
              </tr>
              <tr>
                <td>PRJ-002</td>
                <td>Mobile App Development</td>
                <td>
                  <span class="badge badge--warning">In Progress</span>
                </td>
                <td class="text-right">$150,000</td>
              </tr>
            </tbody>
          </Table>
        </div>
      </ExampleSection>
    </section>

    <section id="props" class="space-y-6">
      <h2 class="section__title">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage" class="space-y-6">
      <h2 class="section__title">Usage Guidelines</h2>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="information-circle" size="sm" />
          Best Practices
        </h3>
        <div class="a11y-card__text space-y-2">
          <ul class="list-disc list-inside space-y-1 text-sm">
            <li>Use tables only for tabular data, not for layout purposes</li>
            <li>Keep column headers concise and descriptive</li>
            <li>Align numerical data to the right for easy comparison</li>
            <li>Use zebra striping for tables with many rows</li>
            <li>Provide sorting and filtering for large data sets</li>
          </ul>
        </div>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="check-badge" size="sm" />
          Accessibility
        </h3>
        <p class="a11y-card__text">
          Use proper <code>&lt;table&gt;</code>, <code>&lt;thead&gt;</code>, <code>&lt;tbody&gt;</code>, <code>&lt;th&gt;</code>, and <code>&lt;td&gt;</code> elements. Include <code>scope</code> attributes on header cells and provide a caption or <code>aria-label</code> for the table's purpose.
        </p>
      </div>
    </section>
  </article>
</DocsLayout>

<script>
  // Handle row selection highlighting for browsers without :has() support
  document.addEventListener('DOMContentLoaded', () => {
    const tables = document.querySelectorAll('.table');
    
    tables.forEach(table => {
      const checkboxes = table.querySelectorAll('.checkbox__input');
      
      // Initialize selected state for pre-checked checkboxes
      checkboxes.forEach(checkbox => {
        const row = checkbox.closest('tr');
        if (row && checkbox.checked) {
          row.classList.add('table-row--selected');
        }
      });
      
      // Handle checkbox changes
      checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', () => {
          const row = checkbox.closest('tr');
          if (row) {
            if (checkbox.checked) {
              row.classList.add('table-row--selected');
            } else {
              row.classList.remove('table-row--selected');
            }
          }
        });
      });
    });
  });
</script>
