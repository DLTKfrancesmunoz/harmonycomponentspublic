---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Stepper from '../../components/ui/Stepper.astro';
import Step from '../../components/ui/Step.astro';
import Icon from '../../components/ui/Icon.astro';

const stepperProps = [
  { name: 'activeStep', type: 'number', default: '0', description: 'Zero-based index of the active step' },
  { name: 'orientation', type: "'horizontal' | 'vertical'", default: "'horizontal'", description: 'Orientation of the stepper' },
  { name: 'nonLinear', type: 'boolean', default: 'false', description: 'Allow jumping to any step (non-linear mode)' },
  { name: 'class', type: 'string', default: 'undefined', description: 'Additional CSS classes' },
];

const stepProps = [
  { name: 'completed', type: 'boolean', default: 'false', description: 'Mark step as completed' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disable step interaction' },
  { name: 'error', type: 'boolean', default: 'false', description: 'Show error state' },
  { name: 'warning', type: 'boolean', default: 'false', description: 'Show warning state' },
  { name: 'success', type: 'boolean', default: 'false', description: 'Show success state (uses success color)' },
  { name: 'icon', type: 'string', default: 'undefined', description: 'Custom icon name (replaces number)' },
  { name: 'class', type: 'string', default: 'undefined', description: 'Additional CSS classes' },
];
---

<DocsLayout title="Stepper" description="Stepper components for displaying progress through a sequence of logical and numbered steps.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Stepper</h1>
        <span class="badge badge--success">stable</span>
      </div>
      <p class="page-header__description">
        Steppers display progress through a sequence of logical and numbered steps. They provide a wizard-like workflow
        and can be used for navigation. Labels are positioned below the step indicators. Steps support success (green with checkmark), warning, and error states.
      </p>
    </header>

    <nav class="article-nav">
      <a href="#examples" class="article-nav__link"><Icon name="eye" size="sm" /> Examples</a>
      <a href="#props" class="article-nav__link"><Icon name="queue-list" size="sm" /> Props</a>
      <a href="#usage" class="article-nav__link"><Icon name="book-open" size="sm" /> Usage</a>
      <a href="#accessibility" class="article-nav__link"><Icon name="check-badge" size="sm" /> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="section__title">Examples</h2>

      <ExampleSection title="Stepper with Alternative Label" description="Labels are positioned below the step indicators. Shows all states: success (green with checkmark), warning, error, and default.">
        <div class="w-full max-w-4xl">
          <Stepper activeStep={2}>
            <Step success>Account verified</Step>
            <Step warning>Review information</Step>
            <Step error>Fix errors</Step>
            <Step>Complete setup</Step>
          </Stepper>
        </div>
      </ExampleSection>

      <ExampleSection title="Linear Stepper with Multiple Steps" description="Complete linear workflow showing proper step progression. Steps must be completed in sequence - future steps are disabled until previous steps are completed.">
        <div class="w-full max-w-6xl">
          <Stepper activeStep={2}>
            <Step completed success>Select campaign settings</Step>
            <Step completed success>Create an ad group</Step>
            <Step>Create an ad</Step>
            <Step>Review campaign</Step>
            <Step>Launch campaign</Step>
          </Stepper>
        </div>
      </ExampleSection>

      <ExampleSection title="Stepper with Descriptions" description="Steps can include descriptions below the label. Labels use Lexend (display font) and descriptions use Figtree (body font) for clear typographic hierarchy.">
        <div class="w-full max-w-6xl">
          <Stepper activeStep={1}>
            <Step completed success>
              Account Setup
              <span slot="description">Verify your email and password</span>
            </Step>
            <Step>
              Profile Information
              <span slot="description">Add your personal details</span>
            </Step>
            <Step>
              Preferences
              <span slot="description">Configure your settings</span>
            </Step>
            <Step>
              Review & Complete
              <span slot="description">Finalize your account</span>
            </Step>
          </Stepper>
        </div>
      </ExampleSection>

      <ExampleSection title="Stepper with Disabled Steps" description="Steps can be explicitly disabled using the disabled prop. Disabled steps appear with reduced opacity and muted colors, and are non-interactive. This is useful when certain steps are temporarily unavailable or require prerequisites.">
        <div class="w-full max-w-6xl">
          <Stepper activeStep={1} nonLinear>
            <Step completed success>Account Setup</Step>
            <Step>Profile Information</Step>
            <Step disabled>
              Payment Method
              <span slot="description">Temporarily unavailable</span>
            </Step>
            <Step disabled>Billing Address</Step>
            <Step>Review & Complete</Step>
          </Stepper>
        </div>
      </ExampleSection>
    </section>

    <section id="props" class="space-y-6">
      <h2 class="section__title">Props</h2>
      
      <div class="space-y-8">
        <div>
          <h3 class="text-lg font-semibold text-primary mb-4">Stepper</h3>
          <PropsTable props={stepperProps} />
        </div>

        <div>
          <h3 class="text-lg font-semibold text-primary mb-4">Step</h3>
          <PropsTable props={stepProps} />
        </div>
      </div>
    </section>

    <section id="usage" class="space-y-6">
      <h2 class="section__title">Usage</h2>
      
      <div class="space-y-4">
        <div class="card">
          <div class="card__body">
            <h3 class="font-semibold text-primary mb-3">
              <Icon name="code-bracket" size="sm" class="inline mr-2" />
              Basic Structure
            </h3>
            <p class="text-sm text-secondary mb-3">
              The Stepper component uses an alternative label layout where labels appear below the step indicators. The step label is provided as slot content.
            </p>
            <div class="text-xs bg-elevated p-4 rounded font-mono">
              &lt;Stepper activeStep={1}&gt;<br />
              &nbsp;&nbsp;&lt;Step completed&gt;Step 1&lt;/Step&gt;<br />
              &nbsp;&nbsp;&lt;Step&gt;Step 2&lt;/Step&gt;<br />
              &nbsp;&nbsp;&lt;Step&gt;Step 3&lt;/Step&gt;<br />
              &lt;/Stepper&gt;
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card__body">
            <h3 class="font-semibold text-primary mb-3">
              <Icon name="code-bracket" size="sm" class="inline mr-2" />
              Step States: Success, Warning, and Error
            </h3>
            <p class="text-sm text-secondary mb-3">
              Steps can display different states. Success state uses the semantic success color (green) with a checkmark icon. Warning and error states use their respective semantic colors.
            </p>
            <div class="text-xs bg-elevated p-4 rounded font-mono">
              &lt;Stepper activeStep={2}&gt;<br />
              &nbsp;&nbsp;&lt;Step success&gt;Verified&lt;/Step&gt;<br />
              &nbsp;&nbsp;&lt;Step warning&gt;Review&lt;/Step&gt;<br />
              &nbsp;&nbsp;&lt;Step error&gt;Fix errors&lt;/Step&gt;<br />
              &nbsp;&nbsp;&lt;Step&gt;Complete&lt;/Step&gt;<br />
              &lt;/Stepper&gt;
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card__body">
            <h3 class="font-semibold text-primary mb-3">
              <Icon name="code-bracket" size="sm" class="inline mr-2" />
              Step with Description
            </h3>
            <p class="text-sm text-secondary mb-3">
              Steps can include a description using a named slot. Labels use Lexend (display font) and descriptions use Figtree (body font) at the same size for clear typographic hierarchy.
            </p>
            <div class="text-xs bg-elevated p-4 rounded font-mono">
              &lt;Step completed success&gt;<br />
              &nbsp;&nbsp;Account Setup<br />
              &nbsp;&nbsp;&lt;template slot="description"&gt;<br />
              &nbsp;&nbsp;&nbsp;&nbsp;Verify your email and password<br />
              &nbsp;&nbsp;&lt;/template&gt;<br />
              &lt;/Step&gt;
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="accessibility" class="space-y-4">
      <h2 class="section__title">Accessibility</h2>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="keyboard" size="sm" />
          Keyboard Navigation
        </h3>
        <p class="a11y-card__text">
          In non-linear mode, steps are keyboard accessible. Use <kbd>Tab</kbd> to navigate between steps,
          and <kbd>Enter</kbd> or <kbd>Space</kbd> to activate a step.
        </p>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="tag" size="sm" />
          ARIA Attributes
        </h3>
        <p class="a11y-card__text">
          The Stepper component uses proper ARIA attributes:
        </p>
        <ul class="a11y-card__text" style="list-style: disc; padding-left: 1.5rem; margin-top: 0.5rem;">
          <li><code>role="group"</code> on the stepper container</li>
          <li><code>aria-current="step"</code> on the active step label</li>
          <li><code>aria-label</code> for step descriptions in non-linear mode</li>
          <li><code>aria-hidden</code> for decorative elements (connectors, indicators)</li>
        </ul>
      </div>
      
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="eye" size="sm" />
          Screen Reader Support
        </h3>
        <p class="a11y-card__text">
          Screen readers announce the step number, label text, and current state (active, completed, error, warning).
          The relationship between steps is clearly communicated through ARIA attributes.
        </p>
      </div>

      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="swatch" size="sm" />
          Visual Indicators
        </h3>
        <p class="a11y-card__text">
          All step states are communicated both visually and through ARIA attributes. Color is not the only
          indicator of state - icons, borders, and text styles also convey information.
        </p>
      </div>
    </section>
  </article>
</DocsLayout>
