---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Date Picker" description="Calendar date selection component.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Date Picker</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Date picker allows users to select dates from a calendar interface or type them directly.
      </p>
    </header>

    <ExampleSection title="Native Date Input" description="Browser's native date picker.">
      <div class="max-w-xs space-y-2">
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Select Date</label>
        <input type="date" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-theme-primary">
      </div>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="date-picker.html"
      code={`<div class="space-y-2">
  <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">
    Select Date
  </label>
  <input 
    type="date" 
    class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-theme-primary"
  >
</div>`}
    />
  </article>
</DocsLayout>

