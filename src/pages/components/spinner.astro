---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Spinner from '../../components/ui/Spinner.astro';
import Button from '../../components/ui/Button.astro';

const props = [
  { name: 'size', type: "'sm' | 'md' | 'lg'", default: "'md'", description: 'Spinner size' },
  { name: 'class', type: 'string', default: '—', description: 'Additional CSS classes for color customization' },
];
---

<DocsLayout title="Spinner" description="Loading spinner indicators.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Spinner</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Loading spinners indicate that content is being loaded or an action is being processed.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Spinner Sizes" description="Three size options for different contexts.">
        <div class="flex items-center gap-8">
          <div class="text-center">
            <Spinner size="sm" />
            <span class="text-xs text-slate-500 mt-2 block">Small</span>
          </div>
          <div class="text-center">
            <Spinner size="md" />
            <span class="text-xs text-slate-500 mt-2 block">Medium</span>
          </div>
          <div class="text-center">
            <Spinner size="lg" />
            <span class="text-xs text-slate-500 mt-2 block">Large</span>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Color Variants" description="Customize spinner color using Tailwind classes.">
        <div class="flex items-center gap-8">
          <div class="text-center">
            <Spinner class="text-theme-primary" />
            <span class="text-xs text-slate-500 mt-2 block">Primary</span>
          </div>
          <div class="text-center">
            <Spinner class="text-success" />
            <span class="text-xs text-slate-500 mt-2 block">Success</span>
          </div>
          <div class="text-center">
            <Spinner class="text-warning" />
            <span class="text-xs text-slate-500 mt-2 block">Warning</span>
          </div>
          <div class="text-center">
            <Spinner class="text-error" />
            <span class="text-xs text-slate-500 mt-2 block">Error</span>
          </div>
          <div class="text-center">
            <Spinner class="text-slate-500" />
            <span class="text-xs text-slate-500 mt-2 block">Neutral</span>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="With Text" description="Spinner alongside loading text.">
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <Spinner size="sm" />
            <span class="text-sm text-slate-600 dark:text-slate-400">Loading...</span>
          </div>
          <div class="flex items-center gap-3">
            <Spinner size="md" />
            <span class="text-sm text-slate-600 dark:text-slate-400">Please wait while we load your data</span>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="In Buttons" description="Spinner inside button during loading state.">
        <div class="flex flex-wrap gap-4">
          <Button variant="primary" disabled>
            <Spinner size="sm" class="text-white" />
            <span>Loading...</span>
          </Button>
          <Button variant="secondary" disabled>
            <Spinner size="sm" class="text-slate-600" />
            <span>Processing</span>
          </Button>
          <Button variant="outline" disabled>
            <Spinner size="sm" />
            <span>Saving...</span>
          </Button>
        </div>
      </ExampleSection>

      <ExampleSection title="Full Page Loading" description="Centered spinner for page-level loading states.">
        <div class="relative h-48 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50">
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <Spinner size="lg" />
            <p class="mt-4 text-sm text-slate-500">Loading content...</p>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Card Loading State" description="Spinner indicating content is loading within a card.">
        <div class="max-w-sm p-6 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-charcoal">
          <div class="flex items-center justify-center h-32">
            <div class="text-center">
              <Spinner size="md" />
              <p class="mt-3 text-sm text-slate-500">Fetching data...</p>
            </div>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Inline Loading" description="Small spinner for inline loading indicators.">
        <div class="flex items-center gap-2 px-3 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 max-w-fit">
          <Spinner size="sm" />
          <span class="text-sm text-slate-600 dark:text-slate-400">Syncing changes...</span>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for operations taking more than 1 second</li>
            <li>• Provide context with loading text when appropriate</li>
            <li>• Size appropriately for the context</li>
            <li>• Use consistent spinner placement</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for instant operations</li>
            <li>• Show multiple spinners simultaneously</li>
            <li>• Use without indicating what's loading</li>
            <li>• Block user interaction indefinitely</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-accessible text-theme-primary"></i>
            ARIA Status
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            The Spinner component includes <code>role="status"</code> and <code>aria-label="Loading"</code> for screen reader announcements.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-eye text-theme-primary"></i>
            Visual Context
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Always pair spinners with visible text to communicate what's happening to all users.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>
