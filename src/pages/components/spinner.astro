---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Spinner" description="Loading spinner indicators.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Spinner</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Loading spinners indicate that content is being loaded or an action is being processed.
      </p>
    </header>

    <ExampleSection title="Spinner Sizes" description="Different spinner sizes.">
      <div class="flex items-center gap-8">
        <div class="text-center">
          <div class="w-4 h-4 border-2 border-theme-primary border-t-transparent rounded-full animate-spin"></div>
          <span class="text-xs text-slate-500 mt-2 block">Small</span>
        </div>
        <div class="text-center">
          <div class="w-6 h-6 border-2 border-theme-primary border-t-transparent rounded-full animate-spin"></div>
          <span class="text-xs text-slate-500 mt-2 block">Medium</span>
        </div>
        <div class="text-center">
          <div class="w-8 h-8 border-2 border-theme-primary border-t-transparent rounded-full animate-spin"></div>
          <span class="text-xs text-slate-500 mt-2 block">Large</span>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 border-3 border-theme-primary border-t-transparent rounded-full animate-spin"></div>
          <span class="text-xs text-slate-500 mt-2 block">X-Large</span>
        </div>
      </div>
    </ExampleSection>

    <ExampleSection title="With Text" description="Spinner with loading text.">
      <div class="flex items-center gap-3">
        <div class="w-5 h-5 border-2 border-theme-primary border-t-transparent rounded-full animate-spin"></div>
        <span class="text-sm text-slate-600 dark:text-slate-400">Loading...</span>
      </div>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="spinner.html"
      code={`<!-- Basic Spinner -->
<div class="w-6 h-6 border-2 border-theme-primary border-t-transparent rounded-full animate-spin"></div>

<!-- Spinner with Text -->
<div class="flex items-center gap-3">
  <div class="w-5 h-5 border-2 border-theme-primary border-t-transparent rounded-full animate-spin"></div>
  <span class="text-sm text-slate-600">Loading...</span>
</div>`}
    />
  </article>
</DocsLayout>

