---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';

const props = [
  { name: 'variant', type: "'primary' | 'secondary' | 'outline' | 'ghost' | 'destructive'", default: "'primary'", description: 'Visual style of the button' },
  { name: 'size', type: "'sm' | 'md' | 'lg'", default: "'md'", description: 'Size of the button' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the button' },
  { name: 'icon', type: 'string', default: '—', description: 'Tabler icon class (e.g., ti-plus)' },
  { name: 'iconPosition', type: "'left' | 'right'", default: "'left'", description: 'Position of the icon relative to text' },
];
---

<DocsLayout title="Buttons" description="Interactive button components with multiple variants, sizes, and states.">
  <article class="space-y-12">
    <!-- Header -->
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Buttons</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Buttons trigger actions and events. Use different variants to communicate the importance and nature of the action.
      </p>
    </header>

    <!-- Quick Links -->
    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1">
        <i class="ti ti-eye"></i> Examples
      </a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1">
        <i class="ti ti-list"></i> Props
      </a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1">
        <i class="ti ti-book"></i> Usage
      </a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1">
        <i class="ti ti-accessible"></i> Accessibility
      </a>
    </nav>

    <!-- Examples -->
    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Primary Variants" description="The main action styles for buttons.">
        <div class="flex flex-wrap gap-4">
          <button class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
            Primary
          </button>
          <button class="px-4 py-2 bg-slate-200 dark:bg-slate-800 hover:bg-slate-300 dark:hover:bg-slate-700 text-slate-900 dark:text-white rounded-lg font-medium transition-colors">
            Secondary
          </button>
          <button class="px-4 py-2 border border-slate-300 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-900 dark:text-white rounded-lg font-medium transition-colors">
            Outline
          </button>
          <button class="px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-900 dark:text-white rounded-lg font-medium transition-colors">
            Ghost
          </button>
          <button class="px-4 py-2 bg-error hover:bg-red-600 text-white rounded-lg font-medium transition-colors">
            Destructive
          </button>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="buttons-variants.html"
        code={`<!-- Primary -->
<button class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
  Primary
</button>

<!-- Secondary -->
<button class="px-4 py-2 bg-slate-200 dark:bg-slate-800 hover:bg-slate-300 dark:hover:bg-slate-700 text-slate-900 dark:text-white rounded-lg font-medium transition-colors">
  Secondary
</button>

<!-- Outline -->
<button class="px-4 py-2 border border-slate-300 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-900 dark:text-white rounded-lg font-medium transition-colors">
  Outline
</button>

<!-- Ghost -->
<button class="px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-900 dark:text-white rounded-lg font-medium transition-colors">
  Ghost
</button>

<!-- Destructive -->
<button class="px-4 py-2 bg-error hover:bg-red-600 text-white rounded-lg font-medium transition-colors">
  Destructive
</button>`}
      />

      <ExampleSection title="Sizes" description="Three size options to fit different contexts.">
        <div class="flex flex-wrap items-center gap-4">
          <button class="px-3 py-1.5 text-sm bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
            Small
          </button>
          <button class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
            Medium
          </button>
          <button class="px-6 py-3 text-lg bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
            Large
          </button>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="buttons-sizes.html"
        code={`<!-- Small -->
<button class="px-3 py-1.5 text-sm bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
  Small
</button>

<!-- Medium (default) -->
<button class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
  Medium
</button>

<!-- Large -->
<button class="px-6 py-3 text-lg bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
  Large
</button>`}
      />

      <ExampleSection title="With Icons" description="Buttons can include icons for visual reinforcement.">
        <div class="flex flex-wrap gap-4">
          <button class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors flex items-center gap-2">
            <i class="ti ti-plus"></i>
            Add Item
          </button>
          <button class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors flex items-center gap-2">
            Continue
            <i class="ti ti-arrow-right"></i>
          </button>
          <button class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors flex items-center gap-2">
            <i class="ti ti-download"></i>
            Download
          </button>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="buttons-icons.html"
        code={`<!-- Icon left -->
<button class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors flex items-center gap-2">
  <i class="ti ti-plus"></i>
  Add Item
</button>

<!-- Icon right -->
<button class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors flex items-center gap-2">
  Continue
  <i class="ti ti-arrow-right"></i>
</button>`}
      />

      <ExampleSection title="Icon Only" description="Compact buttons with just an icon.">
        <div class="flex flex-wrap gap-4">
          <button class="w-10 h-10 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors flex items-center justify-center">
            <i class="ti ti-plus text-lg"></i>
          </button>
          <button class="w-10 h-10 border border-slate-300 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-900 dark:text-white rounded-lg transition-colors flex items-center justify-center">
            <i class="ti ti-settings text-lg"></i>
          </button>
          <button class="w-10 h-10 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-lg transition-colors flex items-center justify-center">
            <i class="ti ti-dots-vertical text-lg"></i>
          </button>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="buttons-icon-only.html"
        code={`<!-- Icon only button -->
<button class="w-10 h-10 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors flex items-center justify-center" aria-label="Add item">
  <i class="ti ti-plus text-lg"></i>
</button>

<!-- Ghost icon button -->
<button class="w-10 h-10 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-lg transition-colors flex items-center justify-center" aria-label="More options">
  <i class="ti ti-dots-vertical text-lg"></i>
</button>`}
      />

      <ExampleSection title="States" description="Disabled and loading states.">
        <div class="flex flex-wrap gap-4">
          <button disabled class="px-4 py-2 bg-theme-primary text-white rounded-lg font-medium opacity-50 cursor-not-allowed">
            Disabled
          </button>
          <button class="px-4 py-2 bg-theme-primary text-white rounded-lg font-medium flex items-center gap-2">
            <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Loading...
          </button>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="buttons-states.html"
        code={`<!-- Disabled -->
<button disabled class="px-4 py-2 bg-theme-primary text-white rounded-lg font-medium opacity-50 cursor-not-allowed">
  Disabled
</button>

<!-- Loading -->
<button class="px-4 py-2 bg-theme-primary text-white rounded-lg font-medium flex items-center gap-2">
  <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
  </svg>
  Loading...
</button>`}
      />
    </section>

    <!-- Props -->
    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <!-- Usage Guidelines -->
    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      
      <div class="space-y-6">
        <div class="prose dark:prose-invert max-w-none">
          <h3>When to Use</h3>
          <ul class="text-slate-600 dark:text-slate-400">
            <li><strong>Primary:</strong> Main call-to-action, one per section</li>
            <li><strong>Secondary:</strong> Alternative actions, less prominent</li>
            <li><strong>Outline:</strong> Secondary actions that need visibility</li>
            <li><strong>Ghost:</strong> Tertiary actions, toolbar buttons</li>
            <li><strong>Destructive:</strong> Delete, remove, or irreversible actions</li>
          </ul>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-6 rounded-lg border border-success/30 bg-success/5">
            <h3 class="font-semibold text-success mb-3 flex items-center gap-2">
              <i class="ti ti-check"></i> Do
            </h3>
            <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
              <li>• Use clear, action-oriented labels</li>
              <li>• Limit primary buttons per view</li>
              <li>• Provide visual feedback on interaction</li>
              <li>• Use icons to reinforce meaning</li>
              <li>• Maintain consistent sizing in groups</li>
            </ul>
          </div>
          <div class="p-6 rounded-lg border border-error/30 bg-error/5">
            <h3 class="font-semibold text-error mb-3 flex items-center gap-2">
              <i class="ti ti-x"></i> Don't
            </h3>
            <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
              <li>• Use vague labels like "Click Here"</li>
              <li>• Disable buttons without explanation</li>
              <li>• Mix too many variants in one area</li>
              <li>• Use destructive style for safe actions</li>
              <li>• Rely solely on color for meaning</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Accessibility -->
    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-keyboard text-theme-primary"></i>
            Keyboard Navigation
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-2">
            All buttons are focusable and can be activated with <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Enter</kbd> or <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Space</kbd>.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-eye text-theme-primary"></i>
            Icon-Only Buttons
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Always include <code>aria-label</code> for icon-only buttons to provide context for screen readers.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-focus-2 text-theme-primary"></i>
            Focus States
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Buttons include visible focus indicators. Use <code>focus:ring-2 focus:ring-theme-primary focus:ring-offset-2</code> for enhanced visibility.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-ban text-theme-primary"></i>
            Disabled State
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Disabled buttons should include <code>aria-disabled="true"</code> and explain why they're disabled via tooltip or adjacent text.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>

