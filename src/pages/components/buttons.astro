---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Button from '../../components/ui/Button.astro';
import Spinner from '../../components/ui/Spinner.astro';

const props = [
  { name: 'variant', type: "'primary' | 'secondary' | 'outline' | 'ghost' | 'destructive'", default: "'primary'", description: 'Visual style of the button' },
  { name: 'size', type: "'sm' | 'md' | 'lg'", default: "'md'", description: 'Size of the button' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the button' },
  { name: 'icon', type: 'string', default: '—', description: 'Tabler icon class (e.g., ti-plus)' },
  { name: 'iconPosition', type: "'left' | 'right'", default: "'left'", description: 'Position of the icon relative to text' },
  { name: 'fullWidth', type: 'boolean', default: 'false', description: 'Makes button full width' },
];
---

<DocsLayout title="Buttons" description="Interactive button components with multiple variants, sizes, and states.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Buttons</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Buttons trigger actions and events. Use different variants to communicate the importance and nature of the action.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Primary Variants" description="The main action styles for buttons.">
        <div class="flex flex-wrap gap-4">
          <Button variant="primary">Primary</Button>
          <Button variant="secondary">Secondary</Button>
          <Button variant="outline">Outline</Button>
          <Button variant="ghost">Ghost</Button>
          <Button variant="destructive">Destructive</Button>
        </div>
      </ExampleSection>

      <ExampleSection title="Sizes" description="Three size options to fit different contexts.">
        <div class="flex flex-wrap items-center gap-4">
          <Button size="sm">Small</Button>
          <Button size="md">Medium</Button>
          <Button size="lg">Large</Button>
        </div>
      </ExampleSection>

      <ExampleSection title="With Icons" description="Buttons can include icons for visual reinforcement.">
        <div class="flex flex-wrap gap-4">
          <Button icon="ti-plus">Add Item</Button>
          <Button icon="ti-arrow-right" iconPosition="right">Continue</Button>
          <Button icon="ti-download">Download</Button>
          <Button variant="secondary" icon="ti-edit">Edit</Button>
          <Button variant="outline" icon="ti-share">Share</Button>
        </div>
      </ExampleSection>

      <ExampleSection title="Icon Only" description="Compact buttons with just an icon.">
        <div class="flex flex-wrap gap-4">
          <Button icon="ti-plus" class="w-10 h-10 !p-0" aria-label="Add item" />
          <Button variant="secondary" icon="ti-edit" class="w-10 h-10 !p-0" aria-label="Edit" />
          <Button variant="outline" icon="ti-settings" class="w-10 h-10 !p-0" aria-label="Settings" />
          <Button variant="ghost" icon="ti-dots-vertical" class="w-10 h-10 !p-0" aria-label="More options" />
          <Button variant="destructive" icon="ti-trash" class="w-10 h-10 !p-0" aria-label="Delete" />
        </div>
      </ExampleSection>

      <ExampleSection title="States" description="Disabled and loading states.">
        <div class="flex flex-wrap gap-4">
          <Button disabled>Disabled</Button>
          <Button variant="secondary" disabled>Disabled Secondary</Button>
          <Button variant="outline" disabled>Disabled Outline</Button>
        </div>
      </ExampleSection>

      <ExampleSection title="Loading State" description="Buttons with loading spinner.">
        <div class="flex flex-wrap gap-4">
          <Button disabled>
            <Spinner size="sm" class="text-white" />
            <span>Loading...</span>
          </Button>
          <Button variant="secondary" disabled>
            <Spinner size="sm" class="text-slate-600" />
            <span>Processing</span>
          </Button>
          <Button variant="outline" disabled>
            <Spinner size="sm" />
            <span>Saving...</span>
          </Button>
        </div>
      </ExampleSection>

      <ExampleSection title="Full Width" description="Buttons that span the full container width.">
        <div class="max-w-sm space-y-3">
          <Button fullWidth>Full Width Primary</Button>
          <Button variant="outline" fullWidth>Full Width Outline</Button>
        </div>
      </ExampleSection>

      <ExampleSection title="Button Combinations" description="Common button patterns.">
        <div class="space-y-4">
          <div class="flex gap-3">
            <Button variant="primary">Save Changes</Button>
            <Button variant="ghost">Cancel</Button>
          </div>
          <div class="flex gap-3">
            <Button variant="destructive" icon="ti-trash">Delete</Button>
            <Button variant="outline">Cancel</Button>
          </div>
          <div class="flex gap-3">
            <Button variant="primary" icon="ti-check">Confirm</Button>
            <Button variant="secondary" icon="ti-x">Reject</Button>
          </div>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      
      <div class="space-y-6">
        <div class="prose dark:prose-invert max-w-none">
          <h3>When to Use Each Variant</h3>
          <ul class="text-slate-600 dark:text-slate-400">
            <li><strong>Primary:</strong> Main call-to-action, one per section</li>
            <li><strong>Secondary:</strong> Alternative actions, less prominent</li>
            <li><strong>Outline:</strong> Secondary actions that need visibility</li>
            <li><strong>Ghost:</strong> Tertiary actions, toolbar buttons</li>
            <li><strong>Destructive:</strong> Delete, remove, or irreversible actions</li>
          </ul>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-6 rounded-lg border border-success/30 bg-success/5">
            <h3 class="font-semibold text-success mb-3 flex items-center gap-2">
              <i class="ti ti-check"></i> Do
            </h3>
            <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
              <li>• Use clear, action-oriented labels</li>
              <li>• Limit primary buttons per view</li>
              <li>• Provide visual feedback on interaction</li>
              <li>• Use icons to reinforce meaning</li>
              <li>• Maintain consistent sizing in groups</li>
            </ul>
          </div>
          <div class="p-6 rounded-lg border border-error/30 bg-error/5">
            <h3 class="font-semibold text-error mb-3 flex items-center gap-2">
              <i class="ti ti-x"></i> Don't
            </h3>
            <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
              <li>• Use vague labels like "Click Here"</li>
              <li>• Disable buttons without explanation</li>
              <li>• Mix too many variants in one area</li>
              <li>• Use destructive style for safe actions</li>
              <li>• Rely solely on color for meaning</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-keyboard text-theme-primary"></i>
            Keyboard Navigation
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            All buttons are focusable and can be activated with <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Enter</kbd> or <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Space</kbd>.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-eye text-theme-primary"></i>
            Icon-Only Buttons
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Always include <code>aria-label</code> for icon-only buttons to provide context for screen readers.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-focus-2 text-theme-primary"></i>
            Focus States
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Buttons include visible focus indicators that meet WCAG 2.1 requirements for contrast.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-ban text-theme-primary"></i>
            Disabled State
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Disabled buttons are marked with <code>disabled</code> attribute. Explain why buttons are disabled via tooltip or adjacent text.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>
