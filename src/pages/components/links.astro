---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Links" description="Text links with icons and variants.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Links</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Links navigate users to other pages or resources. Use appropriate styling to indicate clickability.
      </p>
    </header>

    <ExampleSection title="Link Variants" description="Different link styles.">
      <div class="space-y-4">
        <p><a href="#" class="text-theme-primary hover:underline">Default link</a></p>
        <p><a href="#" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white underline">Subtle link</a></p>
        <p><a href="#" class="text-theme-primary hover:underline inline-flex items-center gap-1">Link with icon <i class="ti ti-external-link text-sm"></i></a></p>
        <p><a href="#" class="text-theme-primary hover:underline inline-flex items-center gap-1"><i class="ti ti-arrow-left text-sm"></i> Back link</a></p>
      </div>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="links.html"
      code={`<!-- Default Link -->
<a href="#" class="text-theme-primary hover:underline">Link text</a>

<!-- Link with External Icon -->
<a href="#" class="text-theme-primary hover:underline inline-flex items-center gap-1">
  External link
  <i class="ti ti-external-link text-sm"></i>
</a>`}
    />
  </article>
</DocsLayout>

