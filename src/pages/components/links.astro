---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Link from '../../components/ui/Link.astro';

const props = [
  { name: 'href', type: 'string', description: 'Link URL', required: true },
  { name: 'variant', type: "'default' | 'subtle' | 'underline'", default: "'default'", description: 'Link style variant' },
  { name: 'external', type: 'boolean', default: 'false', description: 'Open in new tab (adds external icon)' },
  { name: 'icon', type: 'string', default: '—', description: 'Leading icon class' },
];
---

<DocsLayout title="Links" description="Text links with icons and variants.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Links</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Links navigate users to other pages or resources. Use appropriate styling to indicate clickability.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Link Variants" description="Different link styles for various contexts.">
        <div class="space-y-4">
          <p class="text-slate-600 dark:text-slate-400">
            This is a <Link href="#">default link</Link> in the middle of text.
          </p>
          <p class="text-slate-600 dark:text-slate-400">
            This is a <Link href="#" variant="subtle">subtle link</Link> that blends more with text.
          </p>
          <p class="text-slate-600 dark:text-slate-400">
            This is an <Link href="#" variant="underline">underlined link</Link> for emphasis.
          </p>
        </div>
      </ExampleSection>

      <ExampleSection title="External Links" description="Links that open in a new tab with indicator.">
        <div class="space-y-3">
          <div><Link href="https://example.com" external>External website</Link></div>
          <div><Link href="https://docs.example.com" external>Documentation</Link></div>
          <div><Link href="https://github.com" external>GitHub Repository</Link></div>
        </div>
      </ExampleSection>

      <ExampleSection title="Links with Icons" description="Links with leading icons for context.">
        <div class="space-y-3">
          <div><Link href="#" icon="ti-arrow-left">Back to previous page</Link></div>
          <div><Link href="#" icon="ti-download">Download file</Link></div>
          <div><Link href="#" icon="ti-mail">Contact support</Link></div>
          <div><Link href="#" icon="ti-book">Read documentation</Link></div>
          <div><Link href="https://example.com" icon="ti-world" external>Visit website</Link></div>
        </div>
      </ExampleSection>

      <ExampleSection title="Navigation Links" description="Links styled for navigation purposes.">
        <nav class="flex flex-col gap-2">
          <Link href="#" icon="ti-home" variant="subtle">Home</Link>
          <Link href="#" icon="ti-folder" variant="subtle">Projects</Link>
          <Link href="#" icon="ti-users" variant="subtle">Team</Link>
          <Link href="#" icon="ti-settings" variant="subtle">Settings</Link>
        </nav>
      </ExampleSection>

      <ExampleSection title="In Paragraph Context" description="Links within body text.">
        <div class="max-w-prose space-y-4 text-slate-600 dark:text-slate-400">
          <p>
            For more information about our design system, please visit our 
            <Link href="#">documentation portal</Link>. You can also check out our 
            <Link href="https://github.com" external>GitHub repository</Link> for the latest updates.
          </p>
          <p>
            If you have questions, feel free to <Link href="#" icon="ti-mail">email our support team</Link> or 
            <Link href="#">join our community forum</Link> for discussions.
          </p>
        </div>
      </ExampleSection>

      <ExampleSection title="Breadcrumb Links" description="Links in a breadcrumb navigation.">
        <nav class="flex items-center gap-2 text-sm">
          <Link href="#" variant="subtle">Home</Link>
          <span class="text-slate-400">/</span>
          <Link href="#" variant="subtle">Components</Link>
          <span class="text-slate-400">/</span>
          <span class="text-slate-900 dark:text-white font-medium">Links</span>
        </nav>
      </ExampleSection>

      <ExampleSection title="Card with Links" description="Links within a card component.">
        <div class="max-w-sm p-6 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-charcoal">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2">Resources</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">
            Helpful links to get you started.
          </p>
          <div class="space-y-2">
            <div><Link href="#" icon="ti-book">Getting Started Guide</Link></div>
            <div><Link href="#" icon="ti-code">API Reference</Link></div>
            <div><Link href="https://example.com" icon="ti-video" external>Video Tutorials</Link></div>
          </div>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use descriptive link text</li>
            <li>• Indicate external links clearly</li>
            <li>• Use appropriate variants for context</li>
            <li>• Ensure links are visually distinct</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use "click here" as link text</li>
            <li>• Open all links in new tabs</li>
            <li>• Use links for actions (use buttons)</li>
            <li>• Make links look like regular text</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-external-link text-theme-primary"></i>
            External Links
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            External links include <code>target="_blank"</code> and <code>rel="noopener noreferrer"</code> for security, with a visual indicator icon.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-typography text-theme-primary"></i>
            Link Text
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Always use descriptive link text that makes sense out of context. Screen readers often navigate by links alone.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>
