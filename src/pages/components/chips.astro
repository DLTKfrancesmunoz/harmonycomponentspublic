---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Chip from '../../components/ui/Chip.astro';
import Icon from '../../components/ui/Icon.astro';

const props = [
  { name: 'selected', type: 'boolean', default: 'false', description: 'Selected state' },
  { name: 'removable', type: 'boolean', default: 'false', description: 'Shows remove button' },
  { name: 'icon', type: 'string', default: '—', description: 'Leading icon class' },
];
---

<DocsLayout title="Chips" description="Chip components for tags and filters.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Chips</h1>
        <span class="badge badge--success">stable</span>
      </div>
      <p class="page-header__description">
        Chips are compact elements that represent tags, filters, or small pieces of information.
      </p>
    </header>

    <nav class="article-nav">
      <a href="#examples" class="article-nav__link"><Icon name="eye" size="sm" /> Examples</a>
      <a href="#props" class="article-nav__link"><Icon name="queue-list" size="sm" /> Props</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="section__title">Examples</h2>

      <ExampleSection title="Basic Chips" description="Standard chip styling.">
        <div class="flex flex-wrap gap-2">
          <Chip>Design</Chip>
          <Chip>Development</Chip>
          <Chip>Marketing</Chip>
        </div>
      </ExampleSection>

      <ExampleSection title="Selected Chips" description="Chips in selected state.">
        <div class="flex flex-wrap gap-2">
          <Chip>All</Chip>
          <Chip selected>Active</Chip>
          <Chip>Completed</Chip>
          <Chip>Archived</Chip>
        </div>
      </ExampleSection>

      <ExampleSection title="Removable Chips" description="Chips that can be removed.">
        <div class="flex flex-wrap gap-2">
          <Chip removable>React</Chip>
          <Chip removable>TypeScript</Chip>
          <Chip removable>CSS</Chip>
        </div>
      </ExampleSection>

      <ExampleSection title="With Icons" description="Chips with leading icons.">
        <div class="flex flex-wrap gap-2">
          <Chip icon="user">John Doe</Chip>
          <Chip icon="tag">Featured</Chip>
          <Chip icon="calendar">Today</Chip>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="section__title">Props</h2>
      <PropsTable props={props} />
    </section>
  </article>
</DocsLayout>
