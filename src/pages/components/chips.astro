---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Chips" description="Dismissible tags and filter chips.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Chips</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Chips are compact elements representing inputs, attributes, or actions. They can be dismissible or interactive.
      </p>
    </header>

    <ExampleSection title="Basic Chips" description="Simple chips with optional dismiss button.">
      <div class="flex flex-wrap gap-2">
        <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-sm text-slate-700 dark:text-slate-300">
          Design
          <button class="hover:text-slate-900 dark:hover:text-white"><i class="ti ti-x text-xs"></i></button>
        </span>
        <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-theme-primary/10 text-sm text-theme-primary">
          React
          <button class="hover:text-theme-primary-hover"><i class="ti ti-x text-xs"></i></button>
        </span>
        <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-success/10 text-sm text-success">
          <i class="ti ti-check text-xs"></i>
          Complete
        </span>
      </div>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="chips.html"
      code={`<!-- Dismissible Chip -->
<span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-sm text-slate-700 dark:text-slate-300">
  Label
  <button class="hover:text-slate-900 dark:hover:text-white">
    <i class="ti ti-x text-xs"></i>
  </button>
</span>

<!-- Chip with Icon -->
<span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-success/10 text-sm text-success">
  <i class="ti ti-check text-xs"></i>
  Complete
</span>`}
    />
  </article>
</DocsLayout>

