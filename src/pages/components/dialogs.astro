---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';

const props = [
  { name: 'open', type: 'boolean', default: 'false', description: 'Controls dialog visibility', required: true },
  { name: 'onClose', type: 'function', default: '—', description: 'Called when dialog should close', required: true },
  { name: 'size', type: "'sm' | 'md' | 'lg' | 'xl'", default: "'md'", description: 'Dialog width' },
  { name: 'closeOnOverlay', type: 'boolean', default: 'true', description: 'Close when clicking overlay' },
];
---

<DocsLayout title="Dialogs" description="Modal dialog components for focused interactions.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Dialogs</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Dialogs are modal overlays that focus user attention on a specific task or information, temporarily blocking interaction with the rest of the page.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Basic Dialog" description="A simple dialog with title, content, and actions.">
        <button id="open-basic-dialog" class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
          Open Dialog
        </button>
        
        <!-- Dialog Preview (static) -->
        <div class="mt-6 relative">
          <div class="absolute inset-0 bg-black/50 rounded-lg"></div>
          <div class="relative p-6 max-w-md mx-auto bg-white dark:bg-charcoal rounded-xl shadow-2xl">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Dialog Title</h3>
              <button class="text-slate-400 hover:text-slate-600 dark:hover:text-white">
                <i class="ti ti-x text-lg"></i>
              </button>
            </div>
            <p class="text-slate-600 dark:text-slate-400 mb-6">
              This is the dialog content. You can add any content here including forms, images, or other components.
            </p>
            <div class="flex justify-end gap-3">
              <button class="px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg font-medium transition-colors">
                Cancel
              </button>
              <button class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
                Confirm
              </button>
            </div>
          </div>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="dialog.html"
        code={`<!-- Overlay -->
<div class="fixed inset-0 bg-black/50 z-40" id="dialog-overlay"></div>

<!-- Dialog -->
<div class="fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="w-full max-w-md bg-white dark:bg-charcoal rounded-xl shadow-2xl">
    <!-- Header -->
    <div class="flex items-center justify-between p-6 border-b border-slate-200 dark:border-slate-800">
      <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Dialog Title</h3>
      <button class="text-slate-400 hover:text-slate-600 dark:hover:text-white">
        <i class="ti ti-x text-lg"></i>
      </button>
    </div>
    
    <!-- Content -->
    <div class="p-6">
      <p class="text-slate-600 dark:text-slate-400">
        Dialog content goes here.
      </p>
    </div>
    
    <!-- Footer -->
    <div class="flex justify-end gap-3 p-6 border-t border-slate-200 dark:border-slate-800">
      <button class="px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg font-medium">
        Cancel
      </button>
      <button class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium">
        Confirm
      </button>
    </div>
  </div>
</div>`}
      />

      <ExampleSection title="Confirmation Dialog" description="Used for destructive actions.">
        <div class="p-6 max-w-sm mx-auto bg-white dark:bg-charcoal rounded-xl shadow-lg border border-slate-200 dark:border-slate-800">
          <div class="w-12 h-12 rounded-full bg-error/10 flex items-center justify-center mx-auto mb-4">
            <i class="ti ti-alert-triangle text-2xl text-error"></i>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white text-center mb-2">Delete Item?</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 text-center mb-6">
            This action cannot be undone. This will permanently delete the item from your account.
          </p>
          <div class="flex gap-3">
            <button class="flex-1 px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg font-medium transition-colors">
              Cancel
            </button>
            <button class="flex-1 px-4 py-2 bg-error hover:bg-red-600 text-white rounded-lg font-medium transition-colors">
              Delete
            </button>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Dialog with Form" description="Dialog containing a form.">
        <div class="p-6 max-w-md mx-auto bg-white dark:bg-charcoal rounded-xl shadow-lg border border-slate-200 dark:border-slate-800">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Create Project</h3>
            <button class="text-slate-400 hover:text-slate-600 dark:hover:text-white">
              <i class="ti ti-x text-lg"></i>
            </button>
          </div>
          <form class="space-y-4">
            <div class="space-y-2">
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Project Name</label>
              <input type="text" placeholder="My awesome project" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-theme-primary">
            </div>
            <div class="space-y-2">
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Description</label>
              <textarea rows="3" placeholder="Brief description..." class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-theme-primary resize-none"></textarea>
            </div>
            <div class="flex justify-end gap-3 pt-4">
              <button type="button" class="px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg font-medium transition-colors">
                Cancel
              </button>
              <button type="submit" class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
                Create Project
              </button>
            </div>
          </form>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use for focused, important tasks</li>
            <li>• Provide clear title and actions</li>
            <li>• Allow closing via overlay click</li>
            <li>• Keep content concise</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Stack multiple dialogs</li>
            <li>• Use for non-essential content</li>
            <li>• Make dialogs too large</li>
            <li>• Prevent all methods of closing</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-focus-2 text-theme-primary"></i>
            Focus Management
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Focus should be trapped within the dialog when open. On open, focus the first focusable element. On close, return focus to the trigger element.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-keyboard text-theme-primary"></i>
            Keyboard Support
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            <kbd class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-800 rounded text-xs">Esc</kbd> should close the dialog. Tab navigation should cycle through focusable elements within the dialog.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-accessible text-theme-primary"></i>
            ARIA Attributes
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Use <code>role="dialog"</code>, <code>aria-modal="true"</code>, and <code>aria-labelledby</code> pointing to the dialog title.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>

