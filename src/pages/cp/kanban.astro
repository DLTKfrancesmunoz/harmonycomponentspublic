---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Kanban from '../../components/ui/Kanban.astro';
import Icon from '../../components/ui/Icon.astro';
import { EXAMPLE_KANBAN_VIEW_JSON } from '../../types/kanban-view-config';

const kanbanCostpointProps = [
  { name: 'columns', type: 'KanbanCostpointColumn[]', default: '—', description: 'Column definitions with Costpoint cards, optional headerColorLight, loadMoreRemaining.' },
  { name: 'variant', type: "'costpoint'", default: '—', description: 'Must be costpoint for this shell.' },
  { name: 'cardFieldsConfig', type: 'KanbanViewCardField[]', default: '[]', description: 'Five slot definitions matching JSON kanbanView.cardFields.fields' },
  { name: 'cpRecordCount', type: 'number', default: '—', description: 'Derived total when cpRecordTotal omitted (sum of cards)' },
  { name: 'cpRecordShown', type: 'number', default: '—', description: '“Showing X of Y” X (defaults to cpRecordCount)' },
  { name: 'cpRecordTotal', type: 'number', default: '—', description: '“Showing X of Y” Y (defaults to cpRecordCount)' },
  { name: 'cpToolbarTitle', type: 'string', default: '—', description: 'Optional legacy prop; default chrome no longer renders a top toolbar unless you use the cp-toolbar slot.' },
  { name: 'cpSortedBy', type: 'string', default: '—', description: 'Sort field label (“Sorted by: …”); falls back to cpSortLabel' },
  { name: 'cpSortLabel', type: 'string', default: "'Due Date'", description: 'Default sort label when cpSortedBy omitted' },
  { name: 'cpActiveView', type: "'table' | 'form' | 'kanban'", default: "'kanban'", description: 'Only when implementing a custom cp-toolbar / cpToolbar with a view switcher.' },
  { name: 'cpSearchPlaceholder', type: 'string', default: '—', description: 'Quick search placeholder' },
  { name: 'cpScrollColumnIndex', type: 'number', default: '0', description: 'Active column index for nav dots' },
  { name: 'showLoadMore', type: 'boolean', default: 'true', description: 'Show Load more in each column' },
  { name: 'class', type: 'string', default: '—', description: 'Additional CSS classes on the root container' },
];

const kanbanCardCostpointProps = [
  { name: 'id', type: 'string', default: '—', description: 'Record id' },
  { name: 'title', type: 'string', default: '—', description: 'Card title (truncates with ellipsis; full text in tooltip)' },
  { name: 'fieldsConfig', type: 'KanbanViewCardField[]', default: '—', description: 'Five slot configuration (enabled, styleId, fieldName)' },
  { name: 'valuesByFieldName', type: 'Record<string, string>', default: '—', description: 'Field values keyed by fieldName' },
  { name: 'moveOptions', type: 'Option[]', default: '—', description: 'Dropdown options for Move card; disable current column' },
  { name: 'selected', type: 'boolean', default: 'false', description: 'Selected card outline' },
  { name: 'graphicalClass', type: 'string', default: '—', description: 'Optional strip class for conditional graphicalElement styling' },
  { name: 'accentColor', type: 'string', default: '—', description: 'Advanced: optional top accent strip when composing cards manually (not set by built-in Kanban)' },
  { name: 'openRecordLabel', type: 'string', default: "'Open record'", description: 'Footer control label' },
];

const cpCardFieldsConfig = [
  { position: 1 as const, fieldName: 'Assigned', enabled: true, styleId: 'default' },
  { position: 2 as const, fieldName: 'Due', enabled: true, styleId: 'default' },
  { position: 3 as const, fieldName: 'Reserve', enabled: false },
  { position: 4 as const, fieldName: 'Priority', enabled: true, styleId: 'default' },
  { position: 5 as const, fieldName: 'Notes', enabled: false },
];

