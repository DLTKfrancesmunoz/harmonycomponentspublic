---
import { getCollection } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';
import ChangelogFilters from '../components/ChangelogFilters.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';

const allEntries = await getCollection('changelog');

type ChangelogEntry = typeof allEntries[number];

// Helper function to get date key (YYYY-MM-DD format)
function getDateKey(date: Date): string {
  return date.toISOString().split('T')[0];
}

// Sort all entries by date/time descending first (newest first)
const sortedAllEntries = [...allEntries].sort((a, b) => {
  return b.data.date.getTime() - a.data.date.getTime();
});

// Group by date first (not version), so all entries for the same date are together
const groupedByDate: Record<string, ChangelogEntry[]> = {};
for (const entry of sortedAllEntries) {
  const dateKey = getDateKey(entry.data.date);
  
  if (!groupedByDate[dateKey]) {
    groupedByDate[dateKey] = [];
  }
  groupedByDate[dateKey].push(entry);
}

// Sort dates descending (newest first)
const sortedDates = Object.keys(groupedByDate).sort((a, b) => b.localeCompare(a));

// Category configuration
type CategoryKey = 'added' | 'changed' | 'deprecated' | 'removed' | 'fixed' | 'security';
const categoryConfig: Record<CategoryKey, { label: string; color: 'success' | 'info' | 'warning' | 'error' }> = {
  added: { label: 'Added', color: 'success' },
  changed: { label: 'Changed', color: 'info' },
  deprecated: { label: 'Deprecated', color: 'warning' },
  removed: { label: 'Removed', color: 'error' },
  fixed: { label: 'Fixed', color: 'success' },
  security: { label: 'Security', color: 'error' }
};
---

<DocsLayout title="Changelog">
  <div class="changelog-page">
    <header class="changelog-header">
      <h1>Changelog</h1>
      <p class="changelog-description">
        All notable changes to the Harmony Design System are automatically documented here.
        This changelog follows <a href="https://keepachangelog.com/" target="_blank" rel="noopener">Keep a Changelog</a> format
        and adheres to <a href="https://semver.org/" target="_blank" rel="noopener">Semantic Versioning</a>.
      </p>

      <div class="changelog-actions">
        <Button variant="secondary" href="/changelog.xml" icon="rss" iconPosition="left">
          Subscribe via RSS
        </Button>
      </div>
    </header>

    {allEntries.length > 0 ? (
      <>
        <ChangelogFilters entries={allEntries} />

        <div class="changelog-timeline" id="changelog-entries">
          <section class="version-section">
            <div class="version-header">
              <h2 class="version-title">Recent Changes</h2>
            </div>
            
            {sortedDates.map(dateKey => {
              const entries = groupedByDate[dateKey];
              const entryDate = entries[0]?.data.date;

                  // Sort entries by date/time descending (newest first) within this date group
                  const sortedEntries = [...entries].sort((a, b) => {
                    return b.data.date.getTime() - a.data.date.getTime();
                  });

                  // Group entries by category within date, maintaining time order within each category
                  const categoriesOrder: CategoryKey[] = ['added', 'changed', 'deprecated', 'removed', 'fixed', 'security'];
                  const entriesByCategory: any = {};
                  for (const cat of categoriesOrder) {
                    // Filter and sort entries within each category by time (newest first)
                    const categoryEntries = sortedEntries
                      .filter((e: ChangelogEntry) => e.data.category === cat)
                      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
                    if (categoryEntries.length > 0) {
                      entriesByCategory[cat] = categoryEntries;
                    }
                  }

            return (
              <div class="date-section">
                  <div class="date-header">
                    <div class="version-meta">
                      {entryDate && (
                        <time class="version-date" datetime={entryDate.toISOString()}>
                          {entryDate.toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric'
                          })}
                        </time>
                      )}
                      <span class="version-count">({entries.length} {entries.length === 1 ? 'entry' : 'entries'})</span>
                    </div>
                  </div>

                  <div class="version-content">
                        {(Object.entries(entriesByCategory) as [string, ChangelogEntry[]][]).map(([category, categoryEntries]) => {
                          const config = categoryConfig[category as CategoryKey];
                          return (
                            <div class="changelog-category">
                              <h3 class="category-title">
                                <Badge variant={config.color}>
                                  {config.label}
                                </Badge>
                              </h3>
                              <ul class="changelog-entries">
                                {categoryEntries.map((entry) => (
                                  <li
                                    class="changelog-entry"
                                    data-category={entry.data.category}
                                    data-type={entry.data.type}
                                    data-target={entry.data.target}
                                    data-breaking={entry.data.breaking ? 'true' : 'false'}
                                  >
                                    <div class="entry-content">
                                      <strong class="entry-target">{entry.data.target}:</strong>
                                      <span class="entry-description">{entry.data.description}</span>
                                      {entry.data.breaking && (
                                        <Badge variant="error">Breaking</Badge>
                                      )}
                                    </div>

                                    {entry.data.properties && entry.data.properties.length > 0 && (
                                      <ul class="entry-properties">
                                        {entry.data.properties.map((prop: { name: string; change: string; before?: string; after?: string }) => (
                                          <li>
                                            <code>{prop.name}</code>: {prop.change}
                                            {prop.before && prop.after && (
                                              <span> ({prop.before} → {prop.after})</span>
                                            )}
                                          </li>
                                        ))}
                                      </ul>
                                    )}

                                    <div class="entry-meta">
                                      <time class="entry-timestamp" datetime={entry.data.date.toISOString()}>
                                        {entry.data.date.toLocaleString('en-US', {
                                          year: 'numeric',
                                          month: 'short',
                                          day: 'numeric',
                                          hour: '2-digit',
                                          minute: '2-digit'
                                        })}
                                      </time>
                                      {entry.data.commit && (
                                        <>
                                          <span class="entry-meta-separator">·</span>
                                          <span class="commit-hash" title={entry.data.commit.message}>
                                            {entry.data.commit.hash}
                                          </span>
                                          <span class="commit-author">
                                            by {entry.data.commit.author}
                                          </span>
                                        </>
                                      )}
                                    </div>
                                  </li>
                                ))}
                              </ul>
                            </div>
                          );
                        })}
                  </div>
                </div>
              </div>
            );
            })}
          </section>
        </div>
      </>
    ) : (
      <Card elevated>
        <div class="changelog-empty">
          <p>📝 No changelog entries yet.</p>
          <p>
            The changelog automatically updates when commits are pushed to main that modify components or design tokens.
          </p>
          <details class="changelog-empty-details">
            <summary>How does it work?</summary>
            <ul>
              <li>GitHub Actions detects component/token changes automatically</li>
              <li>Changelog entries are generated and committed</li>
              <li>Changes appear here after the workflow completes</li>
            </ul>
          </details>
        </div>
      </Card>
    )}
  </div>
</DocsLayout>

<style>
  .changelog-page {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--spacing-6, 24px);
  }

  .changelog-header {
    margin-bottom: var(--spacing-8, 32px);
  }

  .changelog-header h1 {
    font-size: var(--font-size-display-sm, 2.5rem);
    margin-bottom: var(--spacing-4, 16px);
    font-weight: 700;
  }

  .changelog-description {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--spacing-4, 16px);
  }

  .changelog-description a {
    color: var(--theme-primary);
    text-decoration: underline;
  }

  .changelog-actions {
    display: flex;
    gap: var(--spacing-3, 12px);
  }

  .version-section {
    margin-bottom: var(--spacing-10, 40px);
    border-left: 2px solid var(--border-color);
    padding-left: var(--spacing-6, 24px);
    position: relative;
  }

  .version-section::before {
    content: '';
    position: absolute;
    left: -7px;
    top: 6px;
    width: 12px;
    height: 12px;
    background: var(--theme-primary);
    border-radius: 50%;
    border: 2px solid var(--card-bg);
  }

  .version-header {
    margin-bottom: var(--spacing-6, 24px);
  }

  .version-title {
    font-size: var(--font-size-heading-lg, 1.75rem);
    margin-bottom: var(--spacing-2, 8px);
    font-weight: 600;
  }

  .date-section {
    margin-bottom: var(--spacing-8, 32px);
  }

  .date-section:last-child {
    margin-bottom: 0;
  }

  .date-header {
    margin-bottom: var(--spacing-6, 24px);
  }

  .version-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-3, 12px);
    flex-wrap: wrap;
  }

  .version-date {
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm, 0.875rem);
  }

  .date-header .version-date {
    font-size: var(--font-size-body, 1rem);
    font-weight: 500;
  }

  .version-count {
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm, 0.875rem);
    font-weight: 500;
  }

  .date-header .version-count {
    font-size: var(--font-size-body, 1rem);
  }

  .changelog-category {
    margin-bottom: var(--spacing-6, 24px);
  }

  .category-title {
    font-size: var(--font-size-heading-sm, 1.25rem);
    margin-bottom: var(--spacing-3, 12px);
    font-weight: 600;
  }

  .changelog-entries {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .changelog-entry {
    padding: var(--spacing-4, 16px) 0;
    border-bottom: 1px solid var(--border-color);
  }

  .changelog-entry:last-child {
    border-bottom: none;
  }

  .entry-content {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-2, 8px);
    flex-wrap: wrap;
    margin-bottom: var(--spacing-2, 8px);
  }

  .entry-target {
    color: var(--text-primary);
    font-weight: 600;
  }

  .entry-description {
    color: var(--text-secondary);
    flex: 1;
  }

  .entry-properties {
    margin-top: var(--spacing-2, 8px);
    margin-left: var(--spacing-4, 16px);
    list-style: disc;
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm, 0.875rem);
  }

  .entry-properties code {
    background: var(--elevated-bg);
    padding: 2px 6px;
    border-radius: 3px;
    font-family: monospace;
    font-size: 0.875em;
  }

  .entry-meta {
    margin-top: var(--spacing-2, 8px);
    font-size: var(--font-size-body-sm, 0.875rem);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: var(--spacing-2, 8px);
    flex-wrap: wrap;
  }

  .entry-timestamp {
    color: var(--text-muted);
  }

  .entry-meta-separator {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .commit-hash {
    font-family: monospace;
    background: var(--elevated-bg);
    padding: 2px 6px;
    border-radius: 3px;
    cursor: help;
  }

  .changelog-empty {
    text-align: center;
    padding: var(--spacing-10, 40px);
  }

  .changelog-empty p {
    margin-bottom: var(--spacing-3, 12px);
    color: var(--text-secondary);
  }

  .changelog-empty code {
    background: var(--elevated-bg);
    padding: 4px 8px;
    border-radius: 4px;
    font-family: monospace;
    border: 1px solid var(--border-color);
  }

  .changelog-empty-details {
    margin-top: var(--spacing-4, 16px);
    padding: var(--spacing-3, 12px);
    background: var(--elevated-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-md, 6px);
  }

  .changelog-empty-details summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--theme-primary);
  }

  .changelog-empty-details ul {
    margin-top: var(--spacing-2, 8px);
    padding-left: var(--spacing-4, 16px);
  }
</style>
