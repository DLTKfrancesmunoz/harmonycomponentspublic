---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
---

<DocsLayout title="Shell Footer" description="Bottom bar for workspace navigation.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Shell Footer</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Optional footer bar for workspace tabs, status indicators, or additional navigation.
      </p>
    </header>

    <CodeBlock 
      language="html"
      filename="footer.html"
      code={`<footer class="h-12 bg-white dark:bg-surface border-t border-slate-200 dark:border-border flex items-center px-4">
  <div class="flex items-center gap-4">
    <button class="text-xs text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white">
      Tab 1
    </button>
    <button class="text-xs text-theme-primary font-medium">
      Tab 2 (Active)
    </button>
    <button class="text-xs text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white">
      Tab 3
    </button>
  </div>
</footer>`}
    />
  </article>
</DocsLayout>

