---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Icon from '../../components/ui/Icon.astro';
---

<DocsLayout title="Shell Layout" description="Main application shell layout structure.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <h1 class="page-header__title page-header__title--sm">Shell Layout</h1>
      <p class="page-header__description">
        The shell layout provides the main structure for the application, including header, sidebar, and content areas.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="section__title">Layout Structure</h2>
      
      <ExampleSection title="Full Layout" description="Complete shell with all sections.">
        <div class="border rounded-lg overflow-hidden" style="height: 400px;">
          <div class="h-full flex flex-col">
            <!-- Header -->
            <div class="h-12 bg-nav border-b flex items-center px-4">
              <span class="text-sm text-primary font-medium">Header</span>
            </div>
            <!-- Content -->
            <div class="flex flex-1">
              <!-- Sidebar -->
              <div class="w-48 bg-nav border-r p-4">
                <span class="text-sm text-primary font-medium">Sidebar</span>
                <div class="mt-4 space-y-2">
                  <div class="h-6 bg-hover rounded"></div>
                  <div class="h-6 bg-hover rounded"></div>
                  <div class="h-6 bg-hover rounded"></div>
                </div>
              </div>
              <!-- Main Content -->
              <div class="flex-1 bg-page p-4">
                <span class="text-sm text-primary font-medium">Main Content</span>
                <div class="mt-4 grid grid-cols-2 gap-4">
                  <div class="h-24 bg-card rounded border"></div>
                  <div class="h-24 bg-card rounded border"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Layout Components</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <a href="/shell/header" class="nav-card">
          <div class="nav-card__icon-wrap">
            <Icon name="bars-3" size="sm" class="nav-card__icon" />
          </div>
          <span class="nav-card__title">Header</span>
        </a>
        <a href="/shell/left-sidebar" class="nav-card">
          <div class="nav-card__icon-wrap">
            <Icon name="squares-2x2" size="sm" class="nav-card__icon" />
          </div>
          <span class="nav-card__title">Left Sidebar</span>
        </a>
        <a href="/shell/page-content" class="nav-card">
          <div class="nav-card__icon-wrap">
            <i class="ti ti-layout-board nav-card__icon"></i>
          </div>
          <span class="nav-card__title">Page Content</span>
        </a>
        <a href="/shell/right-sidebar" class="nav-card">
          <div class="nav-card__icon-wrap">
            <Icon name="squares-2x2" size="sm" class="nav-card__icon" />
          </div>
          <span class="nav-card__title">Right Sidebar</span>
        </a>
        <a href="/shell/footer" class="nav-card">
          <div class="nav-card__icon-wrap">
            <i class="ti ti-layout-bottombar nav-card__icon"></i>
          </div>
          <span class="nav-card__title">Footer</span>
        </a>
      </div>
    </section>
  </article>
</DocsLayout>
