---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
---

<DocsLayout title="Page Content" description="Main content area structure and layouts.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Page Content</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        The main content area where page-specific content is rendered, with consistent padding and max-width constraints.
      </p>
    </header>

    <CodeBlock 
      language="html"
      filename="page-content.html"
      code={`<main class="flex-1 overflow-y-auto custom-scroll min-w-0 bg-white dark:bg-obsidian relative h-full">
  <div class="w-full px-6 md:px-12 py-12 max-w-5xl mx-auto">
    <!-- Page Header -->
    <header class="mb-12">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">
        Page Title
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400">
        Page description or subtitle.
      </p>
    </header>
    
    <!-- Page Content -->
    <section>
      <!-- Your content here -->
    </section>
  </div>
</main>`}
    />
  </article>
</DocsLayout>

