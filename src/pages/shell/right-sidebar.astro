---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
---

<DocsLayout title="Right Sidebar" description="Secondary panel for quick access and context.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Right Sidebar</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Optional secondary sidebar for contextual actions, details panels, or quick access features.
      </p>
    </header>

    <CodeBlock 
      language="html"
      filename="right-sidebar.html"
      code={`<aside class="w-64 border-l border-slate-200 dark:border-border bg-white dark:bg-surface hidden xl:flex flex-col h-full">
  <!-- Panel Header -->
  <div class="p-4 border-b border-slate-200 dark:border-border">
    <h3 class="font-semibold text-slate-900 dark:text-white">Details</h3>
  </div>
  
  <!-- Panel Content -->
  <div class="flex-1 overflow-y-auto custom-scroll p-4">
    <!-- Content goes here -->
  </div>
</aside>`}
    />
  </article>
</DocsLayout>

