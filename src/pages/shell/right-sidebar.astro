---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import CPRightSidebar from '../../components/ui/CPRightSidebar.astro';
---

<DocsLayout title="Right Sidebar" description="CP right navigation sidebar docked to the right edge of the screen.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Right Sidebar</h1>
        <span class="badge badge--primary">CP Shell</span>
      </div>
      <p class="page-header__description">
        A collapsible right navigation sidebar that is docked to the right edge of the screen. Shows only icons when collapsed, expands on hover to reveal text labels + icon.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="section__title">Live Demo</h2>
      
      <ExampleSection title="Right Sidebar - Collapsed/Expanded" description="Hover over the sidebar to see it expand with labels.">
        <div class="cp-sidebar-demo">
          <div class="cp-sidebar-demo__content">
            <p class="text-secondary text-sm">
              The right sidebar is docked to the right edge. Hover over it to see the expanded state with labels.
            </p>
            <p class="text-secondary text-sm mt-4">
              <strong>Section 1 - AI & Quick Actions:</strong>
            </p>
            <ul class="list-disc list-inside text-sm text-secondary mt-2 space-y-1">
              <li>Dela AI</li>
              <li>Notifications</li>
              <li>Files</li>
            </ul>
            <p class="text-secondary text-sm mt-4">
              <strong>Section 2 - Document Actions:</strong>
            </p>
            <ul class="list-disc list-inside text-sm text-secondary mt-2 space-y-1">
              <li>Print</li>
              <li>Layout Options</li>
            </ul>
            <p class="text-secondary text-sm mt-4">
              <strong>Section 3 - Settings & Help:</strong>
            </p>
            <ul class="list-disc list-inside text-sm text-secondary mt-2 space-y-1">
              <li>Microphone</li>
              <li>Offline</li>
              <li>Keyboard Shortcuts</li>
              <li>Help</li>
            </ul>
          </div>
          
          <div class="cp-sidebar-demo__sidebar">
            <CPRightSidebar />
          </div>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Behavior</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <div class="a11y-card">
          <h3 class="a11y-card__title">
            <i class="ti ti-arrows-horizontal a11y-card__title-icon"></i>
            Collapsible
          </h3>
          <p class="a11y-card__text">
            Collapsed by default showing only icons (~52px width). Expands on hover to reveal labels (~220px width).
          </p>
        </div>
        
        <div class="a11y-card">
          <h3 class="a11y-card__title">
            <i class="ti ti-layout-sidebar-right a11y-card__title-icon"></i>
            Fixed Position
          </h3>
          <p class="a11y-card__text">
            Docked to the right edge of the viewport, vertically centered. Stays in place while content scrolls.
          </p>
        </div>
        
        <div class="a11y-card">
          <h3 class="a11y-card__title">
            <i class="ti ti-category a11y-card__title-icon"></i>
            Three Sections
          </h3>
          <p class="a11y-card__text">
            Organized into three sections: AI/quick actions (3 items), document actions (2 items), settings/help (4 items).
          </p>
        </div>
        
        <div class="a11y-card">
          <h3 class="a11y-card__title">
            <i class="ti ti-sparkles a11y-card__title-icon"></i>
            Dela AI Integration
          </h3>
          <p class="a11y-card__text">
            Features the Dela AI logo as the primary action, providing quick access to AI assistance.
          </p>
        </div>
      </div>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Styling</h2>
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <i class="ti ti-palette a11y-card__title-icon"></i>
          Visual Properties
        </h3>
        <div class="a11y-card__text space-y-2">
          <ul class="list-disc list-inside space-y-1 text-sm">
            <li><strong>Background:</strong> <code>#fcfdff</code></li>
            <li><strong>Border:</strong> <code>#ffffff</code> (white)</li>
            <li><strong>Border Radius:</strong> 12px (top-left and bottom-left only)</li>
            <li><strong>Shadow:</strong> Multi-layered elevation shadow</li>
            <li><strong>Icon Color:</strong> <code>#373f4e</code></li>
            <li><strong>Hover Background:</strong> <code>rgba(55, 63, 78, 0.08)</code></li>
          </ul>
        </div>
      </div>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Accessibility</h2>
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <i class="ti ti-accessible a11y-card__title-icon"></i>
          Keyboard Navigation
        </h3>
        <p class="a11y-card__text">
          All navigation items are keyboard accessible. Use <kbd>Tab</kbd> to navigate between items and <kbd>Enter</kbd> to activate them.
        </p>
      </div>
    </section>
  </article>
</DocsLayout>
