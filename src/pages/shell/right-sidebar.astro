---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import RightSidebarComponent from '../../components/ui/RightSidebar.astro';
import Icon from '../../components/ui/Icon.astro';
---

<DocsLayout title="Right Sidebar" description="Unified right navigation sidebar that supports all themes (CP, VP, PPM, Maconomy). Docked to the right edge of the screen, shows only icons when collapsed, expands on hover to reveal text labels + icons. All themes start with the Dela logo (RS_DelaDefault.svg / RS_Dela_Active.svg).">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Right Sidebar</h1>
        <span class="badge badge--primary">Shell Component</span>
        <span class="badge badge--secondary">Theme Adaptive</span>
      </div>
      <p class="page-header__description">
        A unified collapsible right navigation sidebar that supports all Harmony themes. The sidebar adapts its icons and sections based on the theme variant. All themes include the Dela logo (RS_DelaDefault.svg default, RS_Dela_Active.svg when active) as the first icon, followed by theme-specific navigation items organized into three sections.
      </p>
    </header>

    <section class="space-y-6">
      <div>
        <h2 class="section__title">Live Demo</h2>
        <p class="text-secondary">
          Switch themes using the picker in the top header to see how the right sidebar adapts. The sidebar automatically shows the correct icons and sections based on the current theme. All themes start with the Dela logo (RS_DelaDefault.svg / RS_Dela_Active.svg).
        </p>
      </div>
      
      <ExampleSection title="Right Sidebar - Theme Adaptive" description="Hover over the sidebar to see it expand with labels. Switch themes to see different icon sets and section configurations.">
        <div class="cp-sidebar-demo">
          <div class="cp-sidebar-demo__content">
            <p class="text-secondary text-sm">
              The right sidebar is docked to the right edge. Hover over it to see the expanded state with labels.
            </p>
            <p class="text-secondary text-sm mt-4">
              <strong>CP Theme (3 sections):</strong>
            </p>
            <ul class="list-disc list-inside text-sm text-secondary mt-2 space-y-1">
              <li><strong>Section 1:</strong> Dela AI, Notifications, Files</li>
              <li><strong>Section 2:</strong> Print, Layout Options</li>
              <li><strong>Section 3:</strong> Microphone, Offline, Keyboard Shortcuts, Help</li>
            </ul>
            <p class="text-secondary text-sm mt-4">
              <strong>VP/PPM/Maconomy Themes (3 sections):</strong>
            </p>
            <ul class="list-disc list-inside text-sm text-secondary mt-2 space-y-1">
              <li><strong>Section 1:</strong> Dela AI (RS_DelaDefault.svg / RS_Dela_Active.svg), Edit, Search, Actions, Related, Templates, Upload, Download</li>
              <li><strong>Section 2:</strong> Notifications, Help, Share</li>
              <li><strong>Section 3:</strong> Accessibility, Language, Dark Mode</li>
            </ul>
          </div>
          
          <div class="cp-sidebar-demo__sidebar">
            <RightSidebarComponent variant="cp" />
          </div>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Behavior</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <div class="a11y-card">
          <h3 class="a11y-card__title">
            <Icon name="arrows-right-left" size="sm" class="a11y-card__title-icon" />
            Collapsible
          </h3>
          <p class="a11y-card__text">
            Collapsed by default showing only icons (~52px width). Expands on hover to reveal labels (~220px width).
          </p>
        </div>
        
        <div class="a11y-card">
          <h3 class="a11y-card__title">
            <Icon name="squares-2x2" size="sm" class="a11y-card__title-icon" />
            Fixed Position
          </h3>
          <p class="a11y-card__text">
            Docked to the right edge of the viewport, vertically centered. Stays in place while content scrolls.
          </p>
        </div>
        
        <div class="a11y-card">
          <h3 class="a11y-card__title">
            <Icon name="squares-plus" size="sm" class="a11y-card__title-icon" />
            Three Sections
          </h3>
          <p class="a11y-card__text">
            All themes organize items into three sections. CP theme has different items per section compared to VP/PPM/Maconomy themes.
          </p>
        </div>
        
        <div class="a11y-card">
          <h3 class="a11y-card__title">
            <Icon name="sparkles" size="sm" class="a11y-card__title-icon" />
            Dela AI Integration
          </h3>
          <p class="a11y-card__text">
            All themes feature the Dela logo (RS_DelaDefault.svg / RS_Dela_Active.svg) as the first icon, providing consistent access to AI assistance across all themes.
          </p>
        </div>
      </div>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Theme Variants</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <div class="a11y-card">
          <h3 class="a11y-card__title">
            <span class="badge badge--cp mr-2">CP</span>
            Costpoint Theme
          </h3>
          <div class="a11y-card__text space-y-2">
            <p class="text-sm"><strong>3 Sections:</strong></p>
            <ul class="list-disc list-inside space-y-1 text-sm">
              <li>AI & Quick Actions (Dela AI, Notifications, Files)</li>
              <li>Document Actions (Print, Layout Options)</li>
              <li>Settings & Help (Microphone, Offline, Keyboard Shortcuts, Help)</li>
            </ul>
          </div>
        </div>
        
        <div class="a11y-card">
          <h3 class="a11y-card__title">
            <span class="badge badge--ppm mr-2">PPM</span>
            PPM Theme
          </h3>
          <div class="a11y-card__text space-y-2">
            <p class="text-sm"><strong>3 Sections:</strong></p>
            <ul class="list-disc list-inside space-y-1 text-sm">
              <li>Actions (Dela AI, Edit, Search, Actions, Related, Templates, Upload, Download)</li>
              <li>Notifications & Help (Notifications, Help, Share)</li>
              <li>Settings (Accessibility, Language, Dark Mode)</li>
            </ul>
          </div>
        </div>
        
        <div class="a11y-card">
          <h3 class="a11y-card__title">
            <span class="badge badge--vp mr-2">VP</span>
            Vantagepoint Theme
          </h3>
          <div class="a11y-card__text space-y-2">
            <p class="text-sm"><strong>3 Sections:</strong></p>
            <ul class="list-disc list-inside space-y-1 text-sm">
              <li>Same structure as PPM theme</li>
              <li>All themes start with Dela logo (RS_DelaDefault.svg / RS_Dela_Active.svg)</li>
            </ul>
          </div>
        </div>
        
        <div class="a11y-card">
          <h3 class="a11y-card__title">
            <span class="badge badge--maconomy mr-2">Maconomy</span>
            Maconomy Theme
          </h3>
          <div class="a11y-card__text space-y-2">
            <p class="text-sm"><strong>3 Sections:</strong></p>
            <ul class="list-disc list-inside space-y-1 text-sm">
              <li>Same structure as PPM theme</li>
              <li>All themes start with Dela logo (RS_DelaDefault.svg / RS_Dela_Active.svg)</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Styling</h2>
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="paint-brush" size="sm" class="a11y-card__title-icon" />
          Visual Properties
        </h3>
        <div class="a11y-card__text space-y-2">
          <ul class="list-disc list-inside space-y-1 text-sm">
            <li><strong>Background:</strong> Uses theme-specific <code>--nav-bg</code> design token</li>
            <li><strong>Border:</strong> Uses theme-specific <code>--border-color</code> design token</li>
            <li><strong>Border Radius:</strong> 12px (top-left and bottom-left only)</li>
            <li><strong>Shadow:</strong> Multi-layered elevation shadow (theme-aware)</li>
            <li><strong>Icon Color:</strong> Uses theme-specific <code>--text-primary</code> design token</li>
            <li><strong>Hover Background:</strong> Uses theme-specific <code>--hover-bg</code> design token</li>
            <li><strong>Layout:</strong> Right-aligned (labels on left, icons on right)</li>
            <li><strong>Logo (RS_DelaDefault.svg / RS_Dela_Active.svg):</strong> 36px with 12px rounded corners, appears first in all themes. Default state uses RS_DelaDefault.svg; active state uses RS_Dela_Active.svg with gradient background (--linear-new), 12px radius.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Accessibility</h2>
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="hand-raised" size="sm" class="a11y-card__title-icon" />
          Keyboard Navigation
        </h3>
        <p class="a11y-card__text">
          All navigation items are keyboard accessible. Use <kbd>Tab</kbd> to navigate between items and <kbd>Enter</kbd> to activate them.
        </p>
      </div>
    </section>
  </article>
</DocsLayout>
