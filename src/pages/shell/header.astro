---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Shell Header" description="Top navigation bar with branding and user controls.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Shell Header</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        The header provides persistent navigation, branding, and access to user controls across all pages.
      </p>
    </header>

    <ExampleSection title="Header Example" description="Standard header layout with branding and actions.">
      <div class="border border-slate-200 dark:border-slate-800 rounded-lg overflow-hidden">
        <div class="h-14 bg-white dark:bg-surface border-b border-slate-200 dark:border-border flex items-center justify-between px-4">
          <!-- Left -->
          <div class="flex items-center gap-2">
            <div class="w-5 h-5 bg-theme-primary rounded-sm"></div>
            <span class="font-display font-bold text-sm text-slate-900 dark:text-white">BRAND</span>
          </div>
          <!-- Center -->
          <span class="text-xs text-slate-500 font-mono">App Name v1.0</span>
          <!-- Right -->
          <div class="flex items-center gap-2">
            <button class="w-8 h-8 flex items-center justify-center rounded hover:bg-slate-100 dark:hover:bg-white/5">
              <i class="ti ti-sun text-slate-600 dark:text-slate-400"></i>
            </button>
            <div class="w-6 h-6 rounded-full bg-slate-300 dark:bg-slate-700"></div>
          </div>
        </div>
      </div>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="header.html"
      code={`<header class="w-full h-14 bg-white dark:bg-surface border-b border-slate-200 dark:border-border flex items-center justify-between px-4 sm:px-6 relative z-50 shrink-0">
  <!-- Brand / Left -->
  <div class="flex items-center gap-4">
    <div class="flex items-center gap-2">
      <div class="w-5 h-5 bg-theme-primary rounded-sm"></div>
      <h1 class="font-display font-bold text-sm text-slate-900 dark:text-white">BRAND</h1>
    </div>
  </div>
  
  <!-- Center -->
  <div class="hidden md:flex">
    <span class="text-xs text-slate-500 font-mono">App Name v1.0</span>
  </div>
  
  <!-- Right Actions -->
  <div class="flex items-center gap-3">
    <button id="theme-toggle" class="w-8 h-8 flex items-center justify-center rounded hover:bg-slate-100 dark:hover:bg-white/5">
      <i class="ti ti-sun text-lg dark:hidden"></i>
      <i class="ti ti-moon text-lg hidden dark:inline-block"></i>
    </button>
    <div class="w-6 h-6 rounded-full bg-slate-300 dark:bg-slate-700"></div>
  </div>
</header>`}
    />
  </article>
</DocsLayout>

