---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Icon from '../../components/ui/Icon.astro';
---

<DocsLayout title="Header" description="Application header component.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <h1 class="page-header__title page-header__title--sm">Header</h1>
      <p class="page-header__description">
        The header provides navigation, branding, and global actions at the top of the application.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="section__title">Header Structure</h2>
      
      <ExampleSection title="Standard Header" description="Header with logo, navigation, and actions.">
        <div class="border rounded-lg overflow-hidden">
          <div class="h-14 bg-nav border-b flex items-center justify-between px-4">
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 bg-theme rounded-full"></div>
              <span class="text-sm font-medium text-primary">Application Name</span>
            </div>
            <div class="flex items-center gap-2">
              <button class="icon-btn"><Icon name="magnifying-glass" size="sm" class="icon-btn__icon" /></button>
              <button class="icon-btn"><Icon name="bell" size="sm" class="icon-btn__icon" /></button>
              <div class="w-8 h-8 bg-elevated rounded-full"></div>
            </div>
          </div>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Header Elements</h2>
      <div class="guidelines">
        <div class="guideline-card guideline-card--do">
          <h3 class="guideline-card__header"><Icon name="check" size="sm" /> Include</h3>
          <ul class="guideline-card__list">
            <li>• Logo or brand mark</li>
            <li>• Primary navigation</li>
            <li>• Search functionality</li>
            <li>• User menu / profile</li>
            <li>• Theme toggle</li>
          </ul>
        </div>
        <div class="guideline-card guideline-card--dont">
          <h3 class="guideline-card__header"><Icon name="x-mark" size="sm" /> Avoid</h3>
          <ul class="guideline-card__list">
            <li>• Too many action buttons</li>
            <li>• Long navigation lists</li>
            <li>• Excessive height</li>
            <li>• Distracting animations</li>
          </ul>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>
