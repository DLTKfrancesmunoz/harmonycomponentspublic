---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { elevations } from '../../tokens/index.ts';

// Build shadow data from tokens
const shadowData = Object.entries(elevations.shadows).map(([key, shadow]) => ({
  key,
  name: key === 'none' ? 'None' : key.charAt(0).toUpperCase() + key.slice(1),
  cssClass: shadow.cssClass,
  level: shadow.level,
  description: shadow.description,
  usage: shadow.usage || []
}));

// Sort shadows by level
shadowData.sort((a, b) => a.level - b.level);
---

<DocsLayout title="Elevations" description="Shadow system for creating depth and hierarchy.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <h1 class="page-header__title page-header__title--sm">Elevations</h1>
      <p class="page-header__description">
        A layered shadow system that creates depth and visual hierarchy in the interface.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="section__title">Shadow Scale</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {shadowData.map((shadow) => (
          <div class={`p-6 bg-card rounded-lg text-center ${shadow.cssClass === 'shadow-none' ? '' : shadow.cssClass}`}>
            <p class="text-sm font-medium text-primary mb-2">{shadow.name}</p>
            <p class="text-xs text-muted mb-2">{shadow.description}</p>
            {shadow.usage && shadow.usage.length > 0 && (
              <p class="text-xs text-secondary mt-1">
                {shadow.usage.join(', ')}
              </p>
            )}
            <p class="text-xs font-mono text-muted mt-2">{shadow.cssClass}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Elevation Hierarchy</h2>
      <div class="space-y-4">
        {elevations.hierarchy.map((level) => {
          const shadow = elevations.shadows[level.shadow as keyof typeof elevations.shadows];
          const shadowClass = shadow?.cssClass || 'shadow-none';
          return (
            <div class={`p-4 bg-card rounded-lg border ${shadowClass === 'shadow-none' ? 'bg-elevated' : ''}`}>
              <div class="flex items-center gap-3 mb-2">
                <span class="text-sm font-medium text-primary">Level {level.level}: {level.name}</span>
                <span class="badge badge--default">{shadowClass}</span>
              </div>
              <p class="text-sm text-secondary">{level.description}</p>
            </div>
          );
        })}
      </div>
    </section>
  </article>
</DocsLayout>
