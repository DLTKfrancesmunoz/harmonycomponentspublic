---
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout title="Elevations" description="Shadow system for creating depth and hierarchy.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <h1 class="page-header__title page-header__title--sm">Elevations</h1>
      <p class="page-header__description">
        A layered shadow system that creates depth and visual hierarchy in the interface.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="section__title">Shadow Scale</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="p-6 bg-card rounded-lg text-center">
          <p class="text-sm font-medium text-primary mb-2">None</p>
          <p class="text-xs text-muted">Ground level</p>
        </div>
        <div class="p-6 bg-card rounded-lg shadow-sm text-center">
          <p class="text-sm font-medium text-primary mb-2">Small</p>
          <p class="text-xs text-muted">Buttons, inputs</p>
        </div>
        <div class="p-6 bg-card rounded-lg shadow-md text-center">
          <p class="text-sm font-medium text-primary mb-2">Medium</p>
          <p class="text-xs text-muted">Floating menus</p>
        </div>
        <div class="p-6 bg-card rounded-lg shadow-lg text-center">
          <p class="text-sm font-medium text-primary mb-2">Large</p>
          <p class="text-xs text-muted">Modals, dialogs</p>
        </div>
        <div class="p-6 bg-card rounded-lg shadow-xl text-center">
          <p class="text-sm font-medium text-primary mb-2">Extra Large</p>
          <p class="text-xs text-muted">Focus elements</p>
        </div>
      </div>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Elevation Hierarchy</h2>
      <div class="space-y-4">
        <div class="p-4 bg-elevated rounded-lg border">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-sm font-medium text-primary">Level 0: Ground</span>
            <span class="badge badge--default">No shadow</span>
          </div>
          <p class="text-sm text-secondary">Page background, base surfaces</p>
        </div>
        <div class="p-4 bg-card rounded-lg shadow-sm border">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-sm font-medium text-primary">Level 1: Raised</span>
            <span class="badge badge--default">shadow-sm</span>
          </div>
          <p class="text-sm text-secondary">Cards, containers, buttons</p>
        </div>
        <div class="p-4 bg-card rounded-lg shadow-md border">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-sm font-medium text-primary">Level 2: Floating</span>
            <span class="badge badge--default">shadow-md</span>
          </div>
          <p class="text-sm text-secondary">Dropdowns, menus, popovers</p>
        </div>
        <div class="p-4 bg-card rounded-lg shadow-lg border">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-sm font-medium text-primary">Level 3: Overlay</span>
            <span class="badge badge--default">shadow-lg</span>
          </div>
          <p class="text-sm text-secondary">Modals, dialogs</p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>
