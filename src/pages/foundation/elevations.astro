---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const elevations = [
  { 
    name: 'shadow-sm', 
    description: 'Subtle elevation for buttons and small elements',
    css: '0 1px 2px 0 rgb(15 23 42 / 0.05)',
    usage: 'Buttons, inputs, small cards'
  },
  { 
    name: 'shadow', 
    description: 'Default elevation for cards and containers',
    css: '0 1px 3px 0 rgb(15 23 42 / 0.1), 0 1px 2px -1px rgb(15 23 42 / 0.1)',
    usage: 'Cards, dropdowns, tooltips'
  },
  { 
    name: 'shadow-md', 
    description: 'Medium elevation for floating elements',
    css: '0 4px 6px -1px rgb(15 23 42 / 0.1), 0 2px 4px -2px rgb(15 23 42 / 0.1)',
    usage: 'Floating menus, popovers'
  },
  { 
    name: 'shadow-lg', 
    description: 'High elevation for prominent elements',
    css: '0 10px 15px -3px rgb(15 23 42 / 0.1), 0 4px 6px -4px rgb(15 23 42 / 0.1)',
    usage: 'Modals, dialogs, notifications'
  },
  { 
    name: 'shadow-xl', 
    description: 'Extra high elevation for overlays',
    css: '0 20px 25px -5px rgb(15 23 42 / 0.1), 0 8px 10px -6px rgb(15 23 42 / 0.1)',
    usage: 'Full-screen modals, image lightboxes'
  },
  { 
    name: 'shadow-2xl', 
    description: 'Maximum elevation for dramatic effect',
    css: '0 25px 50px -12px rgb(15 23 42 / 0.25)',
    usage: 'Hero images, featured content'
  },
];

const borderStyles = [
  { name: 'border', class: 'border border-slate-200 dark:border-slate-800', description: 'Standard border for cards and containers' },
  { name: 'border-2', class: 'border-2 border-slate-200 dark:border-slate-800', description: 'Thicker border for emphasis' },
  { name: 'ring-1', class: 'ring-1 ring-slate-200 dark:ring-slate-800', description: 'Focus ring style border' },
  { name: 'ring-2', class: 'ring-2 ring-theme-primary', description: 'Focus state indicator' },
];
---

<DocsLayout title="Elevations" description="Shadow system for depth and visual hierarchy.">
  <article class="space-y-12">
    <!-- Header -->
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Elevations</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        A layered shadow system that creates depth and visual hierarchy, helping users understand 
        the relationship between UI elements.
      </p>
    </header>

    <!-- Shadow Scale -->
    <section>
      <h2 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Shadow Scale</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {elevations.map((item) => (
          <div class="space-y-4">
            <div class={`h-32 rounded-xl bg-white dark:bg-charcoal ${item.name} flex items-center justify-center`}>
              <code class="text-sm text-slate-600 dark:text-slate-400">{item.name}</code>
            </div>
            <div>
              <h3 class="font-medium text-slate-900 dark:text-white text-sm mb-1">{item.description}</h3>
              <p class="text-xs text-slate-500">{item.usage}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Shadow in Context -->
    <section>
      <h2 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Shadows in Context</h2>
      <div class="p-8 rounded-lg bg-slate-100 dark:bg-surface border border-slate-200 dark:border-slate-800">
        <div class="relative">
          <!-- Base layer -->
          <div class="bg-white dark:bg-charcoal rounded-lg p-6 shadow-sm mb-4">
            <div class="text-sm text-slate-600 dark:text-slate-400">Base content layer</div>
          </div>
          
          <!-- Elevated card -->
          <div class="bg-white dark:bg-charcoal rounded-lg p-6 shadow-md mb-4">
            <div class="text-sm text-slate-600 dark:text-slate-400">Elevated card</div>
          </div>
          
          <!-- Floating element -->
          <div class="absolute top-4 right-4 bg-white dark:bg-charcoal rounded-lg p-4 shadow-xl">
            <div class="text-sm text-slate-600 dark:text-slate-400">Floating element</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Border Styles -->
    <section>
      <h2 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Border Alternatives</h2>
      <p class="text-slate-600 dark:text-slate-400 mb-6">
        In dark themes, subtle borders often work better than shadows for creating separation.
      </p>
      <div class="grid md:grid-cols-2 gap-6">
        {borderStyles.map((item) => (
          <div class="space-y-3">
            <div class={`h-24 rounded-lg bg-white dark:bg-charcoal ${item.class} flex items-center justify-center`}>
              <code class="text-sm text-slate-600 dark:text-slate-400">{item.name}</code>
            </div>
            <p class="text-sm text-slate-500">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Elevation Hierarchy -->
    <section>
      <h2 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Elevation Hierarchy</h2>
      <div class="p-6 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <div class="w-8 h-8 bg-slate-200 dark:bg-slate-800 rounded flex items-center justify-center text-xs font-mono">0</div>
            <div class="flex-1">
              <div class="font-medium text-slate-900 dark:text-white">Ground Level</div>
              <div class="text-sm text-slate-500">Page background, no shadow</div>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-8 h-8 bg-white dark:bg-charcoal shadow-sm rounded flex items-center justify-center text-xs font-mono">1</div>
            <div class="flex-1">
              <div class="font-medium text-slate-900 dark:text-white">Raised</div>
              <div class="text-sm text-slate-500">Cards, containers, buttons (shadow-sm)</div>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-8 h-8 bg-white dark:bg-charcoal shadow-md rounded flex items-center justify-center text-xs font-mono">2</div>
            <div class="flex-1">
              <div class="font-medium text-slate-900 dark:text-white">Floating</div>
              <div class="text-sm text-slate-500">Dropdowns, menus, popovers (shadow-md)</div>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-8 h-8 bg-white dark:bg-charcoal shadow-lg rounded flex items-center justify-center text-xs font-mono">3</div>
            <div class="flex-1">
              <div class="font-medium text-slate-900 dark:text-white">Overlay</div>
              <div class="text-sm text-slate-500">Modals, dialogs (shadow-lg)</div>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-8 h-8 bg-white dark:bg-charcoal shadow-xl rounded flex items-center justify-center text-xs font-mono">4</div>
            <div class="flex-1">
              <div class="font-medium text-slate-900 dark:text-white">Prominent</div>
              <div class="text-sm text-slate-500">Focus elements, highlighted content (shadow-xl)</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Code Usage -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Code Usage</h2>
      <CodeBlock 
        language="html"
        filename="elevations.html"
        code={`<!-- Shadow utilities -->
<div class="shadow-sm">Subtle shadow</div>
<div class="shadow">Default shadow</div>
<div class="shadow-md">Medium shadow</div>
<div class="shadow-lg">Large shadow</div>
<div class="shadow-xl">Extra large shadow</div>

<!-- Combining with borders -->
<div class="border border-slate-200 dark:border-slate-800 shadow-sm">
  Card with border and shadow
</div>

<!-- Focus ring -->
<button class="focus:ring-2 focus:ring-theme-primary focus:ring-offset-2">
  Button with focus ring
</button>

<!-- Hover elevation change -->
<div class="shadow-sm hover:shadow-md transition-shadow">
  Card with hover elevation
</div>`}
      />
    </section>

    <!-- Guidelines -->
    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2">
            <i class="ti ti-check"></i> Do
          </h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use shadows to indicate interaction hierarchy</li>
            <li>• Increase elevation for overlapping elements</li>
            <li>• Combine borders with shadows in dark themes</li>
            <li>• Animate shadow changes on hover/focus</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2">
            <i class="ti ti-x"></i> Don't
          </h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Overuse large shadows (visual noise)</li>
            <li>• Skip elevation levels inconsistently</li>
            <li>• Use shadows without purpose</li>
            <li>• Rely only on shadows in dark themes</li>
          </ul>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>

