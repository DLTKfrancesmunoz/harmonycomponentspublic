---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import Icon from '../../components/ui/Icon.astro';
import { typography } from '../../tokens/index.ts';

// Helper function to get font family name
function getFontFamilyName(fontFamilyKey: string): string {
  const fontMap: Record<string, string> = {
    'display': 'Lexend',
    'sans': 'Figtree',
    'mono': 'JetBrains Mono'
  };
  return fontMap[fontFamilyKey] || fontFamilyKey;
}

// Helper function to get font weight display value
function getFontWeightDisplay(weightKey: string): string {
  const weightMap: Record<string, string> = {
    'light': 'Light (300)',
    'normal': 'Normal (400)',
    'medium': 'Medium (500)',
    'semibold': 'Semibold (600)',
    'bold': 'Bold (700)',
    'extrabold': 'Extrabold (800)'
  };
  return weightMap[weightKey] || weightKey;
}

// Helper function to get line height display value
function getLineHeightDisplay(lineHeightKey: string): string {
  const lineHeightMap: Record<string, string> = {
    'none': '1',
    'tight': '1.25',
    'snug': '1.375',
    'normal': '1.5',
    'relaxed': '1.625',
    'loose': '2'
  };
  return lineHeightMap[lineHeightKey] || lineHeightKey;
}

// Convert fontSize rem to pixels
function remToPixels(rem: string): string {
  const remValue = parseFloat(rem);
  const pixels = remValue * 16;
  return `${pixels}px`;
}

// Build text styles data for the table
const textStylesData = Object.entries(typography.textStyles).map(([key, style]) => {
  const fontSizeRem = style.fontSize;
  const fontSizePx = remToPixels(fontSizeRem);
  
  // Format name: displayXL -> Display XL, headingL -> Heading L, bodyDefault -> Body Default
  const formattedName = key
    .replace(/([A-Z])/g, ' $1')
    .split(' ')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
    .join(' ');
  
  return {
    name: formattedName,
    cssClass: style.cssClass,
    size: `${fontSizePx} / ${fontSizeRem}`,
    weight: getFontWeightDisplay(style.fontWeight),
    lineHeight: getLineHeightDisplay(style.lineHeight),
    font: getFontFamilyName(style.fontFamily)
  };
});
---

<DocsLayout title="Typography" description="Typography system with Display, Heading, Body, and supporting text styles.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <h1 class="page-header__title page-header__title--sm">Typography</h1>
      <p class="page-header__description">
        A comprehensive typography system based on roles and scale, not HTML tags. 
        Display styles for hero content, Headings for hierarchy, Body for content, and supporting styles for labels and captions.
      </p>
    </header>

    <nav class="article-nav">
      <a href="#display" class="article-nav__link"><i class="ti ti-typography"></i> Display</a>
      <a href="#headings" class="article-nav__link"><i class="ti ti-heading"></i> Headings</a>
      <a href="#body" class="article-nav__link"><i class="ti ti-align-left"></i> Body</a>
      <a href="#supporting" class="article-nav__link"><i class="ti ti-tag"></i> Supporting</a>
      <a href="#fonts" class="article-nav__link"><i class="ti ti-text-size"></i> Fonts</a>
    </nav>

    <!-- Display Scale -->
    <section id="display" class="space-y-8">
      <h2 class="section__title">Display</h2>
      <p class="text-secondary text-sm">Large, bold text for hero sections, marketing headlines, and high-impact moments.</p>

      <ExampleSection title="Display XL" description="60px / 3.75rem - Hero headlines, landing pages">
        <p class="text-display-xl text-primary">The quick brown fox</p>
      </ExampleSection>

      <ExampleSection title="Display L" description="48px / 3rem - Section heroes, major announcements">
        <p class="text-display-l text-primary">The quick brown fox jumps</p>
      </ExampleSection>

      <ExampleSection title="Display M" description="36px / 2.25rem - Feature highlights, card heroes">
        <p class="text-display-m text-primary">The quick brown fox jumps over</p>
      </ExampleSection>
    </section>

    <!-- Headings Scale -->
    <section id="headings" class="space-y-8">
      <h2 class="section__title">Headings</h2>
      <p class="text-secondary text-sm">Semantic hierarchy for page structure. Use based on content importance, not visual size.</p>

      <ExampleSection title="Heading XL" description="30px / 1.875rem - Page titles, primary sections">
        <p class="text-heading-xl text-primary">Heading Extra Large</p>
      </ExampleSection>

      <ExampleSection title="Heading L" description="24px / 1.5rem - Major sections, card titles">
        <p class="text-heading-l text-primary">Heading Large</p>
      </ExampleSection>

      <ExampleSection title="Heading M" description="20px / 1.25rem - Subsections, modal titles">
        <p class="text-heading-m text-primary">Heading Medium</p>
      </ExampleSection>

      <ExampleSection title="Heading S" description="18px / 1.125rem - Minor sections, group labels">
        <p class="text-heading-s text-primary">Heading Small</p>
      </ExampleSection>
    </section>

    <!-- Body Scale -->
    <section id="body" class="space-y-8">
      <h2 class="section__title">Body</h2>
      <p class="text-secondary text-sm">Primary content text for readability and comprehension.</p>

      <ExampleSection title="Body Default" description="16px / 1rem - Primary content, paragraphs">
        <p class="text-body-default text-secondary">
          The quick brown fox jumps over the lazy dog. This is standard body text used for 
          paragraphs, descriptions, and general content throughout the interface. It's optimized 
          for readability at various screen sizes.
        </p>
      </ExampleSection>

      <ExampleSection title="Body Emphasized" description="16px / 1rem (semibold) - Important content, lead paragraphs">
        <p class="text-body-emphasized text-primary">
          The quick brown fox jumps over the lazy dog. This emphasized body text draws attention 
          to key information while maintaining readability for longer passages.
        </p>
      </ExampleSection>
    </section>

    <!-- Supporting Scale -->
    <section id="supporting" class="space-y-8">
      <h2 class="section__title">Supporting Styles</h2>
      <p class="text-secondary text-sm">Smaller text for labels, captions, and supplementary information.</p>

      <ExampleSection title="Label" description="14px / 0.875rem - Form labels, navigation items">
        <p class="text-label text-primary">Form Field Label</p>
      </ExampleSection>

      <ExampleSection title="Caption" description="12px / 0.75rem - Help text, timestamps, metadata">
        <p class="text-caption text-muted">Last updated 2 hours ago • 5 min read</p>
      </ExampleSection>

      <ExampleSection title="Overline" description="10px / 0.625rem - Category tags, section labels">
        <p class="text-overline text-muted">FEATURED ARTICLE</p>
      </ExampleSection>
    </section>

    <!-- Font Families -->
    <section id="fonts" class="space-y-8">
      <h2 class="section__title">Font Families</h2>

      <ExampleSection title="Lexend (Display)" description="Used for Display and Heading styles">
        <div class="space-y-3">
          <p class="font-display text-2xl font-bold text-primary">ABCDEFGHIJKLMNOPQRSTUVWXYZ</p>
          <p class="font-display text-2xl font-bold text-primary">abcdefghijklmnopqrstuvwxyz</p>
          <p class="font-display text-2xl font-bold text-primary">0123456789</p>
        </div>
      </ExampleSection>

      <ExampleSection title="Figtree (Body)" description="Used for Body text and UI elements">
        <div class="space-y-3">
          <p class="font-sans text-lg text-primary">ABCDEFGHIJKLMNOPQRSTUVWXYZ</p>
          <p class="font-sans text-lg text-primary">abcdefghijklmnopqrstuvwxyz</p>
          <p class="font-sans text-lg text-primary">0123456789</p>
        </div>
      </ExampleSection>

      <ExampleSection title="JetBrains Mono (Code)" description="Used for code and technical content">
        <div class="space-y-3">
          <code class="font-mono text-sm text-primary">const greeting = "Hello, World!";</code>
          <pre class="font-mono text-sm bg-elevated p-4 rounded-lg overflow-x-auto text-primary">function example() {'{'}
  return true;
{'}'}</pre>
        </div>
      </ExampleSection>
    </section>

    <!-- Type Scale Reference -->
    <section class="space-y-6">
      <h2 class="section__title">Type Scale Reference</h2>
      <div class="card">
        <div class="card__body">
          <table class="props-table">
            <thead>
              <tr>
                <th>Style</th>
                <th>Size</th>
                <th>Weight</th>
                <th>Line Height</th>
                <th>Font</th>
              </tr>
            </thead>
            <tbody>
              {textStylesData.map((style) => (
                <tr>
                  <td><code>{style.cssClass}</code></td>
                  <td>{style.size}</td>
                  <td>{style.weight}</td>
                  <td>{style.lineHeight}</td>
                  <td>{style.font}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Usage Guidelines -->
    <section class="space-y-4">
      <h2 class="section__title">Usage Guidelines</h2>
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <i class="ti ti-bulb a11y-card__title-icon"></i>
          Separate Visuals from Semantics
        </h3>
        <p class="a11y-card__text">
          Choose text styles based on their visual role (Display, Heading, Body), not HTML tags. 
          A dashboard title might be the semantic H1 but use Heading M visually. A hero headline 
          might use Display XL but be an H2 semantically.
        </p>
      </div>
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="hand-raised" size="sm" class="a11y-card__title-icon" />
          Accessibility
        </h3>
        <p class="a11y-card__text">
          Ensure proper heading hierarchy in HTML (H1 → H2 → H3) regardless of visual styling. 
          Screen readers navigate by heading structure, not visual appearance.
        </p>
      </div>
    </section>
  </article>
</DocsLayout>
