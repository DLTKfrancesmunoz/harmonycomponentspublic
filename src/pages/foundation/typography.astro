---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const typeScale = [
  { name: 'text-xs', size: '12px', lineHeight: '16px', example: 'Caption text, labels' },
  { name: 'text-sm', size: '14px', lineHeight: '20px', example: 'Secondary text, descriptions' },
  { name: 'text-base', size: '16px', lineHeight: '24px', example: 'Body text, paragraphs' },
  { name: 'text-lg', size: '18px', lineHeight: '28px', example: 'Lead paragraphs' },
  { name: 'text-xl', size: '20px', lineHeight: '28px', example: 'Section headers' },
  { name: 'text-2xl', size: '24px', lineHeight: '32px', example: 'Card titles' },
  { name: 'text-3xl', size: '30px', lineHeight: '36px', example: 'Page section headers' },
  { name: 'text-4xl', size: '36px', lineHeight: '40px', example: 'Page titles' },
  { name: 'text-5xl', size: '48px', lineHeight: '48px', example: 'Hero titles' },
];

const fontWeights = [
  { name: 'font-normal', weight: '400', usage: 'Body text, paragraphs' },
  { name: 'font-medium', weight: '500', usage: 'Subtle emphasis, labels' },
  { name: 'font-semibold', weight: '600', usage: 'Headings, important text' },
  { name: 'font-bold', weight: '700', usage: 'Strong emphasis, titles' },
  { name: 'font-extrabold', weight: '800', usage: 'Display headings' },
];
---

<DocsLayout title="Typography" description="Font families, type scale, and text styling guidelines.">
  <article class="space-y-12">
    <!-- Header -->
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Typography</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        A typographic system built on Lexend for display text and Figtree for body copy, 
        providing excellent readability across all screen sizes.
      </p>
    </header>

    <!-- Font Families -->
    <section>
      <h2 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Font Families</h2>
      <div class="space-y-8">
        <div class="p-8 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <div class="text-xs font-mono text-slate-500 dark:text-slate-400 mb-3">Display (Lexend)</div>
          <div class="font-display text-4xl font-bold text-slate-900 dark:text-white">
            The quick brown fox jumps
          </div>
          <p class="mt-4 text-sm text-slate-600 dark:text-slate-400">
            Used for headings, titles, and display text. Lexend is optimized for reading proficiency and provides 
            excellent legibility at large sizes.
          </p>
          <div class="mt-4 flex flex-wrap gap-6">
            <div>
              <div class="text-xs text-slate-500 mb-1">Class</div>
              <code class="text-sm bg-slate-200 dark:bg-slate-800 px-2 py-1 rounded">font-display</code>
            </div>
            <div>
              <div class="text-xs text-slate-500 mb-1">Font Stack</div>
              <code class="text-sm bg-slate-200 dark:bg-slate-800 px-2 py-1 rounded">Lexend, sans-serif</code>
            </div>
          </div>
        </div>
        
        <div class="p-8 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <div class="text-xs font-mono text-slate-500 dark:text-slate-400 mb-3">Body (Figtree)</div>
          <div class="text-xl text-slate-900 dark:text-white">
            The quick brown fox jumps over the lazy dog. Pack my box with five dozen liquor jugs.
          </div>
          <p class="mt-4 text-sm text-slate-600 dark:text-slate-400">
            Used for body text, paragraphs, and UI elements. Figtree is a geometric sans-serif with excellent 
            readability at small sizes.
          </p>
          <div class="mt-4 flex flex-wrap gap-6">
            <div>
              <div class="text-xs text-slate-500 mb-1">Class</div>
              <code class="text-sm bg-slate-200 dark:bg-slate-800 px-2 py-1 rounded">font-sans</code>
            </div>
            <div>
              <div class="text-xs text-slate-500 mb-1">Font Stack</div>
              <code class="text-sm bg-slate-200 dark:bg-slate-800 px-2 py-1 rounded">Figtree, sans-serif</code>
            </div>
          </div>
        </div>

        <div class="p-8 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <div class="text-xs font-mono text-slate-500 dark:text-slate-400 mb-3">Monospace (JetBrains Mono)</div>
          <div class="font-mono text-lg text-slate-900 dark:text-white">
            const greeting = "Hello, World!";
          </div>
          <p class="mt-4 text-sm text-slate-600 dark:text-slate-400">
            Used for code snippets, technical values, and data displays. JetBrains Mono is designed specifically 
            for developers with excellent character distinction.
          </p>
          <div class="mt-4 flex flex-wrap gap-6">
            <div>
              <div class="text-xs text-slate-500 mb-1">Class</div>
              <code class="text-sm bg-slate-200 dark:bg-slate-800 px-2 py-1 rounded">font-mono</code>
            </div>
            <div>
              <div class="text-xs text-slate-500 mb-1">Font Stack</div>
              <code class="text-sm bg-slate-200 dark:bg-slate-800 px-2 py-1 rounded">JetBrains Mono, monospace</code>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Type Scale -->
    <section>
      <h2 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Type Scale</h2>
      <div class="space-y-4">
        {typeScale.map((item) => (
          <div class="flex items-baseline gap-4 p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/30">
            <div class="w-20 shrink-0">
              <code class="text-xs text-theme-primary">{item.name}</code>
            </div>
            <div class="w-24 shrink-0 text-xs text-slate-500">{item.size} / {item.lineHeight}</div>
            <div class={`${item.name} text-slate-900 dark:text-white`}>
              The quick brown fox
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Font Weights -->
    <section>
      <h2 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Font Weights</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {fontWeights.map((item) => (
          <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/30">
            <div class={`text-2xl text-slate-900 dark:text-white mb-2 ${item.name}`}>
              {item.name.replace('font-', '').charAt(0).toUpperCase() + item.name.replace('font-', '').slice(1)}
            </div>
            <div class="flex gap-4 text-xs">
              <span class="text-slate-500">Weight: {item.weight}</span>
              <span class="text-slate-400">{item.usage}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Code Usage -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Code Usage</h2>
      <CodeBlock 
        language="html"
        filename="typography.html"
        code={`<!-- Display text -->
<h1 class="font-display text-4xl font-bold">Page Title</h1>

<!-- Body text -->
<p class="text-base text-slate-600 dark:text-slate-400">
  Body paragraph with default font family.
</p>

<!-- Monospace for code -->
<code class="font-mono text-sm">const value = 42;</code>

<!-- Combining size and weight -->
<h2 class="text-2xl font-semibold">Section Header</h2>
<p class="text-sm font-medium">Label text</p>`}
      />
    </section>

    <!-- Usage Guidelines -->
    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2">
            <i class="ti ti-check"></i> Do
          </h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use <code>font-display</code> for headlines and titles</li>
            <li>• Maintain hierarchy with consistent size jumps</li>
            <li>• Use appropriate line heights for readability</li>
            <li>• Keep body text between 14-18px for comfort</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2">
            <i class="ti ti-x"></i> Don't
          </h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Mix too many type sizes on one page</li>
            <li>• Use display font for long paragraphs</li>
            <li>• Go below 12px for readable text</li>
            <li>• Skip heading levels (h1 → h3)</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Accessibility -->
    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-typography text-theme-primary"></i>
            Minimum Font Sizes
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Body text should be at least 16px (1rem) for optimal readability. Small text (12-14px) should be 
            used sparingly for captions and metadata only.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-line-height text-theme-primary"></i>
            Line Height & Spacing
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Adequate line height (1.5 for body text) and paragraph spacing improves readability for users 
            with dyslexia and cognitive disabilities.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>

