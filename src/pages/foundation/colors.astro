---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import Icon from '../../components/ui/Icon.astro';
import { colors } from '../../tokens/index.ts';

// Helper function to format color names (camelCase to Title Case)
function formatColorName(key: string): string {
  return key
    .replace(/([A-Z])/g, ' $1') // Add space before capitals
    .replace(/^./, str => str.toUpperCase()) // Capitalize first letter
    .trim();
}

// Metadata for color descriptions and CSS variable names
const colorMetadata: Record<string, { usage: string, cssVar: string }> = {
  link: { usage: 'Text links', cssVar: '--link-color' },
  pageBackground: { usage: 'Main page background', cssVar: '--page-bg' },
  cellBackground: { usage: 'Table cells, content areas', cssVar: '--surface-bg' },
  cardBackground: { usage: 'Cards, containers', cssVar: '--card-bg' },
  navBackground: { usage: 'Sidebar, header, navigation', cssVar: '--nav-bg' },
  inputBackground: { usage: 'Input fields', cssVar: '--input-bg' },
  inputDisabled: { usage: 'Disabled inputs, dimmed cells', cssVar: '--input-disabled-bg' },
  tableTotal: { usage: 'Table totals, summary rows', cssVar: '--table-total-bg' },
  border: { usage: 'Borders, dividers', cssVar: '--border-color' },
  hover: { usage: 'Hover states', cssVar: '--hover-bg' },
  titleText: { usage: 'Primary text, titles', cssVar: '--text-primary' },
  secondaryText: { usage: 'Secondary text, labels', cssVar: '--text-secondary' },
  mutedText: { usage: 'Muted text, placeholders', cssVar: '--text-muted' }
};

// Dynamically generate semi-light colors from CP light palette (auto-pulls from tokens)
const semiLightColors = Object.entries(colors.themes.cp.palette.light).map(([key, value]) => ({
  key,
  name: formatColorName(key),
  value,
  usage: colorMetadata[key]?.usage || '',
  cssVar: colorMetadata[key]?.cssVar || ''
}));

// Dynamically generate CP semi-dark colors from CP dark palette (auto-pulls from tokens)
const cpSemiDarkColors = Object.entries(colors.themes.cp.palette.dark).map(([key, value]) => ({
  key,
  name: formatColorName(key),
  value,
  usage: colorMetadata[key]?.usage || '',
  cssVar: colorMetadata[key]?.cssVar || ''
}));

// Dynamically generate VP/PPM/Maconomy dark colors (they all use the same dark palette)
const vpPpmMaconomyDarkColors = Object.entries(colors.themes.vp.palette.dark).map(([key, value]) => ({
  key,
  name: formatColorName(key),
  value,
  usage: colorMetadata[key]?.usage || '',
  cssVar: colorMetadata[key]?.cssVar || ''
}));

// Semantic colors - will be updated dynamically based on theme mode
const semanticColorKeys = ['success', 'warning', 'error', 'info'] as const;
const getSemanticColors = (isDark: boolean) => {
  return semanticColorKeys.map(key => ({
    name: key.charAt(0).toUpperCase() + key.slice(1),
    value: isDark ? colors.semantic[key].dark : colors.semantic[key].light,
    usage: colors.semantic[key].description,
    cssVar: `--color-${key}`
  }));
};
---

<DocsLayout title="Colors" description="The foundational color palette for the design system.">
  <article class="space-y-12">
    <!-- Header -->
    <header class="page-header page-header--compact">
      <h1 class="page-header__title page-header__title--sm">Color System</h1>
      <p class="page-header__description">
        A comprehensive color palette designed for both dark and light themes, with semantic colors for consistent communication.
      </p>
      <!-- Theme indicator -->
      <div id="theme-indicator" class="mt-4 badge badge--default">
        <span id="indicator-dark" class="hidden items-center gap-2">
          <Icon name="moon" size="sm" /> <span id="dark-mode-label">Showing Dark Mode Colors</span>
        </span>
        <span id="indicator-light" class="flex items-center gap-2">
          <Icon name="sun" size="sm" /> <span id="light-mode-label">Showing Light Mode Colors</span>
        </span>
      </div>
    </header>

    <!-- SEMI-LIGHT COLORS (All themes) -->
    <section id="semi-light-palette">
      <h2 class="text-sm font-mono text-muted uppercase tracking-widest mb-6">Semi-Light Palette</h2>
      <p id="semi-light-description" class="text-sm text-secondary mb-6">
        Used by all themes (CP, VP, PPM, Maconomy) in light mode.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {semiLightColors.map((color, index) => (
          <div class="space-y-3" data-color-key={color.key}>
            <div class="h-20 rounded-lg border semi-light-swatch"
                 data-css-var={color.cssVar}
                 data-color-key={color.key}
                 style={`background-color: ${color.value}; border-color: var(--border-color);`}></div>
            <div>
              <div class="text-sm font-medium text-primary">{color.name}</div>
              <div class="text-xs font-mono text-muted semi-light-value">{color.value}</div>
            </div>
            <p class="text-xs text-secondary">{color.usage}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CP SEMI-DARK COLORS (CP dark mode only) -->
    <section id="cp-semi-dark-palette" class="hidden">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-sm font-mono text-muted uppercase tracking-widest">CP Semi-Dark Palette</h2>
        <span class="badge badge--primary">CP Dark Mode Only</span>
      </div>
      <p class="text-sm text-secondary mb-6">
        Used by CP theme in dark mode.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {cpSemiDarkColors.map((color, index) => (
          <div class="space-y-3" data-color-key={color.key}>
            <div class="h-20 rounded-lg border cp-dark-swatch"
                 data-css-var={color.cssVar}
                 data-color-key={color.key}
                 style={`background-color: ${color.value}; border-color: var(--border-color);`}></div>
            <div>
              <div class="text-sm font-medium text-primary">{color.name}</div>
              <div class="text-xs font-mono text-muted cp-dark-value">{color.value}</div>
            </div>
            <p class="text-xs text-secondary">{color.usage}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- VP/PPM/MACONOMY DARK COLORS (VP, PPM, Maconomy dark mode) -->
    <section id="vp-ppm-maconomy-dark-palette" class="hidden">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-sm font-mono text-muted uppercase tracking-widest">Dark Mode Palette</h2>
        <span class="badge badge--primary">VP, PPM, Maconomy Dark Mode</span>
      </div>
      <p class="text-sm text-secondary mb-6">
        Used by VP, PPM, and Maconomy themes in dark mode.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {vpPpmMaconomyDarkColors.map((color, index) => (
          <div class="space-y-3" data-color-key={color.key}>
            <div class="h-20 rounded-lg border vp-ppm-maconomy-dark-swatch"
                 data-css-var={color.cssVar}
                 data-color-key={color.key}
                 style={`background-color: ${color.value}; border-color: var(--border-color);`}></div>
            <div>
              <div class="text-sm font-medium text-primary">{color.name}</div>
              <div class="text-xs font-mono text-muted vp-ppm-maconomy-dark-value">{color.value}</div>
            </div>
            <p class="text-xs text-secondary">{color.usage}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- SHARED: Semantic Colors -->
    <section id="semantic-colors-section">
      <h2 class="text-sm font-mono text-muted uppercase tracking-widest mb-6">Semantic Colors</h2>
      <p class="text-sm text-secondary mb-6">
        These colors adapt to light and dark modes for optimal contrast and meaning.
      </p>
      <div id="semantic-colors-grid" class="grid grid-cols-4 gap-4">
        {getSemanticColors(false).map((color) => (
          <div class="space-y-3" data-semantic={color.name.toLowerCase()}>
            <div class="h-20 rounded-lg border"
                 data-css-var={color.cssVar}
                 style={`background-color: ${color.value}; border-color: var(--border-color);`}></div>
            <div>
              <div class="text-sm font-medium text-primary">{color.name}</div>
              <div class="text-xs font-mono text-muted semantic-color-value">{color.value}</div>
            </div>
            <p class="text-xs text-secondary">{color.usage}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- SHARED: Accent Colors -->
    <section>
      <h2 class="text-sm font-mono text-muted uppercase tracking-widest mb-6">Accent Colors</h2>
      <div class="grid grid-cols-2 md:grid-cols-2 gap-4">
        <!-- Theme Primary -->
        <div class="space-y-3">
          <div class="h-20 rounded-lg border bg-theme" style="border-color: var(--border-color);"></div>
          <div>
            <div class="text-sm font-medium text-primary">Theme Primary</div>
            <div id="theme-primary-value" class="text-xs font-mono text-muted">#0073E6</div>
          </div>
          <p class="text-xs text-secondary">Primary brand color, buttons, CTA</p>
        </div>
        <!-- Accent -->
        <div class="space-y-3">
          <div class="h-20 rounded-lg border" style={`background-color: ${colors.accent.accent.value}; border-color: var(--border-color);`}></div>
          <div>
            <div class="text-sm font-medium text-primary">Accent</div>
            <div class="text-xs font-mono text-muted">{colors.accent.accent.value}</div>
          </div>
          <p class="text-xs text-secondary">{colors.accent.accent.description}</p>
        </div>
      </div>
    </section>

    <!-- Accessibility -->
    <section id="accessibility" class="space-y-4">
      <h2 class="section__title">Accessibility</h2>
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="hand-raised" size="sm" class="a11y-card__title-icon" />
          Contrast Ratios
        </h3>
        <p class="a11y-card__text">
          All color combinations meet WCAG AA standards. Primary text on backgrounds maintains a minimum 4.5:1 contrast ratio, 
          while large text maintains 3:1. Interactive elements have clear focus states.
        </p>
      </div>
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <Icon name="eye" size="sm" class="a11y-card__title-icon" />
          Color Blindness
        </h3>
        <p class="a11y-card__text">
          Semantic colors are designed to be distinguishable for users with color vision deficiencies. 
          Always pair color with icons or text labels for critical information.
        </p>
      </div>
    </section>
  </article>

  <script>
    // Helper: Convert RGB to Hex
    function rgbToHex(rgb) {
      const values = rgb.match(/\d+/g);
      if (!values || values.length < 3) return rgb;
      const r = parseInt(values[0]).toString(16).padStart(2, '0');
      const g = parseInt(values[1]).toString(16).padStart(2, '0');
      const b = parseInt(values[2]).toString(16).padStart(2, '0');
      return `#${r}${g}${b}`.toUpperCase();
    }

    // Helper: Get CSS variable value as hex
    function getCSSVariableHex(varName) {
      if (!varName) return null;
      const value = getComputedStyle(document.documentElement)
        .getPropertyValue(varName)
        .trim();
      if (value.startsWith('#')) return value.toUpperCase();
      if (value.startsWith('rgb')) return rgbToHex(value);
      return value;
    }

    function updateColorPalettes() {
      const html = document.documentElement;
      const isDark = html.classList.contains('dark');
      const isCPTheme = html.classList.contains('theme-cp');
      const isVPTheme = html.classList.contains('theme-vp');
      const isPPMTheme = html.classList.contains('theme-ppm');
      const isMaconomyTheme = html.classList.contains('theme-maconomy');
      const isVPOrPPMOrMaconomy = isVPTheme || isPPMTheme || isMaconomyTheme;

      const semiLightPalette = document.getElementById('semi-light-palette');
      const cpSemiDarkPalette = document.getElementById('cp-semi-dark-palette');
      const vpPpmMaconomyDarkPalette = document.getElementById('vp-ppm-maconomy-dark-palette');
      const semiLightDescription = document.getElementById('semi-light-description');

      // Toggle visibility based on theme and mode
      if (isDark && isCPTheme) {
        semiLightPalette?.classList.add('hidden');
        cpSemiDarkPalette?.classList.remove('hidden');
        vpPpmMaconomyDarkPalette?.classList.add('hidden');

        // Update CP dark palette values by reading CSS variables
        document.querySelectorAll('.cp-dark-swatch').forEach(swatch => {
          const cssVar = swatch.getAttribute('data-css-var');

          if (cssVar) {
            const hexValue = getCSSVariableHex(cssVar);
            if (hexValue) {
              swatch.style.backgroundColor = hexValue;

              // Find and update the corresponding value text
              const container = swatch.parentElement;
              const valueEl = container?.querySelector('.cp-dark-value');
              if (valueEl) valueEl.textContent = hexValue;
            }
          }
        });
      } else if (isDark && isVPOrPPMOrMaconomy) {
        semiLightPalette?.classList.add('hidden');
        cpSemiDarkPalette?.classList.add('hidden');
        vpPpmMaconomyDarkPalette?.classList.remove('hidden');

        // Update VP/PPM/Maconomy dark palette values by reading CSS variables
        document.querySelectorAll('.vp-ppm-maconomy-dark-swatch').forEach(swatch => {
          const cssVar = swatch.getAttribute('data-css-var');

          if (cssVar) {
            const hexValue = getCSSVariableHex(cssVar);
            if (hexValue) {
              swatch.style.backgroundColor = hexValue;

              // Find and update the corresponding value text
              const container = swatch.parentElement;
              const valueEl = container?.querySelector('.vp-ppm-maconomy-dark-value');
              if (valueEl) valueEl.textContent = hexValue;
            }
          }
        });
      } else {
        semiLightPalette?.classList.remove('hidden');
        cpSemiDarkPalette?.classList.add('hidden');
        vpPpmMaconomyDarkPalette?.classList.add('hidden');

        // Update semi-light palette values by reading CSS variables
        document.querySelectorAll('.semi-light-swatch').forEach(swatch => {
          const cssVar = swatch.getAttribute('data-css-var');

          if (cssVar) {
            const hexValue = getCSSVariableHex(cssVar);
            if (hexValue) {
              swatch.style.backgroundColor = hexValue;

              // Find and update the corresponding value text
              const container = swatch.parentElement;
              const valueEl = container?.querySelector('.semi-light-value');
              if (valueEl) valueEl.textContent = hexValue;
            }
          }
        });
      }

      // Update semantic colors by reading CSS variables
      document.querySelectorAll('[data-semantic]').forEach(box => {
        const semanticName = box.getAttribute('data-semantic');
        const swatch = box.querySelector('[data-css-var]');
        const cssVar = swatch?.getAttribute('data-css-var');

        if (cssVar) {
          const hexValue = getCSSVariableHex(cssVar);
          if (hexValue) {
            if (swatch) swatch.style.backgroundColor = hexValue;
            const valueEl = box.querySelector('.semantic-color-value');
            if (valueEl) valueEl.textContent = hexValue;
          }
        }
      });

      // Update theme primary by reading CSS variable
      const themePrimaryHex = getCSSVariableHex('--theme-primary');
      const themePrimaryValue = document.getElementById('theme-primary-value');
      if (themePrimaryValue && themePrimaryHex) {
        themePrimaryValue.textContent = themePrimaryHex;
      }

      // Update dark mode indicators
      const indicatorDark = document.getElementById('indicator-dark');
      const indicatorLight = document.getElementById('indicator-light');
      const darkModeLabel = document.getElementById('dark-mode-label');
      const lightModeLabel = document.getElementById('light-mode-label');

      if (isDark) {
        indicatorDark?.classList.remove('hidden');
        indicatorDark?.classList.add('flex');
        indicatorLight?.classList.add('hidden');
        indicatorLight?.classList.remove('flex');

        if (isCPTheme) {
          if (darkModeLabel) darkModeLabel.textContent = 'Showing CP Semi-Dark Colors';
        } else if (isVPOrPPMOrMaconomy) {
          if (darkModeLabel) darkModeLabel.textContent = 'Showing Dark Mode Colors';
        }
      } else {
        indicatorDark?.classList.add('hidden');
        indicatorDark?.classList.remove('flex');
        indicatorLight?.classList.remove('hidden');
        indicatorLight?.classList.add('flex');

        if (lightModeLabel) lightModeLabel.textContent = 'Showing Semi-Light Colors';
      }
    }

    // Initialize on load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', updateColorPalettes);
    } else {
      updateColorPalettes();
    }

    // Watch for theme changes
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === 'class') {
          updateColorPalettes();
        }
      });
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class']
    });
  </script>
</DocsLayout>
