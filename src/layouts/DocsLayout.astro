---
import '../styles/global.css';
import { navigation, componentCount } from '../data/navigation';
import { themeConfig } from '../data/theme-config';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <script is:inline>
    // Immediately apply saved theme to prevent flash
    (function() {
      const savedTheme = localStorage.getItem('theme') || 'dark';
      const savedColorTheme = localStorage.getItem('colorTheme') || 'cp';
      if (savedTheme === 'dark') document.documentElement.classList.add('dark');
      document.documentElement.classList.add('theme-' + savedColorTheme);
    })();
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | Design System</title>
  <meta name="description" content={description || 'Design System Documentation'}>
  
  <!-- Tabler Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>

<body class="bg-white dark:bg-obsidian text-slate-900 dark:text-slate-100 min-h-screen overflow-hidden">
  <div class="flex flex-col h-screen w-full">
    <!-- TOP HEADER -->
    <header class="w-full h-14 bg-white dark:bg-surface border-b border-slate-200 dark:border-border flex items-center justify-between px-4 sm:px-6 relative z-50 shrink-0">
      <!-- Brand / Left -->
      <div class="flex items-center gap-4">
        <a href="/" class="flex items-center gap-2 group cursor-pointer">
          <div class="w-5 h-5 bg-theme-primary rounded-sm group-hover:bg-slate-900 dark:group-hover:bg-white transition-colors"></div>
          <h1 class="font-display font-bold tracking-tight text-slate-900 dark:text-white text-sm">
            DESIGN <span class="text-slate-400 dark:text-slate-500 font-normal">SYSTEM</span>
          </h1>
        </a>
      </div>
      
      <!-- Center - Search -->
      <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        <div class="relative">
          <input 
            type="text" 
            id="search-input"
            placeholder="Search components..." 
            class="w-64 pl-9 pr-4 py-1.5 text-sm bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-transparent rounded-lg focus:outline-none focus:ring-2 focus:ring-theme-primary/50 text-slate-900 dark:text-white placeholder-slate-500"
          >
          <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
          <kbd class="absolute right-3 top-1/2 -translate-y-1/2 text-[10px] text-slate-400 bg-slate-200 dark:bg-slate-800 px-1.5 py-0.5 rounded">⌘K</kbd>
        </div>
        
        <!-- Search Results Dropdown -->
        <div id="search-results" class="hidden absolute top-full left-0 mt-2 w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg shadow-xl py-2 max-h-80 overflow-y-auto z-50">
        </div>
      </div>
      
      <!-- Right Actions -->
      <div class="flex items-center gap-3">
        <!-- Theme Switcher -->
        <div class="relative">
          <button id="theme-picker-btn" class="flex items-center gap-2 px-3 py-1.5 rounded hover:bg-slate-100 dark:hover:bg-white/5 transition-colors">
            <i class="ti ti-palette text-base text-slate-600 dark:text-slate-400"></i>
            <span id="current-theme-name" class="text-xs font-medium text-slate-900 dark:text-white">CP</span>
            <i class="ti ti-chevron-down text-xs text-slate-500 dark:text-slate-400"></i>
          </button>
          
          <div id="theme-picker-menu" class="hidden absolute top-full right-0 mt-2 w-44 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg shadow-xl py-2 z-50">
            <button data-theme="cp" class="theme-option w-full px-4 py-2.5 text-left text-sm hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center justify-between transition-colors">
              <span class="font-medium text-slate-900 dark:text-white">CP</span>
              <span class="w-3 h-3 rounded-full" style="background: #4C92D9"></span>
            </button>
            <button data-theme="vp" class="theme-option w-full px-4 py-2.5 text-left text-sm hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center justify-between transition-colors">
              <span class="font-medium text-slate-900 dark:text-white">VP</span>
              <span class="w-3 h-3 rounded-full" style="background: #4C92D9"></span>
            </button>
            <button data-theme="ppm" class="theme-option w-full px-4 py-2.5 text-left text-sm hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center justify-between transition-colors">
              <span class="font-medium text-slate-900 dark:text-white">PPM</span>
              <span class="w-3 h-3 rounded-full" style="background: #30659F"></span>
            </button>
            <button data-theme="maconomy" class="theme-option w-full px-4 py-2.5 text-left text-sm hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center justify-between transition-colors">
              <span class="font-medium text-slate-900 dark:text-white">Maconomy</span>
              <span class="w-3 h-3 rounded-full" style="background: #804A98"></span>
            </button>
          </div>
        </div>
        
        <!-- Theme Toggle -->
        <button id="theme-toggle" class="w-8 h-8 flex items-center justify-center rounded hover:bg-slate-100 dark:hover:bg-white/5 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
          <i class="ti ti-sun text-lg dark:hidden"></i>
          <i class="ti ti-moon text-lg hidden dark:inline-block"></i>
        </button>
        
        <div class="h-5 w-px bg-slate-200 dark:bg-border mx-1"></div>
        
        <a href="https://github.com" target="_blank" class="w-8 h-8 flex items-center justify-center rounded hover:bg-slate-100 dark:hover:bg-white/5 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
          <i class="ti ti-brand-github text-lg"></i>
        </a>
      </div>
    </header>
    
    <!-- CONTENT WRAPPER -->
    <div class="flex flex-1 overflow-hidden relative">
      <!-- LEFT SIDEBAR -->
      <aside class="w-64 border-r border-slate-200 dark:border-border bg-white dark:bg-surface hidden lg:flex flex-col justify-between h-full">
        <div class="p-4 border-b border-slate-200 dark:border-border">
          <div class="text-[10px] font-mono text-slate-500 dark:text-dim uppercase tracking-wider mb-2">Navigation</div>
          <div class="flex items-center gap-2 text-sm text-slate-900 dark:text-white font-medium">
            <i class="ti ti-components text-theme-primary"></i>
            {componentCount} Sections
          </div>
        </div>
        
        <nav class="flex-1 overflow-y-auto custom-scroll p-4 space-y-1">
          {navigation.map((section) => (
            <>
              <div class="px-3 py-2 text-[10px] font-mono text-slate-500 dark:text-dim uppercase tracking-wider mt-4 first:mt-0">
                {section.title}
              </div>
              {section.items.map((item) => (
                <a 
                  href={item.href} 
                  class:list={[
                    'nav-item flex items-center gap-3 px-3 py-2 text-sm rounded transition-colors group',
                    currentPath === item.href || currentPath === item.href + '/'
                      ? 'active text-slate-900 dark:text-white bg-theme-primary-light'
                      : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5'
                  ]}
                >
                  <i class:list={[
                    `ti ${item.icon} text-base`,
                    currentPath === item.href || currentPath === item.href + '/'
                      ? 'text-theme-primary'
                      : 'text-slate-400 dark:text-dim group-hover:text-theme-primary'
                  ]}></i>
                  {item.title}
                </a>
              ))}
            </>
          ))}
          
          <!-- Theme-specific components section (dynamically populated) -->
          <div id="theme-specific-nav"></div>
        </nav>
        
        <div class="p-4 border-t border-slate-200 dark:border-border">
          <div class="bg-slate-100 dark:bg-panel rounded border border-slate-200 dark:border-border p-3">
            <div class="flex justify-between items-center mb-1">
              <span class="text-[10px] text-slate-500 dark:text-slate-400 font-mono">Coverage</span>
              <span class="text-[10px] text-slate-900 dark:text-white">100%</span>
            </div>
            <div class="w-full bg-slate-200 dark:bg-slate-800 h-1 rounded-full overflow-hidden">
              <div class="bg-theme-primary h-full rounded-full w-full"></div>
            </div>
          </div>
        </div>
      </aside>
      
      <!-- MAIN CONTENT -->
      <main class="flex-1 overflow-y-auto custom-scroll min-w-0 bg-white dark:bg-obsidian relative h-full">
        <div class="w-full px-6 md:px-12 py-12 max-w-5xl mx-auto">
          <slot />
        </div>
      </main>
    </div>
  </div>

  <script define:vars={{ themeConfig, currentPath }}>
    // Theme-specific component configuration (made global for access from other scripts)
    window.themeComponentConfig = themeConfig;
    window.currentPagePath = currentPath;
    
    // Function to render theme-specific navigation (made global)
    window.renderThemeSpecificNav = function(themeName) {
      const themeNav = document.getElementById('theme-specific-nav');
      if (!themeNav) return;
      
      const config = window.themeComponentConfig[themeName];
      if (!config || !config.components || config.components.length === 0) {
        themeNav.innerHTML = '';
        return;
      }
      
      const sectionTitle = `${config.name} Components`;
      let html = `
        <div class="px-3 py-2 text-[10px] font-mono text-slate-500 dark:text-dim uppercase tracking-wider mt-4">
          ${sectionTitle}
        </div>
      `;
      
      config.components.forEach(item => {
        const isActive = window.currentPagePath === item.href || window.currentPagePath === item.href + '/';
        const activeClasses = isActive 
          ? 'active text-slate-900 dark:text-white bg-theme-primary-light' 
          : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5';
        const iconClasses = isActive 
          ? 'text-theme-primary' 
          : 'text-slate-400 dark:text-dim group-hover:text-theme-primary';
        
        html += `
          <a href="${item.href}" class="nav-item flex items-center gap-3 px-3 py-2 text-sm rounded transition-colors group ${activeClasses}">
            <i class="ti ${item.icon} text-base ${iconClasses}"></i>
            ${item.title}
          </a>
        `;
      });
      
      themeNav.innerHTML = html;
    };
  </script>

  <script>
    // Theme Toggle (Dark/Light Mode)
    const themeToggle = document.getElementById('theme-toggle');
    const html = document.documentElement;
    
    // Check for saved dark/light mode preference or default to dark
    const savedTheme = localStorage.getItem('theme') || 'dark';
    html.classList.toggle('dark', savedTheme === 'dark');
    
    // Color Theme Switching
    const themePickerBtn = document.getElementById('theme-picker-btn');
    const themePickerMenu = document.getElementById('theme-picker-menu');
    const themeOptions = document.querySelectorAll('.theme-option');
    const currentThemeName = document.getElementById('current-theme-name');
    
    // Load saved color theme or default to 'cp'
    const savedColorTheme = localStorage.getItem('colorTheme') || 'cp';
    html.classList.forEach(cls => {
      if (cls.startsWith('theme-')) {
        html.classList.remove(cls);
      }
    });
    html.classList.add(`theme-${savedColorTheme}`);
    if (currentThemeName) {
      currentThemeName.textContent = savedColorTheme.toUpperCase();
    }
    
    // Render theme-specific nav for initial load
    if (typeof window.renderThemeSpecificNav === 'function') {
      window.renderThemeSpecificNav(savedColorTheme);
    }
    
    // Toggle theme picker dropdown
    themePickerBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      themePickerMenu?.classList.toggle('hidden');
    });
    
    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (themePickerBtn && themePickerMenu && !themePickerBtn.contains(e.target as Node) && !themePickerMenu.contains(e.target as Node)) {
        themePickerMenu.classList.add('hidden');
      }
    });
    
    // Handle theme selection
    themeOptions.forEach(option => {
      option.addEventListener('click', () => {
        const newTheme = (option as HTMLElement).dataset.theme;
        
        // Remove old theme classes
        html.classList.forEach(cls => {
          if (cls.startsWith('theme-')) {
            html.classList.remove(cls);
          }
        });
        
        // Add new theme class
        html.classList.add(`theme-${newTheme}`);
        localStorage.setItem('colorTheme', newTheme || 'cp');
        if (currentThemeName) {
          currentThemeName.textContent = (newTheme || 'cp').toUpperCase();
        }
        themePickerMenu?.classList.add('hidden');
        
        // Update theme-specific navigation
        if (typeof window.renderThemeSpecificNav === 'function') {
          window.renderThemeSpecificNav(newTheme || 'cp');
        }
      });
    });
    
    // Toggle dark/light mode
    themeToggle?.addEventListener('click', () => {
      html.classList.toggle('dark');
      const newTheme = html.classList.contains('dark') ? 'dark' : 'light';
      localStorage.setItem('theme', newTheme);
    });
    
    // Keyboard shortcut for search
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        document.getElementById('search-input')?.focus();
      }
    });
  </script>
</body>
</html>

