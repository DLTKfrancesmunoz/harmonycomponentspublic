---
interface Props {
  code: string;
  language?: string;
  filename?: string;
}

const { code, language = 'html', filename } = Astro.props;
const id = `code-${Math.random().toString(36).substring(7)}`;
---

<div class="relative group rounded-lg overflow-hidden border border-slate-200 dark:border-slate-800">
  {filename && (
    <div class="bg-slate-100 dark:bg-slate-800 px-4 py-2 text-xs font-mono text-slate-600 dark:text-slate-400 border-b border-slate-200 dark:border-slate-700">
      {filename}
    </div>
  )}
  <div class="relative">
    <pre class="!m-0 !rounded-none bg-slate-900 dark:bg-black p-4 overflow-x-auto"><code id={id} class={`language-${language} text-slate-300 text-sm font-mono whitespace-pre`}>{code}</code></pre>
    <button 
      class="copy-btn"
      data-code={code}
      aria-label="Copy code"
    >
      <i class="ti ti-copy copy-icon"></i>
      <i class="ti ti-check check-icon hidden"></i>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll('.copy-btn').forEach(button => {
    button.addEventListener('click', async () => {
      const code = (button as HTMLElement).dataset.code || '';
      await navigator.clipboard.writeText(code);
      
      const copyIcon = button.querySelector('.copy-icon');
      const checkIcon = button.querySelector('.check-icon');
      
      copyIcon?.classList.add('hidden');
      checkIcon?.classList.remove('hidden');
      button.classList.add('copied');
      
      setTimeout(() => {
        copyIcon?.classList.remove('hidden');
        checkIcon?.classList.add('hidden');
        button.classList.remove('copied');
      }, 2000);
    });
  });
</script>

