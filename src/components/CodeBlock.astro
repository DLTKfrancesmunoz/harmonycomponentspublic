---
/**
 * CodeBlock Component
 *
 * Syntax-highlighted code display with copy button.
 */
import Icon from './ui/Icon.astro';

interface Props {
  code: string;
  language?: string;
  filename?: string;
}

const { code, language = 'html', filename } = Astro.props;
const id = `code-${Math.random().toString(36).substring(7)}`;
---

<div class="code-block">
  {filename && (
    <div class="code-block__header">
      {filename}
    </div>
  )}
  <div class="code-block__content">
    <pre><code id={id} class={`language-${language}`}>{code}</code></pre>
    <button
      class="code-block__copy"
      data-code={code}
      aria-label="Copy code"
    >
      <Icon name="clipboard" class="copy-icon" />
      <Icon name="check" class="check-icon hidden" />
    </button>
  </div>
</div>

<style>
  .code-block {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-color);
  }
  
  .code-block__header {
    background-color: var(--elevated-bg);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-color);
  }
  
  .code-block__content {
    position: relative;
  }
  
  .code-block pre {
    margin: 0;
    border-radius: 0;
    background-color: var(--surface-bg);
    padding: var(--space-4);
    overflow-x: auto;
  }
  
  .code-block code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    white-space: pre;
    background: none;
    padding: 0;
    border-radius: 0;
  }
  
  .code-block__copy {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    padding: var(--space-2);
    border-radius: var(--radius-md);
    background-color: var(--elevated-bg);
    color: var(--text-muted);
    opacity: 0;
    transition: all var(--transition-fast);
  }
  
  .code-block:hover .code-block__copy {
    opacity: 1;
  }
  
  .code-block__copy:hover {
    background-color: var(--hover-bg);
    color: var(--text-primary);
  }
  
  .code-block__copy.copied {
    color: var(--color-success);
  }
</style>

<script>
  document.querySelectorAll('.code-block__copy').forEach(button => {
    button.addEventListener('click', async () => {
      const code = (button as HTMLElement).dataset.code || '';
      await navigator.clipboard.writeText(code);
      
      const copyIcon = button.querySelector('.copy-icon');
      const checkIcon = button.querySelector('.check-icon');
      
      copyIcon?.classList.add('hidden');
      checkIcon?.classList.remove('hidden');
      button.classList.add('copied');
      
      setTimeout(() => {
        copyIcon?.classList.remove('hidden');
        checkIcon?.classList.add('hidden');
        button.classList.remove('copied');
      }, 2000);
    });
  });
</script>
