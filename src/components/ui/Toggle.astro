---
/**
 * Toggle Component
 * 
 * Switch control for on/off states.
 * 
 * @example
 * <Toggle label="Enable notifications" />
 * <Toggle checked label="Dark mode" />
 * <Toggle disabled label="Disabled toggle" />
 */

export interface Props {
  /** Toggle label text */
  label?: string;
  /** Toggle state */
  checked?: boolean;
  /** Disables the toggle */
  disabled?: boolean;
  /** Toggle size */
  size?: 'sm' | 'md';
  /** Toggle name attribute */
  name?: string;
  /** Toggle id attribute */
  id?: string;
  /** Additional CSS classes */
  class?: string;
  /** Any additional HTML attributes */
  [key: string]: any;
}

const {
  label,
  checked = false,
  disabled = false,
  size = 'md',
  name,
  id,
  class: className = '',
  ...rest
} = Astro.props;

// Generate an ID if not provided
const toggleId = id || name || `toggle-${Math.random().toString(36).substr(2, 9)}`;

// Size configurations
const sizes: Record<string, { track: string; thumb: string; thumbOn: string; thumbOff: string }> = {
  sm: { track: 'w-8 h-4', thumb: 'w-3 h-3', thumbOn: 'left-[18px]', thumbOff: 'left-[2px]' },
  md: { track: 'w-11 h-6', thumb: 'w-5 h-5', thumbOn: 'left-[22px]', thumbOff: 'left-[2px]' },
};

const sizeConfig = sizes[size];

// Label classes
const labelClasses = [
  'text-sm select-none',
  disabled ? 'text-slate-400 dark:text-slate-600' : 'text-slate-700 dark:text-slate-300',
].join(' ');
---

<label class={`toggle-wrapper flex items-center gap-3 ${disabled ? 'cursor-not-allowed' : 'cursor-pointer'} ${className}`}>
  <button
    type="button"
    role="switch"
    aria-checked={checked ? 'true' : 'false'}
    id={toggleId}
    disabled={disabled}
    class:list={[
      'toggle-track relative inline-flex shrink-0 rounded-full transition-colors duration-200 ease-in-out',
      'focus:outline-none focus-visible:ring-2 focus-visible:ring-theme-primary focus-visible:ring-offset-2',
      sizeConfig.track,
      disabled ? 'opacity-50 cursor-not-allowed' : 'cursor-pointer',
      checked ? 'bg-theme-primary' : 'bg-slate-300 dark:bg-slate-600',
    ]}
    data-checked={checked}
    data-size={size}
    {...rest}
  >
    <span 
      class:list={[
        'toggle-thumb pointer-events-none absolute top-1/2 -translate-y-1/2 rounded-full bg-white shadow-md transition-all duration-200 ease-in-out',
        sizeConfig.thumb,
        checked ? sizeConfig.thumbOn : sizeConfig.thumbOff,
      ]}
    ></span>
  </button>
  {label && (
    <span class={labelClasses}>{label}</span>
  )}
</label>

<script>
  // Initialize all toggle buttons
  function initToggles() {
    document.querySelectorAll('.toggle-track').forEach((toggle) => {
      const btn = toggle as HTMLButtonElement;
      
      // Remove any existing listeners by cloning
      const newBtn = btn.cloneNode(true) as HTMLButtonElement;
      btn.parentNode?.replaceChild(newBtn, btn);
      
      newBtn.addEventListener('click', () => {
        if (newBtn.disabled) return;
        
        const isChecked = newBtn.getAttribute('data-checked') === 'true';
        const newState = !isChecked;
        const size = newBtn.getAttribute('data-size') || 'md';
        
        // Update aria and data attributes
        newBtn.setAttribute('aria-checked', String(newState));
        newBtn.setAttribute('data-checked', String(newState));
        
        // Update track background color
        if (newState) {
          newBtn.classList.remove('bg-slate-300', 'dark:bg-slate-600');
          newBtn.classList.add('bg-theme-primary');
        } else {
          newBtn.classList.remove('bg-theme-primary');
          newBtn.classList.add('bg-slate-300', 'dark:bg-slate-600');
        }
        
        // Update thumb position
        const thumb = newBtn.querySelector('.toggle-thumb');
        if (thumb) {
          if (size === 'sm') {
            thumb.classList.toggle('left-[2px]', !newState);
            thumb.classList.toggle('left-[18px]', newState);
          } else {
            thumb.classList.toggle('left-[2px]', !newState);
            thumb.classList.toggle('left-[22px]', newState);
          }
        }
        
        // Dispatch change event
        newBtn.dispatchEvent(new CustomEvent('toggle-change', { 
          detail: { checked: newState },
          bubbles: true 
        }));
      });
    });
  }

  // Run on initial load
  initToggles();
  
  // Re-run after Astro page transitions
  document.addEventListener('astro:page-load', initToggles);
</script>
