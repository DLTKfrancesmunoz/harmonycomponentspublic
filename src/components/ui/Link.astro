---
/**
 * Link Component
 *
 * Styled anchor element.
 * Default slot: consumer-provided content (link text). No fallback; consumer must pass content for a meaningful default state.
 */
import Icon from './Icon.astro';

export interface Props {
  href: string;
  external?: boolean;
  muted?: boolean;
  size?: 'small' | 'medium' | 'large';
  class?: string;
  [key: string]: any;
}

const {
  href,
  external = false,
  muted = false,
  size = 'medium',
  class: className = '',
  ...rest
} = Astro.props;

const classes = [
  'link',
  `link--${size}`,
  muted && 'link--muted',
  className,
].filter(Boolean).join(' ');
---

<a
  href={href}
  class={classes}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  {...rest}
><slot />{external && <Icon name="arrow-top-right-on-square" class="link__external-icon" size="xs" />}</a>
