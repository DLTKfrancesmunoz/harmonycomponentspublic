---
/**
 * ProgressBar Component
 * 
 * Visual indicator of progress or completion.
 * 
 * @example
 * <ProgressBar value={50} />
 * <ProgressBar value={75} variant="success" />
 * <ProgressBar value={100} size="lg" showLabel />
 */

export interface Props {
  /** Current progress value (0-100) */
  value?: number;
  /** Bar height */
  size?: 'sm' | 'md' | 'lg';
  /** Color variant */
  variant?: 'default' | 'success' | 'warning' | 'error';
  /** Show percentage label */
  showLabel?: boolean;
  /** Additional CSS classes */
  class?: string;
  /** Any additional HTML attributes */
  [key: string]: any;
}

const {
  value = 0,
  size = 'md',
  variant = 'default',
  showLabel = false,
  class: className = '',
  ...rest
} = Astro.props;

// Clamp value between 0 and 100
const clampedValue = Math.min(100, Math.max(0, value));

// Size classes
const sizeClasses: Record<string, string> = {
  sm: 'h-1',
  md: 'h-2',
  lg: 'h-3',
};

// Variant colors for the fill
const variantClasses: Record<string, string> = {
  default: 'bg-theme-primary',
  success: 'bg-success',
  warning: 'bg-warning',
  error: 'bg-error',
};

// Container classes
const containerClasses = [
  'w-full bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden',
  sizeClasses[size],
  className,
].filter(Boolean).join(' ');

// Fill classes
const fillClasses = [
  'h-full rounded-full transition-all duration-300 ease-out',
  variantClasses[variant],
].join(' ');
---

<div class="w-full">
  {showLabel && (
    <div class="flex justify-between items-center mb-1">
      <span class="text-sm text-slate-600 dark:text-slate-400">Progress</span>
      <span class="text-sm font-medium text-slate-900 dark:text-white">{clampedValue}%</span>
    </div>
  )}
  <div 
    class={containerClasses} 
    role="progressbar"
    aria-valuenow={clampedValue}
    aria-valuemin={0}
    aria-valuemax={100}
    {...rest}
  >
    <div 
      class={fillClasses} 
      style={`width: ${clampedValue}%`}
    ></div>
  </div>
</div>

