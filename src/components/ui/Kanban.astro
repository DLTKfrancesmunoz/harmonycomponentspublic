---
/**
 * Kanban Component
 *
 * Kanban board component that displays tasks in columns (lanes) with cards.
 * Uses design tokens exclusively and leverages existing components.
 */
import Button from './Button.astro';
import Icon from './Icon.astro';
import Card from './Card.astro';
import Dropdown, { type Option } from './Dropdown.astro';
import KanbanCard, { type KanbanCardProps } from './KanbanCard.astro';

export interface KanbanColumn {
  id: string;
  title: string;
  cards: KanbanCardProps[];
}

export interface ActionButton {
  text: string;
  icon?: string;
}

export interface ActionDropdown {
  text: string;
  options?: Option[];
  value?: string;
}

export interface Props {
  columns: KanbanColumn[];
  title?: string;
  actionButtons?: ActionButton[];
  actionDropdowns?: ActionDropdown[];
  class?: string;
  showAddButton?: boolean;
}

const {
  columns,
  title = 'Kanban Board',
  actionButtons = [],
  actionDropdowns = [],
  class: className = '',
  showAddButton = true,
} = Astro.props;
---

<div class={`kanban__container ${className}`}>
  <!-- Title Bar -->
  <div class="kanban__title-bar">
    <div class="kanban__title-bar-content">
      <h1 class="kanban__title">{title}</h1>
      <div class="kanban__title-bar-actions">
        <button type="button" class="kanban__title-bar-icon" aria-label="Expand view">
          <Icon name="arrows-pointing-out" size="sm" />
        </button>
        <button type="button" class="kanban__title-bar-icon" aria-label="Collapse view">
          <Icon name="arrows-pointing-in" size="sm" />
        </button>
        <button type="button" class="kanban__title-bar-icon" aria-label="Help">
          <Icon name="question-mark-circle" size="sm" />
        </button>
        <button type="button" class="kanban__title-bar-icon" aria-label="Minimize">
          <Icon name="minimize" size="sm" />
        </button>
        <button type="button" class="kanban__title-bar-icon" aria-label="Window">
          <Icon name="window-plain" size="sm" />
        </button>
        <button type="button" class="kanban__title-bar-icon" aria-label="Close">
          <Icon name="x-mark" size="sm" />
        </button>
      </div>
    </div>
  </div>

  <!-- Action Bar -->
  <div class="kanban__action-bar">
    <div class="kanban__action-buttons">
      {actionButtons.length > 0 ? (
        actionButtons.map((button) => (
          <Button
            variant="ghost"
            size="sm"
            icon={button.icon}
            class="kanban__action-button"
          >
            {button.text}
          </Button>
        ))
      ) : (
        <>
          <Button variant="ghost" size="sm" icon="trash" class="kanban__action-button">
            Delete
          </Button>
          <Button variant="ghost" size="sm" icon="squares-2x2" class="kanban__action-button">
            Group
          </Button>
          <Button variant="ghost" size="sm" icon="chevron-up" class="kanban__action-button">
            Subcards: Collapse all
          </Button>
          <Button variant="ghost" size="sm" icon="cog-6-tooth" class="kanban__action-button">
            Customize Columns
          </Button>
        </>
      )}
    </div>
    <div class="kanban__action-dropdowns">
      {actionDropdowns.length > 0 ? (
        actionDropdowns.map((dropdown) => (
          <Dropdown
            options={dropdown.options || []}
            value={dropdown.value}
            placeholder={dropdown.text}
            class="kanban__action-dropdown"
          />
        ))
      ) : (
        <>
          <Dropdown
            options={[
              { value: 'all', label: 'All Filters' },
              { value: 'active', label: 'Active' },
              { value: 'completed', label: 'Completed' }
            ]}
            placeholder="All Filters"
            class="kanban__action-dropdown"
          />
          <Dropdown
            options={[
              { value: 'kanban', label: 'Kanban' },
              { value: 'list', label: 'List' },
              { value: 'table', label: 'Table' }
            ]}
            placeholder="Change Views"
            class="kanban__action-dropdown"
          />
        </>
      )}
    </div>
  </div>

  <!-- Columns Container -->
  <section class="kanban__columns-wrapper" role="region" aria-label="Kanban board">
    {columns.map((column) => (
      <Card primary class="kanban__column-card">
        <article 
          class="kanban__column" 
          role="group" 
          aria-label={`${column.title} column`}
        >
          <header class="kanban__column-header">
            <div class="kanban__column-header-content">
              <h2 class="kanban__column-title">{column.title}</h2>
              <span class="kanban__column-count" aria-label={`${column.cards.length} items`}>
                {column.cards.length}
              </span>
            </div>
            <div class="kanban__column-header-actions">
              <button
                type="button"
                class="kanban__column-action-icon"
                aria-label="Column settings"
              >
                <Icon name="cog" size="sm" />
              </button>
              <button
                type="button"
                class="kanban__column-action-icon"
                aria-label="Column menu"
              >
                <Icon name="ellipsis-vertical" size="sm" />
              </button>
              <button
                type="button"
                class="kanban__column-action-icon"
                aria-label="Close column"
              >
                <Icon name="x-mark" size="sm" />
              </button>
            </div>
          </header>
          
          <div class="kanban__column-content">
            {column.cards.map((card) => (
              <KanbanCard
                id={card.id}
                title={card.title}
                description={card.description}
                avatar={card.avatar}
                badges={card.badges}
                progress={card.progress}
                icons={card.icons}
                date={card.date}
                time={card.time}
                class={card.class}
              />
            ))}
            {showAddButton && (
              <Button
                variant="ghost"
                size="sm"
                icon="plus"
                class="kanban__add-button"
                aria-label={`Add card to ${column.title}`}
              >
                Add card
              </Button>
            )}
          </div>
        </article>
      </Card>
    ))}
  </section>
</div>
