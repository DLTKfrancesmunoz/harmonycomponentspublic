---
/**
 * ShellFooter Component
 *
 * A bottom tab bar for workspace navigation, similar to browser tabs.
 * Used by VP, PPM, and Maconomy themes. CP uses FloatingNav instead.
 *
 * @prop {Array} tabs - Array of tab objects with { id, label, active, href }
 * @prop {boolean} showMore - Whether to show "More" dropdown (default: false)
 * @prop {number} moreCount - Number for "More (N)" label (default: 0)
 * @prop {Array} overflowTabs - Array of overflow tabs shown in dropdown (default: [])
 * @prop {boolean} showAddTab - Whether to show "Add Tab" button (default: true)
 * @prop {string} variant - 'default' | 'compact' (default: 'default')
 */
import TabStrip, { type Tab } from './TabStrip.astro';

interface Props {
  tabs: Tab[];
  showMore?: boolean;
  moreCount?: number;
  overflowTabs?: Tab[];
  showAddTab?: boolean;
  variant?: 'default' | 'compact';
}

const {
  tabs = [],
  showMore = false,
  moreCount = 0,
  overflowTabs = [],
  showAddTab = true,
  variant = 'default'
} = Astro.props;

// Determine overflow mode based on showMore prop
const overflowMode = showMore && overflowTabs.length > 0 ? 'manual' : 'none';

// Add pin icon to active tabs (preserve existing icons for non-active tabs)
const tabsWithPinIcon = tabs.map(tab => ({
  ...tab,
  icon: tab.active ? 'pin' : (tab.icon || undefined),
  iconPosition: tab.active ? 'left' : (tab.iconPosition || (tab.icon ? 'left' : undefined))
}));

// Add pin icon to active overflow tabs (preserve existing icons for non-active tabs)
const overflowTabsWithPinIcon = overflowTabs.map(tab => ({
  ...tab,
  icon: tab.active ? 'pin' : (tab.icon || undefined),
  iconPosition: tab.active ? 'left' : (tab.iconPosition || (tab.icon ? 'left' : undefined))
}));
---

<div class="shell-footer" data-variant={variant}>
  <TabStrip
    tabs={tabsWithPinIcon}
    showAddTab={showAddTab}
    overflowMode={overflowMode}
    overflowTabs={overflowTabsWithPinIcon}
    variant={variant}
    class="shell-footer__tabstrip"
  />
</div>

<style>
  .shell-footer {
    background-color: var(--shell-footer-bg);
    border-top: var(--border-width-thin) solid var(--border-color);
    height: var(--shell-footer-height-default);
    width: 100%;
    padding: 0 var(--space-4);
    display: flex;
    align-items: center;
  }

  /* Remove base underline from TabStrip container */
  .shell-footer :global(.tabstrip__container) {
    border-bottom: none;
  }

  /* Override TabStrip tab colors with higher specificity */
  /* Target all tab elements within shell-footer context */
  .shell-footer :global(.tabstrip) :global(.tabstrip__tabs) :global(.tab),
  .shell-footer :global(.tabstrip) :global(.tabstrip__add.tab),
  .shell-footer :global(.tabstrip) :global(.tabstrip__more.tab) {
    color: var(--text-inverse);
    border-bottom: var(--border-width-standard) solid transparent;
  }

  /* Active tab - white text, primary icon and underline */
  .shell-footer :global(.tabstrip) :global(.tabstrip__tabs) :global(.tab.is-active),
  .shell-footer :global(.tabstrip) :global(.tabstrip__add.tab.is-active),
  .shell-footer :global(.tabstrip) :global(.tabstrip__more.tab.is-active) {
    color: var(--text-inverse);
    border-bottom: var(--border-width-thick) solid var(--theme-primary);
  }

  /* Active tab label - white text */
  .shell-footer :global(.tabstrip) :global(.tabstrip__tabs) :global(.tab.is-active) :global(.tab__label),
  .shell-footer :global(.tabstrip) :global(.tabstrip__add.tab.is-active) :global(.tab__label),
  .shell-footer :global(.tabstrip) :global(.tabstrip__more.tab.is-active) :global(.tab__label) {
    color: var(--text-inverse);
  }

  /* Active tab icon - primary color */
  .shell-footer :global(.tabstrip) :global(.tabstrip__tabs) :global(.tab.is-active) :global(.tab__icon),
  .shell-footer :global(.tabstrip) :global(.tabstrip__add.tab.is-active) :global(.tab__icon),
  .shell-footer :global(.tabstrip) :global(.tabstrip__more.tab.is-active) :global(.tab__icon) {
    color: var(--theme-primary);
  }

  /* Hover state for non-active tabs - background and maintain white text */
  .shell-footer :global(.tabstrip) :global(.tabstrip__tabs) :global(.tab:hover:not(.is-active)),
  .shell-footer :global(.tabstrip) :global(.tabstrip__add.tab:hover:not(.is-active)),
  .shell-footer :global(.tabstrip) :global(.tabstrip__more.tab:hover:not(.is-active)) {
    color: var(--text-inverse);
    background-color: var(--shell-footer-tab-hover-bg);
    border-radius: var(--radius-sm);
    margin-top: var(--space-1);
    margin-bottom: var(--space-1);
    padding-top: calc(var(--space-3) - var(--space-1));
    padding-bottom: calc(var(--space-3) - var(--space-1));
  }

  /* Hover state for active tab - background, white text, primary icon and underline */
  .shell-footer :global(.tabstrip) :global(.tabstrip__tabs) :global(.tab.is-active:hover),
  .shell-footer :global(.tabstrip) :global(.tabstrip__add.tab.is-active:hover),
  .shell-footer :global(.tabstrip) :global(.tabstrip__more.tab.is-active:hover) {
    color: var(--text-inverse);
    background-color: var(--shell-footer-tab-hover-bg);
    border-radius: var(--radius-sm);
    border-bottom: var(--border-width-thick) solid var(--theme-primary);
    margin-top: var(--space-1);
    margin-bottom: var(--space-1);
    padding-top: calc(var(--space-3) - var(--space-1));
    padding-bottom: calc(var(--space-3) - var(--space-1));
  }

  /* Active tab hover - label stays white */
  .shell-footer :global(.tabstrip) :global(.tabstrip__tabs) :global(.tab.is-active:hover) :global(.tab__label),
  .shell-footer :global(.tabstrip) :global(.tabstrip__add.tab.is-active:hover) :global(.tab__label),
  .shell-footer :global(.tabstrip) :global(.tabstrip__more.tab.is-active:hover) :global(.tab__label) {
    color: var(--text-inverse);
  }

  /* Active tab hover - icon stays primary */
  .shell-footer :global(.tabstrip) :global(.tabstrip__tabs) :global(.tab.is-active:hover) :global(.tab__icon),
  .shell-footer :global(.tabstrip) :global(.tabstrip__add.tab.is-active:hover) :global(.tab__icon),
  .shell-footer :global(.tabstrip) :global(.tabstrip__more.tab.is-active:hover) :global(.tab__icon) {
    color: var(--theme-primary);
  }

  /* Dark mode override for non-active tabs - white text on dark background */
  html.dark .shell-footer :global(.tabstrip) :global(.tabstrip__tabs) :global(.tab:not(.is-active)),
  html.dark .shell-footer :global(.tabstrip) :global(.tabstrip__add.tab:not(.is-active)),
  html.dark .shell-footer :global(.tabstrip) :global(.tabstrip__more.tab:not(.is-active)) {
    color: var(--text-primary);
  }

  /* Dark mode hover state for non-active tabs - maintain white text */
  html.dark .shell-footer :global(.tabstrip) :global(.tabstrip__tabs) :global(.tab:hover:not(.is-active)),
  html.dark .shell-footer :global(.tabstrip) :global(.tabstrip__add.tab:hover:not(.is-active)),
  html.dark .shell-footer :global(.tabstrip) :global(.tabstrip__more.tab:hover:not(.is-active)) {
    color: var(--text-primary);
  }

  /* Compact variant */
  .shell-footer[data-variant="compact"] {
    height: var(--shell-footer-height-compact);
  }
</style>

