---
/**
 * CPRightSidebar Component
 * 
 * A CP-specific right navigation sidebar that is docked to the right edge of the screen.
 * Shows only icons when collapsed, expands on hover to show text labels + icon.
 * 
 * @prop {string} class - Additional CSS classes to apply
 */

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

// Section 1: AI and quick actions
const section1Items = [
  { icon: 'dela-ai', label: 'Dela AI' },
  { icon: 'bell', label: 'Notifications' },
  { icon: 'arrow-up-tray', label: 'Files' },
];

// Section 2: Document actions
const section2Items = [
  { icon: 'printer', label: 'Print' },
  { icon: 'view-columns', label: 'Layout Options' },
];

// Section 3: Settings and help
const section3Items = [
  { icon: 'microphone-slash', label: 'Microphone' },
  { icon: 'signal-slash', label: 'Offline' },
  { icon: 'command-line', label: 'Keyboard Shortcuts' },
  { icon: 'question-mark-circle', label: 'Help' },
];
---

<nav class:list={['cp-right-sidebar', className]}>
  <!-- Section 1: AI and Quick Actions -->
  <div class="cp-right-sidebar__section">
    {section1Items.map((item) => (
      <a href="#" class="cp-right-sidebar__item">
        <span class="cp-right-sidebar__label">{item.label}</span>
        <span class="cp-right-sidebar__icon">
          {item.icon === 'dela-ai' && (
            <img src="/logos/DelaD.svg" alt="Dela AI" class="cp-right-sidebar__dela-logo" />
          )}
          {item.icon === 'bell' && (
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
            </svg>
          )}
          {item.icon === 'arrow-up-tray' && (
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
            </svg>
          )}
        </span>
      </a>
    ))}
  </div>

  <!-- Section 2: Document Actions -->
  <div class="cp-right-sidebar__section">
    {section2Items.map((item) => (
      <a href="#" class="cp-right-sidebar__item">
        <span class="cp-right-sidebar__label">{item.label}</span>
        <span class="cp-right-sidebar__icon">
          {item.icon === 'printer' && (
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5Zm-3 0h.008v.008H15V10.5Z" />
            </svg>
          )}
          {item.icon === 'view-columns' && (
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 4.5v15m6-15v15m-10.875 0h15.75c.621 0 1.125-.504 1.125-1.125V5.625c0-.621-.504-1.125-1.125-1.125H4.125C3.504 4.5 3 5.004 3 5.625v12.75c0 .621.504 1.125 1.125 1.125Z" />
            </svg>
          )}
        </span>
      </a>
    ))}
  </div>

  <!-- Section 3: Settings and Help -->
  <div class="cp-right-sidebar__section">
    {section3Items.map((item) => (
      <a href="#" class="cp-right-sidebar__item">
        <span class="cp-right-sidebar__label">{item.label}</span>
        <span class="cp-right-sidebar__icon">
          {item.icon === 'microphone-slash' && (
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3l18 18" />
            </svg>
          )}
          {item.icon === 'signal-slash' && (
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3l18 18M8.288 15.038a5.25 5.25 0 0 1 7.424-7.424M12.53 8.47a3.75 3.75 0 0 1 3 3M5.106 17.894a9.75 9.75 0 0 1 13.788-13.788M12 12v.008h.008V12H12Z" />
            </svg>
          )}
          {item.icon === 'command-line' && (
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" />
            </svg>
          )}
          {item.icon === 'question-mark-circle' && (
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
            </svg>
          )}
        </span>
      </a>
    ))}
  </div>
</nav>

