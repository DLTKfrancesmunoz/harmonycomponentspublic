---
/**
 * Badge Component
 * 
 * Small visual indicator for status, categories, or counts.
 * 
 * @example
 * <Badge>Default</Badge>
 * <Badge variant="success">Completed</Badge>
 * <Badge variant="error" style="solid">Failed</Badge>
 * <Badge variant="primary" icon="ti-check">With Icon</Badge>
 */

export interface Props {
  /** Badge color variant */
  variant?: 'default' | 'primary' | 'success' | 'warning' | 'error' | 'info';
  /** Badge visual style */
  style?: 'subtle' | 'solid' | 'outline';
  /** Badge size */
  size?: 'sm' | 'md';
  /** Leading icon class */
  icon?: string;
  /** Show as dot indicator only */
  dot?: boolean;
  /** Additional CSS classes */
  class?: string;
  /** Any additional HTML attributes */
  [key: string]: any;
}

const {
  variant = 'default',
  style = 'subtle',
  size = 'md',
  icon,
  dot = false,
  class: className = '',
  ...rest
} = Astro.props;

// Base classes
const baseClasses = 'font-medium rounded-full inline-flex items-center';

// Size classes
const sizeClasses: Record<string, string> = {
  sm: 'px-2 py-0.5 text-[10px] gap-1',
  md: 'px-2.5 py-1 text-xs gap-1',
};

// Dot size classes
const dotSizeClasses: Record<string, string> = {
  sm: 'w-1.5 h-1.5',
  md: 'w-2 h-2',
};

// Variant + style combinations
const variantStyles: Record<string, Record<string, string>> = {
  default: {
    subtle: 'bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300',
    solid: 'bg-slate-600 text-white',
    outline: 'border border-slate-300 dark:border-slate-700 text-slate-700 dark:text-slate-300',
  },
  primary: {
    subtle: 'bg-theme-primary/10 text-theme-primary',
    solid: 'bg-theme-primary text-white',
    outline: 'border border-theme-primary text-theme-primary',
  },
  success: {
    subtle: 'bg-success/10 text-success',
    solid: 'bg-success text-white',
    outline: 'border border-success text-success',
  },
  warning: {
    subtle: 'bg-warning/10 text-warning',
    solid: 'bg-warning text-white',
    outline: 'border border-warning text-warning',
  },
  error: {
    subtle: 'bg-error/10 text-error',
    solid: 'bg-error text-white',
    outline: 'border border-error text-error',
  },
  info: {
    subtle: 'bg-info/10 text-info',
    solid: 'bg-info text-white',
    outline: 'border border-info text-info',
  },
};

// Dot-only color classes
const dotColorClasses: Record<string, string> = {
  default: 'bg-slate-400',
  primary: 'bg-theme-primary',
  success: 'bg-success',
  warning: 'bg-warning',
  error: 'bg-error',
  info: 'bg-info',
};

// Combine classes for regular badge
const badgeClasses = [
  baseClasses,
  sizeClasses[size],
  variantStyles[variant][style],
  className,
].filter(Boolean).join(' ');

// Dot classes
const dotClasses = [
  'rounded-full',
  dotSizeClasses[size],
  dotColorClasses[variant],
].join(' ');
---

{dot ? (
  <span class={`flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400 ${className}`} {...rest}>
    <span class={dotClasses}></span>
    <slot />
  </span>
) : (
  <span class={badgeClasses} {...rest}>
    {icon && (
      <i class={`ti ${icon} text-sm`}></i>
    )}
    <slot />
  </span>
)}

