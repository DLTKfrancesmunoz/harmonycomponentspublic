---
/**
 * Badge Component
 *
 * Small status indicator or label.
 * Default slot: consumer-provided content (label). No fallback; consumer must pass content for a meaningful default state.
 */
import Icon from './Icon.astro';

export interface Props {
  variant?: 'default' | 'primary' | 'success' | 'warning' | 'error' | 'info' | 'orange' | 'pink' | 'disabled';
  size?: 'small' | 'medium' | 'large';
  icon?: string; // Heroicon name (e.g., "check", "x-mark")
  class?: string;
}

const iconSizeMap = { small: 'xs', medium: 'xs', large: 'sm' } as const;

const {
  variant = 'default',
  size = 'large',
  icon,
  class: className = '',
} = Astro.props;

const classes = [
  'badge',
  `badge--${variant}`,
  `badge--${size}`,
  className,
].filter(Boolean).join(' ');

const iconSize = icon ? iconSizeMap[size] : undefined;
---

<span class={classes}>
  {icon && iconSize && <Icon name={icon} size={iconSize} />}
  <slot />
</span>
