---
/**
 * LeftSidebar Component
 *
 * A unified left navigation sidebar that supports multiple themes (cp, vp, ppm, maconomy).
 * Shows only icons when collapsed, expands on hover to show icon + text labels.
 * Supports configurable sections and icons per theme.
 *
 * @prop {string} variant - Theme variant: 'cp' | 'vp' | 'ppm' | 'maconomy'
 * @prop {Array} sections - Optional custom sections configuration
 * @prop {string} class - Additional CSS classes to apply
 */
import Icon from './Icon.astro';
import Tooltip from './Tooltip.astro';

interface NavItem {
  icon: string;
  label: string;
  href?: string;
  active?: boolean;
  panelTitle?: string; // Panel title when item is clicked (defaults to label)
  panelIcon?: string; // Panel icon when item is clicked (defaults to item icon)
  panelContentId?: string; // Content identifier for contextual content
}

interface Section {
  items: NavItem[];
}

interface Props {
  variant?: 'cp' | 'vp' | 'ppm' | 'maconomy';
  sections?: Section[];
  class?: string;
}

const { variant = 'cp', sections, class: className = '' } = Astro.props;

// Default CP configuration (2 sections)
const cpSections: Section[] = [
  {
    items: [
      { icon: 'home', label: 'Welcome screen' },
      { icon: 'squares-2x2', label: 'Dashboard' },
      { icon: 'star', label: 'My menu' },
      { icon: 'clock', label: 'Recent' },
    ],
  },
  {
    items: [
      { icon: 'magnifying-glass', label: 'Search' },
      { icon: 'squares-plus', label: 'Command Center' },
      { icon: 'calculator', label: 'Accounting' },
      { icon: 'chart-bar', label: 'Planning' },
      { icon: 'document-arrow-down', label: 'Capture & contracts' },
      { icon: 'clipboard-document-list', label: 'Projects' },
      { icon: 'cube', label: 'Materials' },
      { icon: 'clock', label: 'Time & expense' },
      { icon: 'users', label: 'People' },
      { icon: 'document-chart-bar', label: 'Reports' },
      { icon: 'cog-6-tooth', label: 'Admin' },
    ],
  },
];

// Default PPM configuration (1 section)
const ppmSections: Section[] = [
  {
    items: [
      { icon: 'rectangle-group', label: 'Command Center', active: true },
      { icon: 'book-open', label: 'Programs' },
      { icon: 'briefcase', label: 'Portfolios' },
      { icon: 'building-office', label: 'Projects' },
      { icon: 'Risk Shield', label: 'Risk' },
      { icon: 'Report', label: 'Reports' },
      { icon: 'calendar-days', label: 'Calendars' },
      { icon: 'document', label: 'Codes' },
      { icon: 'wallet', label: 'Rates' },
      { icon: 'Resource', label: 'Resources' },
      { icon: 'cog-6-tooth', label: 'Settings' },
      { icon: 'plus', label: 'Add Menu' },
    ],
  },
];

// Default VP configuration (1 section - similar to PPM for now)
const vpSections: Section[] = [
  {
    items: [
      { icon: 'rectangle-group', label: 'Command Center', active: true },
      { icon: 'book-open', label: 'Programs' },
      { icon: 'briefcase', label: 'Portfolios' },
      { icon: 'building-office', label: 'Projects' },
      { icon: 'Risk Shield', label: 'Risk' },
      { icon: 'Report', label: 'Reports' },
      { icon: 'calendar-days', label: 'Calendars' },
      { icon: 'document', label: 'Codes' },
      { icon: 'wallet', label: 'Rates' },
      { icon: 'Resource', label: 'Resources' },
      { icon: 'cog-6-tooth', label: 'Settings' },
      { icon: 'plus', label: 'Add Menu' },
    ],
  },
];

// Default Maconomy configuration (1 section - similar to PPM for now)
const maconomySections: Section[] = [
  {
    items: [
      { icon: 'rectangle-group', label: 'Command Center', active: true },
      { icon: 'book-open', label: 'Programs' },
      { icon: 'briefcase', label: 'Portfolios' },
      { icon: 'building-office', label: 'Projects' },
      { icon: 'Risk Shield', label: 'Risk' },
      { icon: 'Report', label: 'Reports' },
      { icon: 'calendar-days', label: 'Calendars' },
      { icon: 'document', label: 'Codes' },
      { icon: 'wallet', label: 'Rates' },
      { icon: 'Resource', label: 'Resources' },
      { icon: 'cog-6-tooth', label: 'Settings' },
      { icon: 'plus', label: 'Add Menu' },
    ],
  },
];

// Get sections based on variant or use provided sections
const getSections = (): Section[] => {
  if (sections) return sections;
  
  switch (variant) {
    case 'cp':
      return cpSections;
    case 'ppm':
      return ppmSections;
    case 'vp':
      return vpSections;
    case 'maconomy':
      return maconomySections;
    default:
      return cpSections;
  }
};

const sidebarSections = getSections();

// If custom sections are provided, only render those
// Otherwise, render all variants and use CSS to show/hide based on theme
const shouldRenderAllVariants = !sections;
---

<nav class:list={['left-sidebar', `left-sidebar--${variant}`, className]} data-variant={variant}>
  {shouldRenderAllVariants ? (
    <>
      <!-- CP Variant (2 sections) -->
      <div class="left-sidebar__variant left-sidebar__variant--cp">
        {cpSections.map((section, sectionIndex) => (
          <div class="left-sidebar__section">
            {section.items.map((item) => {
              const panelTitle = item.panelTitle || item.label;
              const panelIcon = item.panelIcon || item.icon;
              const itemId = `left-sidebar-item-${sectionIndex}-${section.items.indexOf(item)}`;
              
              return (
                <a 
                  href={item.href || '#'} 
                  class:list={['left-sidebar__item', { 'left-sidebar__item--active': item.active }]}
                  data-panel-title={panelTitle}
                  data-panel-icon={panelIcon}
                  data-panel-content-id={item.panelContentId}
                  data-item-id={itemId}
                  data-left-sidebar-item
                >
                  <Tooltip text={item.label} position="right" class="left-sidebar__item-tooltip">
                    <span class="left-sidebar__icon">
                      <Icon name={item.icon} />
                    </span>
                  </Tooltip>
                  <span class="left-sidebar__label">{item.label}</span>
                </a>
              );
            })}
          </div>
        ))}
      </div>

      <!-- VP Variant (1 section) -->
      <div class="left-sidebar__variant left-sidebar__variant--vp">
        {vpSections.map((section, sectionIndex) => (
          <div class="left-sidebar__section">
            {section.items.map((item) => {
              const panelTitle = item.panelTitle || item.label;
              const panelIcon = item.panelIcon || item.icon;
              const itemId = `left-sidebar-item-${sectionIndex}-${section.items.indexOf(item)}`;
              
              return (
                <a 
                  href={item.href || '#'} 
                  class:list={['left-sidebar__item', { 'left-sidebar__item--active': item.active }]}
                  data-panel-title={panelTitle}
                  data-panel-icon={panelIcon}
                  data-panel-content-id={item.panelContentId}
                  data-item-id={itemId}
                  data-left-sidebar-item
                >
                  <Tooltip text={item.label} position="right" class="left-sidebar__item-tooltip">
                    <span class="left-sidebar__icon">
                      <Icon name={item.icon} />
                    </span>
                  </Tooltip>
                  <span class="left-sidebar__label">{item.label}</span>
                </a>
              );
            })}
          </div>
        ))}
      </div>

      <!-- PPM Variant (1 section) -->
      <div class="left-sidebar__variant left-sidebar__variant--ppm">
        {ppmSections.map((section, sectionIndex) => (
          <div class="left-sidebar__section">
            {section.items.map((item) => {
              const panelTitle = item.panelTitle || item.label;
              const panelIcon = item.panelIcon || item.icon;
              const itemId = `left-sidebar-item-${sectionIndex}-${section.items.indexOf(item)}`;
              
              return (
                <a 
                  href={item.href || '#'} 
                  class:list={['left-sidebar__item', { 'left-sidebar__item--active': item.active }]}
                  data-panel-title={panelTitle}
                  data-panel-icon={panelIcon}
                  data-panel-content-id={item.panelContentId}
                  data-item-id={itemId}
                  data-left-sidebar-item
                >
                  <Tooltip text={item.label} position="right" class="left-sidebar__item-tooltip">
                    <span class="left-sidebar__icon">
                      <Icon name={item.icon} />
                    </span>
                  </Tooltip>
                  <span class="left-sidebar__label">{item.label}</span>
                </a>
              );
            })}
          </div>
        ))}
      </div>

      <!-- Maconomy Variant (1 section) -->
      <div class="left-sidebar__variant left-sidebar__variant--maconomy">
        {maconomySections.map((section, sectionIndex) => (
          <div class="left-sidebar__section">
            {section.items.map((item) => {
              const panelTitle = item.panelTitle || item.label;
              const panelIcon = item.panelIcon || item.icon;
              const itemId = `left-sidebar-item-${sectionIndex}-${section.items.indexOf(item)}`;
              
              return (
                <a 
                  href={item.href || '#'} 
                  class:list={['left-sidebar__item', { 'left-sidebar__item--active': item.active }]}
                  data-panel-title={panelTitle}
                  data-panel-icon={panelIcon}
                  data-panel-content-id={item.panelContentId}
                  data-item-id={itemId}
                  data-left-sidebar-item
                >
                  <Tooltip text={item.label} position="right" class="left-sidebar__item-tooltip">
                    <span class="left-sidebar__icon">
                      <Icon name={item.icon} />
                    </span>
                  </Tooltip>
                  <span class="left-sidebar__label">{item.label}</span>
                </a>
              );
            })}
          </div>
        ))}
      </div>
    </>
  ) : (
    // Custom sections provided - render only those
    sidebarSections.map((section, sectionIndex) => (
      <div class="left-sidebar__section">
        {section.items.map((item) => {
          const panelTitle = item.panelTitle || item.label;
          const panelIcon = item.panelIcon || item.icon;
          const itemId = `left-sidebar-item-${sectionIndex}-${section.items.indexOf(item)}`;
          
          return (
            <a 
              href={item.href || '#'} 
              class:list={['left-sidebar__item', { 'left-sidebar__item--active': item.active }]}
              data-panel-title={panelTitle}
              data-panel-icon={panelIcon}
              data-panel-content-id={item.panelContentId}
              data-item-id={itemId}
              data-left-sidebar-item
            >
              <Tooltip text={item.label} position="right" class="left-sidebar__item-tooltip">
                <span class="left-sidebar__icon">
                  <Icon name={item.icon} />
                </span>
              </Tooltip>
              <span class="left-sidebar__label">{item.label}</span>
            </a>
          );
        })}
      </div>
    ))
  )}
</nav>

<style>
  /* Hide all variants by default */
  .left-sidebar__variant {
    display: none;
  }

  /* Show CP variant when CP theme is active */
  html.theme-cp .left-sidebar__variant--cp {
    display: contents;
  }

  /* Show VP variant when VP theme is active */
  html.theme-vp .left-sidebar__variant--vp {
    display: contents;
  }

  /* Show PPM variant when PPM theme is active */
  html.theme-ppm .left-sidebar__variant--ppm {
    display: contents;
  }

  /* Show Maconomy variant when Maconomy theme is active */
  html.theme-maconomy .left-sidebar__variant--maconomy {
    display: contents;
  }
</style>

<script>
  // Left sidebar panel functionality
  (function() {
    function initLeftSidebarPanel() {
      const leftSidebar = document.querySelector('.left-sidebar') as HTMLElement | null;
      if (!leftSidebar) return;

      const panelItems = leftSidebar.querySelectorAll('[data-left-sidebar-item]');
      const leftPanel = document.querySelector('.shell-panel--left') as HTMLElement | null;

      // Handle item clicks
      panelItems.forEach((item) => {
        const link = item as HTMLAnchorElement;
        
        link.addEventListener('click', (e) => {
          // Only handle if item has panel configuration
          if (!link.dataset.panelTitle) {
            return; // Let default link behavior happen
          }

          e.preventDefault();

          const title = link.dataset.panelTitle || '';
          const icon = link.dataset.panelIcon || '';
          const contentId = link.dataset.panelContentId;

          // Update panel dynamically
          if (leftPanel) {
            // Update title
            const titleElement = leftPanel.querySelector('.shell-panel__title') as HTMLElement | null;
            if (titleElement) {
              titleElement.textContent = title;
            }

            // Update icon - find the icon container and update the icon
            const iconContainer = leftPanel.querySelector('[data-panel-icon-container]') as HTMLElement | null;
            if (iconContainer) {
              // Find existing icon SVG or Icon element
              const existingIcon = iconContainer.querySelector('svg, [data-panel-icon]');
              if (existingIcon) {
                existingIcon.remove();
              }
              
              // Try to find and clone icon from the clicked item
              const sourceIcon = link.querySelector('.left-sidebar__icon svg') as HTMLElement | null;
              if (sourceIcon) {
                const clonedIcon = sourceIcon.cloneNode(true) as HTMLElement;
                // Ensure proper sizing for panel header
                if (clonedIcon.tagName === 'SVG') {
                  clonedIcon.setAttribute('width', '20');
                  clonedIcon.setAttribute('height', '20');
                }
                clonedIcon.setAttribute('data-panel-icon', icon || '');
                iconContainer.appendChild(clonedIcon);
                // Show the icon container
                iconContainer.style.display = 'flex';
              } else if (icon) {
                // If no source icon found but we have an icon name, set data attribute
                iconContainer.setAttribute('data-icon-name', icon);
                iconContainer.style.display = 'flex';
              } else {
                // Hide icon container if no icon
                iconContainer.style.display = 'none';
              }
            }

            // Update content if needed
            if (contentId) {
              leftPanel.setAttribute('data-panel-content-id', contentId);
            }

            // Add default demo content if content area is empty
            const contentArea = leftPanel.querySelector('.shell-panel__content') as HTMLElement | null;
            if (contentArea && !contentArea.hasChildNodes()) {
              contentArea.innerHTML = `
                <div style="padding: var(--space-4);">
                  <p style="color: var(--text-secondary); margin-bottom: var(--space-4);">
                    Panel content for: <strong>${title}</strong>
                  </p>
                  <p style="color: var(--text-secondary); font-size: var(--text-sm);">
                    This is contextual content that would be specific to the "${title}" menu item.
                    In a real application, this content would be dynamically loaded based on the selected item.
                  </p>
                </div>
              `;
            }

            // Open panel
            leftPanel.classList.add('shell-panel--open');
            leftPanel.setAttribute('data-open', 'true');

            // Set sidebar state
            leftSidebar.setAttribute('data-panel-open', 'true');

            // Set active item - clear both data-active and active class
            panelItems.forEach((i) => {
              i.removeAttribute('data-active');
              i.classList.remove('left-sidebar__item--active');
            });
            link.setAttribute('data-active', 'true');
            link.classList.remove('left-sidebar__item--active'); // Remove class-based active if present
          }
        });
      });

      // Handle panel close - listen for close events
      const closeButtons = document.querySelectorAll('[data-panel-close]');
      closeButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const panel = btn.closest('.shell-panel--left') as HTMLElement | null;
          if (panel && panel.classList.contains('shell-panel--open')) {
            // Close panel
            panel.classList.remove('shell-panel--open');
            panel.setAttribute('data-open', 'false');

            // Clear sidebar state
            leftSidebar.removeAttribute('data-panel-open');

            // Clear active item - clear both data-active and active class
            panelItems.forEach((i) => {
              i.removeAttribute('data-active');
              i.classList.remove('left-sidebar__item--active');
            });
          }
        });
      });
    }

    initLeftSidebarPanel();
    document.addEventListener('astro:page-load', initLeftSidebarPanel);
  })();
</script>
