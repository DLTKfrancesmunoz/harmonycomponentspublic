---
/**
 * Table Component
 *
 * Reusable table component with header variants and styling options.
 * Supports optional title bar and action bar via slots.
 * When sortColumns is provided, renders a built-in sortable header row (icons + aria-sort).
 */
import TableDataRegion from './TableDataRegion.astro';

export interface SortColumn {
  key: string;
  label: string;
  align?: 'left' | 'right';
  /** When variant is commandCenter, false hides the sort control for this column. */
  sortable?: boolean;
  /** When variant is commandCenter, false hides the filter control for this column. */
  filterable?: boolean;
}

export interface Props {
  headerVariant?: 'gray' | 'white' | 'none';
  /** 'commandCenter' applies full cell grid, same body sizing as default tables, default striped, and border-based row selection styling. */
  variant?: 'default' | 'commandCenter';
  striped?: boolean;
  reorderable?: boolean;
  grouped?: boolean;
  class?: string;
  sortColumns?: SortColumn[];
  sortColumn?: string | null;
  sortDirection?: 'asc' | 'desc' | null;
  /** Comma- or space-separated `data-row-id` values to expand on load (with `grouped`). */
  groupedDefaultExpanded?: string;
}

const {
  headerVariant = 'gray',
  variant: tableVariant = 'default',
  striped = false,
  reorderable = false,
  grouped = false,
  class: className = '',
  sortColumns,
  sortColumn = null,
  sortDirection = null,
  groupedDefaultExpanded = '',
} = Astro.props;

const isCommandCenter = tableVariant === 'commandCenter';
const effectiveStriped = isCommandCenter ? striped !== false : striped;
const hasCommandCenterSlot = isCommandCenter && Astro.slots.has('command-center-toolbar');
const hasCommandCenterAside = isCommandCenter && Astro.slots.has('command-center-aside');
const useCommandCenterDock = isCommandCenter && hasCommandCenterAside;
const hasFilterBar = Astro.slots.has('filter-bar');
const hasTitleBar = Astro.slots.has('title-bar-content') || Astro.slots.has('title-bar-icons');
const hasActionBar = Astro.slots.has('action-bar');
const hasHeaderSlot = Astro.slots.has('header');
const hasBodySlot = Astro.slots.has('body');
const useSortHeader = sortColumns && sortColumns.length > 0;
const useCommandCenterHeader = isCommandCenter && useSortHeader;

const classes = [
  'table',
  isCommandCenter ? 'table--command-center' : `table--header-${headerVariant}`,
  effectiveStriped && 'table--striped',
  reorderable && 'table--reorderable',
  grouped && 'table--grouped',
  className,
].filter(Boolean).join(' ');

const wrapperClass = [
  'table-wrapper',
  isCommandCenter && 'table-wrapper--command-center',
  hasCommandCenterSlot && 'table-wrapper--has-command-center-toolbar',
  hasCommandCenterAside && 'table-wrapper--has-command-center-aside',
]
  .filter(Boolean)
  .join(' ');

function getSortIcon(key: string) {
  if (sortColumn !== key) return 'chevron-up-down';
  return sortDirection === 'asc' ? 'chevron-up' : 'chevron-down';
}
function getAriaSort(key: string): 'ascending' | 'descending' | undefined {
  if (sortColumn !== key) return undefined;
  return sortDirection === 'asc' ? 'ascending' : 'descending';
}
function getSortLabel(key: string, label: string): string {
  if (sortColumn !== key) return `Sort by ${label}`;
  return `Sort by ${label} ${sortDirection === 'asc' ? 'ascending' : 'descending'}`;
}
---

<div
  class={wrapperClass}
  data-reorderable={reorderable || undefined}
  data-grouped={grouped || undefined}
  data-grouped-default-expanded={grouped && groupedDefaultExpanded ? groupedDefaultExpanded : undefined}
  data-table-variant={isCommandCenter ? 'commandCenter' : undefined}
>
  {reorderable && (
    <template class="table__grip-template">
      <button type="button" class="table__grip-handle" aria-label="Drag to reorder"></button>
    </template>
  )}
  {grouped && (
    <template class="table__expand-template">
      <button type="button" class="table__expand-btn" aria-label="Expand row" aria-expanded="false">
        <span class="table__expand-icon" aria-hidden="true"></span>
      </button>
    </template>
  )}
  {useCommandCenterDock ? (
    <div
      class:list={[
        'command-center-canvas',
        hasCommandCenterSlot ? 'command-center-canvas--with-toolbar' : 'command-center-canvas--no-toolbar',
      ]}
    >
      {hasCommandCenterSlot && (
        <>
          <div class="command-center-canvas__toolbar">
            <div class="table__command-center-toolbar">
              <slot name="command-center-toolbar" />
            </div>
          </div>
          <div class="command-center-canvas__spacer" aria-hidden="true"></div>
        </>
      )}
      <div class="command-center-canvas__main">
        <TableDataRegion
          tableClass={classes}
          hasFilterBar={hasFilterBar}
          hasTitleBar={hasTitleBar}
          hasActionBar={hasActionBar}
          hasHeaderSlot={hasHeaderSlot}
          hasBodySlot={hasBodySlot}
          useCommandCenterHeader={useCommandCenterHeader}
          useSortHeader={!!useSortHeader}
          reorderable={reorderable}
          isCommandCenter={isCommandCenter}
          grouped={grouped}
          sortColumns={sortColumns}
          sortColumn={sortColumn}
          sortDirection={sortDirection}
          getSortIcon={getSortIcon}
          getAriaSort={getAriaSort}
          getSortLabel={getSortLabel}
        >
          <div slot="filter-bar"><slot name="filter-bar" /></div>
          <div slot="title-bar-content"><slot name="title-bar-content" /></div>
          <div slot="title-bar-icons"><slot name="title-bar-icons" /></div>
          <div slot="action-bar"><slot name="action-bar" /></div>
          <div slot="header"><slot name="header" /></div>
          <div slot="body"><slot name="body" /></div>
        </TableDataRegion>
      </div>
      <div class="command-center-canvas__aside">
        <slot name="command-center-aside" />
      </div>
    </div>
  ) : (
    <div class="table__undocked-cluster" style="display: contents">
      {hasCommandCenterSlot && (
        <div class="table__command-center-toolbar">
          <slot name="command-center-toolbar" />
        </div>
      )}
      <TableDataRegion
        tableClass={classes}
        hasFilterBar={hasFilterBar}
        hasTitleBar={hasTitleBar}
        hasActionBar={hasActionBar}
        hasHeaderSlot={hasHeaderSlot}
        hasBodySlot={hasBodySlot}
        useCommandCenterHeader={useCommandCenterHeader}
        useSortHeader={!!useSortHeader}
        reorderable={reorderable}
        isCommandCenter={isCommandCenter}
        grouped={grouped}
        sortColumns={sortColumns}
        sortColumn={sortColumn}
        sortDirection={sortDirection}
        getSortIcon={getSortIcon}
        getAriaSort={getAriaSort}
        getSortLabel={getSortLabel}
      >
        <div slot="filter-bar"><slot name="filter-bar" /></div>
        <div slot="title-bar-content"><slot name="title-bar-content" /></div>
        <div slot="title-bar-icons"><slot name="title-bar-icons" /></div>
        <div slot="action-bar"><slot name="action-bar" /></div>
        <div slot="header"><slot name="header" /></div>
        <div slot="body"><slot name="body" /></div>
      </TableDataRegion>
    </div>
  )}
{reorderable && (
  <script>
    (function () {
      function initReorderableTables() {
        document.querySelectorAll('.table-wrapper[data-reorderable]').forEach(function (wrapper) {
          if (wrapper.dataset.reorderableInit) return;
          wrapper.dataset.reorderableInit = 'true';

          const template = wrapper.querySelector('template.table__grip-template');
          const table = wrapper.querySelector('table');
          const tbody = table?.querySelector('tbody');
          if (!tbody || !template) return;

          const rows = Array.from(tbody.querySelectorAll('tr'));
          let draggedRow = null;
          let draggedIndex = -1;

          rows.forEach(function (row, index) {
            if (row.classList.contains('table-row--total')) {
              const emptyTd = document.createElement('td');
              emptyTd.className = 'table__grip-cell table__grip-cell--placeholder';
              emptyTd.setAttribute('aria-hidden', 'true');
              row.insertBefore(emptyTd, row.firstChild);
              return;
            }

            const gripTd = document.createElement('td');
            gripTd.className = 'table__grip-cell';
            const gripBtn = template.content.cloneNode(true);
            gripTd.appendChild(gripBtn);
            row.insertBefore(gripTd, row.firstChild);

            row.setAttribute('draggable', 'true');
            row.dataset.rowIndex = String(index);

            row.addEventListener('dragstart', function (e) {
              draggedRow = row;
              draggedIndex = index;
              row.classList.add('table-row--dragging');
              e.dataTransfer.effectAllowed = 'move';
              e.dataTransfer.setData('text/plain', String(index));
              e.dataTransfer.setDragImage(row, 0, 0);
            });

            row.addEventListener('dragend', function () {
              row.classList.remove('table-row--dragging');
              draggedRow = null;
              draggedIndex = -1;
            });

            row.addEventListener('dragover', function (e) {
              e.preventDefault();
              e.dataTransfer.dropEffect = 'move';
              if (draggedRow && draggedRow !== row && !row.classList.contains('table-row--total')) {
                row.classList.add('table-row--drag-over');
              }
            });

            row.addEventListener('dragleave', function () {
              row.classList.remove('table-row--drag-over');
            });

            row.addEventListener('drop', function (e) {
              e.preventDefault();
              row.classList.remove('table-row--drag-over');
              if (!draggedRow || draggedRow === row || row.classList.contains('table-row--total')) return;
              const currentRows = Array.from(tbody.querySelectorAll('tr:not(.table-row--total)'));
              const fromIndex = currentRows.indexOf(draggedRow);
              const toIndex = currentRows.indexOf(row);
              if (fromIndex === toIndex) return;
              if (fromIndex < toIndex) {
                tbody.insertBefore(draggedRow, row.nextSibling);
              } else {
                tbody.insertBefore(draggedRow, row);
              }
              const newRows = Array.from(tbody.querySelectorAll('tr'));
              newRows.forEach(function (r, i) { r.dataset.rowIndex = String(i); });
              wrapper.dispatchEvent(new CustomEvent('table-reorder', {
                bubbles: true,
                detail: { fromIndex, toIndex }
              }));
            });
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initReorderableTables);
      } else {
        initReorderableTables();
      }
    })();
  </script>
)}
{grouped && (
  <script>
    (function () {
      const MAX_DEPTH = 4;
      function initGroupedTables() {
        document.querySelectorAll('.table-wrapper[data-grouped]').forEach(function (wrapper) {
          if (wrapper.dataset.groupedInit) return;
          wrapper.dataset.groupedInit = 'true';

          const template = wrapper.querySelector('template.table__expand-template');
          const table = wrapper.querySelector('table');
          const tbody = table?.querySelector('tbody');
          if (!tbody || !template) return;

          const isCC = wrapper.getAttribute('data-table-variant') === 'commandCenter';
          const expandedIds = new Set();
          var defaultExpandedAttr = wrapper.getAttribute('data-grouped-default-expanded');
          if (defaultExpandedAttr) {
            defaultExpandedAttr.split(/[\s,]+/).forEach(function (id) {
              var t = id.trim();
              if (t) expandedIds.add(t);
            });
          }

          function getRowId(row) {
            return row.getAttribute('data-row-id') || null;
          }
          function hasChildren(row) {
            return row.hasAttribute('data-has-children');
          }
          function getParentId(row) {
            return row.getAttribute('data-parent-id') || null;
          }
          function getDepth(row) {
            const d = parseInt(row.getAttribute('data-depth') || '0', 10);
            return Math.min(Math.max(d, 0), MAX_DEPTH);
          }

          function isVisible(row) {
            const parentId = getParentId(row);
            if (!parentId) return true;
            if (!expandedIds.has(parentId)) return false;
            const parentRow = tbody.querySelector('tr[data-row-id="' + parentId + '"]');
            return parentRow ? isVisible(parentRow) : false;
          }

          function updateVisibility() {
            tbody.querySelectorAll('tr[data-parent-id]').forEach(function (row) {
              row.style.display = isVisible(row) ? '' : 'none';
            });
          }

          function toggleExpanded(rowId) {
            if (expandedIds.has(rowId)) {
              expandedIds.delete(rowId);
            } else {
              expandedIds.add(rowId);
            }
            updateVisibility();
            const row = tbody.querySelector('tr[data-row-id="' + rowId + '"]');
            if (row) {
              const btn = row.querySelector('.table__expand-btn');
              if (btn) {
                btn.setAttribute('aria-expanded', expandedIds.has(rowId));
                btn.setAttribute('aria-label', expandedIds.has(rowId) ? 'Collapse row' : 'Expand row');
                btn.classList.toggle('table__expand-btn--expanded', expandedIds.has(rowId));
              }
            }
          }

          const rows = Array.from(tbody.querySelectorAll('tr'));
          rows.forEach(function (row) {
            if (row.classList.contains('table-row--total')) {
              if (isCC) {
                var tdf = row.querySelector('td');
                if (tdf && !tdf.querySelector('.table__cc-project-id-inner')) {
                  tdf.classList.add('table__cc-project-id-cell');
                  var inr = document.createElement('div');
                  inr.className = 'table__cc-project-id-inner';
                  var gg = document.createElement('span');
                  gg.className = 'table__cc-inline-expand-gutter';
                  gg.setAttribute('aria-hidden', 'true');
                  inr.appendChild(gg);
                  while (tdf.firstChild) inr.appendChild(tdf.removeChild(tdf.firstChild));
                  tdf.appendChild(inr);
                }
              } else {
                var emptyTd = document.createElement('td');
                emptyTd.className = 'table__expand-cell table__expand-cell--placeholder';
                emptyTd.setAttribute('aria-hidden', 'true');
                row.insertBefore(emptyTd, row.firstChild);
              }
              return;
            }

            if (isCC) {
              var firstTd = row.querySelector('td');
              if (!firstTd || firstTd.querySelector('.table__cc-project-id-inner')) return;
              var depth0 = getDepth(row);
              if (depth0 > 0) {
                firstTd.style.paddingLeft = 'calc(var(--space-4) * ' + depth0 + ' + var(--space-4))';
              }
              var inner = document.createElement('div');
              inner.className = 'table__cc-project-id-inner';
              var pId = getParentId(row);
              if (pId) {
                var gr = document.createElement('span');
                gr.className = 'table__cc-inline-expand-gutter';
                gr.setAttribute('aria-hidden', 'true');
                inner.appendChild(gr);
              } else if (hasChildren(row)) {
                var rid0 = getRowId(row);
                var wrap0 = document.createElement('span');
                wrap0.className = 'table__cc-inline-expand';
                var btnF = /** @type {DocumentFragment} */ (template.content.cloneNode(true));
                var btnB = btnF.querySelector('button');
                if (btnB && rid0) {
                  btnB.addEventListener('click', function () {
                    toggleExpanded(rid0);
                  });
                }
                wrap0.appendChild(btnF);
                inner.appendChild(wrap0);
              } else {
                var wlf = document.createElement('span');
                wlf.className = 'table__cc-inline-expand';
                wlf.setAttribute('aria-hidden', 'true');
                var ic = document.createElement('span');
                ic.className = 'table__expand-icon table__expand-icon--cc-leaf';
                wlf.appendChild(ic);
                inner.appendChild(wlf);
              }
              var rest = document.createDocumentFragment();
              while (firstTd.firstChild) {
                rest.appendChild(firstTd.removeChild(firstTd.firstChild));
              }
              var rch = /** @type {Node[]} */ (Array.prototype.slice.call(rest.childNodes));
              var vNode;
              if (rch.length === 1 && rch[0].nodeType === 3) {
                var a0 = document.createElement('a');
                a0.className = 'text-link';
                a0.href = '#';
                a0.addEventListener('click', function (e) {
                  e.preventDefault();
                });
                a0.textContent = (rch[0]).textContent;
                vNode = a0;
              } else if (rch.length === 1 && rch[0].nodeName === 'A') {
                (rch[0]).classList.add('text-link');
                vNode = rch[0];
              } else {
                var sp0 = document.createElement('span');
                sp0.className = 'table__cc-project-id-text';
                rch.forEach(function (n) {
                  sp0.appendChild(n);
                });
                vNode = sp0;
              }
              inner.appendChild(vNode);
              firstTd.classList.add('table__cc-project-id-cell');
              firstTd.appendChild(inner);
              return;
            }

            const expandTd = document.createElement('td');
            expandTd.className = 'table__expand-cell';

            if (hasChildren(row)) {
              const rowId = getRowId(row);
              const btn = template.content.cloneNode(true);
              const btnEl = btn.querySelector('button');
              if (btnEl) {
                btnEl.addEventListener('click', function () {
                  toggleExpanded(rowId);
                });
                expandTd.appendChild(btn);
              }
            }

            row.insertBefore(expandTd, row.firstChild);

            const depth = getDepth(row);
            if (depth > 0) {
              const firstContentCell = row.children[1];
              if (firstContentCell) {
                firstContentCell.style.paddingLeft = 'calc(var(--space-4) * ' + depth + ' + var(--space-4))';
              }
            }
          });

          function syncExpandButtons() {
            tbody.querySelectorAll('tr[data-has-children]').forEach(function (row) {
              var id = getRowId(row);
              if (!id) return;
              var btn = row.querySelector('.table__expand-btn');
              if (!btn) return;
              var isOpen = expandedIds.has(id);
              btn.setAttribute('aria-expanded', isOpen);
              btn.setAttribute('aria-label', isOpen ? 'Collapse row' : 'Expand row');
              if (isOpen) btn.classList.add('table__expand-btn--expanded');
              else btn.classList.remove('table__expand-btn--expanded');
            });
          }

          updateVisibility();
          syncExpandButtons();
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initGroupedTables);
      } else {
        initGroupedTables();
      }
    })();
  </script>
)}
<script>
  // Handle row selection and select-all for interactive tables with checkboxes
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.table').forEach((table) => {
      const checkboxes = table.querySelectorAll('.checkbox__input');
      checkboxes.forEach((checkbox) => {
        const isSelectAll =
          checkbox.getAttribute('name') === 'select-all' ||
          checkbox.closest('thead');
        const row = checkbox.closest('tr');
        if (isSelectAll) {
          checkbox.addEventListener('change', () => {
            const rowCheckboxes = table.querySelectorAll(
              'tbody .checkbox__input'
            );
            rowCheckboxes.forEach((cb) => {
              cb.checked = checkbox.checked;
              const r = cb.closest('tr');
              if (r) r.classList.toggle('table-row--selected', checkbox.checked);
            });
          });
        } else if (row && row.closest('tbody')) {
          if (checkbox.checked) row.classList.add('table-row--selected');
          checkbox.addEventListener('change', () => {
            row.classList.toggle('table-row--selected', checkbox.checked);
          });
        }
      });
    });
  });
</script>
</div>
