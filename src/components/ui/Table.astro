---
/**
 * Table Component
 *
 * Reusable table component with header variants and styling options.
 * Supports optional title bar and action bar via slots.
 * When sortColumns is provided, renders a built-in sortable header row (icons + aria-sort).
 */
import Icon from './Icon.astro';

export interface SortColumn {
  key: string;
  label: string;
  align?: 'left' | 'right';
}

export interface Props {
  headerVariant?: 'gray' | 'white' | 'none';
  striped?: boolean;
  reorderable?: boolean;
  grouped?: boolean;
  class?: string;
  sortColumns?: SortColumn[];
  sortColumn?: string | null;
  sortDirection?: 'asc' | 'desc' | null;
}

const {
  headerVariant = 'gray',
  striped = false,
  reorderable = false,
  grouped = false,
  class: className = '',
  sortColumns,
  sortColumn = null,
  sortDirection = null,
} = Astro.props;

const classes = [
  'table',
  `table--header-${headerVariant}`,
  striped && 'table--striped',
  reorderable && 'table--reorderable',
  grouped && 'table--grouped',
  className,
].filter(Boolean).join(' ');

const hasFilterBar = Astro.slots.has('filter-bar');
const hasTitleBar = Astro.slots.has('title-bar-content') || Astro.slots.has('title-bar-icons');
const hasActionBar = Astro.slots.has('action-bar');
const hasHeaderSlot = Astro.slots.has('header');
const hasBodySlot = Astro.slots.has('body');
const useSortHeader = sortColumns && sortColumns.length > 0;

function getSortIcon(key: string) {
  if (sortColumn !== key) return 'chevron-up-down';
  return sortDirection === 'asc' ? 'chevron-up' : 'chevron-down';
}
function getAriaSort(key: string): 'ascending' | 'descending' | undefined {
  if (sortColumn !== key) return undefined;
  return sortDirection === 'asc' ? 'ascending' : 'descending';
}
function getSortLabel(key: string, label: string): string {
  if (sortColumn !== key) return `Sort by ${label}`;
  return `Sort by ${label} ${sortDirection === 'asc' ? 'ascending' : 'descending'}`;
}
---

<div class="table-wrapper" data-reorderable={reorderable || undefined} data-grouped={grouped || undefined}>
  {reorderable && (
    <template class="table__grip-template">
      <button type="button" class="table__grip-handle" aria-label="Drag to reorder"></button>
    </template>
  )}
  {grouped && (
    <template class="table__expand-template">
      <button type="button" class="table__expand-btn" aria-label="Expand row" aria-expanded="false">
        <span class="table__expand-icon" aria-hidden="true"></span>
      </button>
    </template>
  )}
  <!-- Optional Filter Bar -->
  {hasFilterBar && (
    <div class="table__filter-bar">
      <slot name="filter-bar" />
    </div>
  )}

  <!-- Optional Title Bar -->
  {hasTitleBar && (
    <div class="table__title-bar">
      <div class="table__title-bar-content">
        {Astro.slots.has('title-bar-content') && (
          <slot name="title-bar-content" />
        )}
        {Astro.slots.has('title-bar-icons') && (
          <div class="table__title-bar-icons">
            <slot name="title-bar-icons" />
          </div>
        )}
      </div>
    </div>
  )}
  
  <!-- Optional Action Bar -->
  {hasActionBar && (
    <div class="table__action-bar">
      <slot name="action-bar" />
    </div>
  )}
  
  <!-- Table -->
  <table class={classes}>
    <thead>
      {useSortHeader ? (
        <tr>
          {reorderable && (
            <th class="table__grip-column" scope="col" aria-label="Reorder"></th>
          )}
          {grouped && (
            <th class="table__expand-column" scope="col" aria-label="Expand"></th>
          )}
          {sortColumns!.map((col) => (
            <th
              scope="col"
              class={col.align === 'right' ? 'text-right' : 'text-left'}
              aria-sort={getAriaSort(col.key)}
            >
              <button type="button" class="table__sort-header" aria-label={getSortLabel(col.key, col.label)}>
                {col.label}
                <Icon name={getSortIcon(col.key)} size="sm" />
              </button>
            </th>
          ))}
        </tr>
      ) : hasHeaderSlot ? (
        <slot name="header" />
      ) : (
        <tr>
          {reorderable && (
            <th class="table__grip-column" scope="col" aria-label="Reorder"></th>
          )}
          {grouped && (
            <th class="table__expand-column" scope="col" aria-label="Expand"></th>
          )}
          <th scope="col">Column</th>
        </tr>
      )}
    </thead>
    <tbody>
      {hasBodySlot ? (
        <slot name="body" />
      ) : (
        <tr><td>Table body content. Override by passing header and body slots.</td></tr>
      )}
    </tbody>
  </table>
</div>

{reorderable && (
  <script>
    (function () {
      function initReorderableTables() {
        document.querySelectorAll('.table-wrapper[data-reorderable]').forEach(function (wrapper) {
          if (wrapper.dataset.reorderableInit) return;
          wrapper.dataset.reorderableInit = 'true';

          const template = wrapper.querySelector('template.table__grip-template');
          const table = wrapper.querySelector('table');
          const tbody = table?.querySelector('tbody');
          if (!tbody || !template) return;

          const rows = Array.from(tbody.querySelectorAll('tr'));
          let draggedRow = null;
          let draggedIndex = -1;

          rows.forEach(function (row, index) {
            if (row.classList.contains('table-row--total')) {
              const emptyTd = document.createElement('td');
              emptyTd.className = 'table__grip-cell table__grip-cell--placeholder';
              emptyTd.setAttribute('aria-hidden', 'true');
              row.insertBefore(emptyTd, row.firstChild);
              return;
            }

            const gripTd = document.createElement('td');
            gripTd.className = 'table__grip-cell';
            const gripBtn = template.content.cloneNode(true);
            gripTd.appendChild(gripBtn);
            row.insertBefore(gripTd, row.firstChild);

            row.setAttribute('draggable', 'true');
            row.dataset.rowIndex = String(index);

            row.addEventListener('dragstart', function (e) {
              draggedRow = row;
              draggedIndex = index;
              row.classList.add('table-row--dragging');
              e.dataTransfer.effectAllowed = 'move';
              e.dataTransfer.setData('text/plain', String(index));
              e.dataTransfer.setDragImage(row, 0, 0);
            });

            row.addEventListener('dragend', function () {
              row.classList.remove('table-row--dragging');
              draggedRow = null;
              draggedIndex = -1;
            });

            row.addEventListener('dragover', function (e) {
              e.preventDefault();
              e.dataTransfer.dropEffect = 'move';
              if (draggedRow && draggedRow !== row && !row.classList.contains('table-row--total')) {
                row.classList.add('table-row--drag-over');
              }
            });

            row.addEventListener('dragleave', function () {
              row.classList.remove('table-row--drag-over');
            });

            row.addEventListener('drop', function (e) {
              e.preventDefault();
              row.classList.remove('table-row--drag-over');
              if (!draggedRow || draggedRow === row || row.classList.contains('table-row--total')) return;
              const currentRows = Array.from(tbody.querySelectorAll('tr:not(.table-row--total)'));
              const fromIndex = currentRows.indexOf(draggedRow);
              const toIndex = currentRows.indexOf(row);
              if (fromIndex === toIndex) return;
              if (fromIndex < toIndex) {
                tbody.insertBefore(draggedRow, row.nextSibling);
              } else {
                tbody.insertBefore(draggedRow, row);
              }
              const newRows = Array.from(tbody.querySelectorAll('tr'));
              newRows.forEach(function (r, i) { r.dataset.rowIndex = String(i); });
              wrapper.dispatchEvent(new CustomEvent('table-reorder', {
                bubbles: true,
                detail: { fromIndex, toIndex }
              }));
            });
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initReorderableTables);
      } else {
        initReorderableTables();
      }
    })();
  </script>
)}
{grouped && (
  <script>
    (function () {
      const MAX_DEPTH = 4;
      function initGroupedTables() {
        document.querySelectorAll('.table-wrapper[data-grouped]').forEach(function (wrapper) {
          if (wrapper.dataset.groupedInit) return;
          wrapper.dataset.groupedInit = 'true';

          const template = wrapper.querySelector('template.table__expand-template');
          const table = wrapper.querySelector('table');
          const tbody = table?.querySelector('tbody');
          if (!tbody || !template) return;

          const expandedIds = new Set();

          function getRowId(row) {
            return row.getAttribute('data-row-id') || null;
          }
          function hasChildren(row) {
            return row.hasAttribute('data-has-children');
          }
          function getParentId(row) {
            return row.getAttribute('data-parent-id') || null;
          }
          function getDepth(row) {
            const d = parseInt(row.getAttribute('data-depth') || '0', 10);
            return Math.min(Math.max(d, 0), MAX_DEPTH);
          }

          function isVisible(row) {
            const parentId = getParentId(row);
            if (!parentId) return true;
            if (!expandedIds.has(parentId)) return false;
            const parentRow = tbody.querySelector('tr[data-row-id="' + parentId + '"]');
            return parentRow ? isVisible(parentRow) : false;
          }

          function updateVisibility() {
            tbody.querySelectorAll('tr[data-parent-id]').forEach(function (row) {
              row.style.display = isVisible(row) ? '' : 'none';
            });
          }

          function toggleExpanded(rowId) {
            if (expandedIds.has(rowId)) {
              expandedIds.delete(rowId);
            } else {
              expandedIds.add(rowId);
            }
            updateVisibility();
            const row = tbody.querySelector('tr[data-row-id="' + rowId + '"]');
            if (row) {
              const btn = row.querySelector('.table__expand-btn');
              if (btn) {
                btn.setAttribute('aria-expanded', expandedIds.has(rowId));
                btn.setAttribute('aria-label', expandedIds.has(rowId) ? 'Collapse row' : 'Expand row');
                btn.classList.toggle('table__expand-btn--expanded', expandedIds.has(rowId));
              }
            }
          }

          const rows = Array.from(tbody.querySelectorAll('tr'));
          rows.forEach(function (row) {
            if (row.classList.contains('table-row--total')) {
              const emptyTd = document.createElement('td');
              emptyTd.className = 'table__expand-cell table__expand-cell--placeholder';
              emptyTd.setAttribute('aria-hidden', 'true');
              row.insertBefore(emptyTd, row.firstChild);
              return;
            }

            const expandTd = document.createElement('td');
            expandTd.className = 'table__expand-cell';

            if (hasChildren(row)) {
              const rowId = getRowId(row);
              const btn = template.content.cloneNode(true);
              const btnEl = btn.querySelector('button');
              btnEl.addEventListener('click', function () {
                toggleExpanded(rowId);
              });
              expandTd.appendChild(btn);
            }

            row.insertBefore(expandTd, row.firstChild);

            const depth = getDepth(row);
            if (depth > 0) {
              const firstContentCell = row.children[1];
              if (firstContentCell) {
                firstContentCell.style.paddingLeft = 'calc(var(--space-4) * ' + depth + ' + var(--space-4))';
              }
            }
          });

          updateVisibility();
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initGroupedTables);
      } else {
        initGroupedTables();
      }
    })();
  </script>
)}
<script>
  // Handle row selection and select-all for interactive tables with checkboxes
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.table').forEach((table) => {
      const checkboxes = table.querySelectorAll('.checkbox__input');
      checkboxes.forEach((checkbox) => {
        const isSelectAll =
          checkbox.getAttribute('name') === 'select-all' ||
          checkbox.closest('thead');
        const row = checkbox.closest('tr');
        if (isSelectAll) {
          checkbox.addEventListener('change', () => {
            const rowCheckboxes = table.querySelectorAll(
              'tbody .checkbox__input'
            );
            rowCheckboxes.forEach((cb) => {
              cb.checked = checkbox.checked;
              const r = cb.closest('tr');
              if (r) r.classList.toggle('table-row--selected', checkbox.checked);
            });
          });
        } else if (row && row.closest('tbody')) {
          if (checkbox.checked) row.classList.add('table-row--selected');
          checkbox.addEventListener('change', () => {
            row.classList.toggle('table-row--selected', checkbox.checked);
          });
        }
      });
    });
  });
</script>
