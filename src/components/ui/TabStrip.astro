---
/**
 * TabStrip Component
 *
 * A flexible tab component with icon positioning, overflow handling, and Add Tab functionality.
 *
 * @usagePattern icon-position-consistency All tabs must use either inline icon positioning (left/right) OR stacked (top), but cannot mix both. Use the component-level iconPosition prop to enforce consistency across all tabs, or ensure individual tab iconPosition values follow this rule. The component will log a warning if mixed positions are detected (lines 52-68).
 * @usagePattern overflow-modes The overflowMode prop has three behaviors: 'auto' (default) uses ResizeObserver to automatically detect and move tabs to dropdown when they don't fit; 'manual' requires you to provide overflowTabs prop with specific tabs to show in dropdown; 'none' disables overflow handling entirely and may cause horizontal scrolling.
 * @usagePattern named-slots-limitation Custom tab content can only be provided via named slots tab-0 through tab-9, supporting a maximum of 10 tabs with custom content. This is an Astro limitation requiring static slot names. For tabs beyond index 9, only the standard tab rendering is available.
 * @usagePattern custom-events TabStrip dispatches: 'tab-strip:tab-selected', 'tab-strip:close-tab', 'tab-strip:open-new-window', 'tab-strip:set-default' (from per-tab toolbar, ⋮ menu, or More overflow). 'tab-strip:add-tab' when Add Tab is clicked.
 *
 * @prop {Array} tabs - Array of tab objects
 * @prop {boolean} showAddTab - Whether to show "Add Tab" button (default: false)
 * @prop {string} addTabLabel - Label for Add Tab button (default: "Add Tab")
 * @prop {string} overflowMode - 'auto' | 'manual' | 'none' (default: 'auto')
 * @prop {Array} overflowTabs - Manual override for overflow tabs (default: [])
 * @prop {string} variant - 'default' | 'compact' | 'pill' (default: 'default'). The pill selected style applies only when the document uses the VP theme (html.theme-vp); other themes keep the standard underline.
 * @prop {string} iconPosition - Enforce consistent icon position for all tabs: 'left' | 'right' | 'top' (optional)
 * @prop {boolean} showTabOpenInNew - Default: show per-tab open-in-new-window control (overridable per tab)
 * @prop {boolean} showTabClose - Default: show per-tab close control
 * @prop {boolean} showTabOverflowMenu - Default: show per-tab ⋮ menu (open/close/set default omitted from menu when shown inline)
 * @prop {string} class - Additional CSS classes
 */
import Icon from './Icon.astro';

export interface Tab {
  id: string;
  label: string;
  icon?: string;
  iconPosition?: 'left' | 'right' | 'top';
  active?: boolean;
  disabled?: boolean;
  href?: string;
  /** Override component default for this tab */
  showOpenInNewWindow?: boolean;
  showClose?: boolean;
  showMenu?: boolean;
}

interface Props {
  tabs: Tab[];
  showAddTab?: boolean;
  addTabLabel?: string;
  overflowMode?: 'auto' | 'manual' | 'none';
  overflowTabs?: Tab[];
  variant?: 'default' | 'compact' | 'pill';
  iconPosition?: 'left' | 'right' | 'top';
  showTabOpenInNew?: boolean;
  showTabClose?: boolean;
  showTabOverflowMenu?: boolean;
  class?: string;
}

const {
  tabs = [],
  showAddTab = false,
  addTabLabel = 'Add Tab',
  overflowMode = 'auto',
  overflowTabs = [],
  variant = 'default',
  iconPosition: componentIconPosition,
  showTabOpenInNew = false,
  showTabClose = false,
  showTabOverflowMenu = false,
  class: className = ''
} = Astro.props;

const componentId = `tabstrip-${Math.random().toString(36).substr(2, 9)}`;

// Validate icon positions: ensure all tabs use either inline (left/right) OR stacked (top)
// Cannot mix inline with stacked
if (tabs.length > 0 && !componentIconPosition) {
  const positions = tabs
    .filter(tab => tab.icon)
    .map(tab => tab.iconPosition || 'left');
  
  const hasTop = positions.includes('top');
  const hasInline = positions.some(pos => pos === 'left' || pos === 'right');
  
  if (hasTop && hasInline) {
    console.warn(
      `TabStrip: Mixed icon positions detected. All tabs must use either inline (left/right) or stacked (top) positions, not both. ` +
      `Consider using the component-level 'iconPosition' prop to enforce consistency.`
    );
  }
}
---

<div 
  class={`tabstrip ${variant === 'compact' ? 'tabstrip--compact' : ''} ${variant === 'pill' ? 'tabstrip--pill' : ''} ${className}`.trim()}
  data-tabstrip
  data-variant={variant}
  data-overflow-mode={overflowMode}
  id={componentId}
>
  <nav role="tablist" aria-label="Tabs" class="tabstrip__nav">
    <div class="tabstrip__container">
      <div class="tabstrip__tabs" data-tabstrip-tabs>
        {tabs.map((tab) => {
          const iconPosition = componentIconPosition || tab.iconPosition || 'left';
          const iconModifier = iconPosition === 'top' ? 'tab--icon-top' :
                              iconPosition === 'right' ? 'tab--icon-right' :
                              'tab--icon-left';

          const effOpen = tab.showOpenInNewWindow !== undefined ? tab.showOpenInNewWindow : showTabOpenInNew;
          const effClose = tab.showClose !== undefined ? tab.showClose : showTabClose;
          const effMenu = tab.showMenu !== undefined ? tab.showMenu : showTabOverflowMenu;
          const showToolbar = effOpen || effClose || effMenu;
          const menuOpenInNew = effMenu && !effOpen;
          const menuClose = effMenu && !effClose;
          const menuSetDefault = effMenu;

          const tabContent = (
            <>
              {tab.icon && iconPosition === 'top' && (
                <span class="tab__icon-wrapper">
                  <Icon name={tab.icon} size="sm" class="tab__icon" />
                </span>
              )}
              {tab.icon && (iconPosition === 'left' || iconPosition === 'top') && iconPosition !== 'top' && (
                <Icon name={tab.icon} size="sm" class="tab__icon" />
              )}
              <span class="tab__label">{tab.label}</span>
              {tab.icon && iconPosition === 'right' && (
                <Icon name={tab.icon} size="sm" class="tab__icon" />
              )}
            </>
          );

          const tabClasses = [
            'tab',
            tab.active && 'is-active',
            tab.disabled && 'tab--disabled',
            iconModifier
          ].filter(Boolean);

          const tabControl = tab.href ? (
            <a
              href={tab.href}
              role="tab"
              aria-selected={tab.active ? 'true' : 'false'}
              aria-disabled={tab.disabled ? 'true' : 'false'}
              class:list={tabClasses}
              tabindex={tab.active && !tab.disabled ? 0 : -1}
              data-tab-id={tab.id}
              data-tab-icon={tab.icon || ''}
            >
              {tabContent}
            </a>
          ) : (
            <button
              type="button"
              role="tab"
              aria-selected={tab.active ? 'true' : 'false'}
              aria-disabled={tab.disabled ? 'true' : 'false'}
              class:list={tabClasses}
              disabled={tab.disabled}
              tabindex={tab.active && !tab.disabled ? 0 : -1}
              data-tab-id={tab.id}
              data-tab-icon={tab.icon || ''}
            >
              {tabContent}
            </button>
          );

          return (
            <div class="tabstrip__tab-cell" data-tabstrip-tab-cell data-tab-id={tab.id}>
              {tabControl}
              {showToolbar && (
                <div class="tabstrip__tab-toolbar" data-tabstrip-tab-toolbar>
                  {effOpen && (
                    <button
                      type="button"
                      class="tabstrip__tab-action-btn"
                      data-tab-id={tab.id}
                      data-action="open-new-window"
                      aria-label={`Open ${tab.label} in new window`}
                      title="Open in new window"
                    >
                      <Icon name="arrow-top-right-on-square" size="sm" />
                    </button>
                  )}
                  {effClose && (
                    <button
                      type="button"
                      class="tabstrip__tab-action-btn"
                      data-tab-id={tab.id}
                      data-action="close-tab"
                      aria-label={`Close ${tab.label}`}
                      title="Close"
                    >
                      <Icon name="x-mark" size="sm" />
                    </button>
                  )}
                  {effMenu && (
                    <div class="tabstrip__tab-menu-wrapper" data-tabstrip-per-tab-menu>
                      <button
                        type="button"
                        class="tabstrip__tab-action-btn"
                        aria-haspopup="true"
                        aria-expanded="false"
                        aria-label={`More actions for ${tab.label}`}
                        data-tabstrip-per-tab-menu-btn
                      >
                        <Icon name="ellipsis-vertical" size="sm" />
                      </button>
                      <div
                        class="tabstrip__dropdown tabstrip__dropdown--per-tab"
                        role="menu"
                        aria-label={`${tab.label} tab actions`}
                        data-tabstrip-per-tab-dropdown
                      >
                        {menuOpenInNew && (
                          <button
                            type="button"
                            class="tabstrip__dropdown-menu-item"
                            role="menuitem"
                            data-tab-id={tab.id}
                            data-action="open-new-window"
                          >
                            Open in new window
                          </button>
                        )}
                        {menuClose && (
                          <button
                            type="button"
                            class="tabstrip__dropdown-menu-item"
                            role="menuitem"
                            data-tab-id={tab.id}
                            data-action="close-tab"
                          >
                            Close tab
                          </button>
                        )}
                        {menuSetDefault && (
                          <button
                            type="button"
                            class="tabstrip__dropdown-menu-item"
                            role="menuitem"
                            data-tab-id={tab.id}
                            data-action="set-default"
                          >
                            Set as default
                          </button>
                        )}
                      </div>
                    </div>
                  )}
                </div>
              )}
            </div>
          );
        })}
      </div>

      {showAddTab && (
        <button
          type="button"
          class="tab tabstrip__add"
          aria-label={addTabLabel}
          data-tabstrip-add
        >
          <Icon name="plus" size="sm" />
          <span>{addTabLabel}</span>
        </button>
      )}

      {overflowMode !== 'none' && (
        <div class="tabstrip__more-wrapper" data-tabstrip-more style="display: none;">
          <button
            type="button"
            class="tab tabstrip__more"
            aria-label="Show more tabs"
            aria-haspopup="true"
            aria-expanded="false"
            data-tabstrip-more-btn
          >
            <span data-tabstrip-more-label>More (0)</span>
            <Icon name="ellipsis-horizontal" size="sm" />
          </button>

          <div class="tabstrip__dropdown" role="menu" aria-label="Overflow tabs menu" data-tabstrip-dropdown>
            <div class="tabstrip__dropdown-section" data-tabstrip-dropdown-items>
              {overflowTabs.length > 0 && overflowTabs.map((tab) => (
                <div
                  class={`tabstrip__dropdown-item ${tab.active ? 'is-active' : ''}`}
                  role="menuitem"
                >
                  <button
                    type="button"
                    class="tabstrip__dropdown-item-label"
                    data-tab-id={tab.id}
                    data-action="select-tab"
                  >
                    {tab.icon && (
                      <Icon name={tab.icon} size="sm" class="tabstrip__dropdown-item-icon" />
                    )}
                    <span>{tab.label}</span>
                  </button>
                  <div class="tabstrip__dropdown-item-actions">
                    <button
                      type="button"
                      class="tabstrip__dropdown-action-btn"
                      data-tab-id={tab.id}
                      data-action="open-new-window"
                      aria-label={`Open ${tab.label} in new window`}
                      title="Open in new window"
                    >
                      <Icon name="arrow-top-right-on-square" size="sm" />
                    </button>
                    <button
                      type="button"
                      class="tabstrip__dropdown-action-btn"
                      data-tab-id={tab.id}
                      data-action="close-tab"
                      aria-label={`Close ${tab.label}`}
                      title="Close"
                    >
                      <Icon name="x-mark" size="sm" />
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}
    </div>
  </nav>
</div>

<style>
  .tabstrip {
    width: 100%;
  }

  .tabstrip__nav {
    width: 100%;
  }

  .tabstrip__container {
    display: flex;
    align-items: center;
    width: 100%;
    position: relative;
    border-bottom: 1px solid var(--border-color);
  }

  /* overflow-x must not be `hidden` (or `auto`) with overflow-y visible — spec forces y to `auto`
     and clips per-tab ⋮ menus. `clip` trims horizontal overflow without breaking y: visible. */
  .tabstrip__tabs {
    display: flex;
    flex: 1;
    gap: var(--space-1);
    min-width: 0;
    overflow-x: clip;
    overflow-y: visible;
    align-items: stretch;
  }

  .tabstrip__tab-cell {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    flex-shrink: 0;
    min-width: 0;
    max-width: 100%;
  }

  .tabstrip__tab-cell .tab {
    flex: 1;
    min-width: 0;
  }

  .tabstrip__tab-toolbar {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-1);
    flex-shrink: 0;
    padding-left: var(--space-1);
    padding-right: var(--space-1);
  }

  .tabstrip__tab-menu-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .tabstrip__tab-action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-1);
    border: none;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .tabstrip__tab-action-btn:hover {
    background-color: var(--hover-bg);
    color: var(--text-primary);
  }

  :global(.tabstrip__dropdown--per-tab) {
    display: none;
    position: absolute;
    bottom: 100%;
    right: 0;
    left: auto;
    margin-bottom: var(--space-2);
    min-width: var(--dropdown-min-width);
    background-color: var(--card-bg);
    border: var(--border-width-thin) solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-dropdown);
    padding: var(--space-1) 0;
    z-index: calc(var(--z-dropdown) + 1);
    max-height: var(--dropdown-max-height);
    overflow-y: auto;
  }

  .tabstrip__tab-menu-wrapper.is-open :global(.tabstrip__dropdown--per-tab) {
    display: block;
  }

  :global(.tabstrip__dropdown-menu-item) {
    display: block;
    width: 100%;
    text-align: left;
    padding: var(--space-2) var(--space-4);
    border: none;
    background: transparent;
    color: var(--text-primary);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: background-color var(--transition-fast);
  }

  :global(.tabstrip__dropdown-menu-item:hover) {
    background-color: var(--hover-bg);
  }

  .tabstrip__add {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-left: var(--space-2);
    flex-shrink: 0;
  }

  .tabstrip__more-wrapper {
    position: relative;
    display: inline-flex;
    margin-left: var(--space-2);
    flex-shrink: 0;
  }

  .tabstrip__more {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* Dropdown menu */
  :global(.tabstrip__dropdown) {
    display: none;
    position: absolute;
    bottom: 100%;
    left: 0;
    margin-bottom: var(--space-2);
    min-width: var(--dropdown-min-width);
    background-color: var(--card-bg);
    border: var(--border-width-thin) solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-dropdown);
    padding: var(--space-1) 0;
    z-index: var(--z-dropdown);
    max-height: var(--dropdown-max-height);
    overflow-y: auto;
  }

  .tabstrip__more-wrapper[aria-expanded="true"] :global(.tabstrip__dropdown) {
    display: block;
  }

  /* Dropdown items */
  :global(.tabstrip__dropdown-item) {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    color: var(--text-primary);
    transition: background-color var(--transition-fast);
    gap: var(--space-2);
  }

  :global(.tabstrip__dropdown-item:hover) {
    background-color: var(--hover-bg);
  }

  :global(.tabstrip__dropdown-item.is-active) {
    background-color: var(--theme-primary-light);
  }

  :global(.tabstrip__dropdown-item.is-active .tabstrip__dropdown-item-label) {
    color: var(--theme-primary);
  }

  :global(.tabstrip__dropdown-item-label) {
    flex: 1;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-align: left;
    padding: 0;
    border: none;
    background: transparent;
    color: inherit;
    font-size: inherit;
    cursor: pointer;
    min-width: 0;
  }

  :global(.tabstrip__dropdown-item-label span) {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.tabstrip__dropdown-item-icon) {
    flex-shrink: 0;
  }

  :global(.tabstrip__dropdown-item-actions) {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    margin-left: var(--space-2);
    flex-shrink: 0;
  }

  :global(.tabstrip__dropdown-action-btn) {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-1);
    border: none;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  :global(.tabstrip__dropdown-action-btn:hover) {
    background-color: var(--hover-bg);
    color: var(--text-primary);
  }

  /* Tab base and active styles */
  .tab {
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-secondary);
    border: none;
    border-bottom: var(--border-width-standard) solid transparent;
    margin-bottom: -1px;
    cursor: pointer;
    transition: all var(--transition-fast);
    background: transparent;
    text-decoration: none;
    font-family: var(--font-sans);
  }

  .tab:hover {
    color: var(--text-primary);
  }

  .tab.is-active {
    color: var(--theme-primary);
    border-bottom: var(--border-width-thick) solid var(--theme-primary);
  }

  .tab:disabled,
  .tab--disabled {
    color: var(--text-muted);
    cursor: not-allowed;
    opacity: 0.6;
  }

  /* Icon positioning variants */
  .tab--icon-top {
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .tab--icon-top .tab__icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tab--icon-left,
  .tab--icon-right {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .tab--icon-right {
    flex-direction: row-reverse;
  }

  .tab__icon {
    flex-shrink: 0;
  }

  .tab__icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tab__label {
    white-space: nowrap;
  }

  /* Compact variant - styles applied via .tabstrip--compact for exact spec discovery */
  .tabstrip--compact .tab,
  .tabstrip[data-variant="compact"] .tab {
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-13);
  }

  .tabstrip--compact :global(.tabstrip__dropdown-item),
  .tabstrip[data-variant="compact"] :global(.tabstrip__dropdown-item) {
    padding: var(--space-1-5) var(--space-3);
    font-size: var(--text-xs);
  }

  /* VP theme only: pill selected state (mirrors src/styles/components.css) */
  html.theme-vp .tabstrip--pill .tabstrip__container {
    align-items: flex-end;
    padding-bottom: var(--space-2);
  }

  html.theme-vp .tabstrip--pill .tabstrip__tabs {
    gap: var(--space-2);
  }

  html.theme-vp .tabstrip--pill .tab {
    border-bottom: none;
    margin-bottom: 0;
    border-radius: var(--radius-08);
    padding: var(--space-1-5) var(--space-2);
    color: var(--theme-primary);
  }

  html.theme-vp .tabstrip--pill .tab__label {
    line-height: 1;
  }

  html.theme-vp .tabstrip--pill .tab:hover:not(:disabled):not(.tab--disabled):not(.is-active) {
    color: var(--theme-primary-hover);
  }

  html.theme-vp .tabstrip--pill .tab.is-active {
    color: var(--text-inverse);
    background-color: var(--theme-primary);
    border-bottom: none;
    font-weight: var(--font-semibold);
  }

  html.theme-vp .tabstrip--pill .tab.is-active:hover:not(:disabled):not(.tab--disabled) {
    background-color: var(--theme-primary-hover);
    color: var(--text-inverse);
  }

  html.theme-vp .tabstrip--pill .tab--disabled,
  html.theme-vp .tabstrip--pill .tab:disabled {
    color: var(--text-muted);
  }

  html.theme-vp.dark .tabstrip--pill .tab:hover:not(:disabled):not(.tab--disabled):not(.is-active) {
    color: var(--theme-primary-hover);
  }

  html.theme-vp.dark .tabstrip--pill .tab.is-active:hover:not(:disabled):not(.tab--disabled) {
    background-color: var(--theme-primary-hover);
    color: var(--text-inverse);
  }

  /* TabStrip Responsive Styles */
  @media (max-width: var(--breakpoint-md)) {
    /* Narrow view: horizontal scroll; per-tab ⋮ may clip here (overflow-x: auto forces y to auto). */
    .tabstrip__tabs {
      overflow-x: auto;
      overflow-y: visible;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
    }

    .tabstrip__tabs::-webkit-scrollbar {
      height: 4px;
    }

    .tabstrip__tabs::-webkit-scrollbar-track {
      background: transparent;
    }

    .tabstrip__tabs::-webkit-scrollbar-thumb {
      background-color: var(--border-color);
      border-radius: 2px;
    }

    .tab {
      min-width: max-content;
      padding: var(--space-2) var(--space-3);
      font-size: var(--text-sm);
    }

    .tabstrip__add,
    .tabstrip__more-wrapper {
      min-width: 44px;
      min-height: 44px;
    }
  }
</style>

<script>
  function dispatchTabStripAction(
    container: HTMLElement,
    action: string,
    tabId: string | null
  ) {
    if (action === 'select-tab') {
      container.dispatchEvent(
        new CustomEvent('tab-strip:tab-selected', { bubbles: true, detail: { tabId } })
      );
    } else if (action === 'close-tab') {
      container.dispatchEvent(
        new CustomEvent('tab-strip:close-tab', { bubbles: true, detail: { tabId } })
      );
    } else if (action === 'open-new-window') {
      container.dispatchEvent(
        new CustomEvent('tab-strip:open-new-window', { bubbles: true, detail: { tabId } })
      );
    } else if (action === 'set-default') {
      container.dispatchEvent(
        new CustomEvent('tab-strip:set-default', { bubbles: true, detail: { tabId } })
      );
    }
  }

  function closeAllPerTabMenus(container: HTMLElement) {
    container.querySelectorAll('[data-tabstrip-per-tab-menu].is-open').forEach((wrap) => {
      const w = wrap as HTMLElement;
      w.classList.remove('is-open');
      const btn = w.querySelector('[data-tabstrip-per-tab-menu-btn]') as HTMLButtonElement | null;
      btn?.setAttribute('aria-expanded', 'false');
    });
  }

  function getTabButtons(container: HTMLElement) {
    return Array.from(
      container.querySelectorAll(
        '[data-tabstrip-tabs] [data-tabstrip-tab-cell] [role="tab"]'
      )
    ) as (HTMLButtonElement | HTMLAnchorElement)[];
  }

  function initTabStrip(container: HTMLElement) {
    if (container.hasAttribute('data-init')) return;
    container.setAttribute('data-init', 'true');

    const tabsContainer = container.querySelector('[data-tabstrip-tabs]') as HTMLElement;
    const moreWrapper = container.querySelector('[data-tabstrip-more]') as HTMLElement;
    const moreButton = container.querySelector('[data-tabstrip-more-btn]') as HTMLButtonElement;
    const moreLabel = container.querySelector('[data-tabstrip-more-label]') as HTMLElement;
    const dropdown = container.querySelector('[data-tabstrip-dropdown]') as HTMLElement;
    const dropdownItems = container.querySelector('[data-tabstrip-dropdown-items]') as HTMLElement;
    const addButton = container.querySelector('[data-tabstrip-add]') as HTMLButtonElement;
    const overflowMode = container.getAttribute('data-overflow-mode') || 'auto';

    let resizeObserver: ResizeObserver | null = null;
    let moreMenuFocusIndex = -1;
    let perTabMenuFocusIndex = -1;

    function tabButtons() {
      return getTabButtons(container);
    }

    // Calculate overflow (measure tab cells, not raw tabs)
    function calculateOverflow() {
      if (overflowMode === 'none' || !tabsContainer || !moreWrapper) {
        return;
      }

      if (overflowMode === 'manual') {
        const hasOverflow = dropdownItems && dropdownItems.children.length > 0;
        if (hasOverflow) {
          moreWrapper.style.display = 'flex';
          const count = dropdownItems.children.length;
          if (moreLabel) {
            moreLabel.textContent = `More (${count})`;
          }
        } else {
          moreWrapper.style.display = 'none';
        }
        return;
      }

      if (!tabsContainer.parentElement) return;

      const containerWidth = tabsContainer.parentElement.offsetWidth;
      const addTabWidth =
        addButton && addButton.offsetParent !== null
          ? addButton.offsetWidth +
            parseInt(getComputedStyle(addButton).marginLeft || '0') +
            parseInt(getComputedStyle(addButton).marginRight || '0')
          : 0;
      const moreButtonReservedWidth = 90;
      const availableWidth = containerWidth - addTabWidth - moreButtonReservedWidth;

      let totalWidth = 0;
      const cells = Array.from(tabsContainer.querySelectorAll('[data-tabstrip-tab-cell]')) as HTMLElement[];

      cells.forEach((cell, i) => {
        cell.style.display = '';
      });

      const overflowCells: HTMLElement[] = [];

      for (let i = 0; i < cells.length; i++) {
        const cell = cells[i];
        const cellWidth =
          cell.offsetWidth +
          parseInt(getComputedStyle(cell).marginLeft || '0') +
          parseInt(getComputedStyle(cell).marginRight || '0');
        const gap = i > 0 ? parseInt(getComputedStyle(tabsContainer).gap || '0') : 0;

        if (totalWidth + cellWidth + gap <= availableWidth) {
          totalWidth += cellWidth + gap;
        } else {
          overflowCells.push(cell);
          cell.style.display = 'none';
        }
      }

      if (dropdownItems && overflowCells.length > 0) {
        dropdownItems.innerHTML = '';
        overflowCells.forEach((cell) => {
          const tabId = cell.getAttribute('data-tab-id');
          const tabEl = cell.querySelector('[role="tab"]') as HTMLElement | null;
          const label = tabEl?.querySelector('.tab__label')?.textContent?.trim() || '';
          const icon = tabEl?.getAttribute('data-tab-icon') || '';
          const isActive = tabEl?.classList.contains('is-active') ?? false;

          const item = document.createElement('div');
          item.className = `tabstrip__dropdown-item ${isActive ? 'is-active' : ''}`;
          item.setAttribute('role', 'menuitem');

          const labelBtn = document.createElement('button');
          labelBtn.type = 'button';
          labelBtn.className = 'tabstrip__dropdown-item-label';
          labelBtn.setAttribute('data-tab-id', tabId || '');
          labelBtn.setAttribute('data-action', 'select-tab');

          if (icon) {
            const iconEl = document.createElement('span');
            iconEl.className = 'tabstrip__dropdown-item-icon';
            iconEl.setAttribute('data-icon-name', icon);
            iconEl.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16" aria-hidden="true"><!-- Icon: ${icon} --></svg>`;
            labelBtn.insertBefore(iconEl, labelBtn.firstChild);
          }

          const labelSpan = document.createElement('span');
          labelSpan.textContent = label;
          labelBtn.appendChild(labelSpan);

          const actions = document.createElement('div');
          actions.className = 'tabstrip__dropdown-item-actions';

          const openBtn = document.createElement('button');
          openBtn.type = 'button';
          openBtn.className = 'tabstrip__dropdown-action-btn';
          openBtn.setAttribute('data-tab-id', tabId || '');
          openBtn.setAttribute('data-action', 'open-new-window');
          openBtn.setAttribute('aria-label', `Open ${label} in new window`);
          openBtn.setAttribute('title', 'Open in new window');
          openBtn.innerHTML =
            '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25M21 3L6 18" /></svg>';

          const closeBtn = document.createElement('button');
          closeBtn.type = 'button';
          closeBtn.className = 'tabstrip__dropdown-action-btn';
          closeBtn.setAttribute('data-tab-id', tabId || '');
          closeBtn.setAttribute('data-action', 'close-tab');
          closeBtn.setAttribute('aria-label', `Close ${label}`);
          closeBtn.setAttribute('title', 'Close');
          closeBtn.innerHTML =
            '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>';

          actions.appendChild(openBtn);
          actions.appendChild(closeBtn);
          item.appendChild(labelBtn);
          item.appendChild(actions);
          dropdownItems.appendChild(item);
        });
      } else if (dropdownItems && overflowCells.length === 0) {
        dropdownItems.innerHTML = '';
      }

      if (overflowCells.length > 0) {
        moreWrapper.style.display = 'flex';
        if (moreLabel) {
          moreLabel.textContent = `More (${overflowCells.length})`;
        }
      } else {
        moreWrapper.style.display = 'none';
        moreWrapper.setAttribute('aria-expanded', 'false');
        moreButton?.setAttribute('aria-expanded', 'false');
      }
    }

    if (overflowMode === 'auto') {
      resizeObserver = new ResizeObserver(() => {
        calculateOverflow();
      });
      if (tabsContainer.parentElement) {
        resizeObserver.observe(tabsContainer.parentElement);
      }
      setTimeout(() => calculateOverflow(), 0);
    } else if (overflowMode === 'manual') {
      calculateOverflow();
    }

    if (moreButton) {
      moreButton.addEventListener('click', (e) => {
        e.stopPropagation();
        closeAllPerTabMenus(container);
        const isOpen = moreWrapper.getAttribute('aria-expanded') === 'true';
        const newState = (!isOpen).toString();
        moreWrapper.setAttribute('aria-expanded', newState);
        moreButton.setAttribute('aria-expanded', newState);
      });
    }

    if (dropdown) {
      dropdown.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const actionBtn = target.closest('[data-action]') as HTMLElement;
        if (!actionBtn || actionBtn.closest('[data-tabstrip-per-tab-dropdown]')) return;

        e.stopPropagation();
        const action = actionBtn.getAttribute('data-action');
        const tabId = actionBtn.getAttribute('data-tab-id');
        if (action) dispatchTabStripAction(container, action, tabId);

        moreWrapper.setAttribute('aria-expanded', 'false');
        moreButton?.setAttribute('aria-expanded', 'false');
      });
    }

    // Inline toolbar (open / close) — not the ⋮ menu button
    container.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const menuToggle = target.closest('[data-tabstrip-per-tab-menu-btn]');
      if (menuToggle) return;

      const toolbarAction = target.closest(
        '[data-tabstrip-tab-toolbar] [data-action]'
      ) as HTMLElement | null;
      if (!toolbarAction || toolbarAction.closest('[data-tabstrip-per-tab-dropdown]')) return;

      e.stopPropagation();
      const action = toolbarAction.getAttribute('data-action');
      const tabId = toolbarAction.getAttribute('data-tab-id');
      if (action) dispatchTabStripAction(container, action, tabId);
    });

    // Per-tab ⋮ menu toggle
    container.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest('[data-tabstrip-per-tab-menu-btn]') as HTMLButtonElement | null;
      if (!btn || !container.contains(btn)) return;

      e.stopPropagation();
      const wrap = btn.closest('[data-tabstrip-per-tab-menu]') as HTMLElement;
      if (!wrap) return;

      const opening = !wrap.classList.contains('is-open');
      closeAllPerTabMenus(container);
      if (opening) {
        wrap.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });

    // Per-tab dropdown menuitem clicks
    container.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const mi = target.closest(
        '[data-tabstrip-per-tab-dropdown] [data-action]'
      ) as HTMLElement | null;
      if (!mi) return;

      e.stopPropagation();
      const action = mi.getAttribute('data-action');
      const tabId = mi.getAttribute('data-tab-id');
      if (action) dispatchTabStripAction(container, action, tabId);

      const wrap = mi.closest('[data-tabstrip-per-tab-menu]') as HTMLElement | null;
      wrap?.classList.remove('is-open');
      wrap?.querySelector('[data-tabstrip-per-tab-menu-btn]')?.setAttribute('aria-expanded', 'false');
    });

    tabButtons().forEach((tab) => {
      tab.addEventListener('click', (e) => {
        if (tab.getAttribute('aria-disabled') === 'true') {
          e.preventDefault();
          return;
        }
        const tabId = tab.getAttribute('data-tab-id');
        container.dispatchEvent(
          new CustomEvent('tab-strip:tab-selected', { bubbles: true, detail: { tabId } })
        );
      });
    });

    if (addButton) {
      addButton.addEventListener('click', () => {
        container.dispatchEvent(new CustomEvent('tab-strip:add-tab', { bubbles: true }));
      });
    }

    document.addEventListener('click', (e) => {
      const t = e.target as Node;
      if (moreWrapper && !moreWrapper.contains(t)) {
        moreWrapper.setAttribute('aria-expanded', 'false');
        moreButton?.setAttribute('aria-expanded', 'false');
      }
      container.querySelectorAll('[data-tabstrip-per-tab-menu].is-open').forEach((menu) => {
        if (!menu.contains(t)) {
          menu.classList.remove('is-open');
          menu
            .querySelector('[data-tabstrip-per-tab-menu-btn]')
            ?.setAttribute('aria-expanded', 'false');
        }
      });
    });

    container.addEventListener('keydown', (e) => {
      const isMoreOpen = moreWrapper?.getAttribute('aria-expanded') === 'true';
      const openPerTabWrap = container.querySelector(
        '[data-tabstrip-per-tab-menu].is-open'
      ) as HTMLElement | null;
      const moreItems = dropdown
        ? (Array.from(dropdown.querySelectorAll('[data-action]')) as HTMLElement[])
        : [];
      const perTabItems = openPerTabWrap
        ? (Array.from(
            openPerTabWrap.querySelectorAll('[data-tabstrip-per-tab-dropdown] [data-action]')
          ) as HTMLElement[])
        : [];

      if (e.key === 'Escape') {
        if (isMoreOpen) {
          e.preventDefault();
          moreWrapper.setAttribute('aria-expanded', 'false');
          moreButton?.setAttribute('aria-expanded', 'false');
          moreButton?.focus();
        } else if (openPerTabWrap) {
          e.preventDefault();
          closeAllPerTabMenus(container);
          openPerTabWrap.querySelector('[data-tabstrip-per-tab-menu-btn]')?.focus();
        }
        return;
      }

      if (isMoreOpen && ['ArrowDown', 'ArrowUp', 'Home', 'End'].includes(e.key)) {
        e.preventDefault();
        if (e.key === 'ArrowDown') {
          moreMenuFocusIndex = (moreMenuFocusIndex + 1) % moreItems.length;
        } else if (e.key === 'ArrowUp') {
          moreMenuFocusIndex =
            moreMenuFocusIndex <= 0 ? moreItems.length - 1 : moreMenuFocusIndex - 1;
        } else if (e.key === 'Home') {
          moreMenuFocusIndex = 0;
        } else if (e.key === 'End') {
          moreMenuFocusIndex = moreItems.length - 1;
        }
        moreItems[moreMenuFocusIndex]?.focus();
        return;
      }

      if (openPerTabWrap && ['ArrowDown', 'ArrowUp', 'Home', 'End'].includes(e.key)) {
        e.preventDefault();
        if (e.key === 'ArrowDown') {
          perTabMenuFocusIndex = (perTabMenuFocusIndex + 1) % perTabItems.length;
        } else if (e.key === 'ArrowUp') {
          perTabMenuFocusIndex =
            perTabMenuFocusIndex <= 0 ? perTabItems.length - 1 : perTabMenuFocusIndex - 1;
        } else if (e.key === 'Home') {
          perTabMenuFocusIndex = 0;
        } else if (e.key === 'End') {
          perTabMenuFocusIndex = perTabItems.length - 1;
        }
        perTabItems[perTabMenuFocusIndex]?.focus();
        return;
      }

      if (['ArrowLeft', 'ArrowRight'].includes(e.key) && !isMoreOpen && !openPerTabWrap) {
        e.preventDefault();
        const currentTab = document.activeElement as HTMLElement;
        const tabs = tabButtons();
        if (!currentTab || !tabs.includes(currentTab as HTMLButtonElement & HTMLAnchorElement))
          return;

        const direction = e.key === 'ArrowLeft' ? -1 : 1;
        const currentIndex = tabs.indexOf(currentTab as HTMLButtonElement & HTMLAnchorElement);
        let nextIndex = currentIndex + direction;

        if (nextIndex < 0) nextIndex = tabs.length - 1;
        if (nextIndex >= tabs.length) nextIndex = 0;

        const nextTab = tabs[nextIndex];
        if (nextTab && nextTab.getAttribute('aria-disabled') !== 'true') {
          nextTab.focus();
          if (e.shiftKey || e.ctrlKey) {
            nextTab.click();
          }
        }
      }
    });

    return () => {
      if (resizeObserver) {
        resizeObserver.disconnect();
      }
    };
  }

  // Initialize all tab strips
  function initAllTabStrips() {
    document.querySelectorAll('[data-tabstrip]').forEach((container) => {
      initTabStrip(container as HTMLElement);
    });
  }

  // Initialize on load and after Astro page transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAllTabStrips);
  } else {
    initAllTabStrips();
  }

  document.addEventListener('astro:page-load', initAllTabStrips);
</script>
