---
/**
 * Dialog Component
 *
 * Modal dialog for confirmations, forms, or information.
 *
 * @usagePattern footer-buttons When buttonAlignment='left' (default), place primary action button first in footer slot, followed by secondary actions (e.g., Cancel). When buttonAlignment='right', place secondary actions first, then primary action button last. This ensures the visual alignment matches the semantic importance.
 * @usagePattern sticky-layout The dialog uses flexbox column layout with header and footer as flex-shrink: 0 (sticky), and body as flex: 1 with overflow-y: auto. Only the body scrolls when content exceeds available height.
 * @usagePattern footer-button-type Dialog footers are general UI (not page header). Default footer and any custom footer slot content should use theme buttons (buttonType="theme") so dialogs render correctly regardless of the consumer's Button default.
 */
import Icon from './Icon.astro';
import Button from './Button.astro';

export interface Props {
  id: string;
  title: string;
  class?: string;
  buttonAlignment?: 'left' | 'right';
  headerVariant?: 'default' | 'primary';
  /** When using the default footer, label for the Confirm button. Ignored when footer slot is used. */
  confirmLabel?: string;
  /** When using the default footer, label for the Cancel button. Ignored when footer slot is used. */
  cancelLabel?: string;
  /** When using the default footer, optional global function name to call when Confirm is clicked before closing. Ignored when footer slot is used. */
  confirmCallbackName?: string;
  /** When using the default footer, optional label for a third (tertiary/link-style) button. Ignored when footer slot is used. */
  tertiaryLabel?: string;
  /** When using the default footer with a tertiary button, optional global function name to call when the tertiary button is clicked before closing. Ignored when footer slot is used. */
  tertiaryCallbackName?: string;
  /** When true, shows a resize grip in the bottom-right corner; users can drag to resize the dialog. */
  resizable?: boolean;
}

const {
  id,
  title,
  class: className = '',
  buttonAlignment = 'left',
  headerVariant = 'default',
  confirmLabel = 'Confirm',
  cancelLabel = 'Cancel',
  confirmCallbackName,
  tertiaryLabel,
  tertiaryCallbackName,
  resizable = true,
} = Astro.props;

const confirmOnClick = confirmCallbackName
  ? `if (typeof window.${confirmCallbackName} === 'function') { window.${confirmCallbackName}(); } closeDialog('${id}');`
  : `closeDialog('${id}')`;

const tertiaryOnClick = tertiaryCallbackName
  ? `if (typeof window.${tertiaryCallbackName} === 'function') { window.${tertiaryCallbackName}(); } closeDialog('${id}');`
  : `closeDialog('${id}')`;

const classes = ['dialog', resizable && 'dialog--resizable', className].filter(Boolean).join(' ');
const headerClasses = [
  'dialog__header',
  `dialog__header--variant-${headerVariant}`,
].filter(Boolean).join(' ');
const footerClasses = [
  'dialog__footer',
  `dialog__footer--align-${buttonAlignment}`,
].filter(Boolean).join(' ');
---

<div class="dialog-overlay" id={`${id}-overlay`} data-dialog-overlay>
  <div class={classes} role="dialog" aria-modal="true" aria-labelledby={`${id}-title`}>
    <div class={headerClasses}>
      <h2 class="dialog__title" id={`${id}-title`}>{title}</h2>
      <button type="button" class="dialog__close" data-dialog-close aria-label="Close">
        <Icon name="x-mark" />
      </button>
    </div>
    <div class="dialog__body">
      <slot>
        <p class="dialog__body-default">Dialog content. Override by passing default slot content.</p>
      </slot>
    </div>
    <div class={footerClasses}>
      <slot name="footer">
        <!-- Default footer: theme buttons (general UI); optional confirmLabel, cancelLabel, confirmCallbackName, tertiaryLabel, tertiaryCallbackName. Custom footer slot overrides this. -->
        <div class="dialog__footer-actions">
          <Button buttonType="theme" type="button" onclick={confirmOnClick}>{confirmLabel}</Button>
          <Button buttonType="theme" variant="secondary" type="button" onclick={`closeDialog('${id}')`}>{cancelLabel}</Button>
          {tertiaryLabel && (
            <Button buttonType="theme" variant="tertiary" type="button" onclick={tertiaryOnClick}>{tertiaryLabel}</Button>
          )}
        </div>
      </slot>
    </div>
    {resizable && (
      <div class="dialog__resize-grip" data-dialog-resize-grip role="img" aria-label="Resize">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" aria-hidden="true">
          <line x1="12" y1="15" x2="15" y2="12" />
          <line x1="8" y1="15" x2="15" y2="8" />
          <line x1="4" y1="15" x2="15" y2="4" />
        </svg>
      </div>
    )}
  </div>
</div>

<script>
  function initDialogs() {
    // Close buttons
    document.querySelectorAll('[data-dialog-close]').forEach((btn) => {
      btn.addEventListener('click', () => {
        btn.closest('.dialog-overlay')?.classList.remove('is-open');
      });
    });

    // Click outside to close
    document.querySelectorAll('[data-dialog-overlay]').forEach((overlay) => {
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) {
          overlay.classList.remove('is-open');
        }
      });
    });

    // Escape to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll('.dialog-overlay.is-open').forEach((overlay) => {
          overlay.classList.remove('is-open');
        });
      }
    });

    // Resize grip: mousedown on grip -> mousemove/mouseup to resize dialog
    document.querySelectorAll('.dialog--resizable [data-dialog-resize-grip]').forEach((grip) => {
      grip.addEventListener('mousedown', (e) => {
        e.preventDefault();
        const dialog = grip.closest('.dialog') as HTMLElement;
        if (!dialog) return;
        const rect = dialog.getBoundingClientRect();
        const startW = rect.width;
        const startH = rect.height;
        dialog.style.width = startW + 'px';
        dialog.style.height = startH + 'px';
        dialog.style.minWidth = '0';
        dialog.style.maxWidth = 'none';
        dialog.style.maxHeight = 'none';
        const startX = e.clientX;
        const startY = e.clientY;

        const onMove = (moveEvent) => {
          const dx = moveEvent.clientX - startX;
          const dy = moveEvent.clientY - startY;
          const w = Math.max(1, Math.round(startW + dx));
          const h = Math.max(1, Math.round(startH + dy));
          dialog.style.width = w + 'px';
          dialog.style.height = h + 'px';
        };
        const onUp = () => {
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
          document.body.style.userSelect = '';
        };
        document.body.style.userSelect = 'none';
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
    });
  }

  // Global function to open dialog
  (window as any).openDialog = function(id: string) {
    document.getElementById(`${id}-overlay`)?.classList.add('is-open');
  };

  // Global function to close dialog
  (window as any).closeDialog = function(id: string) {
    document.getElementById(`${id}-overlay`)?.classList.remove('is-open');
  };

  initDialogs();
  document.addEventListener('astro:page-load', initDialogs);
</script>
