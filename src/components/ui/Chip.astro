---
/**
 * Chip Component
 * 
 * Compact element for tags, filters, or selections.
 * Can be dismissible or clickable.
 * 
 * @example
 * <Chip>Tag</Chip>
 * <Chip dismissible>Removable</Chip>
 * <Chip variant="primary" icon="ti-tag">Category</Chip>
 */

export interface Props {
  /** Chip color variant */
  variant?: 'default' | 'primary' | 'success' | 'warning' | 'error';
  /** Show dismiss/remove button */
  dismissible?: boolean;
  /** Leading icon class */
  icon?: string;
  /** Make chip clickable/selectable */
  clickable?: boolean;
  /** Selected state (for clickable chips) */
  selected?: boolean;
  /** Additional CSS classes */
  class?: string;
  /** Any additional HTML attributes */
  [key: string]: any;
}

const {
  variant = 'default',
  dismissible = false,
  icon,
  clickable = false,
  selected = false,
  class: className = '',
  ...rest
} = Astro.props;

// Variant classes
const variantClasses: Record<string, string> = {
  default: 'bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border-slate-200 dark:border-slate-700',
  primary: 'bg-theme-primary/10 text-theme-primary border-theme-primary/30',
  success: 'bg-success/10 text-success border-success/30',
  warning: 'bg-warning/10 text-warning border-warning/30',
  error: 'bg-error/10 text-error border-error/30',
};

// Selected state classes
const selectedClasses = selected
  ? 'ring-2 ring-theme-primary ring-offset-1 dark:ring-offset-slate-900'
  : '';

// Clickable classes
const clickableClasses = clickable
  ? 'cursor-pointer hover:opacity-80 transition-opacity'
  : '';

// Combine classes
const chipClasses = [
  'inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded-full border',
  variantClasses[variant],
  selectedClasses,
  clickableClasses,
  className,
].filter(Boolean).join(' ');
---

<span class={chipClasses} {...rest}>
  {icon && (
    <i class={`ti ${icon} text-sm`}></i>
  )}
  <slot />
  {dismissible && (
    <button 
      type="button"
      class="ml-0.5 hover:opacity-70 transition-opacity"
      aria-label="Remove"
    >
      <i class="ti ti-x text-sm"></i>
    </button>
  )}
</span>

