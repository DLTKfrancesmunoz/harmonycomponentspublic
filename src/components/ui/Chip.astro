---
/**
 * Chip Component
 *
 * Compact element for tags, filters, or selections.
 */
import Icon from './Icon.astro';

export interface Props {
  selected?: boolean;
  removable?: boolean;
  icon?: string;
  class?: string;
}

const {
  selected = false,
  removable = false,
  icon,
  class: className = '',
} = Astro.props;

const classes = [
  'chip',
  selected && 'chip--selected',
  className,
].filter(Boolean).join(' ');
---

<span class={classes}>
  {icon && <Icon name={icon} />}
  <slot />
  {removable && (
    <button type="button" class="chip__remove" aria-label="Remove">
      <Icon name="x-mark" />
    </button>
  )}
</span>
