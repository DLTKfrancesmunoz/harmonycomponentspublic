---
/**
 * Spinner Component
 * 
 * Loading indicator with size variants.
 * 
 * @example
 * <Spinner />
 * <Spinner size="lg" />
 * <Spinner size="sm" class="text-success" />
 */

export interface Props {
  /** Spinner size */
  size?: 'sm' | 'md' | 'lg';
  /** Additional CSS classes */
  class?: string;
  /** Any additional HTML attributes */
  [key: string]: any;
}

const {
  size = 'md',
  class: className = '',
  ...rest
} = Astro.props;

// Size classes
const sizeClasses: Record<string, string> = {
  sm: 'w-4 h-4',
  md: 'w-6 h-6',
  lg: 'w-8 h-8',
};

// Combine classes
const spinnerClasses = [
  'animate-spin text-theme-primary',
  sizeClasses[size],
  className,
].filter(Boolean).join(' ');
---

<svg 
  class={spinnerClasses} 
  xmlns="http://www.w3.org/2000/svg" 
  fill="none" 
  viewBox="0 0 24 24"
  role="status"
  aria-label="Loading"
  {...rest}
>
  <circle 
    class="opacity-25" 
    cx="12" 
    cy="12" 
    r="10" 
    stroke="currentColor" 
    stroke-width="4"
  ></circle>
  <path 
    class="opacity-75" 
    fill="currentColor" 
    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
  ></path>
</svg>

