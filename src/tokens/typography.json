{
  "$schema": "https://harmony-ds.com/tokens/typography.schema.json",
  "name": "Harmony Design System Typography",
  "version": "1.0.0",
  "description": "Typography system with font families, sizes, weights, and line heights",

  "fontFamilies": {
    "sans": {
      "value": ["Figtree", "sans-serif"],
      "css": "'Figtree', sans-serif",
      "tailwind": "font-sans",
      "description": "Primary body text font",
      "googleFonts": "https://fonts.googleapis.com/css2?family=Figtree:wght@300..900&display=swap"
    },
    "display": {
      "value": ["Lexend", "sans-serif"],
      "css": "'Lexend', sans-serif",
      "tailwind": "font-display",
      "description": "Headings and display text",
      "googleFonts": "https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;800;900&display=swap"
    },
    "mono": {
      "value": ["JetBrains Mono", "monospace"],
      "css": "'JetBrains Mono', monospace",
      "tailwind": "font-mono",
      "description": "Code and technical content",
      "googleFonts": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap"
    }
  },

  "fontSizes": {
    "xs": {
      "value": "0.75rem",
      "pixels": "12px",
      "tailwind": "text-xs",
      "usage": "Helper text, labels, badges"
    },
    "sm": {
      "value": "0.875rem",
      "pixels": "14px",
      "tailwind": "text-sm",
      "usage": "Secondary text, descriptions"
    },
    "base": {
      "value": "1rem",
      "pixels": "16px",
      "tailwind": "text-base",
      "usage": "Body text, paragraphs"
    },
    "lg": {
      "value": "1.125rem",
      "pixels": "18px",
      "tailwind": "text-lg",
      "usage": "Lead paragraphs, emphasis"
    },
    "xl": {
      "value": "1.25rem",
      "pixels": "20px",
      "tailwind": "text-xl",
      "usage": "Section headings"
    },
    "2xl": {
      "value": "1.5rem",
      "pixels": "24px",
      "tailwind": "text-2xl",
      "usage": "Page section titles"
    },
    "3xl": {
      "value": "1.875rem",
      "pixels": "30px",
      "tailwind": "text-3xl",
      "usage": "Major headings"
    },
    "4xl": {
      "value": "2.25rem",
      "pixels": "36px",
      "tailwind": "text-4xl",
      "usage": "Page titles"
    },
    "5xl": {
      "value": "3rem",
      "pixels": "48px",
      "tailwind": "text-5xl",
      "usage": "Hero headings"
    }
  },

  "fontWeights": {
    "light": {
      "value": 300,
      "tailwind": "font-light"
    },
    "normal": {
      "value": 400,
      "tailwind": "font-normal"
    },
    "medium": {
      "value": 500,
      "tailwind": "font-medium"
    },
    "semibold": {
      "value": 600,
      "tailwind": "font-semibold"
    },
    "bold": {
      "value": 700,
      "tailwind": "font-bold"
    },
    "extrabold": {
      "value": 800,
      "tailwind": "font-extrabold"
    }
  },

  "lineHeights": {
    "none": {
      "value": 1,
      "tailwind": "leading-none"
    },
    "tight": {
      "value": 1.25,
      "tailwind": "leading-tight"
    },
    "snug": {
      "value": 1.375,
      "tailwind": "leading-snug"
    },
    "normal": {
      "value": 1.5,
      "tailwind": "leading-normal"
    },
    "relaxed": {
      "value": 1.625,
      "tailwind": "leading-relaxed"
    },
    "loose": {
      "value": 2,
      "tailwind": "leading-loose"
    }
  },

  "letterSpacing": {
    "tighter": {
      "value": "-0.05em",
      "tailwind": "tracking-tighter"
    },
    "tight": {
      "value": "-0.025em",
      "tailwind": "tracking-tight"
    },
    "normal": {
      "value": "0em",
      "tailwind": "tracking-normal"
    },
    "wide": {
      "value": "0.025em",
      "tailwind": "tracking-wide"
    },
    "wider": {
      "value": "0.05em",
      "tailwind": "tracking-wider"
    },
    "widest": {
      "value": "0.1em",
      "tailwind": "tracking-widest"
    }
  },

  "textStyles": {
    "heading1": {
      "fontFamily": "display",
      "fontSize": "4xl",
      "fontWeight": "bold",
      "lineHeight": "tight",
      "tailwind": "font-display text-4xl font-bold leading-tight"
    },
    "heading2": {
      "fontFamily": "display",
      "fontSize": "2xl",
      "fontWeight": "bold",
      "lineHeight": "tight",
      "tailwind": "font-display text-2xl font-bold leading-tight"
    },
    "heading3": {
      "fontFamily": "display",
      "fontSize": "xl",
      "fontWeight": "semibold",
      "lineHeight": "snug",
      "tailwind": "font-display text-xl font-semibold leading-snug"
    },
    "body": {
      "fontFamily": "sans",
      "fontSize": "base",
      "fontWeight": "normal",
      "lineHeight": "normal",
      "tailwind": "font-sans text-base font-normal leading-normal"
    },
    "bodySmall": {
      "fontFamily": "sans",
      "fontSize": "sm",
      "fontWeight": "normal",
      "lineHeight": "normal",
      "tailwind": "font-sans text-sm font-normal leading-normal"
    },
    "label": {
      "fontFamily": "sans",
      "fontSize": "sm",
      "fontWeight": "medium",
      "lineHeight": "none",
      "tailwind": "font-sans text-sm font-medium leading-none"
    },
    "caption": {
      "fontFamily": "sans",
      "fontSize": "xs",
      "fontWeight": "normal",
      "lineHeight": "normal",
      "tailwind": "font-sans text-xs font-normal leading-normal"
    },
    "code": {
      "fontFamily": "mono",
      "fontSize": "sm",
      "fontWeight": "normal",
      "lineHeight": "normal",
      "tailwind": "font-mono text-sm font-normal leading-normal"
    },
    "codeSmall": {
      "fontFamily": "mono",
      "fontSize": "xs",
      "fontWeight": "normal",
      "lineHeight": "normal",
      "tailwind": "font-mono text-xs font-normal leading-normal"
    }
  },

  "componentDefaults": {
    "button": {
      "fontFamily": "sans",
      "fontWeight": "medium"
    },
    "input": {
      "fontFamily": "sans",
      "fontSize": "base"
    },
    "label": {
      "fontFamily": "sans",
      "fontSize": "sm",
      "fontWeight": "medium"
    },
    "badge": {
      "fontFamily": "sans",
      "fontSize": "xs",
      "fontWeight": "medium"
    }
  }
}

