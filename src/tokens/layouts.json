{
  "$schema": "https://harmony-ds.com/tokens/layouts.schema.json",
  "name": "Harmony Design System Layouts",
  "version": "1.0.0",
  "description": "Layout definitions with component dependencies and props",
  "layouts": {
    "DocsLayout": {
      "filePath": "src/layouts/DocsLayout.astro",
      "description": "DocsLayout layout",
      "components": [
        "Icon"
      ],
      "props": {
        "title": {
          "type": "string",
          "optional": false,
          "description": null
        },
        "description": {
          "type": "string",
          "optional": true,
          "description": null
        }
      }
    },
    "ShellLayout": {
      "filePath": "src/layouts/ShellLayout.astro",
      "description": "Right Panel - rendered when rightPanel prop is provided",
      "components": [
        "ShellHeader",
        "ShellFooter",
        "LeftSidebar",
        "RightSidebar",
        "FloatingNav",
        "ShellPageHeader",
        "ShellPanel"
      ],
      "props": {
        "productName": {
          "type": "string",
          "optional": true,
          "description": null
        },
        "logoSrc": {
          "type": "string",
          "optional": true,
          "description": null
        },
        "companyName": {
          "type": "string",
          "optional": true,
          "description": null
        },
        "showCompanyPicker": {
          "type": "boolean",
          "optional": true,
          "description": null
        },
        "companyColor": {
          "type": "string",
          "optional": true,
          "description": null
        },
        "showFloatingNav": {
          "type": "boolean",
          "optional": true,
          "description": null
        },
        "floatingNavVariant": {
          "type": "'full' | 'compact'",
          "optional": true,
          "description": null
        },
        "showExecute": {
          "type": "boolean",
          "optional": true,
          "description": null
        },
        "saveDisabled": {
          "type": "boolean",
          "optional": true,
          "description": null
        },
        "tabs": {
          "type": "Tab[]",
          "optional": true,
          "description": null
        },
        "showMoreTabs": {
          "type": "boolean",
          "optional": true,
          "description": null
        },
        "moreCount": {
          "type": "number",
          "optional": true,
          "description": null
        },
        "overflowTabs": {
          "type": "Tab[]",
          "optional": true,
          "description": null
        },
        "showAddTab": {
          "type": "boolean",
          "optional": true,
          "description": null
        },
        "footerVariant": {
          "type": "'default' | 'compact'",
          "optional": true,
          "description": null
        },
        "leftSidebarVariant": {
          "type": "'cp' | 'vp' | 'ppm' | 'maconomy'",
          "optional": true,
          "description": null
        },
        "rightSidebarVariant": {
          "type": "'cp' | 'vp' | 'ppm' | 'maconomy'",
          "optional": true,
          "description": null
        },
        "pageHeaderTitle": {
          "type": "string",
          "optional": true,
          "description": null
        },
        "pageHeaderSubtitle": {
          "type": "string",
          "optional": true,
          "description": null
        },
        "pageHeaderPrimaryButton": {
          "type": "ButtonConfig",
          "optional": true,
          "description": null
        },
        "pageHeaderOutlineButton1": {
          "type": "ButtonConfig",
          "optional": true,
          "description": null
        },
        "pageHeaderOutlineButton2": {
          "type": "ButtonConfig",
          "optional": true,
          "description": null
        },
        "pageHeaderOutlineButton3": {
          "type": "ButtonConfig",
          "optional": true,
          "description": null
        },
        "leftPanel": {
          "type": "PanelConfig",
          "optional": true,
          "description": null
        },
        "rightPanel": {
          "type": "PanelConfig",
          "optional": true,
          "description": null
        },
        "class": {
          "type": "string",
          "optional": true,
          "description": null
        }
      }
    }
  }
}