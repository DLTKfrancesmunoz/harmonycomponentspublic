{
  "$schema": "https://harmony-ds.com/tokens/colors.schema.json",
  "name": "Harmony Design System Colors",
  "version": "1.0.0",
  
  "semantic": {
    "success": {
      "light": "#52BD94",
      "dark": "#00E78E",
      "description": "Success states, confirmations, positive actions"
    },
    "warning": {
      "light": "#FFB020",
      "dark": "#F9AF00",
      "description": "Warning states, cautions, attention needed"
    },
    "error": {
      "light": "#D14343",
      "dark": "#F46286",
      "description": "Error states, destructive actions, critical alerts"
    },
    "info": {
      "light": "#3366FF",
      "dark": "#00ADFD",
      "description": "Informational states, neutral highlights"
    }
  },

  "notificationBadge": {
    "error": {
      "value": "#d83148",
      "description": "Notification badge error color (red)"
    },
    "primary": {
      "description": "Notification badge primary color uses theme primary color"
    }
  },

  "alertChip": {
    "blue": {
      "background": "#c7f2ff",
      "foreground": "#205a9e",
      "description": "Alert Chip Blue colors"
    },
    "error": {
      "background": "#ffecef",
      "foreground": "#c1253a",
      "description": "Alert Chip Error colors"
    },
    "warning": {
      "background": "#fff1be",
      "foreground": "#ad5400",
      "description": "Alert Chip Warning colors"
    },
    "success": {
      "background": "#dbf9a8",
      "foreground": "#316d15",
      "description": "Alert Chip Success colors"
    },
    "info": {
      "background": "#d0dfff",
      "foreground": "#454bd4",
      "description": "Alert Chip Info colors"
    },
    "orange": {
      "background": "#ffe2c0",
      "foreground": "#6c1f07",
      "description": "Alert Chip Orange colors"
    },
    "pink": {
      "background": "#ffddf3",
      "foreground": "#b82890",
      "description": "Alert Chip Pink colors"
    },
    "disabled": {
      "background": "#e0e4eb",
      "foreground": "#94a3b8",
      "border": "#bfc6d4",
      "description": "Alert Chip Disabled colors"
    }
  },

  "accent": {
    "acid": {
      "value": "#ccff00",
      "description": "Highlight, special emphasis"
    },
    "accent": {
      "value": "#043852",
      "description": "Secondary accent color"
    }
  },

  "themes": {
    "cp": {
      "name": "Costpoint",
      "primary": {
        "light": "#1D8DFF",
        "dark": "#59ACFF"
      },
      "primaryHover": {
        "light": "#0d7aeb",
        "dark": "#7bb8ff"
      },
      "palette": {
        "light": {
          "link": "#3A70A6",
          "pageBackground": "#E2E4E9",
          "cardBackground": "#F7F8FA",
          "navBackground": "#FCFDFF",
          "inputBackground": "#FFFFFF",
          "inputDisabled": "#EAEAEA",
          "tableTotal": "#F0F3BE",
          "border": "#CBD5E1",
          "hover": "#E5E7EB",
          "titleText": "#373F4E",
          "secondaryText": "#64748B",
          "mutedText": "#94A3B8"
        },
        "dark": {
          "link": "#ADD0FF",
          "pageBackground": "#1F252E",
          "cellBackground": "#212935",
          "cardBackground": "#37424D",
          "navBackground": "#333D47",
          "inputBackground": "#1F252E",
          "inputDisabled": "#333D47",
          "tableTotal": "#223A52",
          "border": "#2D3748",
          "hover": "#3D4A5C",
          "titleText": "#E9ECEF",
          "secondaryText": "#A0AEC0",
          "mutedText": "#6B7280"
        }
      }
    },
    "vp": {
      "name": "Vantagepoint",
      "primary": {
        "light": "#4C92D9",
        "dark": "#59ACFF"
      },
      "primaryHover": {
        "light": "#3d7ab8",
        "dark": "#78baff"
      }
    },
    "ppm": {
      "name": "PPM",
      "primary": {
        "light": "#1D8DFF",
        "dark": "#59ACFF"
      },
      "primaryHover": {
        "light": "#0d7aeb",
        "dark": "#7bb8ff"
      }
    },
    "maconomy": {
      "name": "Maconomy",
      "primary": {
        "light": "#1D8DFF",
        "dark": "#59ACFF"
      },
      "primaryHover": {
        "light": "#0d7aeb",
        "dark": "#7bb8ff"
      }
    }
  },

  "dark": {
    "obsidian": {
      "value": "#09090b",
      "description": "Primary background"
    },
    "charcoal": {
      "value": "#18181b",
      "description": "Elevated surfaces"
    },
    "void": {
      "value": "#000000",
      "description": "Deepest background level"
    },
    "surface": {
      "value": "#0a0a0a",
      "description": "Primary surface background"
    },
    "panel": {
      "value": "#111111",
      "description": "Elevated panels, cards"
    },
    "border": {
      "value": "#222222",
      "description": "Border color"
    },
    "dim": {
      "value": "#444444",
      "description": "Subtle dividers, disabled states"
    },
    "muted": {
      "value": "#525252",
      "description": "Secondary text, icons"
    },
    "text": {
      "value": "#e5e5e5",
      "description": "Primary text"
    }
  },

  "light": {
    "white": {
      "value": "#ffffff",
      "description": "Primary surfaces, cards"
    },
    "pageBackground": {
      "value": "#EDF0F6",
      "description": "Main page background"
    },
    "concrete": {
      "value": "#f4f4f5",
      "description": "Subtle backgrounds"
    },
    "slate": {
      "50": "#f8fafc",
      "100": "#f1f5f9",
      "200": "#e2e8f0",
      "300": "#cbd5e1",
      "400": "#94a3b8",
      "500": "#64748b",
      "600": "#475569",
      "700": "#334155",
      "800": "#1e293b",
      "900": "#0f172a",
      "950": "#020617"
    }
  },

  "themeButton": {
    "primary": {
      "default": {
        "light": "#2D5A9F",
        "dark": "#4A7BC8",
        "description": "Theme button primary default - darker shade equivalent to Figma's #30659f"
      },
      "hover": {
        "light": "#1D4A7A",
        "dark": "#3D6BA8",
        "description": "Theme button primary hover - darker shade equivalent to Figma's #254e7a"
      },
      "disabled": {
        "background": "#e0e4eb",
        "foreground": "#bfc6d4",
        "description": "Theme button primary disabled colors"
      }
    },
    "secondary": {
      "default": {
        "stroke": {
          "light": "#1D4A7A",
          "dark": "#3D6BA8",
          "description": "Theme button secondary default stroke - same as primary hover"
        }
      },
      "hover": {
        "background": "#eaeff5",
        "foreground": {
          "light": "#1D4A7A",
          "dark": "#3D6BA8",
          "description": "Theme button secondary hover foreground"
        },
        "stroke": {
          "light": "#1D4A7A",
          "dark": "#3D6BA8",
          "description": "Theme button secondary hover stroke"
        }
      },
      "disabled": {
        "foreground": "#e0e4eb",
        "description": "Theme button secondary disabled foreground"
      }
    },
    "tertiary": {
      "default": {
        "foreground": {
          "light": "#1D8DFF",
          "dark": "#59ACFF",
          "description": "Theme button tertiary default foreground - uses theme primary"
        }
      },
      "hover": {
        "background": "#eaeff5",
        "description": "Theme button tertiary hover background"
      },
      "disabled": {
        "foreground": "#bfc6d4",
        "description": "Theme button tertiary disabled foreground"
      }
    }
  },

  "pageHeaderButton": {
    "primary": {
      "default": {
        "light": "#043852",
        "dark": "#043852",
        "description": "Page header button primary default - exact from Figma"
      },
      "hover": {
        "light": "#03273a",
        "dark": "#03273a",
        "description": "Page header button primary hover - exact from Figma"
      },
      "disabled": {
        "background": "#e0e4eb",
        "foreground": "#ffffff",
        "description": "Page header button primary disabled colors"
      }
    },
    "secondary": {
      "default": {
        "stroke": {
          "light": "#043852",
          "dark": "#043852",
          "description": "Page header button secondary default stroke"
        },
        "foreground": {
          "light": "#043852",
          "dark": "#043852",
          "description": "Page header button secondary default foreground - dark blue for readability"
        }
      },
      "hover": {
        "background": "#eaeff5",
        "foreground": "#043852",
        "stroke": "#043852",
        "description": "Page header button secondary hover colors"
      },
      "disabled": {
        "foreground": "#e0e4eb",
        "description": "Page header button secondary disabled foreground"
      }
    },
    "tertiary": {
      "default": {
        "foreground": {
          "light": "#043852",
          "dark": "#043852",
          "description": "Page header button tertiary default foreground"
        }
      },
      "hover": {
        "background": "#eaeff5",
        "description": "Page header button tertiary hover background"
      },
      "disabled": {
        "foreground": "#e0e4eb",
        "description": "Page header button tertiary disabled foreground"
      }
    }
  },

  "cssUtilities": {
    "success": { "background": "bg-success", "text": "text-success", "border": "border-success" },
    "warning": { "background": "bg-warning", "text": "text-warning", "border": "border-warning" },
    "error": { "background": "bg-error", "text": "text-error", "border": "border-error" },
    "info": { "background": "bg-info", "text": "text-info", "border": "border-info" },
    "theme": { "background": "bg-theme", "text": "text-theme", "border": "border-theme" },
    "surface": { "page": "bg-page", "card": "bg-card", "surface": "bg-surface", "elevated": "bg-elevated" }
  }
}

