{
  "$schema": "https://harmony-ds.com/tokens/colors.schema.json",
  "name": "Harmony Design System Colors",
  "version": "1.0.0",
  
  "semantic": {
    "success": {
      "value": "#52BD94",
      "description": "Success states, confirmations, positive actions"
    },
    "warning": {
      "value": "#FFB020",
      "description": "Warning states, cautions, attention needed"
    },
    "error": {
      "value": "#D14343",
      "description": "Error states, destructive actions, critical alerts"
    },
    "info": {
      "value": "#3366FF",
      "description": "Informational states, neutral highlights"
    }
  },

  "accent": {
    "acid": {
      "value": "#ccff00",
      "description": "Highlight, special emphasis"
    },
    "accent": {
      "value": "#043852",
      "description": "Secondary accent color"
    }
  },

  "themes": {
    "cp": {
      "name": "Costpoint",
      "primary": {
        "light": "#4C92D9",
        "dark": "#59ACFF"
      },
      "primaryHover": {
        "light": "#3d7ab8",
        "dark": "#78baff"
      },
      "palette": {
        "light": {
          "link": "#3A70A6",
          "pageBackground": "#E2E4E9",
          "cardBackground": "#F7F8FA",
          "navBackground": "#FCFDFF",
          "inputBackground": "#FFFFFF",
          "inputDisabled": "#EAEAEA",
          "tableTotal": "#F0F3BE",
          "border": "#CBD5E1",
          "hover": "#E5E7EB",
          "titleText": "#373F4E",
          "secondaryText": "#64748B",
          "mutedText": "#94A3B8"
        },
        "dark": {
          "link": "#ADD0FF",
          "pageBackground": "#1F252E",
          "cellBackground": "#212935",
          "cardBackground": "#37424D",
          "navBackground": "#333D47",
          "inputBackground": "#1F252E",
          "inputDisabled": "#333D47",
          "tableTotal": "#223A52",
          "border": "#2D3748",
          "hover": "#3D4A5C",
          "titleText": "#E9ECEF",
          "secondaryText": "#A0AEC0",
          "mutedText": "#6B7280"
        }
      }
    },
    "vp": {
      "name": "Vantagepoint",
      "primary": {
        "light": "#4C92D9",
        "dark": "#59ACFF"
      },
      "primaryHover": {
        "light": "#3d7ab8",
        "dark": "#78baff"
      }
    },
    "ppm": {
      "name": "PPM",
      "primary": {
        "light": "#30659F",
        "dark": "#1A88FF"
      },
      "primaryHover": {
        "light": "#265180",
        "dark": "#4da3ff"
      }
    },
    "maconomy": {
      "name": "Maconomy",
      "primary": {
        "light": "#804A98",
        "dark": "#A659EE"
      },
      "primaryHover": {
        "light": "#663b79",
        "dark": "#b877f1"
      }
    }
  },

  "dark": {
    "obsidian": {
      "value": "#09090b",
      "description": "Primary background"
    },
    "charcoal": {
      "value": "#18181b",
      "description": "Elevated surfaces"
    },
    "void": {
      "value": "#000000",
      "description": "Deepest background level"
    },
    "surface": {
      "value": "#0a0a0a",
      "description": "Primary surface background"
    },
    "panel": {
      "value": "#111111",
      "description": "Elevated panels, cards"
    },
    "border": {
      "value": "#222222",
      "description": "Border color"
    },
    "dim": {
      "value": "#444444",
      "description": "Subtle dividers, disabled states"
    },
    "muted": {
      "value": "#525252",
      "description": "Secondary text, icons"
    },
    "text": {
      "value": "#e5e5e5",
      "description": "Primary text"
    }
  },

  "light": {
    "white": {
      "value": "#ffffff",
      "description": "Primary surfaces, cards"
    },
    "pageBackground": {
      "value": "#EDF0F6",
      "description": "Main page background"
    },
    "concrete": {
      "value": "#f4f4f5",
      "description": "Subtle backgrounds"
    },
    "slate": {
      "50": "#f8fafc",
      "100": "#f1f5f9",
      "200": "#e2e8f0",
      "300": "#cbd5e1",
      "400": "#94a3b8",
      "500": "#64748b",
      "600": "#475569",
      "700": "#334155",
      "800": "#1e293b",
      "900": "#0f172a",
      "950": "#020617"
    }
  },

  "cssUtilities": {
    "success": { "background": "bg-success", "text": "text-success", "border": "border-success" },
    "warning": { "background": "bg-warning", "text": "text-warning", "border": "border-warning" },
    "error": { "background": "bg-error", "text": "text-error", "border": "border-error" },
    "info": { "background": "bg-info", "text": "text-info", "border": "border-info" },
    "theme": { "background": "bg-theme", "text": "text-theme", "border": "border-theme" },
    "surface": { "page": "bg-page", "card": "bg-card", "surface": "bg-surface", "elevated": "bg-elevated" }
  }
}

