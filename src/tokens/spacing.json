{
  "$schema": "https://harmony-ds.com/tokens/spacing.schema.json",
  "name": "Harmony Design System Spacing",
  "version": "1.0.0",
  "description": "A consistent spacing scale based on a 4px grid system",

  "scale": {
    "0": {
      "value": "0px",
      "tailwind": "0"
    },
    "0.5": {
      "value": "2px",
      "tailwind": "0.5"
    },
    "1": {
      "value": "4px",
      "tailwind": "1"
    },
    "1.5": {
      "value": "6px",
      "tailwind": "1.5"
    },
    "2": {
      "value": "8px",
      "tailwind": "2"
    },
    "2.5": {
      "value": "10px",
      "tailwind": "2.5"
    },
    "3": {
      "value": "12px",
      "tailwind": "3"
    },
    "3.5": {
      "value": "14px",
      "tailwind": "3.5"
    },
    "4": {
      "value": "16px",
      "tailwind": "4"
    },
    "5": {
      "value": "20px",
      "tailwind": "5"
    },
    "6": {
      "value": "24px",
      "tailwind": "6"
    },
    "7": {
      "value": "28px",
      "tailwind": "7"
    },
    "8": {
      "value": "32px",
      "tailwind": "8"
    },
    "9": {
      "value": "36px",
      "tailwind": "9"
    },
    "10": {
      "value": "40px",
      "tailwind": "10"
    },
    "11": {
      "value": "44px",
      "tailwind": "11"
    },
    "12": {
      "value": "48px",
      "tailwind": "12"
    },
    "14": {
      "value": "56px",
      "tailwind": "14"
    },
    "16": {
      "value": "64px",
      "tailwind": "16"
    },
    "20": {
      "value": "80px",
      "tailwind": "20"
    },
    "24": {
      "value": "96px",
      "tailwind": "24"
    }
  },

  "patterns": {
    "tight": {
      "values": ["gap-1", "gap-2"],
      "pixels": ["4px", "8px"],
      "usage": "Icon + text, compact lists, inline elements"
    },
    "default": {
      "values": ["gap-3", "gap-4"],
      "pixels": ["12px", "16px"],
      "usage": "Form elements, card content, button groups"
    },
    "relaxed": {
      "values": ["gap-6", "gap-8"],
      "pixels": ["24px", "32px"],
      "usage": "Section spacing, page sections"
    },
    "loose": {
      "values": ["gap-12", "gap-16"],
      "pixels": ["48px", "64px"],
      "usage": "Major sections, hero areas"
    }
  },

  "componentDefaults": {
    "button": {
      "sm": { "px": "3", "py": "1.5" },
      "md": { "px": "4", "py": "2" },
      "lg": { "px": "6", "py": "3" }
    },
    "card": {
      "sm": { "p": "4" },
      "md": { "p": "6" },
      "lg": { "p": "8" }
    },
    "input": {
      "default": { "px": "4", "py": "2" }
    },
    "badge": {
      "sm": { "px": "2", "py": "0.5" },
      "md": { "px": "2.5", "py": "1" }
    }
  },

  "tailwindMapping": {
    "padding": {
      "prefix": "p-",
      "variants": ["p", "px", "py", "pt", "pr", "pb", "pl"]
    },
    "margin": {
      "prefix": "m-",
      "variants": ["m", "mx", "my", "mt", "mr", "mb", "ml"]
    },
    "gap": {
      "prefix": "gap-",
      "variants": ["gap", "gap-x", "gap-y"]
    },
    "space": {
      "prefix": "space-",
      "variants": ["space-x", "space-y"]
    }
  }
}

