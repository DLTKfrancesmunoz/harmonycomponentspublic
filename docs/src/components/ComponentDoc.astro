---
interface Props {
  name: string;
  description: string;
  status?: 'stable' | 'beta' | 'deprecated';
}

interface Prop {
  name: string;
  type: string;
  default?: string;
  description: string;
}

interface AccessibilityNote {
  title: string;
  description: string;
}

const { name, description, status = 'stable' } = Astro.props;

const statusColors = {
  stable: 'bg-success/10 text-success border-success/30',
  beta: 'bg-warning/10 text-warning border-warning/30',
  deprecated: 'bg-error/10 text-error border-error/30',
};
---

<article class="space-y-12">
  <!-- Header -->
  <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
    <div class="flex items-center gap-3 mb-4">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">{name}</h1>
      <span class={`text-xs px-2 py-1 rounded-full border ${statusColors[status]}`}>
        {status}
      </span>
    </div>
    <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">{description}</p>
  </header>

  <!-- Quick Links -->
  <nav class="flex gap-4 text-sm">
    <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1">
      <i class="ti ti-eye"></i> Examples
    </a>
    <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1">
      <i class="ti ti-list"></i> Props
    </a>
    <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1">
      <i class="ti ti-book"></i> Usage
    </a>
    <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1">
      <i class="ti ti-accessible"></i> Accessibility
    </a>
  </nav>

  <!-- Content slots -->
  <slot />
</article>




