---
interface Prop {
  name: string;
  type: string;
  default?: string;
  description: string;
  required?: boolean;
}

interface Props {
  props: Prop[];
}

const { props } = Astro.props;
---

<div class="overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-800">
  <table class="props-table">
    <thead>
      <tr>
        <th>Property</th>
        <th>Type</th>
        <th>Default</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      {props.map((prop) => (
        <tr>
          <td>
            <code class="text-theme-primary">{prop.name}</code>
            {prop.required && <span class="text-error ml-1">*</span>}
          </td>
          <td><code class="text-sm">{prop.type}</code></td>
          <td>
            {prop.default ? (
              <code class="text-sm">{prop.default}</code>
            ) : (
              <span class="text-slate-400">—</span>
            )}
          </td>
          <td>{prop.description}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>




