---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
---

<DocsLayout title="Left Sidebar" description="Primary navigation sidebar.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Left Sidebar</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Primary navigation sidebar with icon menu and expandable sections.
      </p>
    </header>

    <CodeBlock 
      language="html"
      filename="left-sidebar.html"
      code={`<aside class="w-64 border-r border-slate-200 dark:border-border bg-white dark:bg-surface hidden lg:flex flex-col justify-between h-full">
  <!-- Header -->
  <div class="p-4 border-b border-slate-200 dark:border-border">
    <div class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-2">
      Navigation
    </div>
  </div>
  
  <!-- Navigation -->
  <nav class="flex-1 overflow-y-auto custom-scroll p-4 space-y-1">
    <a href="#" class="nav-item flex items-center gap-3 px-3 py-2 text-sm rounded hover:bg-slate-100 dark:hover:bg-white/5">
      <i class="ti ti-home text-slate-400"></i>
      <span class="text-slate-700 dark:text-slate-300">Home</span>
    </a>
    <a href="#" class="nav-item active flex items-center gap-3 px-3 py-2 text-sm rounded">
      <i class="ti ti-folder text-theme-primary"></i>
      <span class="text-slate-900 dark:text-white">Projects</span>
    </a>
    <!-- More nav items... -->
  </nav>
  
  <!-- Footer -->
  <div class="p-4 border-t border-slate-200 dark:border-border">
    <!-- Optional footer content -->
  </div>
</aside>`}
    />
  </article>
</DocsLayout>




