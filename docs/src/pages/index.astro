---
import DocsLayout from '../layouts/DocsLayout.astro';
import { navigation } from '../data/navigation';
---

<DocsLayout title="Overview" description="A complete design system with foundation elements, shell layout components, and production-ready UI components.">
  <!-- HERO SECTION -->
  <header class="mb-16 border-b border-slate-200 dark:border-slate-800 pb-12">
    <div class="inline-block mb-4">
      <span class="text-xs font-mono text-theme-primary uppercase tracking-widest px-3 py-1 border border-theme-primary/30 rounded-full">v1.0.0</span>
    </div>
    <h1 class="font-display text-5xl md:text-6xl font-bold tracking-tight mb-6 text-slate-900 dark:text-white">
      Design<br>System
    </h1>
    <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl leading-relaxed">
      A complete design system with foundation elements, shell layout components, and 25 production-ready UI components. 
      Built with accessibility, performance, and flexibility in mind.
    </p>
    <div class="flex flex-wrap gap-4 mt-8">
      <div class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
        <i class="ti ti-check text-theme-primary"></i>
        Dark & Light Themes
      </div>
      <div class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
        <i class="ti ti-check text-theme-primary"></i>
        Foundation System
      </div>
      <div class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
        <i class="ti ti-check text-theme-primary"></i>
        Shell Layout
      </div>
      <div class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
        <i class="ti ti-check text-theme-primary"></i>
        25 Components
      </div>
    </div>
  </header>

  <!-- Quick Start -->
  <section class="mb-16">
    <h2 class="font-display text-2xl font-bold mb-6 text-slate-900 dark:text-white">Quick Start</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <a href="/foundation/colors" class="group p-6 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-theme-primary dark:hover:border-theme-primary transition-colors bg-white dark:bg-surface/50">
        <div class="w-10 h-10 rounded-lg bg-theme-primary/10 flex items-center justify-center mb-4 group-hover:bg-theme-primary/20 transition-colors">
          <i class="ti ti-palette text-xl text-theme-primary"></i>
        </div>
        <h3 class="font-semibold text-slate-900 dark:text-white mb-2">Foundation</h3>
        <p class="text-sm text-slate-600 dark:text-slate-400">Colors, typography, spacing, and elevation tokens.</p>
      </a>
      
      <a href="/shell/layout" class="group p-6 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-theme-primary dark:hover:border-theme-primary transition-colors bg-white dark:bg-surface/50">
        <div class="w-10 h-10 rounded-lg bg-theme-primary/10 flex items-center justify-center mb-4 group-hover:bg-theme-primary/20 transition-colors">
          <i class="ti ti-layout-2 text-xl text-theme-primary"></i>
        </div>
        <h3 class="font-semibold text-slate-900 dark:text-white mb-2">Shell Layout</h3>
        <p class="text-sm text-slate-600 dark:text-slate-400">Headers, sidebars, footers, and page content areas.</p>
      </a>
      
      <a href="/components/buttons" class="group p-6 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-theme-primary dark:hover:border-theme-primary transition-colors bg-white dark:bg-surface/50">
        <div class="w-10 h-10 rounded-lg bg-theme-primary/10 flex items-center justify-center mb-4 group-hover:bg-theme-primary/20 transition-colors">
          <i class="ti ti-components text-xl text-theme-primary"></i>
        </div>
        <h3 class="font-semibold text-slate-900 dark:text-white mb-2">Components</h3>
        <p class="text-sm text-slate-600 dark:text-slate-400">25 production-ready UI components with variants.</p>
      </a>
    </div>
  </section>

  <!-- All Sections -->
  {navigation.map((section) => (
    <section class="mb-12">
      <h2 class="font-display text-xl font-bold mb-6 text-slate-900 dark:text-white flex items-center gap-2">
        <span class="w-1.5 h-6 bg-theme-primary rounded-full"></span>
        {section.title}
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {section.items.map((item) => (
          <a 
            href={item.href}
            class="flex items-center gap-3 p-4 rounded-lg border border-slate-200 dark:border-slate-800 hover:border-theme-primary dark:hover:border-theme-primary transition-colors bg-white dark:bg-surface/30 group"
          >
            <div class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center group-hover:bg-theme-primary/10 transition-colors">
              <i class={`ti ${item.icon} text-slate-500 dark:text-slate-400 group-hover:text-theme-primary transition-colors`}></i>
            </div>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-300 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">
              {item.title}
            </span>
          </a>
        ))}
      </div>
    </section>
  ))}
</DocsLayout>




