---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Checkbox Groups" description="Multiple selection checkbox groups.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Checkbox Groups</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Organized groups of checkboxes for selecting multiple options from a set.
      </p>
    </header>

    <ExampleSection title="Basic Group" description="Vertical checkbox group with label.">
      <fieldset class="space-y-3">
        <legend class="text-sm font-medium text-slate-900 dark:text-white mb-3">Select your interests</legend>
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" checked class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary dark:bg-slate-900">
          <span class="text-sm text-slate-700 dark:text-slate-300">Design</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary dark:bg-slate-900">
          <span class="text-sm text-slate-700 dark:text-slate-300">Development</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" checked class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary focus:ring-theme-primary dark:bg-slate-900">
          <span class="text-sm text-slate-700 dark:text-slate-300">Marketing</span>
        </label>
      </fieldset>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="checkbox-group.html"
      code={`<fieldset class="space-y-3">
  <legend class="text-sm font-medium text-slate-900 dark:text-white mb-3">
    Select your interests
  </legend>
  <label class="flex items-center gap-3 cursor-pointer">
    <input type="checkbox" class="w-5 h-5 rounded border-slate-300 dark:border-slate-700 text-theme-primary">
    <span class="text-sm text-slate-700 dark:text-slate-300">Option 1</span>
  </label>
  <!-- More options... -->
</fieldset>`}
    />
  </article>
</DocsLayout>




