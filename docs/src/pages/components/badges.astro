---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';

const props = [
  { name: 'variant', type: "'default' | 'success' | 'warning' | 'error' | 'info'", default: "'default'", description: 'Badge color variant' },
  { name: 'size', type: "'sm' | 'md'", default: "'md'", description: 'Badge size' },
  { name: 'dot', type: 'boolean', default: 'false', description: 'Show as dot indicator' },
];
---

<DocsLayout title="Badges" description="Badge components for status indicators and labels.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Badges</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Badges are small visual indicators used to highlight status, categories, or counts.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Badge Variants" description="Different color variants for various use cases.">
        <div class="flex flex-wrap gap-3">
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300">Default</span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-theme-primary/10 text-theme-primary">Primary</span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-success/10 text-success">Success</span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-warning/10 text-warning">Warning</span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-error/10 text-error">Error</span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-info/10 text-info">Info</span>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="badges.html"
        code={`<span class="px-2.5 py-1 text-xs font-medium rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300">Default</span>
<span class="px-2.5 py-1 text-xs font-medium rounded-full bg-theme-primary/10 text-theme-primary">Primary</span>
<span class="px-2.5 py-1 text-xs font-medium rounded-full bg-success/10 text-success">Success</span>
<span class="px-2.5 py-1 text-xs font-medium rounded-full bg-warning/10 text-warning">Warning</span>
<span class="px-2.5 py-1 text-xs font-medium rounded-full bg-error/10 text-error">Error</span>
<span class="px-2.5 py-1 text-xs font-medium rounded-full bg-info/10 text-info">Info</span>`}
      />

      <ExampleSection title="Solid Badges" description="Solid background badges for stronger emphasis.">
        <div class="flex flex-wrap gap-3">
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-slate-600 text-white">Default</span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-theme-primary text-white">Primary</span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-success text-white">Success</span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-warning text-white">Warning</span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-error text-white">Error</span>
        </div>
      </ExampleSection>

      <ExampleSection title="Badge with Border" description="Outlined badges for subtle emphasis.">
        <div class="flex flex-wrap gap-3">
          <span class="px-2.5 py-1 text-xs font-medium rounded-full border border-slate-300 dark:border-slate-700 text-slate-700 dark:text-slate-300">Default</span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full border border-theme-primary text-theme-primary">Primary</span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full border border-success text-success">Success</span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full border border-error text-error">Error</span>
        </div>
      </ExampleSection>

      <ExampleSection title="Status Dots" description="Minimal status indicators.">
        <div class="flex flex-wrap gap-6">
          <span class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
            <span class="w-2 h-2 rounded-full bg-success"></span>
            Online
          </span>
          <span class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
            <span class="w-2 h-2 rounded-full bg-warning"></span>
            Away
          </span>
          <span class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
            <span class="w-2 h-2 rounded-full bg-error"></span>
            Busy
          </span>
          <span class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
            <span class="w-2 h-2 rounded-full bg-slate-400"></span>
            Offline
          </span>
        </div>
      </ExampleSection>

      <ExampleSection title="Badge with Icon" description="Badges with leading icons.">
        <div class="flex flex-wrap gap-3">
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-success/10 text-success flex items-center gap-1">
            <i class="ti ti-check text-sm"></i>
            Completed
          </span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-warning/10 text-warning flex items-center gap-1">
            <i class="ti ti-clock text-sm"></i>
            Pending
          </span>
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-error/10 text-error flex items-center gap-1">
            <i class="ti ti-x text-sm"></i>
            Failed
          </span>
        </div>
      </ExampleSection>

      <ExampleSection title="Count Badges" description="Numeric badges for notifications.">
        <div class="flex flex-wrap gap-6">
          <div class="relative">
            <button class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center">
              <i class="ti ti-bell text-lg text-slate-600 dark:text-slate-400"></i>
            </button>
            <span class="absolute -top-1 -right-1 w-5 h-5 bg-error text-white text-xs font-medium rounded-full flex items-center justify-center">3</span>
          </div>
          <div class="relative">
            <button class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center">
              <i class="ti ti-message text-lg text-slate-600 dark:text-slate-400"></i>
            </button>
            <span class="absolute -top-1 -right-1 w-5 h-5 bg-theme-primary text-white text-xs font-medium rounded-full flex items-center justify-center">12</span>
          </div>
          <div class="relative">
            <button class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center">
              <i class="ti ti-inbox text-lg text-slate-600 dark:text-slate-400"></i>
            </button>
            <span class="absolute -top-1 -right-1 px-1.5 min-w-5 h-5 bg-error text-white text-xs font-medium rounded-full flex items-center justify-center">99+</span>
          </div>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use consistent colors for status</li>
            <li>• Keep badge text concise</li>
            <li>• Position badges consistently</li>
            <li>• Use icons to reinforce meaning</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use too many badges at once</li>
            <li>• Mix badge styles inconsistently</li>
            <li>• Use badges for long text</li>
            <li>• Rely solely on color for meaning</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
        <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
          <i class="ti ti-accessible text-theme-primary"></i>
          Screen Reader Support
        </h3>
        <p class="text-sm text-slate-600 dark:text-slate-400">
          For notification badges, include <code>aria-label</code> to describe the count (e.g., "3 unread notifications").
          Status badges should include text that screen readers can announce.
        </p>
      </div>
    </section>
  </article>
</DocsLayout>




