---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Specialty Inputs" description="Number, URL, and currency inputs.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Specialty Inputs</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Specialized input types for numbers, URLs, currency, and other formatted data.
      </p>
    </header>

    <ExampleSection title="Input Types" description="Different specialized input types.">
      <div class="space-y-4 max-w-sm">
        <div class="space-y-2">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Number Input</label>
          <input type="number" placeholder="0" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white">
        </div>
        <div class="space-y-2">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Currency Input</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500">$</span>
            <input type="number" placeholder="0.00" step="0.01" class="w-full pl-7 pr-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white">
          </div>
        </div>
        <div class="space-y-2">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">URL Input</label>
          <div class="relative">
            <i class="ti ti-link absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
            <input type="url" placeholder="https://example.com" class="w-full pl-10 pr-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-900 text-slate-900 dark:text-white">
          </div>
        </div>
      </div>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="specialty-inputs.html"
      code={`<!-- Currency Input -->
<div class="relative">
  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500">$</span>
  <input type="number" placeholder="0.00" step="0.01" class="w-full pl-7 pr-4 py-2 border rounded-lg">
</div>

<!-- URL Input -->
<div class="relative">
  <i class="ti ti-link absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
  <input type="url" placeholder="https://example.com" class="w-full pl-10 pr-4 py-2 border rounded-lg">
</div>`}
    />
  </article>
</DocsLayout>




