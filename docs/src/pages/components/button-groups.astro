---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Button Groups" description="Horizontal button groups and segmented controls.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Button Groups</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Group related buttons together or create segmented controls for switching between views.
      </p>
    </header>

    <ExampleSection title="Basic Button Group" description="Buttons grouped together with shared borders.">
      <div class="inline-flex rounded-lg border border-slate-200 dark:border-slate-800 overflow-hidden">
        <button class="px-4 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 border-r border-slate-200 dark:border-slate-800">Left</button>
        <button class="px-4 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 border-r border-slate-200 dark:border-slate-800">Center</button>
        <button class="px-4 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800">Right</button>
      </div>
    </ExampleSection>

    <ExampleSection title="Segmented Control" description="Toggle between mutually exclusive options.">
      <div class="inline-flex rounded-lg bg-slate-100 dark:bg-slate-800 p-1">
        <button class="px-4 py-1.5 text-sm font-medium rounded-md bg-white dark:bg-slate-700 text-slate-900 dark:text-white shadow-sm">Day</button>
        <button class="px-4 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white">Week</button>
        <button class="px-4 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white">Month</button>
      </div>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="button-group.html"
      code={`<!-- Basic Button Group -->
<div class="inline-flex rounded-lg border border-slate-200 dark:border-slate-800 overflow-hidden">
  <button class="px-4 py-2 text-sm font-medium border-r border-slate-200 dark:border-slate-800">Left</button>
  <button class="px-4 py-2 text-sm font-medium border-r border-slate-200 dark:border-slate-800">Center</button>
  <button class="px-4 py-2 text-sm font-medium">Right</button>
</div>

<!-- Segmented Control -->
<div class="inline-flex rounded-lg bg-slate-100 dark:bg-slate-800 p-1">
  <button class="px-4 py-1.5 text-sm font-medium rounded-md bg-white dark:bg-slate-700 shadow-sm">Active</button>
  <button class="px-4 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-400">Inactive</button>
</div>`}
    />
  </article>
</DocsLayout>




