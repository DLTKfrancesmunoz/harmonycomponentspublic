---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Tooltips" description="Hover information overlays.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Tooltips</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Tooltips provide additional information when users hover over or focus on an element.
      </p>
    </header>

    <ExampleSection title="Basic Tooltip" description="Hover over the button to see the tooltip.">
      <div class="relative inline-block group">
        <button class="px-4 py-2 bg-theme-primary hover:bg-theme-primary-hover text-white rounded-lg font-medium transition-colors">
          Hover me
        </button>
        <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-1.5 bg-slate-900 dark:bg-slate-700 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap">
          This is a tooltip
          <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-slate-900 dark:border-t-slate-700"></div>
        </div>
      </div>
    </ExampleSection>

    <ExampleSection title="Tooltip Positions" description="Tooltips can appear in different positions.">
      <div class="flex gap-8 py-8">
        <div class="relative inline-block group">
          <button class="px-3 py-1.5 text-sm border border-slate-300 dark:border-slate-700 rounded-lg">Top</button>
          <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-1.5 bg-slate-900 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity">
            Top tooltip
          </div>
        </div>
        <div class="relative inline-block group">
          <button class="px-3 py-1.5 text-sm border border-slate-300 dark:border-slate-700 rounded-lg">Bottom</button>
          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-2 px-3 py-1.5 bg-slate-900 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity">
            Bottom tooltip
          </div>
        </div>
      </div>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="tooltip.html"
      code={`<div class="relative inline-block group">
  <button class="px-4 py-2 bg-theme-primary text-white rounded-lg">
    Hover me
  </button>
  <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-1.5 bg-slate-900 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap">
    Tooltip content
    <!-- Arrow -->
    <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-slate-900"></div>
  </div>
</div>`}
    />
  </article>
</DocsLayout>




