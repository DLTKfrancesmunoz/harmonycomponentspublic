---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="List Menu" description="Vertical navigation menus.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">List Menu</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Vertical list menus for navigation, settings, or action lists.
      </p>
    </header>

    <ExampleSection title="Basic Menu" description="Simple navigation menu.">
      <div class="max-w-xs border border-slate-200 dark:border-slate-800 rounded-lg overflow-hidden">
        <nav class="py-1">
          <a href="#" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800">
            <i class="ti ti-home text-slate-400"></i> Home
          </a>
          <a href="#" class="flex items-center gap-3 px-4 py-2 text-sm bg-theme-primary/10 text-theme-primary">
            <i class="ti ti-folder"></i> Projects
          </a>
          <a href="#" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800">
            <i class="ti ti-settings text-slate-400"></i> Settings
          </a>
        </nav>
      </div>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="list-menu.html"
      code={`<nav class="py-1">
  <a href="#" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800">
    <i class="ti ti-home text-slate-400"></i>
    Home
  </a>
  <a href="#" class="flex items-center gap-3 px-4 py-2 text-sm bg-theme-primary/10 text-theme-primary">
    <i class="ti ti-folder"></i>
    Active Item
  </a>
</nav>`}
    />
  </article>
</DocsLayout>




