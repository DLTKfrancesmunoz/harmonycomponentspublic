---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Tab Strip" description="Horizontal tab navigation.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Tab Strip</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Tab strips allow users to navigate between related content sections.
      </p>
    </header>

    <ExampleSection title="Underline Tabs" description="Classic underline style tabs.">
      <div class="border-b border-slate-200 dark:border-slate-800">
        <nav class="flex gap-6">
          <button class="pb-3 text-sm font-medium text-theme-primary border-b-2 border-theme-primary">Overview</button>
          <button class="pb-3 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white border-b-2 border-transparent">Features</button>
          <button class="pb-3 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white border-b-2 border-transparent">Pricing</button>
        </nav>
      </div>
    </ExampleSection>

    <ExampleSection title="Pill Tabs" description="Rounded pill style tabs.">
      <div class="inline-flex rounded-lg bg-slate-100 dark:bg-slate-800 p-1">
        <button class="px-4 py-1.5 text-sm font-medium rounded-md bg-white dark:bg-slate-700 text-slate-900 dark:text-white shadow-sm">All</button>
        <button class="px-4 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white">Active</button>
        <button class="px-4 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white">Archived</button>
      </div>
    </ExampleSection>

    <ExampleSection title="With Icons" description="Tabs with icons.">
      <div class="border-b border-slate-200 dark:border-slate-800">
        <nav class="flex gap-6">
          <button class="pb-3 text-sm font-medium text-theme-primary border-b-2 border-theme-primary flex items-center gap-2">
            <i class="ti ti-home"></i> Home
          </button>
          <button class="pb-3 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white border-b-2 border-transparent flex items-center gap-2">
            <i class="ti ti-settings"></i> Settings
          </button>
        </nav>
      </div>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="tabs.html"
      code={`<!-- Underline Tabs -->
<div class="border-b border-slate-200 dark:border-slate-800">
  <nav class="flex gap-6">
    <button class="pb-3 text-sm font-medium text-theme-primary border-b-2 border-theme-primary">Active</button>
    <button class="pb-3 text-sm font-medium text-slate-600 dark:text-slate-400 border-b-2 border-transparent">Inactive</button>
  </nav>
</div>

<!-- Pill Tabs -->
<div class="inline-flex rounded-lg bg-slate-100 dark:bg-slate-800 p-1">
  <button class="px-4 py-1.5 text-sm font-medium rounded-md bg-white dark:bg-slate-700 shadow-sm">Active</button>
  <button class="px-4 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-400">Inactive</button>
</div>`}
    />
  </article>
</DocsLayout>




