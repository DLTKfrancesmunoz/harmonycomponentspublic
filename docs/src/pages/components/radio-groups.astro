---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Radio Groups" description="Grouped radio selections.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Radio Groups</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Organized radio button groups with card-style and list layouts.
      </p>
    </header>

    <ExampleSection title="Card Style Radio Group" description="Radio options as selectable cards.">
      <div class="grid sm:grid-cols-3 gap-4 max-w-lg">
        <label class="relative cursor-pointer">
          <input type="radio" name="plan" checked class="peer sr-only">
          <div class="p-4 rounded-lg border-2 border-slate-200 dark:border-slate-800 peer-checked:border-theme-primary peer-checked:bg-theme-primary/5 transition-colors text-center">
            <span class="block font-medium text-slate-900 dark:text-white">Basic</span>
            <span class="text-sm text-slate-500">$10/mo</span>
          </div>
        </label>
        <label class="relative cursor-pointer">
          <input type="radio" name="plan" class="peer sr-only">
          <div class="p-4 rounded-lg border-2 border-slate-200 dark:border-slate-800 peer-checked:border-theme-primary peer-checked:bg-theme-primary/5 transition-colors text-center">
            <span class="block font-medium text-slate-900 dark:text-white">Pro</span>
            <span class="text-sm text-slate-500">$25/mo</span>
          </div>
        </label>
        <label class="relative cursor-pointer">
          <input type="radio" name="plan" class="peer sr-only">
          <div class="p-4 rounded-lg border-2 border-slate-200 dark:border-slate-800 peer-checked:border-theme-primary peer-checked:bg-theme-primary/5 transition-colors text-center">
            <span class="block font-medium text-slate-900 dark:text-white">Enterprise</span>
            <span class="text-sm text-slate-500">Custom</span>
          </div>
        </label>
      </div>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="radio-group.html"
      code={`<label class="relative cursor-pointer">
  <input type="radio" name="plan" class="peer sr-only">
  <div class="p-4 rounded-lg border-2 border-slate-200 dark:border-slate-800 peer-checked:border-theme-primary peer-checked:bg-theme-primary/5 text-center">
    <span class="block font-medium">Option</span>
    <span class="text-sm text-slate-500">Description</span>
  </div>
</label>`}
    />
  </article>
</DocsLayout>




