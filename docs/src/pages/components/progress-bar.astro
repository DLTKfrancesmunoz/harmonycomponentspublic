---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Progress Bar" description="Linear progress indicators.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Progress Bar</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Progress bars show the completion status of a task or process.
      </p>
    </header>

    <ExampleSection title="Progress Variants" description="Different progress states.">
      <div class="space-y-6 max-w-md">
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-slate-600 dark:text-slate-400">Progress</span>
            <span class="text-slate-900 dark:text-white">45%</span>
          </div>
          <div class="h-2 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
            <div class="h-full bg-theme-primary rounded-full" style="width: 45%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-slate-600 dark:text-slate-400">Complete</span>
            <span class="text-success">100%</span>
          </div>
          <div class="h-2 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
            <div class="h-full bg-success rounded-full w-full"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-slate-600 dark:text-slate-400">Warning</span>
            <span class="text-warning">80%</span>
          </div>
          <div class="h-2 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
            <div class="h-full bg-warning rounded-full" style="width: 80%"></div>
          </div>
        </div>
      </div>
    </ExampleSection>

    <CodeBlock 
      language="html"
      filename="progress-bar.html"
      code={`<div>
  <div class="flex justify-between text-sm mb-1">
    <span class="text-slate-600 dark:text-slate-400">Progress</span>
    <span class="text-slate-900 dark:text-white">45%</span>
  </div>
  <div class="h-2 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
    <div class="h-full bg-theme-primary rounded-full" style="width: 45%"></div>
  </div>
</div>`}
    />
  </article>
</DocsLayout>




