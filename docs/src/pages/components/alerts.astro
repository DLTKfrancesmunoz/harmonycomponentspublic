---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import PropsTable from '../../components/PropsTable.astro';
import ExampleSection from '../../components/ExampleSection.astro';

const props = [
  { name: 'variant', type: "'success' | 'warning' | 'error' | 'info'", default: "'info'", description: 'Alert type and color' },
  { name: 'title', type: 'string', default: '—', description: 'Optional title text' },
  { name: 'dismissible', type: 'boolean', default: 'false', description: 'Show close button' },
  { name: 'icon', type: 'string', default: 'auto', description: 'Custom icon (auto-selected by variant)' },
];
---

<DocsLayout title="Alerts" description="Alert components for displaying important messages and notifications.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Alerts</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Alerts display important messages to users. Use different variants to communicate the nature and urgency of the message.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Alert Variants" description="Four semantic variants for different message types.">
        <div class="space-y-4">
          <div class="flex items-start gap-3 p-4 rounded-lg bg-success/10 border border-success/30">
            <i class="ti ti-circle-check text-success text-xl shrink-0 mt-0.5"></i>
            <div>
              <h4 class="font-medium text-success">Success</h4>
              <p class="text-sm text-success/80">Your changes have been saved successfully.</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3 p-4 rounded-lg bg-warning/10 border border-warning/30">
            <i class="ti ti-alert-triangle text-warning text-xl shrink-0 mt-0.5"></i>
            <div>
              <h4 class="font-medium text-warning">Warning</h4>
              <p class="text-sm text-warning/80">Your session will expire in 5 minutes.</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3 p-4 rounded-lg bg-error/10 border border-error/30">
            <i class="ti ti-circle-x text-error text-xl shrink-0 mt-0.5"></i>
            <div>
              <h4 class="font-medium text-error">Error</h4>
              <p class="text-sm text-error/80">Failed to save changes. Please try again.</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3 p-4 rounded-lg bg-info/10 border border-info/30">
            <i class="ti ti-info-circle text-info text-xl shrink-0 mt-0.5"></i>
            <div>
              <h4 class="font-medium text-info">Info</h4>
              <p class="text-sm text-info/80">A new version is available for download.</p>
            </div>
          </div>
        </div>
      </ExampleSection>

      <CodeBlock 
        language="html"
        filename="alerts.html"
        code={`<!-- Success Alert -->
<div class="flex items-start gap-3 p-4 rounded-lg bg-success/10 border border-success/30">
  <i class="ti ti-circle-check text-success text-xl shrink-0 mt-0.5"></i>
  <div>
    <h4 class="font-medium text-success">Success</h4>
    <p class="text-sm text-success/80">Your changes have been saved successfully.</p>
  </div>
</div>

<!-- Warning Alert -->
<div class="flex items-start gap-3 p-4 rounded-lg bg-warning/10 border border-warning/30">
  <i class="ti ti-alert-triangle text-warning text-xl shrink-0 mt-0.5"></i>
  <div>
    <h4 class="font-medium text-warning">Warning</h4>
    <p class="text-sm text-warning/80">Your session will expire in 5 minutes.</p>
  </div>
</div>

<!-- Error Alert -->
<div class="flex items-start gap-3 p-4 rounded-lg bg-error/10 border border-error/30">
  <i class="ti ti-circle-x text-error text-xl shrink-0 mt-0.5"></i>
  <div>
    <h4 class="font-medium text-error">Error</h4>
    <p class="text-sm text-error/80">Failed to save changes. Please try again.</p>
  </div>
</div>

<!-- Info Alert -->
<div class="flex items-start gap-3 p-4 rounded-lg bg-info/10 border border-info/30">
  <i class="ti ti-info-circle text-info text-xl shrink-0 mt-0.5"></i>
  <div>
    <h4 class="font-medium text-info">Info</h4>
    <p class="text-sm text-info/80">A new version is available for download.</p>
  </div>
</div>`}
      />

      <ExampleSection title="Dismissible Alert" description="Alert with close button.">
        <div class="flex items-start gap-3 p-4 rounded-lg bg-info/10 border border-info/30">
          <i class="ti ti-info-circle text-info text-xl shrink-0 mt-0.5"></i>
          <div class="flex-1">
            <h4 class="font-medium text-info">New Feature Available</h4>
            <p class="text-sm text-info/80">Check out our new dashboard analytics feature.</p>
          </div>
          <button class="text-info hover:text-info/80 transition-colors">
            <i class="ti ti-x text-lg"></i>
          </button>
        </div>
      </ExampleSection>

      <ExampleSection title="Inline Alert" description="Compact alert without title.">
        <div class="flex items-center gap-2 px-3 py-2 rounded-lg bg-warning/10 border border-warning/30 text-sm text-warning">
          <i class="ti ti-alert-triangle"></i>
          <span>Unsaved changes will be lost.</span>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use appropriate variant for message type</li>
            <li>• Keep messages concise and actionable</li>
            <li>• Place alerts near related content</li>
            <li>• Allow dismissal for non-critical alerts</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use alerts for decorative purposes</li>
            <li>• Show too many alerts at once</li>
            <li>• Use error style for warnings</li>
            <li>• Hide critical information in alerts</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-speakerphone text-theme-primary"></i>
            ARIA Roles
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Use <code>role="alert"</code> for important messages that should interrupt screen readers. Use <code>role="status"</code> for less urgent updates.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-palette text-theme-primary"></i>
            Color Independence
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Don't rely solely on color to convey meaning. Always include icons and descriptive text alongside color coding.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>




