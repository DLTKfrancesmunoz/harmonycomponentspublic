---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const spacingScale = [
  { name: '0', value: '0px', class: 'w-0' },
  { name: '0.5', value: '2px', class: 'w-0.5' },
  { name: '1', value: '4px', class: 'w-1' },
  { name: '1.5', value: '6px', class: 'w-1.5' },
  { name: '2', value: '8px', class: 'w-2' },
  { name: '2.5', value: '10px', class: 'w-2.5' },
  { name: '3', value: '12px', class: 'w-3' },
  { name: '3.5', value: '14px', class: 'w-3.5' },
  { name: '4', value: '16px', class: 'w-4' },
  { name: '5', value: '20px', class: 'w-5' },
  { name: '6', value: '24px', class: 'w-6' },
  { name: '7', value: '28px', class: 'w-7' },
  { name: '8', value: '32px', class: 'w-8' },
  { name: '9', value: '36px', class: 'w-9' },
  { name: '10', value: '40px', class: 'w-10' },
  { name: '11', value: '44px', class: 'w-11' },
  { name: '12', value: '48px', class: 'w-12' },
  { name: '14', value: '56px', class: 'w-14' },
  { name: '16', value: '64px', class: 'w-16' },
  { name: '20', value: '80px', class: 'w-20' },
  { name: '24', value: '96px', class: 'w-24' },
];

const commonPatterns = [
  { name: 'Tight', values: ['gap-1', 'gap-2'], usage: 'Icon + text, compact lists' },
  { name: 'Default', values: ['gap-3', 'gap-4'], usage: 'Form elements, card content' },
  { name: 'Relaxed', values: ['gap-6', 'gap-8'], usage: 'Section spacing, page sections' },
  { name: 'Loose', values: ['gap-12', 'gap-16'], usage: 'Major sections, hero areas' },
];
---

<DocsLayout title="Spacing" description="Consistent spacing scale for margins, padding, and gaps.">
  <article class="space-y-12">
    <!-- Header -->
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-4">Spacing</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        A consistent spacing scale based on a 4px grid, providing harmonious rhythm and visual balance 
        throughout the interface.
      </p>
    </header>

    <!-- Spacing Scale -->
    <section>
      <h2 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Spacing Scale</h2>
      <div class="space-y-2">
        {spacingScale.map((item) => (
          <div class="flex items-center gap-4 p-3 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/30">
            <div class="w-16 shrink-0">
              <code class="text-xs text-theme-primary">{item.name}</code>
            </div>
            <div class="w-16 shrink-0 text-xs text-slate-500">{item.value}</div>
            <div class="flex-1">
              <div class={`${item.class} h-4 bg-theme-primary rounded`}></div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Common Patterns -->
    <section>
      <h2 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Common Patterns</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {commonPatterns.map((pattern) => (
          <div class="p-6 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
            <h3 class="font-semibold text-slate-900 dark:text-white mb-2">{pattern.name}</h3>
            <div class="flex gap-2 mb-3">
              {pattern.values.map((value) => (
                <code class="text-xs bg-slate-200 dark:bg-slate-800 px-2 py-1 rounded">{value}</code>
              ))}
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400">{pattern.usage}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Visual Examples -->
    <section>
      <h2 class="text-sm font-mono text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-6">Visual Examples</h2>
      
      <div class="space-y-8">
        <!-- Padding Example -->
        <div class="p-6 rounded-lg border border-slate-200 dark:border-slate-800">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-4">Padding</h3>
          <div class="flex flex-wrap gap-4">
            <div class="p-2 bg-theme-primary/20 border-2 border-dashed border-theme-primary rounded">
              <div class="bg-theme-primary text-white text-xs px-2 py-1 rounded">p-2</div>
            </div>
            <div class="p-4 bg-theme-primary/20 border-2 border-dashed border-theme-primary rounded">
              <div class="bg-theme-primary text-white text-xs px-2 py-1 rounded">p-4</div>
            </div>
            <div class="p-6 bg-theme-primary/20 border-2 border-dashed border-theme-primary rounded">
              <div class="bg-theme-primary text-white text-xs px-2 py-1 rounded">p-6</div>
            </div>
            <div class="p-8 bg-theme-primary/20 border-2 border-dashed border-theme-primary rounded">
              <div class="bg-theme-primary text-white text-xs px-2 py-1 rounded">p-8</div>
            </div>
          </div>
        </div>

        <!-- Gap Example -->
        <div class="p-6 rounded-lg border border-slate-200 dark:border-slate-800">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-4">Gap (Flexbox/Grid)</h3>
          <div class="space-y-4">
            <div>
              <code class="text-xs text-slate-500 mb-2 block">gap-2 (8px)</code>
              <div class="flex gap-2">
                <div class="w-12 h-8 bg-theme-primary rounded"></div>
                <div class="w-12 h-8 bg-theme-primary rounded"></div>
                <div class="w-12 h-8 bg-theme-primary rounded"></div>
              </div>
            </div>
            <div>
              <code class="text-xs text-slate-500 mb-2 block">gap-4 (16px)</code>
              <div class="flex gap-4">
                <div class="w-12 h-8 bg-theme-primary rounded"></div>
                <div class="w-12 h-8 bg-theme-primary rounded"></div>
                <div class="w-12 h-8 bg-theme-primary rounded"></div>
              </div>
            </div>
            <div>
              <code class="text-xs text-slate-500 mb-2 block">gap-6 (24px)</code>
              <div class="flex gap-6">
                <div class="w-12 h-8 bg-theme-primary rounded"></div>
                <div class="w-12 h-8 bg-theme-primary rounded"></div>
                <div class="w-12 h-8 bg-theme-primary rounded"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Code Usage -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Code Usage</h2>
      <CodeBlock 
        language="html"
        filename="spacing.html"
        code={`<!-- Padding -->
<div class="p-4">All sides: 16px</div>
<div class="px-6 py-4">Horizontal: 24px, Vertical: 16px</div>
<div class="pt-8 pb-4">Top: 32px, Bottom: 16px</div>

<!-- Margin -->
<div class="m-4">All sides: 16px</div>
<div class="mx-auto">Center horizontally</div>
<div class="mt-8 mb-4">Top: 32px, Bottom: 16px</div>

<!-- Gap (Flexbox/Grid) -->
<div class="flex gap-4">Flex with 16px gap</div>
<div class="grid grid-cols-3 gap-6">Grid with 24px gap</div>

<!-- Space between children -->
<div class="space-y-4">Vertical space: 16px</div>
<div class="space-x-2">Horizontal space: 8px</div>`}
      />
    </section>

    <!-- Guidelines -->
    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2">
            <i class="ti ti-check"></i> Do
          </h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use consistent spacing throughout components</li>
            <li>• Increase spacing for visual hierarchy</li>
            <li>• Use gap utilities for flex/grid layouts</li>
            <li>• Group related items with tighter spacing</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2">
            <i class="ti ti-x"></i> Don't
          </h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use arbitrary pixel values</li>
            <li>• Mix spacing patterns inconsistently</li>
            <li>• Overuse large spacing values</li>
            <li>• Ignore responsive spacing needs</li>
          </ul>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>




