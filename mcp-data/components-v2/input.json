{
  "name": "Input",
  "type": "component",
  "filePath": "src/components/ui/Input.astro",
  "description": "Input Component",
  "props": {
    "type": {
      "type": "'text' | 'email' | 'password' | 'number' | 'url' | 'search' | 'tel'",
      "optional": true,
      "default": "'text'"
    },
    "placeholder": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "value": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "name": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "id": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "disabled": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "error": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "errorMessage": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "icon": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "required": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "label": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "labelVariant": {
      "type": "'inline' | 'stacked'",
      "optional": true,
      "default": null
    },
    "labelFor": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light"
  },
  "specs": {
    "cp-light": {
      "_meta": {
        "theme": "cp",
        "mode": "light",
        "locked": true
      },
      "_buildContract": {
        "criticalSelectors": {
          ".input-form-wrapper__label": {
            "margin-bottom": "0",
            "white-space": "nowrap"
          },
          ".input-wrapper__error": {
            "margin-top": "4px",
            "font-size": "0.875rem",
            "color": "#F46286",
            "font-family": "'Figtree', sans-serif"
          },
          ".input-wrapper__icon": {
            "position": "absolute",
            "left": "16px",
            "top": "50%",
            "transform": "translateY(-50%)",
            "color": "#6B7280",
            "pointer-events": "none",
            "z-index": "10"
          },
          ".input-form-wrapper": {
            "display": "flex",
            "flex-direction": "column"
          },
          ".input-wrapper": {
            "position": "relative"
          },
          ".input": {
            "width": "100%",
            "height": "40px",
            "padding": "0 16px",
            "font-family": "'Figtree', sans-serif",
            "font-size": "1rem",
            "color": "#373F4E",
            "background-color": "#FFFFFF",
            "border": "1px solid #BFC6D4",
            "border-radius": "0.5rem",
            "transition": "all 150ms ease"
          },
          ".wrapperClasses": {}
        },
        "forbiddenModifications": [
          "Do not use Tailwind arbitrary values",
          "Do not change hex colors to named colors",
          "Do not simplify box-shadow values",
          "Do not add CSS properties that are not in criticalSelectors or in elements[].styles (or element states)",
          "Do not reorder children: follow contentOrder and elements[].children order exactly",
          "Build exactly what is in the spec: structure, styles, and defaultContent from the JSON only; no inference, no additions, no \"fixes\""
        ]
      },
      "elements": [
        {
          "selector": ".input-form-wrapper__label",
          "tag": "div",
          "styles": {
            "margin-bottom": "0",
            "white-space": "nowrap"
          },
          "children": [
            ".input-wrapper__error"
          ]
        },
        {
          "selector": ".input-wrapper__error",
