            "color": "#6B7280",
            "pointer-events": "none",
            "z-index": "10"
          },
          "children": [
            ".input-form-wrapper"
          ],
          "parent": ".input-wrapper"
        },
        {
          "selector": ".input-form-wrapper",
          "tag": "div",
          "styles": {
            "display": "flex",
            "flex-direction": "column"
          },
          "children": [
            ".input-wrapper"
          ],
          "parent": ".input-wrapper__icon"
        },
        {
          "selector": ".input-wrapper",
          "tag": "div",
