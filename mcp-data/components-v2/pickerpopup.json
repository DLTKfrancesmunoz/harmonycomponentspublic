    "cp-light": {
      "_meta": {
        "theme": "cp",
        "mode": "light",
        "locked": true
      },
      "_buildContract": {
        "criticalSelectors": {
          ".picker-popup": {
            "display": "none",
            "position": "absolute",
            "top": "calc(100% + 8px)",
            "left": "0",
            "background-color": "#F7F8FA",
            "border": "1px solid #BFC6D4",
            "border-radius": "0.5rem",
            "box-shadow": "0 20px 25px -5px rgb(15 23 42 / 0.1), 0 8px 10px -6px rgb(15 23 42 / 0.1)",
            "padding": "16px",
            "z-index": "400",
            "min-width": "280px",
            "max-width": "320px"
          },
          ".picker-popup__close": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "center",
            "width": "32px",
            "height": "32px",
            "padding": "0",
            "background": "transparent",
            "border": "none",
            "border-radius": "0.375rem",
            "color": "#525969",
            "cursor": "pointer",
            "transition": "all 150ms ease"
          },
          ".picker-popup__header": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "space-between",
            "margin-bottom": "16px",
            "padding-bottom": "12px",
            "border-bottom": "1px solid #BFC6D4"
          },
          ".picker-popup__title": {
            "font-size": "1rem",
            "font-weight": "600",
            "color": "#373F4E",
            "margin": "0",
            "font-family": "'Figtree', sans-serif"
          }
        },
        "forbiddenModifications": [
          "Do not use Tailwind arbitrary values",
          "Do not change hex colors to named colors",
          "Do not simplify box-shadow values",
          "Do not add CSS properties that are not in criticalSelectors or in elements[].styles (or element states)",
          "Do not reorder children: follow contentOrder and elements[].children order exactly",
          "Build exactly what is in the spec: structure, styles, and defaultContent from the JSON only; no inference, no additions, no \"fixes\""
        ]
      },
      "elements": [
