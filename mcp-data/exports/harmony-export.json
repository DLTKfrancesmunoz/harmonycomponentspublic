{
  "version": "1.0.0",
  "source": "Harmony Design System",
  "designSystemOverview": {
    "version": "1.0.0",
    "description": "Harmony Design System overview for AI — global rules and tokens. Read first when building any component, template, recipe, or applying tokens to a framework.",
    "fonts": {
      "sans": {
        "family": "Figtree",
        "stack": "'Figtree', sans-serif",
        "description": "Primary body text",
        "googleFonts": "https://fonts.googleapis.com/css2?family=Figtree:wght@300..900&display=swap"
      },
      "display": {
        "family": "Lexend",
        "stack": "'Lexend', sans-serif",
        "description": "Headings and display text",
        "googleFonts": "https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;800;900&display=swap"
      },
      "mono": {
        "family": "JetBrains Mono",
        "stack": "'JetBrains Mono', monospace",
        "description": "Code and technical content",
        "googleFonts": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap"
      }
    },
    "icons": {
      "source": "Heroicons",
      "sizePx": "24",
      "naming": "kebab-case",
      "pathPattern": {
        "outline": "node_modules/heroicons/24/outline/{name}.svg",
        "solid": "node_modules/heroicons/24/solid/{name}.svg"
      },
      "resolutionOrder": [
        "Heroicons",
        "Tabler",
        "public/{name}.svg"
      ],
      "sizes": {
        "xs": {
          "width": 12,
          "height": 12
        },
        "sm": {
          "width": 16,
          "height": 16
        },
        "md": {
          "width": 20,
          "height": 20
        },
        "lg": {
          "width": 24,
          "height": 24
        },
        "xl": {
          "width": 32,
          "height": 32
        }
      }
    },
    "fallbackIcons": {
      "behavior": "Render placeholder with '?' when icon name is missing or unresolved",
      "style": {
        "background": "#ffecef",
        "color": "#c1253a",
        "fontSize": "8px",
        "borderRadius": "2px"
      },
      "cssVars": {
        "bg": "--icon-fallback-bg",
        "text": "--icon-fallback-text",
        "fontSize": "--icon-fallback-font-size",
        "radius": "--icon-fallback-radius"
      }
    },
    "themes": [
      "cp",
      "vp",
      "ppm",
      "maconomy"
    ],
    "modes": [
      "light",
      "dark"
    ],
    "defaults": {
      "theme": "cp",
      "mode": "light"
    },
    "spacing": {
      "grid": "4px",
      "scale": {
        "0": "0px",
        "1": "4px",
        "2": "8px",
        "3": "12px",
        "4": "16px",
        "6": "24px",
        "8": "32px",
        "0.5": "2px"
      }
    },
    "typography": {
      "fontSizes": {
        "xs": "0.75rem",
        "sm": "0.875rem",
        "base": "1rem",
        "lg": "1.125rem",
        "xl": "1.25rem"
      },
      "fontWeights": {
        "light": 300,
        "normal": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      }
    },
    "borderRadius": {
      "scale": [
        "4px",
        "8px",
        "12px",
        "16px",
        "24px",
        "9999px"
      ],
      "cssVars": [
        "--radius-04",
        "--radius-08",
        "--radius-12",
        "--radius-16",
        "--radius-24",
        "--radius-100"
      ]
    }
  },
  "sampleBuildSpec": {
    "props": {
      "variant": {
        "type": "'primary' | 'secondary' | 'tertiary' | 'outline' | 'ghost' | 'destructive' | 'dela' | 'dela-pill'",
        "optional": true,
        "default": "'primary'"
      },
      "buttonType": {
        "type": "'theme' | 'pageHeader'",
        "optional": true,
        "default": "'theme'"
      },
      "size": {
        "type": "'xs' | 'sm' | 'md' | 'lg'",
        "optional": true,
        "default": "'md'"
      },
      "orientation": {
        "type": "'horizontal' | 'vertical'",
        "optional": true,
        "default": "'horizontal'"
      },
      "disabled": {
        "type": "boolean",
        "optional": true,
        "default": "false"
      },
      "loading": {
        "type": "boolean",
        "optional": true,
        "default": "false"
      },
      "loadingText": {
        "type": "string",
        "optional": true,
        "default": null
      },
      "icon": {
        "type": "string",
        "optional": true,
        "default": null
      },
      "iconPosition": {
        "type": "'left' | 'right'",
        "optional": true,
        "default": "'left'"
      },
      "type": {
        "type": "'button' | 'submit' | 'reset'",
        "optional": true,
        "default": "'button'"
      },
      "fullWidth": {
        "type": "boolean",
        "optional": true,
        "default": "false"
      },
      "href": {
        "type": "string",
        "optional": true,
        "default": null
      },
      "class": {
        "type": "string",
        "optional": true,
        "default": "''"
      }
    },
    "layout": {
      "display": "inline-flex",
      "flexDirection": "row",
      "alignItems": "center",
      "justifyContent": "center",
      "gap": "8px"
    },
    "spacing": {
      "paddingTop": "8px",
      "paddingRight": "12px",
      "paddingBottom": "8px",
      "paddingLeft": "12px"
    },
    "dimensions": {
      "height": "40px",
      "minWidth": "auto",
      "maxWidth": "none"
    },
    "typography": {
      "fontFamily": "'Figtree', sans-serif",
      "fontSize": "1rem",
      "fontWeight": "500",
      "lineHeight": null
    },
    "borders": {
      "width": null,
      "style": null,
      "radius": "9999px"
    },
    "states": {
      "default": {
        "background": "#4C92D9",
        "text": "#FFFFFF",
        "border": "transparent",
        "iconColor": "#FFFFFF"
      },
      "hover": {
        "background": "#3D7BC4",
        "text": "#FFFFFF",
        "border": "transparent",
        "iconColor": "#FFFFFF"
      },
      "active": {
        "background": "#4C92D9",
        "text": "#FFFFFF",
        "border": "transparent",
        "iconColor": "#FFFFFF"
      },
      "focus": {
        "background": "#4C92D9",
        "text": "#FFFFFF",
        "border": "transparent",
        "iconColor": "#FFFFFF",
        "outline": "1px solid #F7F8FA",
        "outlineOffset": "0"
      },
      "disabled": {
        "background": "#e0e4eb",
        "text": "#bfc6d4",
        "border": "transparent",
        "iconColor": "#bfc6d4",
        "cursor": "not-allowed",
        "opacity": "1"
      }
    },
    "icons": {
      "iconSizePx": "16px",
      "gapBetweenIconAndText": "8px"
    }
  }
}