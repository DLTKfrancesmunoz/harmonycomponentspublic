  "states": {
    "default": {
      "cursor": "pointer",
      "textDecoration": "none",
      "whiteSpace": "nowrap"
    },
    "hover": {
      "textDecoration": "none"
    },
    "focused": {
      "outline": "1px solid var(--card-bg)",
      "outlineOffset": "0",
      "boxShadow": "var(--focus-ring-primary)"
    },
    "pressed": {
      "textDecoration": "none"
    },
    "disabled": {
      "cursor": "not-allowed",
      "pointerEvents": "none",
      "opacity": "1"
    }
  },
  "cssClassStyles": {
    ".chip": {
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center",
      "fontFamily": "'Figtree', sans-serif",
      "fontWeight": "400",
      "borderRadius": "4px",
      "border": "1px solid transparent",
      "transition": "all 150ms ease",
      "whiteSpace": "nowrap",
      "cursor": "pointer"
    },
    ".chip--sm": {
      "height": "16px",
      "padding": "4px 8px",
      "gap": "4px",
      "fontSize": "0.625rem",
      "lineHeight": "16px"
    },
    ".chip--md": {
      "height": "24px",
      "padding": "4px 8px",
      "gap": "4px",
      "fontSize": "0.875rem",
      "lineHeight": "20px"
    },
    ".chip--lg": {
      "height": "32px",
      "padding": "6px 8px",
      "gap": "4px",
      "fontSize": "1rem",
      "lineHeight": "20px"
    },
    ".chip--sm :global(svg):not(.chip__dots-svg)": {
      "width": "12px",
      "height": "12px"
    },
    ".chip--md :global(svg):not(.chip__dots-svg)": {
      "width": "16px",
      "height": "16px"
    },
    ".chip--lg :global(svg):not(.chip__dots-svg)": {
      "width": "16px",
      "height": "16px"
    },
    ".chip--fill": {
      "backgroundColor": "var(--theme-primary)",
      "borderColor": "var(--theme-primary)",
      "color": "var(--text-inverse)"
    },
    ".chip--fill.chip--hover": {
      "backgroundColor": "var(--theme-primary-hover)",
      "borderColor": "var(--theme-primary-hover)",
      "color": "var(--text-inverse)"
    },
    ".chip--fill.chip--focused": {
      "backgroundColor": "var(--theme-primary)",
      "borderColor": "var(--theme-primary)",
      "color": "var(--text-inverse)",
      "outline": "1px solid var(--card-bg)",
      "outlineOffset": "0",
      "boxShadow": "var(--focus-ring-primary)"
    },
    ".chip--fill.chip--pressed": {
      "backgroundColor": "var(--theme-primary)",
      "borderColor": "var(--theme-primary)",
      "color": "var(--text-inverse)"
    },
    ".chip--fill.chip--disabled": {
      "backgroundColor": "#e0e4eb",
      "borderColor": "#e0e4eb",
      "color": "#94a3b8",
      "cursor": "not-allowed",
      "opacity": "1"
    },
    ".chip--outline": {
      "backgroundColor": "transparent",
      "borderColor": "var(--theme-primary)",
      "color": "var(--theme-primary)"
    },
    ".chip--outline.chip--hover": {
      "backgroundColor": "var(--hover-bg)",
      "borderColor": "var(--theme-primary)",
      "color": "var(--theme-primary)"
    },
    ".chip--outline.chip--focused": {
      "backgroundColor": "var(--hover-bg)",
      "borderColor": "var(--theme-primary)",
      "color": "var(--theme-primary)",
      "outline": "1px solid var(--card-bg)",
      "outlineOffset": "0",
      "boxShadow": "var(--focus-ring-primary)"
    },
    ".chip--outline.chip--pressed": {
      "backgroundColor": "var(--theme-primary)",
      "borderColor": "var(--theme-primary)",
      "color": "var(--text-inverse)"
    },
    ".chip--outline.chip--disabled": {
      "backgroundColor": "transparent",
      "borderColor": "#bfc6d4",
      "color": "#94a3b8",
      "cursor": "not-allowed",
      "opacity": "1"
    },
    ".chip--horiz-dots": {
      "padding": "4px 8px"
    },
    ".chip--vert-dots": {
      "padding": "4px 8px"
    },
    ".chip--sm.chip--vert-dots": {
      "width": "16px",
      "minWidth": "16px"
    },
    ".chip--md.chip--vert-dots": {
      "width": "24px",
      "minWidth": "24px"
    },
    ".chip--lg.chip--vert-dots": {
      "width": "32px",
      "minWidth": "32px"
    },
    ".chip--horiz-dots.chip--sm": {
      "width": "auto",
      "minWidth": "14px"
    },
    ".chip--horiz-dots.chip--md": {
      "width": "auto",
      "minWidth": "18px"
    },
    ".chip--horiz-dots.chip--lg": {
      "width": "auto",
      "minWidth": "24px"
    },
    ".chip__dots": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "center",
      "flexShrink": "0",
      "width": "100%",
      "height": "100%"
    },
    ".chip__dots-svg": {
      "width": "100%",
      "height": "100%"
    },
    ".chip--sm .chip__dots--horiz .chip__dots-svg": {
      "width": "14px",
      "height": "3px"
    },
    ".chip--md .chip__dots--horiz .chip__dots-svg": {
      "width": "18px",
      "height": "4px"
    },
    ".chip--lg .chip__dots--horiz .chip__dots-svg": {
      "width": "24px",
      "height": "5.333px"
    },
    ".chip--sm .chip__dots--vert .chip__dots-svg": {
      "width": "2px",
      "height": "9px"
    },
    ".chip--md .chip__dots--vert .chip__dots-svg": {
      "width": "3.111px",
      "height": "14px"
    },
    ".chip--lg .chip__dots--vert .chip__dots-svg": {
      "width": "4.148px",
      "height": "18.667px"
    },
    ".chip__overflow-text": {
      "fontWeight": "400",
      "fontSize": "inherit",
      "lineHeight": "inherit"
    },
    ".chip--selected": {
      "backgroundColor": "var(--theme-primary-light)",
      "borderColor": "var(--theme-primary)",
      "color": "var(--theme-primary)"
    },
    ".chip--selected.chip--fill": {
      "backgroundColor": "var(--theme-primary)",
      "color": "var(--text-inverse)"
    },
    ".chip__remove": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "center",
      "border": "none",
      "background": "transparent",
      "padding": "0",
      "marginLeft": "4px",
      "cursor": "pointer",
      "transition": "all 150ms ease",
      "flexShrink": "0",
      "color": "inherit"
    },
    ".chip--sm .chip__remove": {
      "width": "12px",
      "height": "12px"
    },
    ".chip--md .chip__remove": {
      "width": "16px",
      "height": "16px"
    },
    ".chip--lg .chip__remove": {
      "width": "16px",
      "height": "16px"
    },
    ".chip__remove:hover": {
      "opacity": "0.8"
    },
    ".chip--disabled .chip__remove": {
      "cursor": "not-allowed",
      "opacity": "1"
    },
    ".chip--disabled .chip__remove:hover": {
      "opacity": "1"
    },
    "@media (max-width: 768px)": {
      ".chip__remove": {
        "minWidth": "44px",
        "minHeight": "44px"
      }
    }
  }
}
