    "insetShadows": {},
    "cssVars": {
      "focusRingError": "--focus-ring-error",
      "focusRingErrorChecked": "--focus-ring-error-checked",
      "focusRingWarning": "--focus-ring-warning",
      "focusRingWarningChecked": "--focus-ring-warning-checked"
    }
  },
  "states": {
    "default": {
      "root": {
        "border": "none",
        "padding": "0",
        "margin": "0"
      },
      "legend": {
        "display": "conditional (if legend prop provided)",
        "color": "var(--text-primary)",
        "fontFamily": "var(--font-display)",
        "fontSize": "var(--text-sm)",
        "fontWeight": "var(--font-semibold)",
        "marginBottom": "var(--space-3)"
      },
      "content": {
        "display": "flex",
        "flexDirection": "column",
        "gap": "var(--space-3)"
      },
      "message": {
        "display": "none"
      }
    },
    "error": {
      "root": {
        "border": "none",
        "padding": "0",
        "margin": "0",
        "ariaInvalid": "true"
      },
      "legend": {
        "display": "conditional (if legend prop provided)",
        "color": "var(--color-error)",
        "fontFamily": "var(--font-display)",
        "fontSize": "var(--text-sm)",
        "fontWeight": "var(--font-semibold)",
        "marginBottom": "var(--space-3)"
      },
      "content": {
        "display": "flex",
        "flexDirection": "column",
        "gap": "var(--space-3)"
      },
      "message": {
        "display": "flex (if errorMessage provided)",
        "alignItems": "center",
        "gap": "var(--space-1)",
        "marginTop": "var(--space-1)",
        "fontSize": "var(--text-sm)",
        "color": "var(--text-secondary)"
      },
      "messageIcon": {
        "color": "var(--color-error)",
        "flexShrink": "0"
      },
      "childCheckbox": {
        "borderColor": "var(--color-error)",
        "borderWidth": "var(--border-width-standard)"
      }
    },
    "warning": {
      "root": {
        "border": "none",
        "padding": "0",
        "margin": "0"
      },
      "legend": {
        "display": "conditional (if legend prop provided)",
        "color": "var(--color-warning)",
        "fontFamily": "var(--font-display)",
        "fontSize": "var(--text-sm)",
        "fontWeight": "var(--font-semibold)",
        "marginBottom": "var(--space-3)"
      },
      "content": {
        "display": "flex",
        "flexDirection": "column",
        "gap": "var(--space-3)"
      },
      "message": {
        "display": "flex (if warningMessage provided and error is false)",
        "alignItems": "center",
        "gap": "var(--space-1)",
        "marginTop": "var(--space-1)",
        "fontSize": "var(--text-sm)",
        "color": "var(--text-secondary)"
      },
      "messageIcon": {
        "color": "var(--color-warning)",
        "flexShrink": "0"
      },
      "childCheckbox": {
        "borderColor": "var(--color-warning)"
      }
    },
    "horizontal": {
      "content": {
        "flexDirection": "row",
        "flexWrap": "wrap",
        "gap": "var(--space-4)"
      }
    },
    "vertical": {
      "content": {
        "flexDirection": "column",
        "gap": "var(--space-3)"
      }
    },
    "withLegend": {
      "legend": {
        "display": "block"
      }
    },
    "withErrorMessage": {
      "message": {
        "display": "flex",
        "variant": "error"
      }
    },
    "withWarningMessage": {
      "message": {
        "display": "flex",
        "variant": "warning"
      }
    }
  },
  "cssClassStyles": {
    ".checkbox-group-wrapper": {
      "border": "none",
      "padding": "0",
      "margin": "0"
    },
    ".checkbox-group-wrapper__content": {
      "display": "flex",
      "flexDirection": "column",
      "gap": "12px"
    },
    ".checkbox-group-wrapper--horizontal .checkbox-group-wrapper__content": {
      "flexDirection": "row",
      "flexWrap": "wrap",
      "gap": "16px"
    },
    ".checkbox-group-wrapper__legend": {
      "fontFamily": "'Lexend', sans-serif",
      "fontSize": "0.875rem",
      "fontWeight": "600",
      "color": "var(--text-primary)",
      "marginBottom": "12px"
    },
    ".checkbox-group-wrapper__legend--error": {
      "color": "var(--color-error)"
    },
    ".checkbox-group-wrapper__legend--warning": {
      "color": "var(--color-warning)"
    },
    ".checkbox-group-wrapper__message": {
      "display": "flex",
      "alignItems": "center",
      "gap": "4px",
      "marginTop": "4px",
      "fontSize": "0.875rem",
      "color": "var(--text-secondary)"
    },
    ".checkbox-group-wrapper__message-icon": {
      "flexShrink": "0"
    },
    ".checkbox-group-wrapper__message--error .checkbox-group-wrapper__message-icon": {
      "color": "var(--color-error)"
    },
    ".checkbox-group-wrapper__message--warning .checkbox-group-wrapper__message-icon": {
      "color": "var(--color-warning)"
    },
    ".checkbox-group-wrapper--error .checkbox__box": {
      "borderColor": "var(--color-error)",
      "borderWidth": "2px"
    },
    ".checkbox-group-wrapper--error .checkbox__input:checked + .checkbox__box": {
      "backgroundColor": "var(--theme-primary)",
      "borderColor": "var(--theme-primary)",
      "boxShadow": "0 0 0 2px var(--color-error)"
    },
    ".checkbox-group-wrapper--error .checkbox__input:focus + .checkbox__box": {
      "boxShadow": "var(--focus-ring-error)"
    },
    ".checkbox-group-wrapper--error .checkbox__input:checked:focus + .checkbox__box": {
      "boxShadow": "var(--focus-ring-error-checked)"
    },
    ".checkbox-group-wrapper--warning .checkbox__box": {
      "borderColor": "var(--color-warning)"
    },
    ".checkbox-group-wrapper--warning .checkbox__input:checked + .checkbox__box": {
      "backgroundColor": "var(--theme-primary)",
      "borderColor": "var(--theme-primary)",
      "boxShadow": "0 0 0 1px var(--color-warning)"
    },
    ".checkbox-group-wrapper--warning .checkbox__input:focus + .checkbox__box": {
      "boxShadow": "var(--focus-ring-warning)"
    },
    ".checkbox-group-wrapper--warning .checkbox__input:checked:focus + .checkbox__box": {
      "boxShadow": "var(--focus-ring-warning-checked)"
    },
    "@media (max-width: 768px)": {
      ".checkbox-group-wrapper--horizontal .checkbox-group-wrapper__content": {
        "flexDirection": "column",
        "gap": "12px"
      },
      ".checkbox-group-wrapper__content": {
        "gap": "12px"
      }
    }
  }
}
