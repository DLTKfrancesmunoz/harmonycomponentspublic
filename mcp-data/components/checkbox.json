      "borderWidth": "2px"
    }
  },
  "cssClassStyles": {
    ".checkbox": {
      "display": "inline-flex",
      "alignItems": "center",
      "gap": "8px",
      "cursor": "pointer"
    },
    ".checkbox__input": {
      "position": "absolute",
      "opacity": "0",
      "width": "0",
      "height": "0"
    },
    ".checkbox__box": {
      "width": "18px",
      "height": "18px",
      "border": "2px solid",
      "borderRadius": "4px",
      "backgroundColor": "var(--input-bg)",
      "borderColor": "var(--border-color)",
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "center",
      "transition": "all 150ms ease",
      "flexShrink": "0"
    },
    ".checkbox__input:checked + .checkbox__box": {
      "backgroundColor": "var(--theme-primary)",
      "borderColor": "var(--theme-primary)"
    },
    ".checkbox__input:focus + .checkbox__box": {
      "boxShadow": "var(--focus-ring-primary)"
    },
    ".checkbox__input:disabled + .checkbox__box": {
      "opacity": "0.5",
      "cursor": "not-allowed"
    },
    ".checkbox__icon": {
      "color": "white",
      "fontSize": "0.75rem",
      "opacity": "0",
      "transform": "scale(0)",
      "transition": "all 150ms ease"
    },
    ".checkbox__input:checked + .checkbox__box .checkbox__icon": {
      "opacity": "1",
      "transform": "scale(1)"
    },
    ".checkbox__label": {
      "fontSize": "0.875rem",
      "color": "var(--text-primary)"
    },
    ".checkbox--disabled": {
      "cursor": "not-allowed"
    },
    ".checkbox--disabled .checkbox__label": {
      "color": "var(--text-muted)"
    },
    ".checkbox--warning .checkbox__box": {
      "borderColor": "var(--color-warning)"
    },
    ".checkbox--warning .checkbox__input:checked + .checkbox__box": {
      "backgroundColor": "var(--theme-primary)",
      "borderColor": "var(--theme-primary)",
      "boxShadow": "0 0 0 1px var(--color-warning)"
    },
    ".checkbox--warning .checkbox__input:focus + .checkbox__box": {
      "boxShadow": "var(--focus-ring-warning)"
    },
    ".checkbox--warning .checkbox__input:checked:focus + .checkbox__box": {
      "boxShadow": "var(--focus-ring-warning-checked)"
    },
    ".checkbox--error .checkbox__box": {
      "borderColor": "var(--color-error)",
      "borderWidth": "2px"
    },
    ".checkbox--error .checkbox__input:checked + .checkbox__box": {
      "backgroundColor": "var(--theme-primary)",
      "borderColor": "var(--theme-primary)",
      "boxShadow": "0 0 0 2px var(--color-error)"
    },
    ".checkbox--error .checkbox__input:focus + .checkbox__box": {
      "boxShadow": "var(--focus-ring-error)"
    },
    ".checkbox--error .checkbox__input:checked:focus + .checkbox__box": {
      "boxShadow": "var(--focus-ring-error-checked)"
    },
    ".checkbox-wrapper": {
      "display": "flex",
      "flexDirection": "column"
    },
    ".checkbox-wrapper__warning, .checkbox-wrapper__error": {
      "display": "flex",
      "alignItems": "center",
      "gap": "4px",
      "marginTop": "4px",
      "fontSize": "0.875rem",
      "color": "var(--text-secondary)"
    },
    ".checkbox-wrapper__warning": {
      "color": "var(--text-secondary)"
    },
    ".checkbox-wrapper__warning-icon": {
      "color": "var(--color-warning)",
      "flexShrink": "0"
    },
    ".checkbox-wrapper__error": {
      "color": "var(--text-secondary)"
    },
    ".checkbox-wrapper__error-icon": {
      "color": "var(--color-error)",
      "flexShrink": "0"
    },
    "@media (max-width: 768px)": {
      ".checkbox": {
        "minHeight": "44px"
      }
    }
  }
}
