    "shadows": {
      "sm": {
        "light": "0 1px 2px 0 rgb(15 23 42 / 0.05)",
        "dark": "0 1px 2px 0 rgba(0, 0, 0, 0.3)",
        "cssVar": "--shadow-sm"
      },
      "lg": {
        "light": "0 10px 15px -3px rgb(15 23 42 / 0.1), 0 4px 6px -4px rgb(15 23 42 / 0.1)",
        "dark": "0 10px 15px -3px rgba(0, 0, 0, 0.4), 0 4px 6px -4px rgba(0, 0, 0, 0.3)",
        "cssVar": "--shadow-lg"
      }
    },
    "cssVars": {
      "shadowSm": "--shadow-sm",
      "shadowLg": "--shadow-lg"
    }
  },
  "states": {
    "default": {
      "root": {
        "backgroundColor": "var(--card-bg)",
        "border": "1px solid var(--border-color)",
        "borderRadius": "12px",
        "boxShadow": "var(--shadow-sm)",
        "overflow": "hidden"
      },
      "header": {
        "padding": "16px",
        "borderBottom": "1px solid var(--border-color)"
      },
      "body": {
        "padding": "16px"
      },
      "footer": {
        "padding": "16px",
        "borderTop": "1px solid var(--border-color)",
        "backgroundColor": "var(--elevated-bg)"
      }
    },
    "hover": {
      "interactive": {
        "borderColor": "var(--theme-primary)",
        "boxShadow": "var(--shadow-lg)"
      }
    },
    "focus": {
      "interactive": {
        "outline": "none"
      }
    }
  },
  "cssClassStyles": {
    ".card": {
      "backgroundColor": "var(--card-bg)",
      "border": "1px solid var(--border-color)",
      "borderRadius": "var(--radius-xl)",
      "overflow": "hidden",
      "boxShadow": "var(--shadow-sm)"
    },
    ".card--elevated": {
      "boxShadow": "var(--shadow-lg)"
    },
    ".card--interactive": {
      "cursor": "pointer",
      "transition": "all var(--transition-fast)"
    },
    ".card--interactive:hover": {
      "borderColor": "var(--theme-primary)",
      "boxShadow": "var(--shadow-lg)"
    },
    ".card--primary": {
      "borderTop": "var(--space-1) solid var(--theme-primary)"
    },
    ".card__header": {
      "padding": "var(--space-4)",
      "borderBottom": "1px solid var(--border-color)"
    },
    ".card__title": {
      "fontFamily": "var(--font-display)",
      "fontSize": "var(--text-lg)",
      "fontWeight": "var(--font-semibold)",
      "color": "var(--text-primary)"
    },
    ".card__subtitle": {
      "fontSize": "var(--text-sm)",
      "color": "var(--text-secondary)",
      "marginTop": "var(--space-1)"
    },
    ".card__body": {
      "padding": "var(--space-4)"
    },
    ".card__footer": {
      "padding": "var(--space-4)",
      "borderTop": "1px solid var(--border-color)",
      "backgroundColor": "var(--elevated-bg)"
    },
    ".card__header--colored": {
      "height": "var(--space-12)",
      "backgroundColor": "var(--theme-primary)",
      "padding": "0 var(--space-4)",
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "borderTopLeftRadius": "var(--radius-xl)",
      "borderTopRightRadius": "var(--radius-xl)"
    },
    ".card__header--colored, .card__header--colored div, .card__header--colored span, .card__header--colored p": {
      "color": "var(--text-inverse)"
    },
    ".card__header--colored svg, .card__header--colored :global(svg)": {
      "color": "var(--text-inverse)",
      "stroke": "currentColor"
    },
    ".card__header--colored .card__header-content": {
      "display": "flex",
      "flexDirection": "column",
      "gap": "var(--space-1)",
      "flex": "1"
    },
    ".card__header--colored .card__header-title": {
      "fontFamily": "var(--font-display)",
      "fontSize": "var(--heading-m)",
      "fontWeight": "var(--font-semibold)",
      "lineHeight": "var(--space-6)",
      "color": "var(--text-inverse)",
      "margin": "0"
    },
    ".card__header--colored .card__header-subtitle": {
      "fontFamily": "var(--font-sans)",
      "fontSize": "var(--label)",
      "lineHeight": "var(--space-5)",
      "color": "var(--text-inverse)",
      "opacity": "0.9",
      "margin": "0"
    },
    ".card__header--colored .card__header-actions": {
      "display": "flex",
      "alignItems": "center",
      "gap": "var(--space-2)"
    },
    ".card__header--colored .card__header-actions svg, .card__header--colored .card__header-actions :global(svg)": {
      "color": "var(--text-inverse)",
      "stroke": "currentColor"
    },
    ".card--with-header .card__body": {
      "borderTopLeftRadius": "0",
      "borderTopRightRadius": "0"
    }
  }
}
