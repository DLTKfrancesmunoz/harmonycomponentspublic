  "guidance": {
    "patterns": {
      "header-slot-precedence": "The card header can be created two ways: (1) using the header slot for custom content, or (2) using headerTitle and headerSubtitle props for automatic rendering. The header slot takes precedence and will completely replace any headerTitle/headerSubtitle props. When using props, set withHeader=true to render the header section.",
      "header-actions-slot": "The header-actions slot is independent of the main header slot and always renders in the top-right corner of the header when provided. It works with both custom header slot content and prop-based headers.",
      "variant-combinations": "Card variants can be combined: elevated adds shadow elevation, interactive adds hover effects and pointer cursor, and primary adds a 6px top border in the theme primary color. Multiple variants can be applied simultaneously (e.g., elevated + interactive + primary).",
      "slot-structure": "The card uses three slots: header (optional), default (card body, always in card__body), and footer (optional, only when Astro.slots.has('footer'))."
    },
    "guidelines": {
      "when-to-use": "Use Card for grouped content with optional header and footer. Use elevated for emphasis, interactive for clickable cards, primary for highlighted top border.",
      "composition": "Compose with header slot or headerTitle/headerSubtitle; use footer slot for actions or secondary content."
    }
  },
