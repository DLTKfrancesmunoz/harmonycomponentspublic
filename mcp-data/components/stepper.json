    ".stepper--horizontal .step": {
      "display": "flex",
      "flex-direction": "column",
      "align-items": "center",
      "flex": "1 1 0",
      "min-width": "120px",
      "position": "relative",
      "flex-shrink": "0",
      "padding-right": "12px",
      "gap": "8px"
    },
    ".stepper--horizontal .step:first-child": {
      "padding-left": "0"
    },
    ".stepper--horizontal .step:last-child": {
      "padding-right": "0"
    },
    ".stepper--vertical .step": {
      "display": "grid",
      "grid-template-columns": "40px 1fr",
      "grid-template-rows": "auto",
      "align-items": "start",
      "width": "100%",
      "padding-bottom": "16px",
      "position": "relative",
      "gap": "0 12px",
      "border": "none"
    },
    ".stepper--vertical .step:last-child": {
      "padding-bottom": "0"
    },
    ".stepper--vertical .step__indicator": {
      "grid-column": "1",
      "grid-row": "1"
    },
    ".stepper--vertical .step__label": {
