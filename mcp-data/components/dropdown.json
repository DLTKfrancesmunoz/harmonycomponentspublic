    },
    ".dropdown__chevron": {
      "color": "#6B7280",
      "transition": "transform 150ms ease"
    },
    ".dropdown.is-open .dropdown__chevron": {
      "transform": "rotate(180deg)"
    },
    ".dropdown__menu": {
      "display": "none",
      "position": "absolute",
      "top": "100%",
      "left": "0",
