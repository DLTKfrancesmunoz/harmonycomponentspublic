      "max-height": "calc(100vh - 200px)",
      "overflow-y": "auto",
      "right": "0",
      "width": "100%",
      "max-width": "100vw"
    },
    ".dropdown.is-open .dropdown__menu": {
      "display": "block"
    },
    ".dropdown__item": {
      "display": "flex",
      "align-items": "center",
      "gap": "8px",
      "width": "100%",
      "padding": "12px 16px",
      "font-size": "0.875rem",
      "color": "#373F4E",
      "text-align": "left",
      "cursor": "pointer",
      "transition": "background-color 150ms ease",
      "min-height": "44px"
    },
    ".dropdown__item:hover": {
      "background-color": "#E5E7EB"
    },
    ".dropdown__item.is-selected": {
      "background-color": "rgba(76, 146, 217, 0.1)",
