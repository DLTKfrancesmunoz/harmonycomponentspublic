{
  "name": "TimePicker",
  "type": "component",
  "filePath": "src/components/ui/TimePicker.astro",
  "description": "TimePicker Component",
  "props": {
    "value": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "min": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "max": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "disabled": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "format": {
      "type": "'12' | '24'",
      "optional": true,
      "default": "'24'"
    },
    "step": {
      "type": "number",
      "optional": true,
      "default": "1"
    },
    "id": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light"
  },
  "specs": {},
  "guidance": {
    "patterns": {},
    "guidelines": {}
  },
  "interactivity": {
    "events": [
      {
        "name": "change",
        "description": "Triggered when time is selected"
      }
    ],
    "state": [
      {
        "name": "value",
        "type": "string",
        "description": "Selected time"
      }
    ]
  },
  "examples": [
    {
      "name": "Time selection",
      "description": "Pick time",
      "snippet": "<TimePicker value={...} />"
    }
  ]
}