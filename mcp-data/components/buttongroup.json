    ".btn-group--horizontal.btn-group--default .btn": {
      "marginLeft": "0",
      "border": "none"
    },
    ".btn-group--horizontal.btn-group--default .btn--primary:first-child, .btn-group--horizontal.btn-group--default .btn.btn--selected:first-child": {
      "borderRadius": "8px 6px 6px 8px"
    },
    ".btn-group--horizontal.btn-group--default .btn--primary:not(:first-child):not(:last-child), .btn-group--horizontal.btn-group--default .btn.btn--selected:not(:first-child):not(:last-child)": {
      "borderRadius": "6px"
    },
    ".btn-group--horizontal.btn-group--default .btn--primary:last-child, .btn-group--horizontal.btn-group--default .btn.btn--selected:last-child": {
      "borderRadius": "6px 8px 8px 6px"
    },
    ".btn-group--horizontal.btn-group--default .btn:not(.btn--primary):not(.btn--selected):first-child": {
      "borderRadius": "8px 0 0 8px"
    },
    ".btn-group--horizontal.btn-group--default .btn:not(.btn--primary):not(.btn--selected):last-child": {
      "borderRadius": "0 8px 8px 0"
    },
    ".btn-group--horizontal.btn-group--default .btn:not(.btn--primary):not(.btn--selected):not(:first-child):not(:last-child)": {
      "borderRadius": "0"
    },
    ".btn-group--vertical": {
      "flexDirection": "column"
    },
    ".btn-group--vertical.btn-group--default": {
      "gap": "0"
    },
    ".btn-group--vertical.btn-group--default .btn": {
      "marginLeft": "0",
      "border": "none",
      "width": "100%"
    },
    ".btn-group--vertical.btn-group--default .btn--primary:first-child, .btn-group--vertical.btn-group--default .btn.btn--selected:first-child": {
      "borderRadius": "8px 8px 6px 6px"
    },
    ".btn-group--vertical.btn-group--default .btn--primary:not(:first-child):not(:last-child), .btn-group--vertical.btn-group--default .btn.btn--selected:not(:first-child):not(:last-child)": {
      "borderRadius": "6px"
    },
    ".btn-group--vertical.btn-group--default .btn--primary:last-child, .btn-group--vertical.btn-group--default .btn.btn--selected:last-child": {
      "borderRadius": "6px 6px 8px 8px"
    },
    ".btn-group--vertical.btn-group--default .btn:not(.btn--primary):not(.btn--selected):first-child": {
      "borderRadius": "8px 8px 0 0"
    },
    ".btn-group--vertical.btn-group--default .btn:not(.btn--primary):not(.btn--selected):last-child": {
      "borderRadius": "0 0 8px 8px"
    },
    ".btn-group--vertical.btn-group--default .btn:not(.btn--primary):not(.btn--selected):not(:first-child):not(:last-child)": {
      "borderRadius": "0"
    },
    ".btn-group--default .btn--primary, .btn-group--default .btn.btn--selected": {
      "backgroundColor": "var(--theme-primary)",
      "color": "var(--text-inverse)",
      "border": "none"
    },
    ".btn-group--default .btn--primary:hover, .btn-group--default .btn.btn--selected:hover": {
      "backgroundColor": "var(--theme-primary-hover)"
    },
    ".btn-group--default .btn--primary:focus-visible, .btn-group--default .btn.btn--selected:focus-visible": {
      "outline": "1px solid var(--card-bg)",
      "outlineOffset": "0",
      "boxShadow": "var(--focus-ring-primary)"
    },
    ".btn-group--default .btn:not(.btn--primary):not(.btn--selected)": {
      "backgroundColor": "var(--input-bg)",
      "color": "var(--theme-btn-secondary-stroke)",
      "border": "none"
    },
    ".btn-group--default .btn--outline:not(.btn--primary):not(.btn--selected), .btn-group--default .btn--secondary:not(.btn--primary):not(.btn--selected), .btn-group--default .btn--tertiary:not(.btn--primary):not(.btn--selected), .btn-group--default .btn--ghost:not(.btn--primary):not(.btn--selected)": {
      "color": "var(--theme-btn-secondary-stroke)"
    },
    ".btn-group--default .btn:not(.btn--primary):not(.btn--selected):hover": {
      "backgroundColor": "var(--theme-primary-hover-light)"
    },
    ".btn-group--default .btn:not(.btn--primary):not(.btn--selected):focus-visible": {
      "outline": "1px solid var(--card-bg)",
      "outlineOffset": "0",
      "boxShadow": "var(--focus-ring-primary)"
    },
    ".btn-group--sm .btn": {
