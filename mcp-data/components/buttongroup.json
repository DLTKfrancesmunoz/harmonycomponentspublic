    },
    ".btn-group--lg .btn": {
      "height": "48px",
      "padding": "0 24px",
      "fontSize": "1.125rem"
    },
    ".btn-group--default .btn:disabled, .btn-group--default .btn.btn--disabled": {
      "opacity": "0.5",
      "cursor": "not-allowed",
      "pointerEvents": "none"
    },
    ".btn-group--outline": {
      "border": "none",
      "padding": "0",
      "backgroundColor": "transparent"
    },
    ".btn-group--outline .btn": {
      "borderRadius": "0",
      "marginLeft": "-1px"
    },
    ".btn-group--outline .btn:first-child": {
      "borderRadius": "8px 0 0 8px"
    },
    ".btn-group--outline .btn:last-child": {
      "borderRadius": "0 8px 8px 0"
    },
    ".btn-group--outline .btn:not(:last-child)": {
      "borderRightColor": "transparent"
    },
    "@media (max-width: 768px)": {
      ".btn-group--horizontal": {
        "flexDirection": "column",
        "width": "100%"
      },
      ".btn-group--horizontal.btn-group--default": {
        "gap": "8px"
      },
      ".btn-group--horizontal.btn-group--default .btn": {
