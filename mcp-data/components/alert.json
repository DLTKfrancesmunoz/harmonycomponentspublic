      "position": "relative",
      "display": "flex",
      "padding": "0",
      "border": "none",
      "border-radius": "8px",
      "box-shadow": "0 4px 6px -1px rgb(15 23 42 / 0.1), 0 2px 4px -2px rgb(15 23 42 / 0.1)",
      "background-color": "#F7F8FA",
      "overflow": "hidden"
    },
    ".alert--enhanced .alert__border": {
      "width": "8px",
      "flex-shrink": "0",
      "background-color": "#3366FF",
      "border-radius": "8px 0 0 8px"
    },
    ".alert--enhanced.alert--success .alert__border": {
      "background-color": "#17A871"
    },
    ".alert--enhanced.alert--warning .alert__border": {
      "background-color": "#FFB020"
    },
    ".alert--enhanced.alert--error .alert__border": {
      "background-color": "#D83148"
    },
    ".alert--enhanced.alert--info .alert__border": {
      "background-color": "#3366FF"
    },
    ".alert--enhanced .alert__content": {
      "display": "flex",
      "flex-direction": "column",
      "flex": "1",
      "padding": "12px",
      "gap": "8px"
    },
    ".alert--enhanced .alert__inner": {
      "display": "flex",
      "gap": "8px",
      "align-items": "flex-start"
    },
    ".alert--enhanced .alert__text": {
      "flex": "1",
      "min-width": "0"
    },
    ".alert--enhanced .alert__icon": {
      "flex-shrink": "0",
      "font-size": "1rem",
      "width": "20px",
      "height": "20px"
    },
    ".alert--enhanced .alert__title": {
      "font-family": "'Lexend', sans-serif",
      "font-size": "0.875rem",
      "font-weight": "500",
      "color": "#373F4E",
      "margin-bottom": "4px",
      "line-height": "20px"
    },
    ".alert--enhanced .alert__message": {
      "font-size": "13px",
      "font-weight": "400",
      "color": "#373F4E",
      "line-height": "18px"
    },
    ".alert--enhanced .alert__close": {
      "flex-shrink": "0",
      "width": "16px",
      "height": "16px",
      "display": "flex",
      "align-items": "center",
      "justify-content": "center",
      "color": "#525969",
      "cursor": "pointer",
      "transition": "color 150ms ease"
    },
    ".alert--enhanced .alert__close:hover": {
      "color": "#373F4E"
    },
    ".alert__actions": {
      "display": "flex",
      "flex-direction": "column",
      "gap": "8px",
      "padding-left": "calc(20px + 8px)",
      "padding-top": "8px"
    },
    ".alert__buttons": {
      "display": "flex",
      "gap": "8px",
      "align-items": "center"
    },
    ".alert__link": {
      "font-size": "0.75rem",
      "font-weight": "400",
      "color": "#005bb3",
      "text-decoration": "none",
      "line-height": "16px",
      "transition": "color 150ms ease"
    },
    ".alert__link:hover": {
      "text-decoration": "underline"
    },
    ".alert__progress": {
      "padding-top": "8px",
      "padding-left": "calc(20px + 8px)"
    }
