{
  "name": "DateTimePicker",
  "type": "component",
  "filePath": "src/components/ui/DateTimePicker.astro",
  "description": "DateTimePicker Component",
  "props": {
    "value": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "min": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "max": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "disabled": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "timeFormat": {
