{
  "name": "DatePicker",
  "type": "component",
  "filePath": "src/components/ui/DatePicker.astro",
  "description": "DatePicker Component",
  "props": {
    "value": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "min": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "max": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "disabled": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "locale": {
      "type": "string",
      "optional": true,
      "default": "'en-US'"
    },
    "id": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light"
  },
  "specs": {},
  "guidance": {
    "patterns": {},
    "guidelines": {}
  },
  "interactivity": {
    "events": [
      {
        "name": "change",
        "description": "Triggered when a date is selected"
      }
    ],
    "state": [
      {
        "name": "value",
        "type": "string",
        "description": "Selected date"
      },
      {
        "name": "viewMonth",
        "type": "string",
        "description": "Currently displayed month/year in calendar view"
      }
    ]
  },
  "examples": [
    {
      "name": "Calendar picker",
      "description": "Standalone calendar",
      "snippet": "<DatePicker value={date} onchange={...} />"
    }
  ]
