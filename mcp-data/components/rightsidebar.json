  "guidance": {
    "patterns": {
      "theme-variant-icons": "Each theme variant (cp, vp, ppm, maconomy) has its own predefined icon set. All themes start with Dela custom logo (RS_DelaDefault.svg default, RS_Dela_Active.svg active) as the first item. CP has 3 sections with 3, 2, and 4 items. VP, PPM, and Maconomy have 3 sections with 8, 3, and 3 items. Use the template in the spec for the exact sections and items.",
      "custom-icon-support": "Navigation items support two icon approaches: standard Icon component (icon: Heroicons name) or custom images (isCustom: true, customSrc, customSrcActive). Custom images use right-sidebar__dela-logo classes.",
      "panel-data-attributes": "Items use data attributes for ShellPanel: panelTitle, panelIcon, panelContentId, useGradientHeader. Dela AI items get gradient header automatically."
    },
    "guidelines": {
      "when-to-use": "Use RightSidebar for unified right navigation. Collapsed shows icons only (52px); hover expands to 220px with labels. Theme variant controls which default sections/items are shown.",
      "composition": "Place inside shell layout; connect to ShellPanel for panel content when item is clicked."
    }
  },
  "interactivity": {
    "events": [
      {
        "name": "click",
        "description": "Item click or sidebar toggle"
