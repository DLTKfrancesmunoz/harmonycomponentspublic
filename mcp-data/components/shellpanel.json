      "visibility": "visible"
    },
    ".shell-panel__action--close": {
      "min-width": "calc(24px + 8px)",
      "min-height": "calc(24px + 8px)"
    },
    ".shell-panel__action:focus-visible": {
      "outline": "1px solid #F7F8FA",
      "outline-offset": "0",
      "box-shadow": "0 0 0 3px rgba(76, 146, 217, 0.1), 0 0 0 4px #F7F8FA"
    },
    ".shell-panel__content": {
      "flex": "1",
      "overflow-y": "auto",
      "overflow-x": "hidden",
      "padding": "16px 96px 16px 16px",
      "background-color": "#F7F8FA"
    },
    ".shell-layout .shell-panel--right .shell-panel__content": {
      "border-radius": "0 0 0 16px",
      "padding-right": "calc(52px + 16px)"
    },
    ".shell-layout .shell-panel--left .shell-panel__content": {
      "border-radius": "0 0 16px 0",
      "padding-left": "calc(52px + 16px)"
    },
    ".shell-panel__content::-webkit-scrollbar": {
      "width": "8px"
    },
    ".shell-panel__content::-webkit-scrollbar-track": {
      "background": "transparent"
    },
    ".shell-panel__content::-webkit-scrollbar-thumb": {
      "background-color": "#BFC6D4",
      "border-radius": "4px"
    },
    ".shell-panel__content::-webkit-scrollbar-thumb:hover": {
      "background-color": "#525969"
    }
  },
