{
  "name": "design-system-docs",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "start": "serve dist -l ${PORT:-3000}",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate:props": "node scripts/extract-component-props.js",
    "generate:tokens": "node scripts/parse-css-tokens.js",
    "generate:components": "node scripts/generate-components-json.js",
    "generate:layouts": "node scripts/generate-layouts-json.js",
    "generate:manifest": "node scripts/generate-manifest.js",
    "generate:all": "npm run generate:props && npm run generate:tokens && npm run generate:components && npm run generate:layouts && npm run generate:manifest"
  },
  "dependencies": {
    "astro": "^5.16.7",
    "heroicons": "^2.2.0",
    "serve": "^14.2.0"
  },
  "devDependencies": {
    "postcss": "^8.4.0",
    "postcss-value-parser": "^4.2.0"
  }
}
