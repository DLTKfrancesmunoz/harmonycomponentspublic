{
  "name": "@dltkfrancesmunoz/harmony-react",
  "version": "1.0.0",
  "description": "Harmony Design System — React components and agent skills (public distribution)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DLTKfrancesmunoz/harmonycomponentspublic.git",
    "directory": "harmony-react-conversion"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./components/*": {
      "import": "./dist/components/*.js",
      "types": "./dist/components/*.d.ts"
    },
    "./skills/*": "./.cursor/skills/*",
    "./styles/*": "./src/components/harmony/*.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/components/harmony",
    ".cursor/skills",
    ".cursor/agents",
    "README.md"
  ],
  "keywords": [
    "react",
    "design-system",
    "harmony",
    "components",
    "ui",
    "agent-skills",
    "cursor-skills",
    "public"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc && vite build --mode lib",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "typescript": "~5.6.2",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0"
  }
}
